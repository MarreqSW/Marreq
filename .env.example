# Copy this file to .env and fill in your local values.
# .env is never committed to git.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL used by the application and by Diesel CLI.
# Default matches docker/docker-compose.yml host mapping (5433 -> container 5432).
# For a native Postgres on 5432, override this URL.
DATABASE_URL=postgres://rust:rust@127.0.0.1:5433/marreq

# Rocket session/cookie signing key.
# Required for `cargo run --release` and for the Docker backend image (release build).
# Docker Compose supplies a dev-only default if unset; set your own for shared or prod hosts:
#   openssl rand -base64 32
# ROCKET_SECRET_KEY=

# ── Web UI ────────────────────────────────────────────────────────────────────
# Rocket serves JSON under /api and GET / (service descriptor). The SPA (e.g. Vite or Docker :8080) is the UI.
# Session cookie: use __Host-session + Secure on HTTPS in production.
# MARREQ_SECURE_SESSION_COOKIE=1

# Deployment mode is selected at build time:
# - Default self-hosted Server mode: cargo run -p marreq
# - Hosted Cloud mode: cargo run -p marreq --no-default-features --features cloud
#
# Cloud mode enables public registration, email verification, and password reset.
# MARREQ_PUBLIC_BASE_URL=https://marreq.example.com
# MARREQ_SITE_ADMIN_EMAIL=admin@example.com
# MARREQ_SITE_ADMIN_BOOTSTRAP_PASSWORD=

# CORS (dev: Vite on 5173 + Rocket on 8000). Production same-origin via nginx may omit.
# CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5173
# CORS_ALLOW_CREDENTIALS=true

# CSRF Origin allowlist (unsafe methods). Include the SPA origin (e.g. :8080) when UI and API ports differ.
# Docker Compose sets this for the split stack; override if you use another host/port.
# CSRF_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# ── Semantic search / embeddings ─────────────────────────────────────────────
# Set EMBEDDINGS_ENABLED=false to disable vector search entirely.
EMBEDDINGS_ENABLED=false
EMBEDDING_PROVIDER=ollama          # ollama | openai
EMBEDDING_MODEL=nomic-embed-text
# Local Ollama default. Docker Compose maps the stack Ollama to host :11435 (see docker/README.md).
OLLAMA_URL=http://localhost:11434

# ── Email notifications (SMTP) ────────────────────────────────────────────────
# Set SMTP_HOST to enable email delivery for user notifications and Cloud auth emails.
# Leave unset to disable email (in-app notifications still work; Cloud users cannot receive verification/reset emails).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=marreq@example.com

# ── RAG (retrieval-augmented generation) ─────────────────────────────────────
# Set RAG_ENABLED=false to disable LLM-assisted search.
RAG_ENABLED=false
RAG_MODEL=llama3.2
RAG_MAX_TOKENS=1024
RAG_TOP_K=10
