{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:import/recommended"
  ],
  "plugins": [
    "import"
  ],
  "parserOptions": {
    "sourceType": "module"
  },
  "rules": {
    "no-implicit-globals": "error",
    "no-unused-vars": [
      "error",
      {
        "args": "after-used",
        "ignoreRestSiblings": true
      }
    ],
    "prefer-const": "error",
    "import/no-cycle": [
      "error",
      {
        "maxDepth": 1
      }
    ]
  }
}
