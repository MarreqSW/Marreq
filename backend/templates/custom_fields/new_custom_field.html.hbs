{{#*inline "page"}}
<div class="mb-4">
  <h1>New Custom Field</h1>
  <p class="text-secondary">Add a project-specific metadata field for requirements</p>
</div>

<section>
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Field definition</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="label" class="form-label c-form-label">Label</label>
          <input type="text" name="label" id="label" class="form-control c-form-control" required placeholder="e.g. Priority">
        </div>

        <div class="form-group c-form-group">
          <label for="field_type" class="form-label c-form-label">Type</label>
          <select name="field_type" id="field_type" class="form-control c-form-control c-form-control--select" required>
            <option value="text">Text</option>
            <option value="number">Number</option>
            <option value="boolean">Boolean</option>
            <option value="enum">Enum (fixed options)</option>
          </select>
        </div>

        <div class="form-group c-form-group" id="enum-values-group" style="display: none;">
          <label for="enum_values" class="form-label c-form-label">Enum values (one per line or comma-separated)</label>
          <textarea name="enum_values" id="enum_values" class="form-control c-form-control c-form-control--textarea" rows="4" placeholder="Option A&#10;Option B&#10;Option C"></textarea>
          <small class="text-secondary">Required when type is Enum</small>
        </div>

        <div class="form-group c-form-group">
          <label for="sort_order" class="form-label c-form-label">Sort order</label>
          <input type="number" name="sort_order" id="sort_order" class="form-control c-form-control" value="0" min="0">
          <small class="text-secondary">Lower numbers appear first</small>
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Create custom field</button>
          <a href="/p/{{selected_project_slug}}/custom_fields" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
<script>
(function() {
  var sel = document.getElementById('field_type');
  var group = document.getElementById('enum-values-group');
  function toggle() { group.style.display = sel.value === 'enum' ? 'block' : 'none'; }
  sel.addEventListener('change', toggle);
  toggle();
})();
</script>
{{/inline}}
{{> layout this page_id="new_custom_field"}}
