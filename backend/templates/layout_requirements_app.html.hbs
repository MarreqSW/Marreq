{{!--
  Full-chrome layout for requirements list (Tailwind + Material Symbols).
  Depends on: Bootstrap 5 JS/CSS for modals, /static/marreq.css for edit panel.
--}}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{{#if page_title}}{{page_title}} - {{/if}}Marreq</title>
  <script src="/static/js/theme-prefetch.js"></script>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;family=JetBrains+Mono&amp;display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/static/marreq.css">
  <link rel="stylesheet" href="/static/css/pages/requirements.css">
  <link rel="icon" type="image/x-icon" href="/static/favicon.ico">
  {{#if csrf_token}}<meta name="csrf-token" content="{{csrf_token}}">{{/if}}
  <script id="tailwind-config">
    tailwind.config = {
      important: '#req-app-root',
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            'secondary-fixed-dim': '#c1c3ed',
            'on-tertiary-container': '#e17c5a',
            'surface-container-highest': '#e0e3e5',
            'on-primary': '#ffffff',
            'primary-container': '#1a237e',
            'on-tertiary-fixed': '#390c00',
            'surface-bright': '#f8f9fb',
            primary: '#000666',
            'surface-dim': '#d8dadc',
            'inverse-on-surface': '#eff1f3',
            'on-tertiary-fixed-variant': '#7b2e12',
            'surface-variant': '#e0e3e5',
            'secondary-container': '#d2d4ff',
            'on-surface': '#191c1e',
            outline: '#767683',
            'primary-fixed-dim': '#bdc2ff',
            'inverse-primary': '#bdc2ff',
            'tertiary-container': '#5c1800',
            'on-secondary-fixed-variant': '#414467',
            'error-container': '#ffdad6',
            'on-error': '#ffffff',
            'surface-container': '#eceef0',
            'on-primary-container': '#8690ee',
            'on-secondary-container': '#575b7f',
            'surface-container-high': '#e6e8ea',
            'inverse-surface': '#2d3133',
            'surface-tint': '#4c56af',
            'surface-container-lowest': '#ffffff',
            'secondary-fixed': '#e0e0ff',
            'on-primary-fixed': '#000767',
            background: '#f8f9fb',
            secondary: '#585c80',
            'on-primary-fixed-variant': '#343d96',
            'on-secondary-fixed': '#151839',
            'on-error-container': '#93000a',
            'on-secondary': '#ffffff',
            'tertiary-fixed': '#ffdbd0',
            'on-tertiary': '#ffffff',
            'surface-container-low': '#f2f4f6',
            'on-background': '#191c1e',
            'tertiary-fixed-dim': '#ffb59d',
            error: '#ba1a1a',
            'primary-fixed': '#e0e0ff',
            surface: '#f8f9fb',
            'on-surface-variant': '#454652',
            tertiary: '#380b00',
            'outline-variant': '#c6c5d4',
          },
          fontFamily: {
            headline: ['Public Sans', 'sans-serif'],
            body: ['Inter', 'sans-serif'],
            label: ['Inter', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
          borderRadius: { DEFAULT: '0.125rem', lg: '0.25rem', xl: '0.5rem', full: '0.75rem' },
        },
      },
    };
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    #req-app-root .req-app-body { font-family: Inter, sans-serif; }
    #req-app-root h1, #req-app-root h2, #req-app-root h3 { font-family: 'Public Sans', sans-serif; }
    #req-app-root .req-id { font-family: 'JetBrains Mono', monospace; }
  </style>
</head>
<body class="bg-surface text-on-surface" {{#if page_id}}data-page="{{page_id}}"{{/if}}>
<div id="req-app-root" class="flex min-h-screen" data-requirements-ui="tailwind-app">
  {{~> page}}
</div>
<div class="modal fade" id="requirementDiffModal" tabindex="-1" aria-labelledby="requirementDiffModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="requirementDiffModalLabel">Requirement diff</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <small class="text-muted">
            <span class="text-danger">Red</span> = Removed · <span class="text-success">Green</span> = Added · <span class="text-muted">Gray</span> = Unchanged
          </small>
        </div>
        <div id="requirementDiffContent"></div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script type="module" src="/static/js/app.js"></script>
</body>
</html>
