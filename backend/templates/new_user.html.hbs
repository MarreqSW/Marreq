{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New User</h1>
  <p class="text-secondary">Create a new user account</p>
  {{#if error}}
    <div class="alert alert-error c-alert c-alert--error mt-3">{{error}}</div>
  {{/if}}
</div>

<section id="Users">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>User Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="username" class="form-label c-form-label">Username</label>
            <input type="text" name="username" id="username" class="form-control c-form-control" autocomplete="username" required>
          </div>
          
          <div class="form-group c-form-group">
            <label for="name" class="form-label c-form-label">Full Name</label>
            <input type="text" name="name" id="name" class="form-control c-form-control" autocomplete="name" required>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="email" class="form-label c-form-label">Email Address</label>
          <input type="email" name="email" id="email" class="form-control c-form-control" autocomplete="email" required>
        </div>

        <div class="form-group c-form-group">
          <label for="password_hash" class="form-label c-form-label">Password</label>
          <input type="password" name="password_hash" id="password_hash" class="form-control c-form-control" autocomplete="new-password" required>
          <small class="form-text c-form-text">Minimum 8 characters (15+ recommended).</small>
        </div>

        <input type="hidden" id="project_id" name="project_id" value="">
        <input type="hidden" id="is_admin" name="is_admin" value="false">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Create User</button>
          <a href="/" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="new_user"}}
