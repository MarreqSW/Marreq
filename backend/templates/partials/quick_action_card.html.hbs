{{!--
  Expected parameters:
    href: target URL (required unless disabled)
    icon: icon class name
    label: button label
    modifier: optional modifier class (e.g., marreq-action-card--primary)
    disabled: truthy value marks the card as disabled
    title: optional tooltip/title attribute

  Depends on: css/50-components/dashboard.css
--}}
{{#if disabled}}
  <span
    class="marreq-action-card{{#if modifier}} {{modifier}}{{/if}} marreq-nav-link--disabled"
    aria-disabled="true"
    {{#if title}}title="{{title}}"{{/if}}>
    {{#if icon}}
    <i class="{{icon}}" aria-hidden="true"></i>
    {{/if}}
    <span>{{label}}</span>
    {{#if badge}}
      <span class="marreq-badge">{{badge}}</span>
    {{/if}}
  </span>
{{else}}
  <a
    href="{{href}}"
    class="marreq-action-card{{#if modifier}} {{modifier}}{{/if}}"
    {{#if title}}title="{{title}}"{{/if}}>
    {{#if icon}}
    <i class="{{icon}}" aria-hidden="true"></i>
    {{/if}}
    <span>{{label}}</span>
    {{#if badge}}
      <span class="marreq-badge">{{badge}}</span>
    {{/if}}
  </a>
{{/if}}
