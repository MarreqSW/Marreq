{{!--
  Verification Methods — multi-select dropdown partial for requirement forms.
  Uses c-custom-dropdown BEM classes from 50-components/dropdown.css.

  Required context:
    verification_with_selected — [{id, title, selected}]

  The partial renders a custom dropdown with multi-select behaviour and a
  "+ Create verification method" footer action.  A hidden <select multiple>
  submits verification_method_ids[] to the server.
--}}
<div class="c-reqform-field">
  <label for="verification_method_ids" class="c-reqform-field__label">
    Verification methods <span class="c-reqform-field__required">*</span>
  </label>
  <div class="c-custom-dropdown" data-dropdown="verification" data-multi data-placeholder="Select verification methods...">
    <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
      <span class="c-custom-dropdown__value c-custom-dropdown__value--placeholder" data-role="dropdown-value">Select verification methods...</span>
      <span class="c-custom-dropdown__arrow">&#9660;</span>
    </button>
    <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
      <div class="c-custom-dropdown__list" data-role="dropdown-list">
        {{#each verification_with_selected}}
        <button type="button" class="c-custom-dropdown__item{{#if selected}} c-custom-dropdown__item--selected{{/if}}" data-value="{{id}}">
          {{title}}
        </button>
        {{else}}
        <div class="c-custom-dropdown__empty">
          No verification methods available yet
        </div>
        {{/each}}
      </div>
      <div class="c-custom-dropdown__footer">
        <button type="button" class="c-custom-dropdown__action" data-action="create-verification">
          + Create verification method
        </button>
      </div>
    </div>
    <select name="verification_method_ids" id="verification_method_ids" class="c-custom-dropdown__hidden" multiple required hidden>
      {{#each verification_with_selected}}
      <option value="{{id}}" {{#if selected}}selected{{/if}}>{{title}}</option>
      {{/each}}
    </select>
  </div>
</div>
