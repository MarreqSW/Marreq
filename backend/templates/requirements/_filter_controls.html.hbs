{{!--
  PARTIAL: Filter Controls
  Search bar and filter dropdowns for requirements
--}}
<section class="marreq-requirements-controls c-card" aria-label="Filters">
  <div class="marreq-requirements-controls__inner">
    <form
      method="GET"
      action="{{#if project.id}}/p/{{project.slug}}/requirements{{else}}/requirements{{/if}}"
      class="marreq-requirements-filter-bar"
      id="requirementsFilterForm">
      <div class="marreq-requirements-filter-bar__search">
        <label for="requirementsSearch" class="u-visually-hidden">Search requirements</label>
        <input type="search"
          id="requirementsSearch"
          class="marreq-requirements-filter-bar__search-input"
          name="search"
          placeholder="Filter by title, key, or text…"
          autocomplete="off" />
        <span class="marreq-requirements-filter-bar__shortcut" aria-hidden="true">/</span>
      </div>
      <div class="marreq-requirements-filter-bar__selects">
        <label for="statusFilter" class="u-visually-hidden">Filter by status</label>
        <select
          id="statusFilter"
          name="status_filter"
          class="marreq-requirements-filter-bar__select"
          data-filter-control="status"
          data-filter-label="Status">
          <option value="">Status · All</option>
          {{#each statuses}}
            <option value="{{id}}" {{#if (eq id ../current_status_filter)}}selected{{/if}}>
              {{title}}
            </option>
          {{/each}}
        </select>

        <label for="verificationFilter" class="u-visually-hidden">Filter by verification mode</label>
        <select
          id="verificationFilter"
          name="verification_filter"
          class="marreq-requirements-filter-bar__select"
          data-filter-control="verification"
          data-filter-label="Verification">
          <option value="">Verification · All</option>
          {{#each verifications}}
            <option value="{{id}}" {{#if (eq id ../current_verification_filter)}}selected{{/if}}>
              {{title}}
            </option>
          {{/each}}
        </select>

        <label for="categoryFilter" class="u-visually-hidden">Filter by category</label>
        <select
          id="categoryFilter"
          name="category_filter"
          class="marreq-requirements-filter-bar__select"
          data-filter-control="category"
          data-filter-label="Category">
          <option value="">Category · All</option>
          {{#each categories}}
            <option value="{{id}}" {{#if (eq id ../current_category_filter)}}selected{{/if}}>
              {{title}}
            </option>
          {{/each}}
        </select>

        <label for="applicabilityFilter" class="u-visually-hidden">Filter by applicability</label>
        <select
          id="applicabilityFilter"
          name="applicability_filter"
          class="marreq-requirements-filter-bar__select"
          data-filter-control="applicability"
          data-filter-label="Applicability">
          <option value="">Applicability · All</option>
          {{#each applicability}}
            <option value="{{id}}" {{#if (eq id ../current_applicability_filter)}}selected{{/if}}>
              {{title}}
            </option>
          {{/each}}
        </select>

        <label for="approvalFilter" class="u-visually-hidden">Filter by approval</label>
        <select
          id="approvalFilter"
          name="approval_filter"
          class="marreq-requirements-filter-bar__select"
          data-filter-control="approval"
          data-filter-label="Approval">
          <option value="">Approval · All</option>
          <option value="approved" {{#if approval_filter_approved}}selected{{/if}}>Approved only</option>
          <option value="not_approved" {{#if approval_filter_not_approved}}selected{{/if}}>Not approved</option>
        </select>

        {{#if custom_field_definitions}}
        {{#each custom_field_definitions}}
        <label for="custom_filter_{{id}}" class="u-visually-hidden">Filter by {{label}}</label>
        {{#if (eq field_type "enum")}}
        <select
          id="custom_filter_{{id}}"
          class="marreq-requirements-filter-bar__select custom-filter-input"
          data-field-id="{{id}}"
          data-filter-label="{{label}}">
          <option value="">{{label}} · All</option>
          {{#if enum_values}}
          {{#each enum_values}}
          <option value="{{this}}" {{#if (eq this ../current_filter_value)}}selected{{/if}}>{{this}}</option>
          {{/each}}
          {{/if}}
        </select>
        {{else if (eq field_type "boolean")}}
        <select
          id="custom_filter_{{id}}"
          class="marreq-requirements-filter-bar__select custom-filter-input"
          data-field-id="{{id}}"
          data-filter-label="{{label}}">
          <option value="">{{label}} · All</option>
          <option value="true" {{#if (eq current_filter_value "true")}}selected{{/if}}>Yes</option>
          <option value="false" {{#if (eq current_filter_value "false")}}selected{{/if}}>No</option>
        </select>
        {{else}}
        <input type="text"
          id="custom_filter_{{id}}"
          class="marreq-requirements-filter-bar__select custom-filter-input"
          data-field-id="{{id}}"
          data-filter-label="{{label}}"
          placeholder="{{label}}"
          value="{{current_filter_value}}">
        {{/if}}
        {{/each}}
        <input type="hidden" name="custom_filters" id="custom_filters_hidden" value="{{custom_filters_param}}">
        {{/if}}
      </div>

      <div class="marreq-requirements-filter-bar__actions">
        <button type="button" class="marreq-requirements-filter-bar__clear" data-action="clear-filters">
          Clear filters
        </button>
        <button type="submit" class="marreq-requirements-filter-bar__submit">
          Apply
        </button>
      </div>
    </form>

    <div
      class="marreq-requirements-filter-chips"
      aria-live="polite"
      id="requirementsFilterChips"
      hidden>
    </div>
  </div>
</section>
