{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<section id="profile" class="user-details-section c-user-details">
  <div class="card user-details-card c-card c-user-details__card">
    <div class="user-details-header c-user-details__header">
      <div class="user-details-title c-user-details__title">
        <span class="user-details-label c-user-details__label">My Profile</span>
        <div class="user-name-row c-user-details__name-row">
          <h1 class="user-details-name c-user-details__name">{{user.name}}</h1>
          {{#if user.is_admin}}
            <span class="user-level-badge c-user-details__level-badge">Administrator</span>
          {{else}}
            <span class="user-level-badge c-user-details__level-badge">Standard User</span>
          {{/if}}
        </div>
        <p class="user-details-username c-user-details__username">@{{user.username}}</p>
      </div>
      <div class="user-details-actions c-user-details__actions">
        <a href="/user/profile/edit" class="btn btn-primary btn-sm c-user-details__action">Edit Profile</a>
      </div>
    </div>
    {{#if profile_updated}}
      <div class="alert alert-success mt-3 c-alert c-alert--success" role="status">
        Your profile was updated successfully.
      </div>
    {{/if}}
    <div class="user-details-body c-user-details__body">
      <div class="user-info-grid c-user-details__info-grid">
        <div class="user-info-item c-user-details__info-item">
          <span class="user-info-label c-user-details__info-label">Full Name</span>
          <span class="user-info-value c-user-details__info-value">{{user.name}}</span>
        </div>
        <div class="user-info-item c-user-details__info-item">
          <span class="user-info-label c-user-details__info-label">Username</span>
          <span class="user-info-value c-user-details__info-value">@{{user.username}}</span>
        </div>
        <div class="user-info-item c-user-details__info-item">
          <span class="user-info-label c-user-details__info-label">Email</span>
          <span class="user-info-value c-user-details__info-value">{{user.email}}</span>
        </div>
        <div class="user-info-item c-user-details__info-item">
          <span class="user-info-label c-user-details__info-label">Member Since</span>
          <span class="user-info-value c-user-details__info-value">{{user.creation_date}}</span>
        </div>
        <div class="user-info-item c-user-details__info-item">
          <span class="user-info-label c-user-details__info-label">Last Login</span>
          <span class="user-info-value c-user-details__info-value">{{user.last_login}}</span>
        </div>
      </div>
      <p class="user-details-help-text c-user-details__help-text">
        Keep your contact information up to date so teammates can reach you.
      </p>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="user_profile"}}
