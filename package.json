{
  "name": "marreq",
  "version": "1.0.0",
  "type": "module",
  "description": "A comprehensive web-based requirements and test management system built with Rust, Rocket, and PostgreSQL. This software provides a complete solution for managing hierarchical requirements, tests, traceability matrices, and generating reports.",
  "main": "index.js",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "commit": "cz",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check:unused-css": "node .github/workflows/purgecss-ci.mjs",
    "screenshots:manual": "node doc/UserManual/capture_screenshots.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariusmm/Marreq.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mariusmm/Marreq/issues"
  },
  "homepage": "https://github.com/mariusmm/Marreq#readme",
  "devDependencies": {
    "playwright": "^1.49.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vitest/ui": "^4.0.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "happy-dom": "^20.0.10",
    "purgecss": "^6.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-clean-order": "^7.0.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^7.0.0",
    "vitest": "^4.0.6"
  }
}
