{
  "name": "marreq",
  "version": "1.0.0",
  "type": "module",
  "description": "A comprehensive web-based requirements and test management system built with Rust, Rocket, and PostgreSQL. This software provides a complete solution for managing hierarchical requirements, tests, traceability matrices, and generating reports.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "backend/tests"
  },
  "scripts": {
    "commit": "cz",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "check:unused-css": "node .github/workflows/purgecss-ci.mjs",
    "screenshots:manual": "node docs/user-manual/capture_screenshots.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mariusmm/Marreq.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mariusmm/Marreq/issues"
  },
  "homepage": "https://github.com/mariusmm/Marreq#readme",
  "overrides": {
    "css-tree": "3.2.1",
    "minimist": "1.2.8",
    "tmp": "0.2.5",
    "lodash": "4.17.23"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "happy-dom": "^20.8.3",
    "playwright": "^1.58.2",
    "purgecss": "^8.0.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "vitest": "^4.0.18"
  }
}
