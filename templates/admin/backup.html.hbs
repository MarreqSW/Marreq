{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Database Backup</h1>
            
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-download"></i> Generate Database Backup
                    </h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h6>Backup Information:</h6>
                        <ul class="mb-0">
                            <li>Backup format: PostgreSQL SQL dump</li>
                            <li>Compatible with: PostgreSQL 9.5+</li>
                            <li>Backup filename format: <code>reqman-backup_YYYYMMDD_HHMMSS.sql</code></li>
                            <li>Includes: All tables, data, and schema</li>
                        </ul>
                    </div>
                    
                    <div class="mt-3">
                        <form method="post" action="/admin/backup/generate" id="backupForm">
                            <button type="submit" class="btn btn-primary" onclick="generateBackup(event)">
                                <i class="fas fa-download"></i> Generate Backup
                            </button>
                        </form>
                        
                        <script>
                        function generateBackup(event) {
                            event.preventDefault();
                            
                            // Generate timestamp for filename
                            const now = new Date();
                            const year = now.getFullYear();
                            const month = String(now.getMonth() + 1).padStart(2, '0');
                            const day = String(now.getDate()).padStart(2, '0');
                            const hours = String(now.getHours()).padStart(2, '0');
                            const minutes = String(now.getMinutes()).padStart(2, '0');
                            const seconds = String(now.getSeconds()).padStart(2, '0');
                            
                            const timestamp = `${year}${month}${day}_${hours}${minutes}${seconds}`;
                            const filename = `reqman-backup_${timestamp}.sql`;
                            
                            // Update form action with filename
                            const form = document.getElementById('backupForm');
                            form.action = `/admin/backup/generate/${filename}`;
                            
                            // Submit the form
                            form.submit();
                        }
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/inline}}

{{> layout}} 