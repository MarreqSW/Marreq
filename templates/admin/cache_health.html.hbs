{{#extend "layout"}}
{{!--
  Depends on: js/pages/adminCacheHealth.js
--}}
{{#content "title"}}Cache Health - ReqMan{{/content}}

{{#content "content"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2>Cache Health Status</h2>
            <p class="text-muted">Monitor the health and performance of the application cache</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="card-title mb-0">Cache Status</h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="row">
                        <div class="col-6">
                            <strong>Overall Status:</strong>
                        </div>
                        <div class="col-6">
                            {{#if (eq health.status "healthy")}}
                                <span class="badge bg-success">{{health.status}}</span>
                            {{else if (eq health.status "degraded")}}
                                <span class="badge bg-warning">{{health.status}}</span>
                            {{else}}
                                <span class="badge bg-danger">{{health.status}}</span>
                            {{/if}}
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Total Entries:</strong>
                        </div>
                        <div class="col-6">
                            {{health.total_entries}}
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Active Entries:</strong>
                        </div>
                        <div class="col-6">
                            {{health.active_entries}}
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Expired Entries:</strong>
                        </div>
                        <div class="col-6">
                            {{health.expired_entries}}
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Memory Usage:</strong>
                        </div>
                        <div class="col-6">
                            {{health.memory_usage}} entries
                        </div>
                    </div>
                    <div class="row mt-2">
                        <div class="col-6">
                            <strong>Last Cleanup:</strong>
                        </div>
                        <div class="col-6">
                            {{health.last_cleanup}}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="card-title mb-0">Cache Actions</h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="d-grid gap-2">
                        <a href="/admin/cache/stats" class="btn btn-primary">
                            <i class="fas fa-chart-bar"></i> View Statistics
                        </a>
                        <a href="/cache/warm" class="btn btn-success">
                            <i class="fas fa-fire"></i> Warm Cache
                        </a>
                        <a href="/admin/cache/cleanup" class="btn btn-warning">
                            <i class="fas fa-broom"></i> Cleanup Expired
                        </a>
                        <a href="/admin/cache/clear" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Clear All Cache
                        </a>
                        <button class="btn btn-info" type="button" data-action="refresh-health">
                            <i class="fas fa-sync-alt"></i> Refresh Health Data
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Real-time Performance Monitoring -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="card-title mb-0">
                        Real-time Performance Monitoring
                        <div class="float-end">
                            <span class="badge bg-success" id="connection-status">Connected</span>
                        </div>
                    </h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4 class="text-success" id="hit-rate">--</h4>
                                <small class="text-muted">Hit Rate (%)</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4 class="text-info" id="total-requests">--</h4>
                                <small class="text-muted">Total Requests</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4 class="text-primary" id="avg-access-time">--</h4>
                                <small class="text-muted">Avg Access Time (ms)</small>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center">
                                <h4 class="text-warning" id="memory-usage">--</h4>
                                <small class="text-muted">Memory Usage (MB)</small>
                            </div>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-success" id="efficiency-bar" role="progressbar" style="width: 0%">
                                    <span id="efficiency-text">0%</span>
                                </div>
                            </div>
                            <small class="text-muted">Cache Efficiency</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="card-title mb-0">Cache Health Details</h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Health Indicators</h6>
                            <ul class="list-unstyled">
                                <li>
                                    <i class="fas fa-circle text-{{#if health.cleanup_needed}}warning{{else}}success{{/if}} me-2"></i>
                                    <strong>Cleanup Status:</strong> 
                                    {{#if health.cleanup_needed}}Needed{{else}}Up to date{{/if}}
                                </li>
                                <li>
                                    <i class="fas fa-circle text-{{#if (gt health.expired_entries 10)}}warning{{else}}success{{/if}} me-2"></i>
                                    <strong>Expired Entries:</strong> 
                                    {{#if (gt health.expired_entries 10)}}High{{else}}Normal{{/if}}
                                </li>
                                <li>
                                    <i class="fas fa-circle text-{{#if (gt health.total_entries 1000)}}warning{{else}}success{{/if}} me-2"></i>
                                    <strong>Cache Size:</strong> 
                                    {{#if (gt health.total_entries 1000)}}Large{{else}}Normal{{/if}}
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6>Performance Tips</h6>
                            <ul class="list-unstyled">
                                <li><i class="fas fa-lightbulb text-warning me-2"></i>Monitor hit rate for optimal performance</li>
                                <li><i class="fas fa-lightbulb text-warning me-2"></i>Regular cleanup prevents memory bloat</li>
                                <li><i class="fas fa-lightbulb text-warning me-2"></i>Warm cache improves initial response times</li>
                                <li><i class="fas fa-lightbulb text-warning me-2"></i>Balance TTL between freshness and performance</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{{/content}}
{{/extend}}
