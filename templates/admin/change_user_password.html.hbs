{{!-- Admin: set another user's password (no current password required). Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h1>Change Password</h1>
      <p class="mb-0 text-muted">Setting password for <strong>{{target_user.username}}</strong>{{#if target_user.name}} ({{target_user.name}}){{/if}}</p>
    </div>
    <div class="card-body c-card__body">
      <form method="POST" action="/user/{{user_id}}/change_password" class="form">
        <div class="form-group c-form-group">
          <label for="new_password" class="form-label c-form-label">New Password</label>
          <input type="password" id="new_password" name="new_password" class="form-control c-form-control" autocomplete="new-password" required>
          <small class="form-text c-form-text">Minimum 8 characters (15+ recommended).</small>
        </div>

        <div class="form-group c-form-group">
          <label for="confirm_password" class="form-label c-form-label">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-control c-form-control" autocomplete="new-password" required>
        </div>

        {{#if error}}
          <div class="alert alert-error c-alert c-alert--error">
            {{error}}
          </div>
        {{/if}}

        {{#if success}}
          <div class="alert alert-success c-alert c-alert--success">
            {{success}}
          </div>
        {{/if}}

        <div class="form-actions c-form-actions">
          <button type="submit" class="btn btn-primary c-form-actions__action">Set Password</button>
          <a href="/admin/users" class="btn btn-outline c-form-actions__action">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="admin_change_user_password"}}
