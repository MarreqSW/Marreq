{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Admin Dashboard</h1>
            
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card c-card">
                        <div class="card-header c-card__header">
                            <h5 class="mb-0">
                                <i class="fas fa-database"></i> Database Management
                            </h5>
                        </div>
                        <div class="card-body c-card__body">
                            <p>Manage database backups and maintenance tasks.</p>
                            <a href="/admin/backup" class="btn btn-primary">
                                <i class="fas fa-download"></i> Database Backup
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-4">
                    <div class="card c-card">
                        <div class="card-header c-card__header">
                            <h5 class="mb-0">
                                <i class="fas fa-users"></i> User Management
                            </h5>
                        </div>
                        <div class="card-body c-card__body">
                            <p>Manage system users and permissions.</p>
                            <a href="/admin/users" class="btn btn-primary">
                                <i class="fas fa-users"></i> Manage Users
                            </a>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4 mb-4">
                    <div class="card c-card">
                        <div class="card-header c-card__header">
                            <h5 class="mb-0">
                                <i class="fas fa-list-alt"></i> System Logs
                            </h5>
                        </div>
                        <div class="card-body c-card__body">
                            <p>View system activity and audit logs.</p>
                            <a href="/logs" class="btn btn-primary">
                                <i class="fas fa-list-alt"></i> View Logs
                            </a>
                        </div>
                    </div>
                </div>
                

            </div>
        </div>
    </div>
</div>
{{/inline}}

{{> layout this}} 