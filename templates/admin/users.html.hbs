{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>User Management</h1>
                <a href="/user/new" class="btn btn-primary">
                    <i class="fas fa-plus"></i> New User
                </a>
            </div>
            
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="mb-0">System Users</h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="table-responsive c-table-responsive">
                        <table class="table table-striped c-table c-table--striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Username</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Admin</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each users}}
                                <tr>
                                    <td>{{user_id}}</td>
                                    <td>{{user_username}}</td>
                                    <td>{{user_name}}</td>
                                    <td>{{user_email}}</td>
                                    <td>
                                        {{#if is_admin}}
                                            <span class="badge bg-success">Admin</span>
                                        {{else}}
                                            <span class="badge bg-secondary">User</span>
                                        {{/if}}
                                    </td>
                                    <td>
                                        <a href="/user/{{user_id}}/show" class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <a href="/user/{{user_id}}/edit" class="btn btn-sm btn-outline-warning">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/inline}}

{{> layout}}