{{!--
  Depends on: css/pages/applicability.css, js/pages/applicability.js
  Dynamic classes: reqman-applicability-row[hidden]
--}}
{{#*inline "page"}}
<section class="reqman-applicability-page">
  <div class="reqman-applicability-page__header">
    <h1 class="reqman-applicability-page__title">Applicability</h1>
    <a href="/p/{{selected_project_id}}/applicability/new" class="btn btn-primary">New Applicability</a>
  </div>

  <div class="reqman-applicability-page__toolbar">
    <label for="applicability-search-input" class="u-sr-only">Search applicability</label>
    <input
      id="applicability-search-input"
      type="search"
      class="form-control reqman-applicability-page__search c-form-control"
      placeholder="Search applicability by title, tag, or description"
      autocomplete="off"
    >
  </div>

  <div class="reqman-applicability-list" id="applicability-list">
    {{#each applicability}}
      {{> applicability_item}}
    {{else}}
      <p class="reqman-applicability-empty" id="applicability-empty-state">No applicability items yet.</p>
    {{/each}}
  </div>
  <p class="reqman-applicability-empty" id="applicability-empty-filter" hidden>No applicability items match your search.</p>
</section>
{{/inline}}
{{> layout page_id="applicability"}}
