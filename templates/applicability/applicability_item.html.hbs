{{!--
  Depends on: css/pages/applicability.css, js/pages/applicability.js
  Dynamic classes: reqman-applicability-row (visibility toggled)
--}}
<article class="reqman-applicability-row" data-applicability-row data-search-text="{{app_title}} {{app_tag}} {{app_description}} {{app_id}}">
  <div class="reqman-applicability-row__main">
    <div class="reqman-applicability-row__headline">
      <span class="reqman-applicability-tag" aria-label="Applicability tag {{app_tag}}">{{app_tag}}</span>
      <h3 class="reqman-applicability-row__title">{{app_title}}</h3>
    </div>
    {{#if app_description}}
      <p class="reqman-applicability-row__description">{{app_description}}</p>
    {{/if}}
  </div>
  <div class="reqman-applicability-row__meta">
    <span class="reqman-applicability-row__id" title="Applicability ID">#{{app_id}}</span>
    <div class="reqman-applicability-row__actions">
      <a
        href="/p/{{@root.selected_project_id}}/requirements?applicability_filter={{app_id}}"
        class="btn btn-secondary btn-sm reqman-applicability-row__action-btn"
      >View Requirements</a>
      <a href="/p/{{@root.selected_project_id}}/applicability/edit/{{app_id}}" class="btn btn-outline btn-sm reqman-applicability-row__action-btn">Edit</a>
      <button
        class="btn btn-danger btn-sm reqman-applicability-row__action-btn"
        type="button"
        data-action="delete-applicability"
        data-applicability-id="{{app_id}}"
        data-applicability-title="applicability {{app_tag}}"
        data-project-id="{{@root.selected_project_id}}"
      >Delete</button>
    </div>
  </div>
</article>
