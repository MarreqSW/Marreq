{{!--
  Depends on: css/pages/applicability.css, js/pages/applicability.js
  Dynamic classes: reqman-list-page__row (visibility toggled)
--}}
<article class="reqman-list-page__row" data-applicability-row data-search-text="{{app_title}} {{app_tag}} {{app_description}} {{app_id}}">
  <div class="reqman-list-page__row-main">
    <div class="reqman-list-page__row-headline">
      <span class="reqman-list-page__tag" aria-label="Applicability tag {{app_tag}}">{{app_tag}}</span>
      <h3 class="reqman-list-page__row-title">{{app_title}}</h3>
    </div>
    {{#if app_description}}
      <p class="reqman-list-page__row-description">{{app_description}}</p>
    {{/if}}
  </div>
  <div class="reqman-list-page__row-meta">
    <span class="reqman-list-page__row-id" title="Applicability ID">#{{app_id}}</span>
    <div class="reqman-list-page__row-actions">
      <a
        href="/p/{{@root.selected_project_id}}/requirements?applicability_filter={{app_id}}"
        class="btn btn-secondary btn-sm reqman-list-page__action-btn"
      >View Requirements</a>
      <a href="/p/{{@root.selected_project_id}}/applicability/edit/{{app_id}}" class="btn btn-outline btn-sm reqman-list-page__action-btn">Edit</a>
      <button
        class="btn btn-danger btn-sm reqman-list-page__action-btn"
        type="button"
        data-action="delete-applicability"
        data-applicability-id="{{app_id}}"
        data-applicability-title="applicability {{app_tag}}"
        data-project-id="{{@root.selected_project_id}}"
      >Delete</button>
    </div>
  </div>
</article>
