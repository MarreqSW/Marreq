<div class="card requirement-card">
  <div class="card-body">
    <div class="requirement-header">
      <div>
        <span class="requirement-id">APP-{{app_id}}</span>
        <h3 class="requirement-title">{{app_title}}</h3>
      </div>
      <div class="requirement-actions">
        <a href="/edit_applicability/{{app_id}}" class="btn btn-outline btn-sm">Edit</a>
        <button onclick="deleteApplicability({{app_id}})" class="btn btn-danger btn-sm">Delete</button>
      </div>
    </div>
    
    <p class="requirement-description">{{app_description}}</p>
    
    <div class="requirement-meta">
      <div class="meta-item">
        <span class="meta-label">Tag</span>
        <span class="meta-value tag">{{app_tag}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">ID</span>
        <span class="meta-value">{{app_id}}</span>
      </div>
    </div>
  </div>
</div>

<script>
function deleteApplicability(applicabilityId) {
  if (confirm('Are you sure you want to delete this applicability? This action cannot be undone.')) {
    fetch(`/delete_applicability/${applicabilityId}`, {
      method: 'DELETE',
    })
    .then(response => {
      if (response.ok) {
        window.location.reload();
      } else {
        alert('Error deleting applicability');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error deleting applicability');
    });
  }
}
</script> 