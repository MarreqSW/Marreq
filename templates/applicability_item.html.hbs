{{!--
  Depends on: css/50-components/cards.css, js/app.js (delete handler)
  Dynamic classes: requirement-card
--}}
<div class="card requirement-card">
  <div class="card-body">
    <div class="requirement-header">
      <div>
        <span class="requirement-id">APP-{{app_id}}</span>
        <h3 class="requirement-title">{{app_title}}</h3>
      </div>
      <div class="requirement-actions">
        <a href="/p/{{project_id}}/applicability/edit/{{app_id}}" class="btn btn-outline btn-sm">Edit</a>
        <button
          class="btn btn-danger btn-sm"
          type="button"
          data-action="delete-applicability"
          data-project-id="{{project_id}}"
          data-applicability-id="{{app_id}}"
        >Delete</button>
      </div>
    </div>
    
    <p class="requirement-description">{{app_description}}</p>
    
    <div class="requirement-meta">
      <div class="meta-item">
        <span class="meta-label">Tag</span>
        <span class="meta-value tag">{{app_tag}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">ID</span>
        <span class="meta-value">{{app_id}}</span>
      </div>
    </div>
  </div>
</div>
