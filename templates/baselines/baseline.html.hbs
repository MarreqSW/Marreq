{{!-- Single baseline view: metadata, requirements snapshot, traceability --}}
{{#*inline "page"}}
<div class="container-fluid mt-3">
  <div class="d-flex justify-content-between align-items-baseline mb-3">
    <h1 class="marreq-list-page__title">Baseline: {{baseline.name}}</h1>
    <a href="/p/{{selected_project_id}}/export_reqif?baseline_id={{baseline.id}}" class="btn btn-outline-primary btn-sm">Export ReqIF</a>
  </div>

  <div class="card c-card mb-4">
    <div class="card-body c-card__body">
      {{#if baseline.description}}
        <p class="card-text">{{baseline.description}}</p>
      {{/if}}
      <p class="text-muted small mb-0">
        Created {{baseline.created_at}}
        {{#if created_by_name}}by {{created_by_name}}{{/if}}
      </p>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-7">
      <div class="card c-card">
        <div class="card-header c-card__header">
          <h5 class="mb-0">Requirements in this baseline</h5>
        </div>
        <div class="card-body c-card__body p-0">
          {{#if requirements.0}}
            <div class="table-responsive">
              <table class="table table-sm table-hover mb-0">
                <thead>
                  <tr>
                    <th>ID</th>
                    <th>Reference</th>
                    <th>Title</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each requirements}}
                    <tr>
                      <td><a href="/p/{{../selected_project_id}}/requirements/show/{{id}}{{#if current_version_id}}/version/{{current_version_id}}{{/if}}">#{{id}}</a></td>
                      <td><code>{{reference_code}}</code></td>
                      <td><a href="/p/{{../selected_project_id}}/requirements/show/{{id}}{{#if current_version_id}}/version/{{current_version_id}}{{/if}}">{{title}}</a></td>
                      <td class="text-end">
                        {{#unless same_as_current}}
                        <button type="button" class="btn btn-link btn-sm p-0 small text-muted text-decoration-none"
                          data-action="show-baseline-diff"
                          data-project-id="{{../selected_project_id}}"
                          data-baseline-id="{{../baseline.id}}"
                          data-req-id="{{id}}"
                          aria-label="Diff this requirement vs current">Diff vs current</button>
                        {{/unless}}
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{else}}
            <p class="p-3 text-muted mb-0">No requirements in this baseline.</p>
          {{/if}}
        </div>
      </div>
    </div>
    <div class="col-lg-5">
      <div class="card c-card">
        <div class="card-header c-card__header">
          <h5 class="mb-0">Traceability (req ↔ test)</h5>
        </div>
        <div class="card-body c-card__body p-0">
          {{#if traceability.0}}
            <ul class="list-group list-group-flush mb-0">
              {{#each traceability}}
                <li class="list-group-item"><a href="/p/{{../selected_project_id}}/requirements/show/{{requirement_id}}{{#if version_id}}/version/{{version_id}}{{/if}}">{{requirement_reference}}</a> ↔ <a href="/p/{{../selected_project_id}}/tests/show/{{test_id}}">{{test_reference}}</a></li>
              {{/each}}
            </ul>
          {{else}}
            <p class="p-3 text-muted mb-0">No traceability links in this baseline.</p>
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <a href="/p/{{selected_project_id}}/baselines" class="btn btn-outline-secondary">Back to Baselines</a>
  </div>
</div>
{{/inline}}
{{> layout this page_id="baseline"}}
