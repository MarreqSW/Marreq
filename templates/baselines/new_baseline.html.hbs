{{!-- New baseline form --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New Baseline</h1>
  <p class="text-secondary">Create an immutable snapshot of current requirements and traceability.</p>

  {{#unless selected_project_id}}
  <div class="alert alert-info c-alert">
    <strong>Project Selection Required:</strong> Please select a project from the dropdown in the navigation bar above before creating a baseline.
    <br><br>
    <strong>Available Projects:</strong>
    <ul class="mb-0 mt-2">
      {{#each projects}}
        <li><strong>{{name}}</strong> (ID: {{id}})</li>
      {{/each}}
    </ul>
  </div>
  {{/unless}}
</div>

<section id="Baselines">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Baseline Details</h3>
    </div>
    <div class="card-body c-card__body">
      <div class="alert alert-info c-alert mb-3">
        This will snapshot all current requirement versions and the traceability matrix. The baseline cannot be changed later.
      </div>
      <p class="text-muted small mb-3">
        All requirements in the project are included (current version at creation time). Approval state does not filter baseline contents.
      </p>
      <form method="post" action="/{{selected_project_slug}}/baselines/new">
        <div class="form-group c-form-group">
          <label for="name" class="form-label c-form-label">Name</label>
          <input type="text" name="name" id="name" class="form-control c-form-control" placeholder="e.g. Release 1.0" required>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description (optional)</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="3"></textarea>
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary" {{#unless selected_project_id}}disabled{{/unless}}>Create Baseline</button>
          <a href="/{{selected_project_slug}}/baselines" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="new_baseline"}}
