{{#*inline "page"}}
<section class="category-page">
  <div class="category-page__header">
    <h1 class="category-page__title">Categories</h1>
    <a href="/p/{{selected_project_id}}/categories/new" class="btn btn-primary">New Category</a>
  </div>

  <div class="category-page__toolbar">
    <label for="category-search-input" class="sr-only">Search categories</label>
    <input
      id="category-search-input"
      type="search"
      class="form-control category-page__search"
      placeholder="Search categories by title, tag, or description"
      autocomplete="off"
    >
  </div>

  <div class="category-list" id="category-list">
    {{#each categories}}
      {{> category}}
    {{else}}
      <p class="category-empty" id="category-empty-state">No categories yet.</p>
    {{/each}}
  </div>
  <p class="category-empty" id="category-empty-filter" hidden>No categories match your search.</p>
</section>

<script>
(function() {
  const searchInput = document.getElementById('category-search-input');
  const list = document.getElementById('category-list');
  const rows = Array.from(list ? list.querySelectorAll('[data-category-row]') : []);
  const emptyInitial = document.getElementById('category-empty-state');
  const emptyFiltered = document.getElementById('category-empty-filter');

  if (!searchInput || !rows.length) {
    return;
  }

  function filterRows(value) {
    const query = value.trim().toLowerCase();
    let visibleCount = 0;

    rows.forEach((row) => {
      const haystack = row.dataset.searchText || row.textContent || '';
      const match = haystack.toLowerCase().includes(query);
      row.hidden = !match;
      if (match) {
        visibleCount += 1;
      }
    });

    if (emptyInitial) {
      emptyInitial.hidden = true;
    }

    if (emptyFiltered) {
      emptyFiltered.hidden = visibleCount !== 0;
    }
  }

  searchInput.addEventListener('input', (event) => {
    filterRows(event.target.value);
  });
})();
</script>
{{/inline}}
{{> layout}}
