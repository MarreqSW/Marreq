{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Category</h1>
  <p class="text-secondary">Update category details</p>
</div>

<section id="Categories">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Category Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="cat_title" class="form-label c-form-label">Category Title</label>
          <input type="text" name="cat_title" id="cat_title" value="{{categories.cat_title}}" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="cat_description" class="form-label c-form-label">Description</label>
          <textarea name="cat_description" id="cat_description" class="form-control c-form-control c-form-control--textarea" rows="4" required>{{categories.cat_description}}</textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="cat_tag" class="form-label c-form-label">Tag</label>
          <input type="text" name="cat_tag" id="cat_tag" value="{{categories.cat_tag}}" class="form-control c-form-control" placeholder="e.g., FEATURE, BUG, ENHANCEMENT" required>
          <small class="text-secondary">A short identifier for the category</small>
        </div>

        <input type="hidden" id="cat_id" name="cat_id" value="{{categories.cat_id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{categories.project_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update Category</button>
          <a href="/p/{{selected_project_id}}/categories" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout page_id="edit_category"}} 
