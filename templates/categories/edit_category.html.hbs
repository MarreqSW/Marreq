{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Category</h1>
  <p class="text-secondary">Update category details</p>
</div>

<section id="Categories">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Category Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="title" class="form-label c-form-label">Category Title</label>
          <input type="text" name="title" id="title" value="{{categories.title}}" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="4" required>{{categories.description}}</textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="tag" class="form-label c-form-label">Tag</label>
          <input type="text" name="tag" id="tag" value="{{categories.tag}}" class="form-control c-form-control" placeholder="e.g., FEATURE, BUG, ENHANCEMENT" required>
          <small class="text-secondary">A short identifier for the category</small>
        </div>

        <input type="hidden" id="id" name="id" value="{{categories.id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{categories.project_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update Category</button>
          <a href="/p/{{selected_project_id}}/categories" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="edit_category"}} 
