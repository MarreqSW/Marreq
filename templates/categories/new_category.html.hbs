{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New Category</h1>
  <p class="text-secondary">Create a new category for organizing requirements</p>
  
  {{#unless selected_project_id}}
  <div class="alert alert-info c-alert">
    <strong>Project Selection Required:</strong> Please select a project from the dropdown in the navigation bar above before creating a category.
    <br><br>
    <strong>Available Projects:</strong>
    <ul class="mb-0 mt-2">
      {{#each projects}}
        <li><strong>{{name}}</strong> (ID: {{project_id}})</li>
      {{/each}}
    </ul>
  </div>
  {{/unless}}
</div>

<section id="Categories">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Category Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="title" class="form-label c-form-label">Category Title</label>
          <input type="text" name="title" id="title" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="4" required></textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="tag" class="form-label c-form-label">Tag</label>
          <input type="text" name="tag" id="tag" class="form-control c-form-control" placeholder="e.g., FEATURE, BUG, ENHANCEMENT" required>
          <small class="text-secondary">A short identifier for the category</small>
        </div>

        {{#if selected_project_id}}
        <input type="hidden" name="project_id" value="{{selected_project_id}}">
        {{else}}
        <div class="alert alert-warning c-alert">
          <strong>Warning:</strong> No project selected. Please select a project from the dropdown above before creating a category.
        </div>
        {{/if}}

        <div class="mt-4">
          <button type="submit" class="btn btn-primary" {{#unless selected_project_id}}disabled{{/unless}}>Create Category</button>
          <a href="/p/{{selected_project_id}}/categories" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="new_category"}} 
