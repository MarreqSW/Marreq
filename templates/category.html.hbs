<div class="card requirement-card">
  <div class="card-body">
    <div class="requirement-header">
      <div>
        <span class="requirement-id">CAT-{{cat_id}}</span>
        <h3 class="requirement-title">{{cat_title}}</h3>
      </div>
      <div class="requirement-actions">
        <a href="/edit_category/{{cat_id}}" class="btn btn-outline btn-sm">Edit</a>
        <button onclick="deleteCategory({{cat_id}})" class="btn btn-danger btn-sm">Delete</button>
      </div>
    </div>
    
    <p class="requirement-description">{{cat_description}}</p>
    
    <div class="requirement-meta">
      <div class="meta-item">
        <span class="meta-label">Tag</span>
        <span class="meta-value">{{cat_tag}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">ID</span>
        <span class="meta-value">{{cat_id}}</span>
      </div>
    </div>
  </div>
</div>

<script>
function deleteCategory(categoryId) {
  if (confirm('Are you sure you want to delete this category? This action cannot be undone.')) {
    fetch(`/delete_category/${categoryId}`, {
      method: 'DELETE',
    })
    .then(response => {
      if (response.ok) {
        window.location.reload();
      } else {
        alert('Error deleting category');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error deleting category');
    });
  }
}
</script> 