{{!--
  Depends on: css/pages/categories.css, js/pages/categories.js
  Dynamic classes: reqman-category-row (visibility toggled)
--}}
<article class="reqman-category-row" data-category-row data-search-text="{{cat_title}} {{cat_tag}} {{cat_description}} {{cat_id}}">
  <div class="reqman-category-row__main">
    <div class="reqman-category-row__headline">
      <span class="reqman-category-tag" aria-label="Category tag {{cat_tag}}">{{cat_tag}}</span>
      <h3 class="reqman-category-row__title">{{cat_title}}</h3>
    </div>
    {{#if cat_description}}
      <p class="reqman-category-row__description">{{cat_description}}</p>
    {{/if}}
  </div>
  <div class="reqman-category-row__meta">
    <span class="reqman-category-row__id" title="Category ID">#{{cat_id}}</span>
    <div class="reqman-category-row__actions">
      <a
        href="/p/{{@root.selected_project_id}}/requirements?category_filter={{cat_id}}"
        class="btn btn-secondary btn-sm reqman-category-row__action-btn"
      >View Requirements</a>
      <a href="/p/{{@root.selected_project_id}}/categories/edit/{{cat_id}}" class="btn btn-outline btn-sm reqman-category-row__action-btn">Edit</a>
      <button
        class="btn btn-danger btn-sm reqman-category-row__action-btn"
        type="button"
        data-action="delete-category"
        data-category-id="{{cat_id}}"
        data-category-title="category {{cat_tag}}"
        data-project-id="{{@root.selected_project_id}}"
      >Delete</button>
    </div>
  </div>
</article>
