<article class="category-row" data-category-row data-search-text="{{cat_title}} {{cat_tag}} {{cat_description}} {{cat_id}}">
  <div class="category-row__main">
    <div class="category-row__headline">
      <span class="category-tag" aria-label="Category tag {{cat_tag}}">{{cat_tag}}</span>
      <h3 class="category-row__title">{{cat_title}}</h3>
    </div>
    {{#if cat_description}}
      <p class="category-row__description">{{cat_description}}</p>
    {{/if}}
  </div>
  <div class="category-row__meta">
    <span class="category-row__id" title="Category ID">#{{cat_id}}</span>
    <div class="category-row__actions">
      <a href="/p/{{@root.selected_project_id}}/categories/edit/{{cat_id}}" class="btn btn-outline btn-sm">Edit</a>
      <button onclick="deleteCategory({{cat_id}})" class="btn btn-danger btn-sm" type="button">Delete</button>
    </div>
  </div>
</article>

<script>
function deleteCategory(categoryId) {
  if (confirm('Are you sure you want to delete this category? This action cannot be undone.')) {
    fetch(`/p/{{@root.selected_project_id}}/categories/delete/${categoryId}`, {
      method: 'DELETE',
    })
    .then(response => {
      if (response.ok) {
        window.location.reload();
      } else {
        alert('Error deleting category');
      }
    })
    .catch(error => {
      console.error('Error:', error);
      alert('Error deleting category');
    });
  }
}
</script> 
