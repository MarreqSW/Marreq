{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h1>Change Password</h1>
    </div>
    <div class="card-body c-card__body">
      <form method="POST" action="/change_password" class="form">
        <div class="form-group c-form-group">
          <label for="current_password" class="form-label c-form-label">Current Password</label>
          <input type="password" id="current_password" name="current_password" class="form-control c-form-control" required>
        </div>
        
        <div class="form-group c-form-group">
          <label for="new_password" class="form-label c-form-label">New Password</label>
          <input type="password" id="new_password" name="new_password" class="form-control c-form-control" required>
          <small class="form-text c-form-text">Password must be at least 8 characters long</small>
        </div>
        
        <div class="form-group c-form-group">
          <label for="confirm_password" class="form-label c-form-label">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" class="form-control c-form-control" required>
        </div>
        
        {{#if error}}
          <div class="alert alert-error c-alert c-alert--error">
            {{error}}
          </div>
        {{/if}}
        
        {{#if success}}
          <div class="alert alert-success c-alert c-alert--success">
            {{success}}
          </div>
        {{/if}}
        
        <div class="form-actions c-form-actions">
          <button type="submit" class="btn btn-primary c-form-actions__action">Change Password</button>
          <a href="/" class="btn btn-outline c-form-actions__action">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="change_password"}} 
