{{#*inline "page"}}
<section class="marreq-list-page">
  <div class="marreq-list-page__header">
    <h1 class="marreq-list-page__title">Custom fields</h1>
    {{#if can_manage_custom_fields}}
    <a href="/p/{{selected_project_id}}/custom_fields/new" class="btn btn-primary">New custom field</a>
    {{/if}}
  </div>

  {{#if delete_error_message}}
  <div class="alert alert-warning mb-3" role="alert">{{delete_error_message}}</div>
  {{/if}}

  <div class="marreq-list-page__list">
    {{#each custom_fields}}
    <article class="card shadow-sm border-0 mb-3">
      <div class="card-body d-flex flex-wrap justify-content-between align-items-start gap-2">
        <div>
          <h3 class="h5 mb-1">{{this.label}}</h3>
          <p class="text-muted small mb-0">
            Type: <span class="text-body">{{this.field_type}}</span>
            {{#if this.enum_values}}
            · Enum options defined
            {{/if}}
            · Order: {{this.sort_order}}
          </p>
          {{#if (lookup ../in_use_counts this.id)}}
          <span class="badge bg-secondary mt-1">In use by {{lookup ../in_use_counts this.id}} version(s)</span>
          {{/if}}
        </div>
        {{#if ../can_manage_custom_fields}}
        <div class="d-flex gap-2">
          <a href="/p/{{../selected_project_id}}/custom_fields/edit/{{this.id}}" class="btn btn-outline btn-sm">Edit</a>
          <button
            type="button"
            class="btn btn-danger btn-sm"
            data-action="delete-custom-field"
            data-field-id="{{this.id}}"
            data-field-label="{{this.label}}"
            data-project-id="{{../selected_project_id}}"
          >Delete</button>
        </div>
        {{/if}}
      </div>
    </article>
    {{else}}
    <p class="text-muted">No custom fields yet. Create one to add project-specific metadata to requirements.</p>
    {{/each}}
  </div>
</section>
{{/inline}}
{{> layout this page_id="custom_fields"}}
