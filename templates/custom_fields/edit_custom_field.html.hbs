{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Custom Field</h1>
  <p class="text-secondary">Update field definition</p>
</div>

{{#if (gt in_use_count 0)}}
<div class="alert alert-info mb-3" role="status">
  This field is in use by <strong>{{in_use_count}}</strong> requirement version(s). You can still edit the label, type, and options. Deleting is only possible when no version uses it.
</div>
{{/if}}

<section>
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Field definition</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="label" class="form-label c-form-label">Label</label>
          <input type="text" name="label" id="label" class="form-control c-form-control" value="{{custom_field.label}}" required>
        </div>

        <div class="form-group c-form-group">
          <label for="field_type" class="form-label c-form-label">Type</label>
          <select name="field_type" id="field_type" class="form-control c-form-control c-form-control--select" required>
            <option value="text" {{#if (eq custom_field.field_type "text")}}selected{{/if}}>Text</option>
            <option value="number" {{#if (eq custom_field.field_type "number")}}selected{{/if}}>Number</option>
            <option value="boolean" {{#if (eq custom_field.field_type "boolean")}}selected{{/if}}>Boolean</option>
            <option value="enum" {{#if (eq custom_field.field_type "enum")}}selected{{/if}}>Enum (fixed options)</option>
          </select>
        </div>

        <div class="form-group c-form-group" id="enum-values-group" style="display: {{#if (eq custom_field.field_type "enum")}}block{{else}}none{{/if}};">
          <label for="enum_values" class="form-label c-form-label">Enum values (one per line or comma-separated)</label>
          <textarea name="enum_values" id="enum_values" class="form-control c-form-control c-form-control--textarea" rows="4">{{enum_values_string}}</textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="sort_order" class="form-label c-form-label">Sort order</label>
          <input type="number" name="sort_order" id="sort_order" class="form-control c-form-control" value="{{custom_field.sort_order}}" min="0">
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update custom field</button>
          <a href="/p/{{selected_project_id}}/custom_fields" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
<script>
(function() {
  var sel = document.getElementById('field_type');
  var group = document.getElementById('enum-values-group');
  function toggle() { group.style.display = sel.value === 'enum' ? 'block' : 'none'; }
  sel.addEventListener('change', toggle);
  toggle();
})();
</script>
{{/inline}}
{{> layout page_id="edit_custom_field"}}
