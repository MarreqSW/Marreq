{{!-- Depends on: css/pages/groups.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4 marreq-group-edit-page">
  <div class="row g-4">
    <div class="col-lg-8">
      <div class="card c-card">
        <div class="card-header c-card__header">
          <h3 class="mb-0"><i class="fas fa-gear me-2" aria-hidden="true"></i>Group Settings</h3>
        </div>
        <div class="card-body c-card__body">
          {{#if success}}
            <div class="alert alert-success c-alert" role="alert">{{success}}</div>
          {{/if}}
          {{#if error}}
            <div class="alert alert-danger c-alert" role="alert">{{error}}</div>
          {{/if}}

          <form method="POST" action="/{{group.slug}}/-/settings" class="vstack gap-3">
            <div>
              <label for="name" class="form-label c-form-label">Group Name *</label>
              <input type="text" class="form-control c-form-control" id="name" name="name" value="{{group.name}}" required>
            </div>

            <div>
              <label for="description" class="form-label c-form-label">Description</label>
              <textarea class="form-control c-form-control c-form-control--textarea" id="description" name="description" rows="5">{{group.description}}</textarea>
            </div>

            <div class="d-flex justify-content-between">
              <a href="/{{group.slug}}" class="btn btn-secondary">
                <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to Group
              </a>
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-save" aria-hidden="true"></i> Save Changes
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card c-card mb-4">
        <div class="card-header c-card__header">
          <h2 class="h6 mb-0">Group Snapshot</h2>
        </div>
        <div class="card-body c-card__body">
          <p class="mb-2"><strong>Members:</strong> {{group.member_count}}</p>
          <p class="mb-0"><strong>Projects:</strong> {{group.project_count}}</p>
        </div>
      </div>

      <div class="card c-card marreq-group-danger">
        <div class="card-header c-card__header">
          <h2 class="h6 mb-0">Danger Zone</h2>
        </div>
        <div class="card-body c-card__body">
          <p class="text-muted small">Deleting a group is permanent. The group must not have any projects attached.</p>
          <form method="POST" action="/{{group.slug}}/-/delete">
            <button
              type="submit"
              class="btn btn-outline-danger w-100"
              data-confirm="Delete this group? This action cannot be undone."
            >
              <i class="fas fa-trash me-1" aria-hidden="true"></i> Delete Group
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{{/inline}}
{{> layout this page_id="group-edit"}}
