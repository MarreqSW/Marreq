{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Profile</h1>
  <p class="text-secondary">Update your personal information</p>
</div>

<section id="edit-profile">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Profile Details</h3>
    </div>
    <div class="card-body c-card__body">
      {{#if profile_error}}
        <div class="alert alert-danger c-alert" role="alert">
          We couldn't save your changes. Please try again.
        </div>
      {{/if}}
      <form method="post" action="/user/profile/edit">
        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="name" class="form-label c-form-label">Full Name</label>
            <input
              type="text"
              name="name"
              id="name"
              value="{{user.name}}"
              class="form-control c-form-control"
              required>
          </div>

          <div class="form-group c-form-group">
            <label for="username" class="form-label c-form-label">Username</label>
            <input
              type="text"
              name="username"
              id="username"
              value="{{user.username}}"
              class="form-control c-form-control"
              required>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="email" class="form-label c-form-label">Email Address</label>
          <input
            type="email"
            name="email"
            id="email"
            value="{{user.email}}"
            class="form-control c-form-control"
            required>
        </div>

        <input type="hidden" id="id" name="id" value="{{user.id}}">
        <input type="hidden" id="is_admin" name="is_admin" value="{{#if user.is_admin}}true{{else}}false{{/if}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Save Changes</button>
          <a href="/user/profile" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout page_id="edit_profile"}}
