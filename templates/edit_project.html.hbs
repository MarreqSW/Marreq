{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h3 class="mb-0">
                        <i class="fas fa-edit"></i> Edit Project
                    </h3>
                </div>
                <div class="card-body c-card__body">
                    <form method="POST" action="/p/{{project.project_id}}/edit">
                        <div class="mb-3">
                            <label for="name" class="form-label c-form-label">Project Name *</label>
                            <input type="text" class="form-control c-form-control" id="name" name="name" value="{{project.name}}" required>
                        </div>
                        
                        <div class="mb-3">
                            <label for="description" class="form-label c-form-label">Description</label>
                            <textarea class="form-control c-form-control c-form-control--textarea" id="description" name="description" rows="3">{{project.description}}</textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label for="status_id" class="form-label c-form-label">Status</label>
                            <select class="form-select c-form-select c-form-control c-form-control--select" id="status_id" name="status_id">
                                <option value="active" {{#if (eq project.status_id 'active')}}selected{{/if}}>Active</option>
                                <option value="inactive" {{#if (eq project.status_id 'inactive')}}selected{{/if}}>Inactive</option>
                                <option value="completed" {{#if (eq project.status_id 'completed')}}selected{{/if}}>Completed</option>
                                <option value="on-hold" {{#if (eq project.status_id 'on-hold')}}selected{{/if}}>On Hold</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label for="owner_id" class="form-label c-form-label">Project Owner *</label>
                            <select class="form-select c-form-select c-form-control c-form-control--select" id="owner_id" name="owner_id" required>
                                {{#unless project.owner_id}}
                                    <option value="" disabled selected>Select an owner</option>
                                {{/unless}}
                                {{#each users}}
                                    <option value="{{id}}" {{#if (eq id ../project.owner_id)}}selected{{/if}}>
                                        {{name}} ({{username}})
                                    </option>
                                {{/each}}
                            </select>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/projects" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Projects
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Project
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}
{{> layout page_id="edit_project"}} 