{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Requirement</h1>
  <p class="text-secondary">Update requirement details</p>
</div>

<section id="Requirements">
  <div class="card">
    <div class="card-header">
      <h3>Requirement Details</h3>
    </div>
    <div class="card-body">
      <form method="post">
        <div class="grid grid-2">
          <div class="form-group">
            <label for="req_title" class="form-label">Title</label>
            <input type="text" name="req_title" id="req_title" value="{{requirements.req_title}}" class="form-control" required>
          </div>
          
          <div class="form-group">
            <label for="req_reference" class="form-label">Reference</label>
            <input type="text" name="req_reference" id="req_reference" value="{{requirements.req_reference}}" class="form-control">
            <small class="text-secondary">Must follow format REQ-{CATEGORY_TAG}-NUMBER (e.g., REQ-SYS-1). Leave empty to auto-generate.</small>
            <div id="reference-error" class="text-danger" style="display: none;"></div>
          </div>
        </div>

        <div class="form-group">
          <label for="req_description" class="form-label">Description</label>
          <textarea name="req_description" id="req_description" class="form-control" rows="4" required>{{requirements.req_description}}</textarea>
        </div>

        <div class="form-group">
          <label for="req_justification" class="form-label">Justification (Optional)</label>
          <textarea name="req_justification" id="req_justification" class="form-control" rows="3">{{requirements.req_justification}}</textarea>
          <small class="text-secondary">Explain the rationale behind this requirement</small>
        </div>

        <div class="grid grid-3">
          <div class="form-group">
            <label for="req_author" class="form-label">Author</label>
            <select name="req_author" id="req_author" class="form-control" required>
              {{#each users }}
                <option value="{{user_id}}">{{user_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_reviewer" class="form-label">Reviewer</label>
            <select name="req_reviewer" id="req_reviewer" class="form-control" required>
              {{#each users }}
                <option value="{{user_id}}">{{user_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_category" class="form-label">Category</label>
            <select name="req_category" id="req_category" class="form-control" required>
              {{#each categories }}
                <option value="{{cat_id}}">{{cat_title}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_applicability" class="form-label">Applicability</label>
            <select name="req_applicability" id="req_applicability" class="form-control" required>
              {{#each applicability }}
                <option value="{{app_id}}">{{app_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="grid grid-3">
          <div class="form-group">
            <label for="req_current_status" class="form-label">Status</label>
            <select name="req_current_status" id="req_current_status" class="form-control" required>
              {{#each status }}
                <option value="{{st_id}}">{{st_title}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_verification" class="form-label">Verification Mode</label>
            <select name="req_verification" id="req_verification" class="form-control" required>
              {{#each verification}}
                <option value="{{verification_id}}">{{verification_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_parent" class="form-label">Parent Requirement</label>
            <select name="req_parent" id="req_parent" class="form-control">
              <option value="0">None</option>
              {{#each parent }}
                <option value="{{req_id}}">{{req_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="req_link" class="form-label">Link</label>
          <input type="url" id="req_link" name="req_link" value="{{requirements.req_link}}" class="form-control" placeholder="https://example.com">
        </div>

        <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
        <input type="hidden" id="req_id" name="req_id" value="{{requirements.req_id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{requirements.project_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update Requirement</button>
          <a href="/requirements/{{requirements.req_id}}" class="btn btn-outline">Cancel</a>
          <a href="/requirements" class="btn btn-outline">Back to Requirements</a>
          
          <!-- Delete Button with Access Control -->
          <button id="delete-btn" onclick="deleteRequirement({{requirements.req_id}}, '{{requirements.req_title}}')" class="btn btn-danger" style="display: none;">Delete Requirement</button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
// Requirement data for setting selected values
const requirementData = {
  req_author: {{req_author_id}},
  req_reviewer: {{req_reviewer_id}},
  req_category: {{req_category_id}},
  req_applicability: {{req_applicability_id}},
  req_current_status: {{req_current_status_id}},
  req_verification: {{req_verification_id}},
  req_parent: {{req_parent_id}}
};

// Category data for validation
const categoryData = [
  {{#each categories}}
    { id: {{cat_id}}, tag: "{{cat_tag}}" },
  {{/each}}
];

// Function to set selected values
function setSelectedValues() {
  // Set author
  const authorSelect = document.getElementById('req_author');
  if (authorSelect) {
    authorSelect.value = String(requirementData.req_author);
  }
  
  // Set reviewer
  const reviewerSelect = document.getElementById('req_reviewer');
  if (reviewerSelect) {
    reviewerSelect.value = String(requirementData.req_reviewer);
  }
  
  // Set category
  const categorySelect = document.getElementById('req_category');
  if (categorySelect) {
    categorySelect.value = String(requirementData.req_category);
  }
  
  // Set applicability
  const applicabilitySelect = document.getElementById('req_applicability');
  if (applicabilitySelect) {
    applicabilitySelect.value = String(requirementData.req_applicability);
  }
  
  // Set status
  const statusSelect = document.getElementById('req_current_status');
  if (statusSelect) {
    statusSelect.value = String(requirementData.req_current_status);
  }
  
  // Set verification
  const verificationSelect = document.getElementById('req_verification');
  if (verificationSelect) {
    verificationSelect.value = String(requirementData.req_verification);
  }
  
  // Set parent
  const parentSelect = document.getElementById('req_parent');
  if (parentSelect) {
    parentSelect.value = String(requirementData.req_parent);
  }
}

// Reference validation function
function validateReference() {
  const referenceInput = document.getElementById('req_reference');
  const categorySelect = document.getElementById('req_category');
  const errorDiv = document.getElementById('reference-error');
  const submitButton = document.querySelector('button[type="submit"]');
  
  const reference = referenceInput.value.trim();
  const categoryId = parseInt(categorySelect.value);
  
  // Clear previous error
  errorDiv.style.display = 'none';
  errorDiv.textContent = '';
  submitButton.disabled = false;
  
  // If reference is empty, it's valid (will be auto-generated)
  if (reference === '') {
    return true;
  }
  
  // Find the selected category
  const selectedCategory = categoryData.find(cat => cat.id === categoryId);
  if (!selectedCategory) {
    return true; // Can't validate without category
  }
  
  // Check if reference follows the general format (REQ-TAG-NUMBER)
  const generalPattern = /^REQ-[A-Z]+-\d+$/;
  if (!generalPattern.test(reference)) {
    errorDiv.textContent = `Reference must follow the format "REQ-TAG-NUMBER" (e.g., REQ-${selectedCategory.tag}-1).`;
    errorDiv.style.display = 'block';
    submitButton.disabled = true;
    return false;
  }
  
  // For new references, check if they match the selected category
  // For existing references, be more lenient
  const expectedPrefix = `REQ-${selectedCategory.tag}-`;
  if (!reference.startsWith(expectedPrefix)) {
    errorDiv.textContent = `Warning: Reference "${reference}" doesn't match the selected category "${selectedCategory.tag}". Consider updating the reference to match the category.`;
    errorDiv.style.display = 'block';
    // Don't disable submit for existing references
    return true;
  }
  
  return true;
}

// Function to show/hide delete button based on status and user permissions
function updateDeleteButtonVisibility() {
  const deleteBtn = document.getElementById('delete-btn');
  const statusId = parseInt(requirementData.req_current_status);
  const isAdmin = {{#if user.is_admin}}true{{else}}false{{/if}};
  
  // Show delete button if status is Draft (1) or Proposal (2), or if user is admin
  if (statusId === 1 || statusId === 2 || isAdmin) {
    deleteBtn.style.display = 'inline-block';
  } else {
    deleteBtn.style.display = 'none';
  }
}

// Add event listeners
document.addEventListener('DOMContentLoaded', function() {
  // Set selected values first
  setSelectedValues();
  
  // Update delete button visibility
  updateDeleteButtonVisibility();
  
  const referenceInput = document.getElementById('req_reference');
  const categorySelect = document.getElementById('req_category');
  
  referenceInput.addEventListener('input', validateReference);
  categorySelect.addEventListener('change', validateReference);
  
  // Initial validation
  validateReference();
});
</script>
{{/inline}}
{{> layout}}


