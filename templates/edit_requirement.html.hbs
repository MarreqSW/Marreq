{{!--
  Depends on: css/50-components/forms.css, js/pages/requirementForm.js
  Dynamic classes: status-{{requirements.req_current_status}}
--}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Requirement</h1>
  <p class="text-secondary">Update requirement details</p>
</div>

<section id="Requirements">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Requirement Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post" data-requirement-form data-allow-soft-mismatch="true">
        <div class="grid grid-2">
          <div class="form-group c-form-group">
            <label for="req_title" class="form-label c-form-label">Title</label>
            <input type="text" name="req_title" id="req_title" value="{{requirements.req_title}}" class="form-control c-form-control" required>
          </div>
          
          <div class="form-group c-form-group">
            <label for="req_reference" class="form-label c-form-label">Reference</label>
            <input type="text" name="req_reference" id="req_reference" value="{{requirements.req_reference}}" class="form-control c-form-control">
            <small class="text-secondary">Must follow format REQ-{CATEGORY_TAG}-NUMBER (e.g., REQ-SYS-1). Leave empty to auto-generate.</small>
            <div id="reference-error" class="text-danger" style="display: none;"></div>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="req_description" class="form-label c-form-label">Description</label>
          <textarea name="req_description" id="req_description" class="form-control c-form-control c-form-control--textarea" rows="4" required>{{requirements.req_description}}</textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="req_justification" class="form-label c-form-label">Justification (Optional)</label>
          <textarea name="req_justification" id="req_justification" class="form-control c-form-control c-form-control--textarea" rows="3">{{requirements.req_justification}}</textarea>
          <small class="text-secondary">Explain the rationale behind this requirement</small>
        </div>

        <div class="grid grid-3">
          <div class="form-group c-form-group">
            <label for="req_author" class="form-label c-form-label">Author</label>
            <select name="req_author" id="req_author" class="form-control c-form-control c-form-control--select" required>
              {{#each users }}
                <option value="{{user_id}}" {{#if (eq user_id ../req_author_id)}}selected{{/if}}>{{user_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="req_reviewer" class="form-label c-form-label">Reviewer</label>
            <select name="req_reviewer" id="req_reviewer" class="form-control c-form-control c-form-control--select" required>
              {{#each users }}
                <option value="{{user_id}}" {{#if (eq user_id ../req_reviewer_id)}}selected{{/if}}>{{user_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="req_category" class="form-label c-form-label">Category</label>
            <select name="req_category" id="req_category" class="form-control c-form-control c-form-control--select" required>
              {{#each categories }}
                <option value="{{cat_id}}" data-tag="{{cat_tag}}" {{#if (eq cat_id ../req_category_id)}}selected{{/if}}>{{cat_title}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="req_applicability" class="form-label c-form-label">Applicability</label>
            <select name="req_applicability" id="req_applicability" class="form-control c-form-control c-form-control--select" required>
              {{#each applicability }}
                <option value="{{app_id}}" {{#if (eq app_id ../req_applicability_id)}}selected{{/if}}>{{app_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="grid grid-3">
          <div class="form-group c-form-group">
            <label for="req_current_status" class="form-label c-form-label">Status</label>
            <select name="req_current_status" id="req_current_status" class="form-control c-form-control c-form-control--select" required>
              {{#each status }}
                <option value="{{st_id}}" {{#if (eq st_id ../req_current_status_id)}}selected{{/if}}>{{st_title}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="req_verification" class="form-label c-form-label">Verification Mode</label>
            <select name="req_verification" id="req_verification" class="form-control c-form-control c-form-control--select" required>
              {{#each verification}}
                <option value="{{verification_id}}" {{#if (eq verification_id ../req_verification_id)}}selected{{/if}}>{{verification_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="req_parent" class="form-label c-form-label">Parent Requirement</label>
            <select name="req_parent" id="req_parent" class="form-control c-form-control c-form-control--select">
              <option value="0" {{#if (eq 0 ../req_parent_id)}}selected{{/if}}>None</option>
              {{#each parent }}
                <option value="{{req_id}}" {{#if (eq req_id ../req_parent_id)}}selected{{/if}}>{{req_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="req_link" class="form-label c-form-label">Link</label>
          <input type="url" id="req_link" name="req_link" value="{{requirements.req_link}}" class="form-control c-form-control" placeholder="https://example.com">
        </div>

        <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
        <input type="hidden" id="req_id" name="req_id" value="{{requirements.req_id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{requirements.project_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary" data-role="submit-requirement">Update Requirement</button>
          <a href="/p/{{requirements.project_id}}/requirements/show/{{requirements.req_id}}" class="btn btn-outline">Cancel</a>
          <a href="/p/{{requirements.project_id}}/requirements" class="btn btn-outline">Back to Requirements</a>
          
          {{#if (or (eq requirements.req_current_status_id 1) (eq requirements.req_current_status_id 2) user.is_admin)}}
          <button
            class="btn btn-danger"
            type="button"
            data-action="delete-requirement"
            data-project-id="{{requirements.project_id}}"
            data-requirement-id="{{requirements.req_id}}"
            data-requirement-title="{{requirements.req_title}}"
          >Delete Requirement</button>
          {{/if}}
        </div>
      </form>
    </div>
  </div>
</section>

{{/inline}}
{{> layout page_id="requirement-form"}}
