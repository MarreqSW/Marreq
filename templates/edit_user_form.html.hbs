<div class="mb-4">
  <h1>Edit User</h1>
  <p class="text-secondary">Update user account details</p>
</div>

<section id="Users">
  <div class="card">
    <div class="card-header">
      <h3>User Details</h3>
    </div>
    <div class="card-body">
      <form method="post" action="/user/edit/{{users.user_id}}">
        <div class="grid grid-2">
          <div class="form-group">
            <label for="user_name" class="form-label">Full Name</label>
            <input type="text" name="user_name" id="user_name" value="{{users.user_name}}" class="form-control" required>
          </div>

          <div class="form-group">
            <label for="user_username" class="form-label">Username</label>
            <input type="text" name="user_username" id="user_username" value="{{users.user_username}}" class="form-control" required>
          </div>
        </div>

        <div class="form-group">
          <label for="user_email" class="form-label">Email Address</label>
          <input type="email" name="user_email" id="user_email" value="{{users.user_email}}" class="form-control" required>
        </div>

        <input type="hidden" id="is_admin" name="is_admin" value="{{#if users.is_admin}}true{{else}}false{{/if}}">

        <input type="hidden" id="user_id" name="user_id" value="{{users.user_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update User</button>
          <a href="/user/{{users.user_id}}/show" class="btn btn-outline">Cancel</a>
          <a href="/admin/users" class="btn btn-outline">Back to User Management</a>
        </div>
      </form>
    </div>
  </div>
</section>
