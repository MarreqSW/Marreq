<div class="mb-4">
  <h1>Edit User</h1>
  <p class="text-secondary">Update user account details</p>
</div>

<section id="Users">
  <div class="card">
    <div class="card-header">
      <h3>User Details</h3>
    </div>
    <div class="card-body">
      <form method="post" action="/edit_user/{{users.user_id}}">
        <div class="grid grid-2">
          <div class="form-group">
            <label for="user_name" class="form-label">Full Name</label>
            <input type="text" name="user_name" id="user_name" value="{{users.user_name}}" class="form-control" required>
          </div>

          <div class="form-group">
            <label for="user_username" class="form-label">Username</label>
            <input type="text" name="user_username" id="user_username" value="{{users.user_username}}" class="form-control" required>
          </div>
        </div>

        <div class="form-group">
          <label for="user_email" class="form-label">Email Address</label>
          <input type="email" name="user_email" id="user_email" value="{{users.user_email}}" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="user_level" class="form-label">User Level</label>
          <select name="user_level" id="user_level" class="form-control" required>
            <option value="1" {{#if (eq users.user_level 1)}}selected{{/if}}>Admin</option>
            <option value="2" {{#if (eq users.user_level 2)}}selected{{/if}}>User</option>
            <option value="3" {{#if (eq users.user_level 3)}}selected{{/if}}>Guest</option>
          </select>
        </div>

        <input type="hidden" id="user_id" name="user_id" value="{{users.user_id}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update User</button>
          <a href="/users/{{users.user_id}}" class="btn btn-outline">Cancel</a>
          <a href="/" class="btn btn-outline">Back to Home</a>
        </div>
      </form>
    </div>
  </div>
</section>
