{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger c-card">
                <div class="card-header bg-danger text-white c-card__header">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i>
                        {{#if title}}{{title}}{{else}}Error{{/if}}
                    </h4>
                </div>
                <div class="card-body c-card__body">
                    <div class="text-center mb-4 u-text-center">
                        <i class="fas fa-exclamation-circle text-danger" style="font-size: 4rem;"></i>
                    </div>
                    
                    <h5 class="card-title text-center mb-3 u-text-center">{{#if message}}{{message}}{{else}}An error occurred while processing your request.{{/if}}</h5>
                    
                    {{#if details}}
                    <div class="alert alert-info c-alert">
                        <strong>Details:</strong> {{details}}
                    </div>
                    {{/if}}
                    
                    <div class="text-center mt-4 u-text-center">
                        <a href="/" class="btn btn-primary me-2">
                            <i class="fas fa-home"></i> Go to Home
                        </a>
                        <button type="button" class="btn btn-secondary" data-action="history-back">
                            <i class="fas fa-arrow-left"></i> Go Back
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}
{{> layout this page_id="error"}}
