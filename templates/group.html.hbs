{{!-- Depends on: css/pages/groups.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4 marreq-group-page">
  {{#if success}}
    <div class="alert alert-success c-alert" role="alert">{{success}}</div>
  {{/if}}
  {{#if error}}
    <div class="alert alert-danger c-alert" role="alert">{{error}}</div>
  {{/if}}

  <div class="marreq-group-hero card c-card">
    <div class="card-body c-card__body">
      <div class="marreq-group-hero__header">
        <div>
          <p class="marreq-group-hero__eyebrow">Group</p>
          <h1 class="marreq-group-hero__title">{{group.name}}</h1>
          <p class="marreq-group-hero__subtitle">Your role: {{group.current_role_label}}</p>
        </div>
        <div class="marreq-group-hero__actions">
          <a href="/g/{{group.slug}}/members" class="btn btn-primary">View Members</a>
          {{#if can_manage_members}}
            <a href="/g/{{group.slug}}/edit" class="btn btn-outline">Settings</a>
          {{/if}}
        </div>
      </div>

      {{#if group.description}}
        <p class="marreq-group-hero__description">{{group.description}}</p>
      {{/if}}

      <div class="marreq-group-hero__stats">
        <div class="marreq-group-stat">
          <span class="marreq-group-stat__value">{{group.member_count}}</span>
          <span class="marreq-group-stat__label">Members</span>
        </div>
        <div class="marreq-group-stat">
          <span class="marreq-group-stat__value">{{group.project_count}}</span>
          <span class="marreq-group-stat__label">Projects</span>
        </div>
        <div class="marreq-group-stat">
          <span class="marreq-group-stat__value">{{group.owners_label}}</span>
          <span class="marreq-group-stat__label">Owners</span>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mt-1">
    <div class="col-lg-8">
      <div class="card c-card">
        <div class="card-header c-card__header d-flex justify-content-between align-items-center">
          <div>
            <h2 class="h5 mb-0">Projects in This Group</h2>
            <p class="text-muted mb-0">Project visibility still follows direct project membership.</p>
          </div>
          <span class="badge bg-primary bg-gradient">{{group.project_count}} Projects</span>
        </div>
        <div class="card-body c-card__body marreq-group-projects">
          {{#if related_projects.0}}
            {{#each related_projects}}
              <article class="marreq-group-project">
                <div class="marreq-group-project__main">
                  <div class="marreq-group-project__headline">
                    <h3 class="marreq-group-project__title">{{name}}</h3>
                    <span class="badge bg-light text-dark">{{status_label}}</span>
                  </div>
                  {{#if description}}
                    <p class="marreq-group-project__description">{{description}}</p>
                  {{/if}}
                  {{#if owner_name}}
                    <p class="marreq-group-project__owner">Owned by {{owner_name}}</p>
                  {{/if}}
                  {{#if restricted_message}}
                    <p class="marreq-group-project__restriction">{{restricted_message}}</p>
                  {{/if}}
                </div>
                <div class="marreq-group-project__actions">
                  {{#if can_open}}
                    <a href="/p/{{slug}}" class="btn btn-primary btn-sm">Open Project</a>
                  {{else}}
                    <span class="badge bg-secondary-subtle text-secondary-emphasis">Access restricted</span>
                  {{/if}}
                  {{#if can_edit_project}}
                    <a href="/p/{{slug}}/edit" class="btn btn-outline btn-sm">Edit Project</a>
                  {{/if}}
                </div>
              </article>
            {{/each}}
          {{else}}
            <p class="text-muted mb-0">No projects have been assigned to this group yet.</p>
          {{/if}}
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card c-card mb-4">
        <div class="card-header c-card__header">
          <h2 class="h6 mb-0">Administration</h2>
        </div>
        <div class="card-body c-card__body">
          <p class="text-muted small">Groups organize projects and membership, but they do not grant project access on their own.</p>
          <div class="d-grid gap-2">
            <a href="/g/{{group.slug}}/members" class="btn btn-outline-primary">Manage Members</a>
            {{#if can_manage_members}}
              <a href="/g/{{group.slug}}/edit" class="btn btn-outline-secondary">Edit Group</a>
            {{/if}}
            <a href="/groups" class="btn btn-link px-0">Back to all groups</a>
          </div>
        </div>
      </div>

      <div class="card c-card">
        <div class="card-header c-card__header">
          <h2 class="h6 mb-0">What Grouping Means</h2>
        </div>
        <div class="card-body c-card__body">
          <ul class="small text-muted mb-0 marreq-group-notes">
            <li>Projects can belong to one group.</li>
            <li>Group owners manage the member roster.</li>
            <li>Project access still requires direct project membership.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>
{{/inline}}
{{> layout this page_id="group"}}
