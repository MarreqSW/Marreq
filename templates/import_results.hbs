{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h3>Import Results</h3>
                </div>
                <div class="card-body c-card__body">
                    {{#if result.success}}
                    <div class="alert alert-success c-alert c-alert--success">
                        <h5>✅ Import Successful!</h5>
                        <p>{{result.message}}</p>
                        <p><strong>Records imported:</strong> {{result.imported_count}}</p>
                    </div>
                    {{else}}
                    <div class="alert alert-danger c-alert">
                        <h5>❌ Import Failed</h5>
                        <p>{{result.message}}</p>
                        {{#if result.imported_count}}
                        <p><strong>Records processed before error:</strong> {{result.imported_count}}</p>
                        {{/if}}
                    </div>
                    {{/if}}
                    
                    {{#if result.errors}}
                    <div class="mt-4">
                        <h5>Errors:</h5>
                        <div class="alert alert-danger c-alert">
                            <ul class="mb-0">
                                {{#each result.errors}}
                                <li>{{this}}</li>
                                {{/each}}
                            </ul>
                        </div>
                    </div>
                    {{/if}}
                    
                    <div class="mt-4">
                        <h5>What happened:</h5>
                        <ul>
                            <li>The Excel file was processed using the column mappings you specified</li>
                            <li>Data was imported into the currently selected project</li>
                            {{#if result.success}}
                            <li>All data was successfully imported</li>
                            <li>New categories, applicability options, and other references were created as needed</li>
                            {{else}}
                            <li>Import failed and no changes were made to the database</li>
                            <li>Please check the error messages above and try again</li>
                            {{/if}}
                        </ul>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <a href="/" class="btn btn-primary">Go to Homepage</a>
                        {{#if result.success}}
                        <a href="/{{selected_project_slug}}/import_excel" class="btn btn-secondary">Import Another File</a>
                        {{#if (eq result.import_type "requirements")}}
                        <a href="{{#if selected_project_id}}/{{selected_project_slug}}/requirements{{else}}/requirements{{/if}}" class="btn btn-outline-primary">View Requirements</a>
                        {{else}}
                        <a href="/{{selected_project_slug}}/verifications" class="btn btn-outline-primary">View Verifications</a>
                        {{/if}}
                        {{else}}
                        <a href="/{{selected_project_slug}}/import_excel" class="btn btn-outline-primary">Try Import Again</a>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/inline}}
{{> layout this}}