{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header">
                    <h3>Import Results</h3>
                </div>
                <div class="card-body">
                    {{#if result.success}}
                    <div class="alert alert-success">
                        <h5>✅ Import Successful!</h5>
                        <p>{{result.message}}</p>
                        <p><strong>Records imported:</strong> {{result.imported_count}}</p>
                    </div>
                    {{else}}
                    <div class="alert alert-warning">
                        <h5>⚠️ Import Completed with Errors</h5>
                        <p>{{result.message}}</p>
                        <p><strong>Records imported:</strong> {{result.imported_count}}</p>
                    </div>
                    {{/if}}
                    
                    {{#if result.errors}}
                    <div class="mt-4">
                        <h5>Errors:</h5>
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                {{#each result.errors}}
                                <li>{{this}}</li>
                                {{/each}}
                            </ul>
                        </div>
                    </div>
                    {{/if}}
                    
                    <div class="mt-4">
                        <h5>What happened:</h5>
                        <ul>
                            <li>The Excel file was processed using the column mappings you specified</li>
                            <li>Data was imported into the currently selected project</li>
                            <li>If any errors occurred during import, the entire operation was rolled back</li>
                            <li>New categories, applicability options, and other references were created as needed</li>
                        </ul>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <a href="/" class="btn btn-primary">Go to Homepage</a>
                        <a href="/import_excel" class="btn btn-secondary">Import Another File</a>
                        {{#if (eq result.import_type "requirements")}}
                        <a href="{{#if selected_project_id}}/p/{{selected_project_id}}/requirements{{else}}/requirements{{/if}}" class="btn btn-outline-primary">View Requirements</a>
                        {{else}}
                        <a href="/p/{{selected_project_id}}/tests" class="btn btn-outline-primary">View Tests</a>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{{/inline}}
{{> layout}} 