{{#*inline "page"}}
<!-- Quick Actions Dropdown -->
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div class="dropdown">
      <button class="btn btn-primary dropdown-toggle" type="button" id="quickActionsDropdown" data-bs-toggle="dropdown" aria-expanded="false">
        Quick Actions
      </button>
      <ul class="dropdown-menu" aria-labelledby="quickActionsDropdown">
        {{#if user.is_admin}}
        <li><a class="dropdown-item" href="/new_project">New Project</a></li>
        <li><hr class="dropdown-divider"></li>
        {{/if}}
        <li><a class="dropdown-item" href="/new_requirement">New Requirement</a></li>
        <li><a class="dropdown-item" href="/new_test">New Test</a></li>
        <li><a class="dropdown-item" href="/new_category">New Category</a></li>
        <li><a class="dropdown-item" href="/new_applicability">New Applicability</a></li>
        <li><a class="dropdown-item" href="/new_user">New User</a></li>
        <li><hr class="dropdown-divider"></li>
        {{#if user.is_admin}}
        <li><a class="dropdown-item" href="/import_excel">Import Excel</a></li>
        <li><hr class="dropdown-divider"></li>
        {{/if}}
        <li><a class="dropdown-item" href="/requirements.xls">Export Requirements</a></li>
        <li><a class="dropdown-item" href="/tests.xls">Export Tests</a></li>
        <li><a class="dropdown-item" href="/matrix.xls">Export Matrix</a></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="/users">View Users</a></li>
        <li><a class="dropdown-item" href="/reports">View Reports</a></li>
      </ul>
    </div>
  </div>
</div>

<div class="text-center mb-5">
  <h2>{{selected_project_name}}</h2>
</div>

<div class="dashboard-grid">
  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Requirements <span class="badge bg-primary">{{requirements_count}}</span></h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>View and manage all your software requirements</p>
      </div>
      <div class="card-actions">
        <a href="/requirements" class="btn btn-primary">View Requirements</a>
        <a href="/requirements.xls" class="btn btn-success">Export Excel</a>
        {{#if user.is_admin}}
        <a href="/import_excel" class="btn btn-warning">Import Excel</a>
        {{/if}}
        <a href="/new_requirement" class="btn btn-outline">New Requirement</a>
      </div>
    </div>
  </div>

  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Tests <span class="badge bg-primary">{{tests_count}}</span></h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>Manage test cases and verification methods</p>
      </div>
      <div class="card-actions">
        <a href="/tests" class="btn btn-primary">View Tests</a>
        <a href="/tests.xls" class="btn btn-success">Export Excel</a>
        {{#if user.is_admin}}
        <a href="/import_excel" class="btn btn-warning">Import Excel</a>
        {{/if}}
        <a href="/new_test" class="btn btn-outline">New Test</a>
      </div>
    </div>
  </div>

  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Traceability Matrix</h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>Link requirements to tests and generate reports</p>
      </div>
      <div class="card-actions">
        <a href="/matrix" class="btn btn-primary">View Matrix</a>
        <a href="/matrix.xls" class="btn btn-success">Export Excel</a>
      </div>
    </div>
  </div>

  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Categories</h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>Organize requirements with categories</p>
      </div>
      <div class="card-actions">
        <a href="/categories" class="btn btn-primary">View Categories</a>
        <a href="/new_category" class="btn btn-outline">New Category</a>
      </div>
    </div>
  </div>

  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Applicability</h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>Define which products/systems requirements apply to</p>
      </div>
      <div class="card-actions">
        <a href="/applicability" class="btn btn-primary">View Applicability</a>
        <a href="/new_applicability" class="btn btn-outline">New Applicability</a>
      </div>
    </div>
  </div>

  <div class="card dashboard-card">
    <div class="card-header">
      <h3>Users</h3>
    </div>
    <div class="card-body">
      <div class="card-description">
        <p>Manage user accounts and permissions</p>
      </div>
      <div class="card-actions">
        <a href="/users" class="btn btn-primary">View Users</a>
        <a href="/new_user" class="btn btn-outline">New User</a>
      </div>
    </div>
  </div>
</div>
{{/inline}}
{{> layout}}