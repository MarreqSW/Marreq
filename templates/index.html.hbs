{{#*inline "page"}}
{{!-- Set flag to hide navigation --}}
<div class="reqman-portal">
  <!-- Left Navigation Sidebar -->
  <aside class="reqman-sidebar" id="mainSidebar">
    <div class="reqman-sidebar__header">
      <a href="/" class="reqman-sidebar__brand">
        <span class="reqman-sidebar__brand-text">ReqMan</span>
      </a>
      <div class="reqman-sidebar__header-actions">
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false"
          title="Toggle dark mode">
          <span class="theme-toggle-icon theme-toggle-icon-sun" aria-hidden="true">☀</span>
          <span class="theme-toggle-icon theme-toggle-icon-moon" aria-hidden="true">🌙</span>
        </button>
        <button type="button" class="reqman-sidebar__toggle" id="sidebarToggle" aria-label="Toggle sidebar">
          <i class="fas fa-chevron-left"></i>
        </button>
      </div>
    </div>

    <nav class="reqman-sidebar__nav" aria-label="Main navigation">
      <!-- Overview Section -->
      <div class="reqman-nav-section">
        <h3 class="reqman-nav-section__title">Overview</h3>
        <ul class="reqman-nav-list">
          <li>
            <a href="/" class="reqman-nav-link reqman-nav-link--active" aria-current="page">
              <i class="fas fa-chart-line"></i>
              <span>Dashboard</span>
            </a>
          </li>
          <li>
            <a href="#activity" class="reqman-nav-link reqman-nav-link--disabled" title="Coming soon">
              <i class="fas fa-stream"></i>
              <span>Activity Feed</span>
              <span class="reqman-badge reqman-badge--soon">Soon</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Projects Section -->
      <div class="reqman-nav-section">
        <h3 class="reqman-nav-section__title">Projects</h3>
        <ul class="reqman-nav-list">
          <li>
            <a href="/projects" class="reqman-nav-link">
              <i class="fas fa-folder-tree"></i>
              <span>All Projects</span>
            </a>
          </li>
          {{#if user.is_admin}}
          <li>
            <a href="/new_project" class="reqman-nav-link">
              <i class="fas fa-plus-circle"></i>
              <span>Create Project</span>
            </a>
          </li>
          {{/if}}
        </ul>
      </div>

      <!-- Workflows Section (Placeholder) -->
      <div class="reqman-nav-section">
        <h3 class="reqman-nav-section__title">Workflows</h3>
        <ul class="reqman-nav-list">
          <li>
            <a href="#change-requests" class="reqman-nav-link reqman-nav-link--disabled" title="Coming soon">
              <i class="fas fa-code-branch"></i>
              <span>Change Requests</span>
              <span class="reqman-badge reqman-badge--soon">Soon</span>
            </a>
          </li>
          <li>
            <a href="#reviews" class="reqman-nav-link reqman-nav-link--disabled" title="Coming soon">
              <i class="fas fa-user-check"></i>
              <span>Reviews</span>
              <span class="reqman-badge reqman-badge--soon">Soon</span>
            </a>
          </li>
        </ul>
      </div>

      {{#if user.is_admin}}
      <!-- Admin Section -->
      <div class="reqman-nav-section">
        <h3 class="reqman-nav-section__title">Administration</h3>
        <ul class="reqman-nav-list">
          <li>
            <a href="/admin" class="reqman-nav-link">
              <i class="fas fa-shield-alt"></i>
              <span>Admin Panel</span>
            </a>
          </li>
          <li>
            <a href="/admin/users" class="reqman-nav-link">
              <i class="fas fa-users-cog"></i>
              <span>User Management</span>
            </a>
          </li>
          <li>
            <a href="/logs" class="reqman-nav-link">
              <i class="fas fa-list-alt"></i>
              <span>System Logs</span>
            </a>
          </li>
        </ul>
      </div>
      {{/if}}
    </nav>

    <div class="reqman-sidebar__footer">
      <div class="reqman-user-info">
        <div class="reqman-user-info__avatar">
          <i class="fas fa-user-circle"></i>
        </div>
        <div class="reqman-user-info__details">
          <div class="reqman-user-info__name">
            {{#if user.user_name}}{{user.user_name}}{{else}}{{user.user_username}}{{/if}}
          </div>
          <div class="reqman-user-info__email">{{user.user_email}}</div>
        </div>
        <div class="reqman-user-info__actions">
          <div class="dropdown">
            <button class="reqman-user-menu-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"
              title="User menu">
              <i class="fas fa-cog" aria-hidden="true"></i>
              <span class="visually-hidden">User menu</span>
            </button>

            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/user/profile"><i class="fas fa-user me-2"></i>My Profile</a></li>
              <li><a class="dropdown-item" href="/change_password"><i class="fas fa-key me-2"></i>Change Password</a>
              </li>
              <li>
                <hr class="dropdown-divider">
              </li>
              <li><a class="dropdown-item text-danger" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a>
              </li>
            </ul>
          </div>


        </div>
      </div>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main class="reqman-main" id="mainContent">
    <div class="reqman-main__header">
      <button type="button" class="reqman-mobile-toggle" id="mobileToggle" aria-label="Toggle navigation">
        <i class="fas fa-bars"></i>
      </button>
      <div class="reqman-main__title">
        <h1>
          {{#if user.user_name}}
          Welcome back, {{user.user_name}}
          {{else}}
          Requirements Dashboard
          {{/if}}
        </h1>
        <p class="reqman-main__subtitle">Manage requirements, tests, and traceability across all your projects</p>
      </div>
    </div>

    <!-- Quick Actions -->
    <section class="reqman-section">
      <h2 class="reqman-section__title">Quick Actions</h2>
      <div class="reqman-quick-actions">
        <a href="/projects" class="reqman-action-card reqman-action-card--primary">
          <i class="fas fa-folder-tree"></i>
          <span>Browse Projects</span>
        </a>
        {{#if user.is_admin}}
        <a href="/new_project" class="reqman-action-card">
          <i class="fas fa-folder-plus"></i>
          <span>Create Project</span>
        </a>
        <a href="#review-verifications" class="reqman-action-card reqman-nav-link--disabled" title="Coming soon">
          <i class="fas fa-code-branch"></i>
          <span>Failing Tests</span>
        </a>
        <a href="/admin" class="reqman-action-card">
          <i class="fas fa-shield-alt"></i>
          <span>Admin Panel</span>
        </a>
        {{/if}}
      </div>
    </section>

    <!-- Projects List -->
    <section class="reqman-section">
      <div class="reqman-section__header">
        <h2 class="reqman-section__title">Your Projects</h2>
        <a href="/projects" class="reqman-link-arrow">
          View all
          <i class="fas fa-arrow-right"></i>
        </a>
      </div>

      {{#if projects}}
      <div class="reqman-projects-grid">
        {{#each projects}}
        <article class="reqman-project-card">
          <div class="reqman-project-card__header">
            <h3>{{project_name}}</h3>
            <span class="reqman-badge reqman-badge--{{project_status_badge}}">{{project_status}}</span>
          </div>
          {{#if project_description}}
          <p class="reqman-project-card__description">{{project_description}}</p>
          {{/if}}
          <div class="reqman-project-card__meta">
            <div class="reqman-project-card__meta-item">
              <i class="fas fa-user"></i>
              <span>
                {{#if project_owner_name}}
                {{project_owner_name}}
                {{else}}
                Owner: {{project_owner_id}}
                {{/if}}
              </span>
            </div>
            {{#if role_label}}
            <div class="reqman-project-card__meta-item">
              <i class="fas fa-id-badge"></i>
              <span>{{role_label}}</span>
            </div>
            {{/if}}
          </div>
          <div class="reqman-project-card__actions">
            <a href="/p/{{project_id}}" class="reqman-btn reqman-btn--primary">
              <i class="fas fa-eye"></i>
              Open
            </a>
            <a href="/p/{{project_id}}/requirements" class="reqman-btn reqman-btn--outline">
              <i class="fas fa-clipboard-list"></i>
              Requirements
            </a>
          </div>
        </article>
        {{/each}}
      </div>
      {{else}}
      <div class="reqman-empty-state">
        <i class="fas fa-folder-open"></i>
        <h3>No Projects Yet</h3>
        <p>Create your first project to start managing requirements and tests</p>
        {{#if user.is_admin}}
        <a href="/new_project" class="reqman-btn reqman-btn--primary">
          <i class="fas fa-plus"></i>
          Create Project
        </a>
        {{/if}}
      </div>
      {{/if}}
    </section>

    <!-- Recent Activity Placeholder -->
    <section class="reqman-section">
      <h2 class="reqman-section__title">Recent Activity</h2>
      <div class="reqman-placeholder-feature">
        <i class="fas fa-clock"></i>
        <h3>Activity Feed Coming Soon</h3>
        <p>Track project updates, requirement changes, and team activities in real-time</p>
      </div>
    </section>
  </main>
</div>

<script>
  (function () {
    const sidebar = document.getElementById('mainSidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const mobileToggle = document.getElementById('mobileToggle');
    const STORAGE_KEY = 'reqman_sidebar_collapsed';

    // Load saved state
    const isCollapsed = localStorage.getItem(STORAGE_KEY) === 'true';
    if (isCollapsed && window.innerWidth >= 992) {
      sidebar.classList.add('reqman-sidebar--collapsed');
    }

    // Toggle sidebar
    function toggleSidebar() {
      const collapsed = sidebar.classList.toggle('reqman-sidebar--collapsed');
      if (window.innerWidth >= 992) {
        localStorage.setItem(STORAGE_KEY, collapsed);
      }
    }

    if (sidebarToggle) {
      sidebarToggle.addEventListener('click', toggleSidebar);
    }

    if (mobileToggle) {
      mobileToggle.addEventListener('click', () => {
        sidebar.classList.toggle('reqman-sidebar--mobile-open');
      });
    }

    // Close sidebar on mobile when clicking outside
    document.addEventListener('click', (e) => {
      if (window.innerWidth < 992 &&
        !sidebar.contains(e.target) &&
        !mobileToggle.contains(e.target) &&
        sidebar.classList.contains('reqman-sidebar--mobile-open')) {
        sidebar.classList.remove('reqman-sidebar--mobile-open');
      }
    });

    // Count projects from DOM
    const projectCards = document.querySelectorAll('.reqman-project-card');
    const projectCountEl = document.querySelector('[data-project-count]');
    if (projectCountEl && projectCards.length > 0) {
      projectCountEl.textContent = projectCards.length;
    }
  })();
</script>

<style>
  :root {
    --sidebar-width: 280px;
    --sidebar-collapsed-width: 70px;
    --header-height: 60px;
    --spacing-xs: 0.5rem;
    --spacing-sm: 0.75rem;
    --spacing-md: 1rem;
    --spacing-lg: 1.5rem;
    --spacing-xl: 2rem;
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --transition-base: 0.2s ease;
  }

  .reqman-portal {
    display: flex;
    min-height: 100vh;
    background: var(--background-color, #f5f7fa);
  }

  /* Sidebar Styles */
  .reqman-sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--surface-color, #ffffff);
    border-right: 1px solid var(--border-color, #e2e8f0);
    display: flex;
    flex-direction: column;
    transition: width var(--transition-base), transform var(--transition-base);
    z-index: 100;
  }

  .reqman-sidebar--collapsed {
    width: var(--sidebar-collapsed-width);
  }

  .reqman-sidebar__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color, #e2e8f0);
    min-height: var(--header-height);
  }

  .reqman-sidebar__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
    padding: calc(var(--space-1, 0.25rem) + 2px) var(--space-2, 0.5rem);
    border-radius: var(--radius-md);
    transition: color 0.2s ease;
  }

  .reqman-sidebar__brand::before {
    content: 'R';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: var(--radius-md);
    background: var(--primary-color, #3b82f6);
    color: white;
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .reqman-sidebar__brand:hover,
  .reqman-sidebar__brand:focus-visible {
    color: var(--primary-color, #3b82f6);
  }

  .reqman-sidebar__brand:focus-visible {
    outline: 2px solid rgba(37, 99, 235, 0.45);
    outline-offset: 4px;
  }

  .reqman-sidebar--collapsed .reqman-sidebar__brand-text {
    display: none;
  }

  .reqman-sidebar__header-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .reqman-sidebar__header-actions .theme-toggle {
    width: 2.25rem;
    height: 2.25rem;
  }

  .reqman-sidebar--collapsed .reqman-sidebar__header-actions .theme-toggle {
    display: none;
  }

  .reqman-sidebar__toggle {
    padding: var(--spacing-xs);
    background: transparent;
    border: none;
    color: var(--text-secondary, #64748b);
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: all var(--transition-base);
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .reqman-sidebar__toggle:hover {
    background: var(--surface-muted, #f1f5f9);
    color: var(--primary-color, #3b82f6);
  }

  .reqman-sidebar--collapsed .reqman-sidebar__toggle i {
    transform: rotate(180deg);
  }

  .reqman-sidebar__nav {
    flex: 1;
    overflow-y: auto;
    padding: var(--spacing-md);
  }

  .reqman-nav-section {
    margin-bottom: var(--spacing-lg);
  }

  .reqman-nav-section__title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary, #64748b);
    padding: 0 var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .reqman-sidebar--collapsed .reqman-nav-section__title {
    display: none;
  }

  .reqman-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .reqman-nav-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--text-primary, #1e293b);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
    position: relative;
  }

  .reqman-nav-link i {
    width: 20px;
    text-align: center;
    font-size: 1.1rem;
  }

  .reqman-nav-link:hover {
    background: var(--surface-muted, #f1f5f9);
    color: var(--primary-color, #3b82f6);
  }

  .reqman-nav-link--active {
    background: var(--primary-color, #3b82f6);
    color: white;
  }

  .reqman-nav-link--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .reqman-sidebar--collapsed .reqman-nav-link span:not(.reqman-badge) {
    display: none;
  }

  .reqman-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 9999px;
    margin-left: auto;
  }

  .reqman-badge--soon {
    background: var(--warning-light, #fef3c7);
    color: var(--warning-dark, #92400e);
  }

  .reqman-sidebar__footer {
    padding: var(--spacing-md);
    border-top: 1px solid var(--border-color, #e2e8f0);
  }

  .reqman-user-info {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    position: relative;
  }

  .reqman-user-info__avatar {
    font-size: 2rem;
    color: var(--primary-color, #3b82f6);
    flex-shrink: 0;
  }

  .reqman-user-info__details {
    overflow: hidden;
  }

  .reqman-user-info__name {
    font-weight: 600;
    font-size: 0.875rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reqman-user-info__email {
    font-size: 0.75rem;
    color: var(--text-secondary, #64748b);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .reqman-sidebar--collapsed .reqman-user-info__details {
    display: none;
  }

  .reqman-user-info__actions {
    margin-left: auto;
  }

  .reqman-user-menu-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: transparent;
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-md);
    color: var(--text-secondary, #64748b);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .reqman-user-menu-toggle:hover {
    background: var(--surface-muted, #f1f5f9);
    border-color: var(--primary-color, #3b82f6);
    color: var(--primary-color, #3b82f6);
  }

  .reqman-sidebar--collapsed .reqman-user-info__actions {
    display: none;
  }

  /* Main Content Styles */
  .reqman-main {
    flex: 1;
    margin-left: var(--sidebar-width);
    padding: var(--spacing-xl);
    transition: margin-left var(--transition-base);
  }

  .reqman-sidebar--collapsed+.reqman-main {
    margin-left: var(--sidebar-collapsed-width);
  }

  .reqman-main__header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .reqman-mobile-toggle {
    display: none;
    padding: var(--spacing-sm);
    background: var(--surface-color, #ffffff);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-md);
    cursor: pointer;
  }

  .reqman-main__title h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 var(--spacing-xs) 0;
    color: var(--text-primary, #1e293b);
  }

  .reqman-main__subtitle {
    color: var(--text-secondary, #64748b);
    margin: 0;
  }

  /* Metrics Cards */
  .reqman-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .reqman-metric-card {
    background: var(--surface-color, #ffffff);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .reqman-metric-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: grid;
    place-items: center;
    font-size: 1.5rem;
  }

  .reqman-metric-card__icon--primary {
    background: #dbeafe;
    color: #1e40af;
  }

  .reqman-metric-card__icon--success {
    background: #d1fae5;
    color: #065f46;
  }

  .reqman-metric-card__icon--warning {
    background: #fef3c7;
    color: #92400e;
  }

  .reqman-metric-card__icon--info {
    background: #e0e7ff;
    color: #3730a3;
  }

  .reqman-metric-card__value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary, #1e293b);
  }

  .reqman-metric-card__label {
    font-size: 0.875rem;
    color: var(--text-secondary, #64748b);
  }

  /* Sections */
  .reqman-section {
    margin-bottom: var(--spacing-xl);
  }

  .reqman-section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
  }

  .reqman-section__title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 var(--spacing-lg) 0;
    color: var(--text-primary, #1e293b);
  }

  .reqman-link-arrow {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--primary-color, #3b82f6);
    text-decoration: none;
    font-weight: 600;
  }

  .reqman-link-arrow:hover {
    text-decoration: underline;
  }

  /* Quick Actions */
  .reqman-quick-actions {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .reqman-action-card {
    background: var(--surface-color, #ffffff);
    border: 2px dashed var(--border-color, #e2e8f0);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    text-align: center;
    text-decoration: none;
    color: var(--text-primary, #1e293b);
    transition: all var(--transition-base);
  }

  .reqman-action-card:hover {
    border-color: var(--primary-color, #3b82f6);
    background: #eff6ff;
    transform: translateY(-2px);
  }

  .reqman-action-card--primary {
    background: var(--primary-color, #3b82f6);
    color: white;
    border-style: solid;
  }

  .reqman-action-card--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .reqman-action-card i {
    font-size: 1.5rem;
  }

  /* Projects Grid */
  .reqman-projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }

  .reqman-project-card {
    background: var(--surface-color, #ffffff);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    transition: all var(--transition-base);
  }

