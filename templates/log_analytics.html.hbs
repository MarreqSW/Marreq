{{!--
  Depends on: css/50-components/tables.css, js/pages/logAnalytics.js
--}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Log Analytics</h1>
                <div>
                    <a href="/logs" class="btn btn-secondary me-2">Back to Logs</a>
                    <a href="/-/admin" class="btn btn-outline-secondary">Admin</a>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="card text-center c-card u-text-center">
                        <div class="card-body c-card__body">
                            <h5 class="card-title">Last 7 Days</h5>
                            <h2 class="text-primary">{{last_7_days}}</h2>
                            <p class="card-text c-card__text">Log entries</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center c-card u-text-center">
                        <div class="card-body c-card__body">
                            <h5 class="card-title">Last 30 Days</h5>
                            <h2 class="text-success">{{last_30_days}}</h2>
                            <p class="card-text c-card__text">Log entries</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center c-card u-text-center">
                        <div class="card-body c-card__body">
                            <h5 class="card-title">Last 90 Days</h5>
                            <h2 class="text-info">{{last_90_days}}</h2>
                            <p class="card-text c-card__text">Log entries</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <div class="card c-card">
                        <div class="card-header c-card__header">
                            <h5 class="mb-0">System Activity Overview</h5>
                        </div>
                        <div class="card-body c-card__body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6>Recent Activity Trends</h6>
                                    <ul class="list-unstyled">
                                        <li><strong>7-day average:</strong> <span class="average-7" data-average="7" data-value="{{last_7_days}}" data-divisor="7">{{last_7_days}}</span> entries/day</li>
                                        <li><strong>30-day average:</strong> <span class="average-30" data-average="30" data-value="{{last_30_days}}" data-divisor="30">{{last_30_days}}</span> entries/day</li>
                                        <li><strong>90-day average:</strong> <span class="average-90" data-average="90" data-value="{{last_90_days}}" data-divisor="90">{{last_90_days}}</span> entries/day</li>
                                    </ul>
                                </div>
                                <div class="col-md-6">
                                    <h6>System Health</h6>
                                    <div class="alert alert-info c-alert">
                                        <strong>Log Retention:</strong> 90 days<br>
                                        <strong>Storage:</strong> Active monitoring<br>
                                        <strong>Status:</strong> Healthy
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <div class="card c-card">
                        <div class="card-header c-card__header">
                            <h5 class="mb-0">Maintenance Actions</h5>
                        </div>
                        <div class="card-body c-card__body">
                            <form method="post" action="/cleanup_logs" class="d-inline">
                                <button type="submit" class="btn btn-warning" data-confirm="Are you sure you want to clean up logs older than 90 days? This action cannot be undone.">
                                    <i class="fas fa-broom"></i> Clean Up Old Logs
                                </button>
                            </form>
                            <p class="text-muted mt-2">
                                <small>This will remove log entries older than 90 days to free up database space.</small>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}

{{> layout this page_id="log-analytics"}}
