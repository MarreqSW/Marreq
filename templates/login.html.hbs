<!doctype html>
<!-- Depends on: /static/css/index.css, /static/js/app.js -->
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ReqMan</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <script src="/static/js/theme-prefetch.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/static/reqman.css">
  <link rel="icon" href="/static/favicon.ico">
</head>

<body class="login-page" data-page="login">
  <main>
    <div class="reqman-login">
      <button
        data-theme-toggle
        class="theme-toggle reqman-login__theme-toggle c-theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        aria-pressed="false"
        title="Toggle dark mode">
        <span class="theme-toggle-icon theme-toggle-icon-sun c-theme-toggle__icon c-theme-toggle__icon--sun" aria-hidden="true">☀</span>
        <span class="theme-toggle-icon theme-toggle-icon-moon c-theme-toggle__icon c-theme-toggle__icon--moon" aria-hidden="true">🌙</span>
      </button>
      <div class="reqman-login__card">
        <header class="reqman-login__header">
          <h1>Welcome to ReqMan</h1>
          <p>Please sign in to continue</p>
        </header>

        <form method="POST" action="/login" class="reqman-login__form">
          <div class="mb-3">
            <label for="username" class="form-label c-form-label">Username</label>
            <input id="username" name="username" type="text" class="form-control c-form-control" autocomplete="username" required>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label c-form-label">Password</label>
            <input id="password" name="password" type="password" class="form-control c-form-control" autocomplete="current-password" required>
          </div>

          {{#if error}}
          <div class="alert alert-danger c-alert">{{error}}</div>
          {{/if}}

          <button type="submit" class="btn btn-primary w-100">Sign In</button>
        </form>

        <footer class="reqman-login__footer">
          <p>Default credentials: alice / ChangeMe123!</p>
        </footer>
      </div>

      <p>&copy; 2026 ReqMan - Requirements Management System</p>
    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script type="module" src="/static/js/app.js"></script>
</body>

</html>
