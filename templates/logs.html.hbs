{{> layout}}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>System Logs</h1>
                <a href="/admin" class="btn btn-secondary">Back to Admin</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent Activity</h5>
                </div>
                <div class="card-body">
                    {{#if logs}}
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>User</th>
                                        <th>Action</th>
                                        <th>Entity</th>
                                        <th>Description</th>
                                        <th>IP Address</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each logs}}
                                    <tr>
                                        <td>{{format_datetime created_at}}</td>
                                        <td>{{user_id}}</td>
                                        <td>
                                            <span class="badge bg-{{get_action_color action_type}}">
                                                {{action_type}}
                                            </span>
                                        </td>
                                        <td>
                                            {{#if entity_id}}
                                                <a href="/logs/{{entity_type}}/{{entity_id}}">
                                                    {{entity_type}} #{{entity_id}}
                                                </a>
                                            {{else}}
                                                {{entity_type}}
                                            {{/if}}
                                        </td>
                                        <td>{{description}}</td>
                                        <td>
                                            <small class="text-muted">{{ip_address}}</small>
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    {{else}}
                        <div class="text-center text-muted">
                            <p>No logs found.</p>
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Helper function to format datetime
function format_datetime(datetime_str) {
    const date = new Date(datetime_str);
    return date.toLocaleString();
}

// Helper function to get action color
function get_action_color(action_type) {
    switch(action_type) {
        case 'CREATE': return 'success';
        case 'UPDATE': return 'primary';
        case 'DELETE': return 'danger';
        case 'LOGIN': return 'info';
        case 'LOGOUT': return 'secondary';
        case 'EXPORT': return 'warning';
        case 'IMPORT': return 'warning';
        case 'STATUS_CHANGE': return 'info';
        default: return 'secondary';
    }
}

// Apply formatting to all rows
document.addEventListener('DOMContentLoaded', function() {
    const rows = document.querySelectorAll('tbody tr');
    rows.forEach(row => {
        const actionCell = row.querySelector('td:nth-child(3) .badge');
        if (actionCell) {
            const actionType = actionCell.textContent.trim();
            actionCell.className = `badge bg-${get_action_color(actionType)}`;
        }
    });
});
</script> 