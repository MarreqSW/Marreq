{{!--
  Depends on: css/50-components/tables.css, js/pages/logs.js
  Dynamic classes: badge bg-*
--}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>System Logs</h1>
                <div>
                    <a href="/export_logs" class="btn btn-primary me-2">
                        <i class="fas fa-download"></i> Export All Logs
                    </a>
                    <a href="/log_analytics" class="btn btn-info me-2">
                        <i class="fas fa-chart-bar"></i> Analytics
                    </a>
                    <a href="/admin" class="btn btn-secondary">Back to Admin</a>
                </div>
            </div>

            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="mb-0">Recent Activity</h5>
                </div>
                <div class="card-body c-card__body">
                    {{#if logs}}
                        <div class="table-responsive c-table-responsive">
                            <table class="table table-striped c-table c-table--striped">
                                <thead>
                                    <tr>
                                        <th>Timestamp</th>
                                        <th>User</th>
                                        <th>Action</th>
                                        <th>Entity</th>
                                        <th>Description</th>
                                        <th>IP Address</th>
                                        <th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each logs}}
                                    <tr>
                                        <td class="datetime-cell" data-timestamp="{{created_at}}">{{created_at}}</td>
                                        <td>{{username}}</td>
                                        <td>
                                            <span class="badge action-badge" data-action-type="{{action_type}}">
                                                {{action_type}}
                                            </span>
                                        </td>
                                        <td>
                                            {{#if entity_id}}
                                                <a href="/logs/{{entity_type}}/{{entity_id}}">
                                                    {{entity_type}} #{{entity_id}}
                                                </a>
                                            {{else}}
                                                {{entity_type}}
                                            {{/if}}
                                        </td>
                                        <td>{{description}}</td>
                                        <td>
                                            <small class="text-muted">{{ip_address}}</small>
                                        </td>
                                        <td>
                                            {{#if old_values}}
                                                <button
                                                    class="btn btn-sm btn-outline-info"
                                                    type="button"
                                                    data-action="show-changes"
                                                    data-old-values="{{old_values}}"
                                                    data-new-values="{{new_values}}"
                                                >
                                                    View Changes
                                                </button>
                                            {{/if}}
                                        </td>
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    {{else}}
                        <div class="text-center text-muted u-text-center">
                            <p>No logs found.</p>
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for showing changes -->
<div class="modal fade" id="changesModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Changes</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <small class="text-muted">
                        <span class="text-danger">🔴 Red</span> = Removed/Changed values | 
                        <span class="text-success">🟢 Green</span> = Added/New values | 
                        <span class="text-muted">⚪ Gray</span> = Unchanged values
                    </small>
                </div>
                <div id="changesContent">
                    <!-- Content will be loaded here -->
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}

{{> layout page_id="logs"}}
