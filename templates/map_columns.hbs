{{!--
  Depends on: css/50-components/forms.css, js/pages/mapColumns.js
--}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h3>Map Excel Columns to Database Fields</h3>
                    <p class="mb-0">Import Type: <strong>{{import_type}}</strong> | Records to Import: <strong>{{data_count}}</strong></p>
                </div>
                <div class="card-body c-card__body">
                    <form id="mappingForm" action="/import_excel/process" method="post">
                        <input type="hidden" name="import_type" value="{{import_type}}">
                        <input type="hidden" name="temp_file" value="{{temp_file}}">
                        <input type="hidden" name="column_mappings" id="columnMappings">
                        
                        <div class="row">
                            <div class="col-md-6">
                                <h5>Excel Columns</h5>
                                <div class="table-responsive c-table-responsive">
                                    <table class="table table-sm c-table c-table--sm">
                                        <thead>
                                            <tr>
                                                <th>Column</th>
                                                <th>Sample Value</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#each columns}}
                                            <tr>
                                                <td><strong>{{name}}</strong></td>
                                                <td><small class="text-muted">{{sample_value}}</small></td>
                                            </tr>
                                            {{/each}}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <h5>Database Fields</h5>
                                <div class="table-responsive c-table-responsive">
                                    <table class="table table-sm c-table c-table--sm">
                                        <thead>
                                            <tr>
                                                <th>Field</th>
                                                <th>Description</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {{#each available_fields}}
                                            <tr>
                                                <td><strong>{{this}}</strong></td>
                                                <td><small class="text-muted">Database field for {{this}}</small></td>
                                            </tr>
                                            {{/each}}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        
                        <hr>
                        
                        <h5>Column Mappings</h5>
                        <div class="alert alert-warning c-alert">
                            <strong>Important:</strong> Map Excel columns to the appropriate database fields. 
                            Unmapped columns will be ignored. Required fields should be mapped for successful import.
                        </div>
                        
                        <div id="mappingContainer">
                            {{#each columns}}
                            <div class="row mb-3">
                                <div class="col-md-4">
                                    <label class="form-label c-form-label">Excel Column: <strong>{{name}}</strong></label>
                                </div>
                                <div class="col-md-6">
                                    <select class="form-select mapping-select c-form-select c-form-control c-form-control--select" data-excel-column="{{name}}">
                                        <option value="">-- Skip this column --</option>
                                        {{#each ../available_fields}}
                                        <option value="{{this}}">{{this}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <small class="text-muted">{{sample_value}}</small>
                                </div>
                            </div>
                            {{/each}}
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Import Data</button>
                            <a href="/import_excel" class="btn btn-secondary">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}
{{> layout page_id="map-columns"}}
