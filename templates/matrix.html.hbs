{{!--
  Enhanced Traceability Traceability Matrix
  Depends on: css/50-components/tables.css, css/pages/matrix.css, js/pages/matrix.js
  Features: Sticky headers, virtual scrolling, filters, search, grouping, export
--}}
{{#*inline "page"}}
<div class="matrix-header mb-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
      <h1 class="matrix-title">Traceability Matrix</h1>
      <p class="text-secondary matrix-subtitle">Requirements to Tests mapping and verification status</p>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <div class="d-flex gap-1 align-items-center">
        {{#if has_prev_page}}
          <a 
            href="/p/{{selected_project_id}}/matrix?page={{prev_page}}&per_page={{per_page}}{{#if current_sort_by}}&sort_by={{current_sort_by}}{{/if}}{{#if current_sort_order}}&sort_order={{current_sort_order}}{{/if}}{{#if test_status_filter}}&test_status_filter={{test_status_filter}}{{/if}}{{#if req_status_filter}}&req_status_filter={{req_status_filter}}{{/if}}{{#if category_filter}}&category_filter={{category_filter}}{{/if}}{{#if applicability_filter}}&applicability_filter={{applicability_filter}}{{/if}}{{#if search}}&search={{search}}{{/if}}"
            class="text-secondary"
            style="text-decoration: none; font-size: 1.25rem; line-height: 1; opacity: 0.7; transition: opacity 0.2s;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.7'"
            aria-label="Previous page"
            title="Previous page"
          >‹</a>
        {{else}}
          <span class="text-secondary" style="font-size: 1.25rem; line-height: 1; opacity: 0.3;" aria-disabled="true">‹</span>
        {{/if}}
        <span class="text-secondary" style="font-size: 0.875rem; margin: 0 0.5rem;">
          <span aria-label="Showing page information">Page {{page}} of {{total_pages}}</span>
        </span>
        {{#if has_next_page}}
          <a 
            href="/p/{{selected_project_id}}/matrix?page={{next_page}}&per_page={{per_page}}{{#if current_sort_by}}&sort_by={{current_sort_by}}{{/if}}{{#if current_sort_order}}&sort_order={{current_sort_order}}{{/if}}{{#if test_status_filter}}&test_status_filter={{test_status_filter}}{{/if}}{{#if req_status_filter}}&req_status_filter={{req_status_filter}}{{/if}}{{#if category_filter}}&category_filter={{category_filter}}{{/if}}{{#if applicability_filter}}&applicability_filter={{applicability_filter}}{{/if}}{{#if search}}&search={{search}}{{/if}}"
            class="text-secondary"
            style="text-decoration: none; font-size: 1.25rem; line-height: 1; opacity: 0.7; transition: opacity 0.2s;"
            onmouseover="this.style.opacity='1'"
            onmouseout="this.style.opacity='0.7'"
            aria-label="Next page"
            title="Next page"
          >›</a>
        {{else}}
          <span class="text-secondary" style="font-size: 1.25rem; line-height: 1; opacity: 0.3;" aria-disabled="true">›</span>
        {{/if}}
      </div>
      <button id="toggleGrouping" class="btn btn-outline-secondary" aria-label="Toggle grouping">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7"></rect>
          <rect x="14" y="3" width="7" height="7"></rect>
          <rect x="14" y="14" width="7" height="7"></rect>
          <rect x="3" y="14" width="7" height="7"></rect>
        </svg>
        <span class="btn-text">Group</span>
      </button>
      <a href="/p/{{selected_project_id}}/matrix.xls" class="btn btn-success" aria-label="Export matrix to Excel">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14,2 14,8 20,8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10,9 9,9 8,9"></polyline>
        </svg>
        <span class="btn-text">Excel</span>
      </a>
      <a href="/p/{{selected_project_id}}/matrix.csv{{#if test_status_filter}}?test_status_filter={{test_status_filter}}{{/if}}" class="btn btn-primary" aria-label="Export matrix to CSV">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14,2 14,8 20,8"></polyline>
        </svg>
        <span class="btn-text">CSV</span>
      </a>
    </div>
  </div>
  
  <!-- Compact Filter Bar -->
  <div class="matrix-filter-card filter-card c-filter-card mt-3" style="padding: 1rem;">
    <form method="get" class="filter-form c-filter-form" role="search" aria-label="Matrix filters" id="matrixFilterForm" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr 1fr auto; gap: 0.75rem; align-items: end;">
      
      <!-- Search (wider) -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="search" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Search
        </label>
        <input 
          type="text" 
          name="search" 
          id="search" 
          class="filter-select c-filter-select c-form-control" 
          placeholder="ID, title, reference... (Ctrl+K)"
          value="{{search}}"
          style="padding: 0.5rem 0.75rem; font-size: 0.875rem;"
        />
      </div>
      
      <!-- Requirement Status -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="req_status_filter" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Req Status
        </label>
        <select name="req_status_filter" id="req_status_filter" class="filter-select c-filter-select c-form-control c-form-control--select" style="padding: 0.5rem 0.75rem; font-size: 0.875rem;">
          <option value="">All</option>
          {{#each req_statuses}}
            <option value="{{req_st_id}}" {{#if (eq ../req_status_filter req_st_id)}}selected{{/if}}>{{req_st_title}}</option>
          {{/each}}
        </select>
      </div>

      <!-- Category -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="category_filter" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Category
        </label>
        <select name="category_filter" id="category_filter" class="filter-select c-filter-select c-form-control c-form-control--select" style="padding: 0.5rem 0.75rem; font-size: 0.875rem;">
          <option value="">All</option>
          {{#each categories}}
            <option value="{{req_cat_id}}" {{#if (eq ../category_filter req_cat_id)}}selected{{/if}}>{{req_cat_title}}</option>
          {{/each}}
        </select>
      </div>

      <!-- Applicability -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="applicability_filter" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Applicability
        </label>
        <select name="applicability_filter" id="applicability_filter" class="filter-select c-filter-select c-form-control c-form-control--select" style="padding: 0.5rem 0.75rem; font-size: 0.875rem;">
          <option value="">All</option>
          {{#each applicabilities}}
            <option value="{{req_appl_id}}" {{#if (eq ../applicability_filter req_appl_id)}}selected{{/if}}>{{req_appl_title}}</option>
          {{/each}}
        </select>
      </div>

      <!-- Test Status -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="test_status_filter" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Test Status
        </label>
        <select name="test_status_filter" id="test_status_filter" class="filter-select c-filter-select c-form-control c-form-control--select" style="padding: 0.5rem 0.75rem; font-size: 0.875rem;">
          <option value="">All</option>
          {{#each test_statuses}}
            <option value="{{test_st_id}}" {{#if (eq ../test_status_filter test_st_id)}}selected{{/if}}>{{test_st_title}}</option>
          {{/each}}
        </select>
      </div>
      
      <!-- Per Page -->
      <div class="filter-group c-filter-group" style="margin: 0;">
        <label for="per_page" class="filter-label c-filter-label" style="font-size: 0.875rem; margin-bottom: 0.25rem;">
          Show
        </label>
        <select name="per_page" id="per_page" class="filter-select c-filter-select c-form-control c-form-control--select" style="padding: 0.5rem 0.75rem; font-size: 0.875rem;">
          <option value="25" {{#if (eq per_page 25)}}selected{{/if}}>25</option>
          <option value="50" {{#if (eq per_page 50)}}selected{{/if}}>50</option>
          <option value="100" {{#if (eq per_page 100)}}selected{{/if}}>100</option>
          <option value="200" {{#if (eq per_page 200)}}selected{{/if}}>200</option>
        </select>
      </div>
      
      <!-- Actions -->
      <div class="filter-actions c-filter-actions" style="display: flex; gap: 0.5rem; margin: 0; align-self: end;">
        <button type="submit" class="btn btn-sm btn-primary" aria-label="Apply filters" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
          Apply
        </button>
        {{#if (or test_status_filter req_status_filter category_filter applicability_filter search)}}
          <a href="/p/{{selected_project_id}}/matrix" class="btn btn-sm btn-outline-secondary" aria-label="Clear all filters" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
            Clear
          </a>
        {{/if}}
      </div>
      
      <!-- Preserve sort order -->
      {{#if current_sort_order}}
        <input type="hidden" name="sort_order" value="{{current_sort_order}}" />
      {{/if}}
    </form>
    
    <!-- Active Filters Pills -->
    {{#if (or test_status_filter req_status_filter category_filter applicability_filter search)}}
    <div class="matrix-active-filters mt-2" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.875rem;">
      <span style="color: var(--text-secondary); font-weight: 500;">Active filters:</span>
      {{#if search}}
        <span class="filter-pill" style="background: var(--primary-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Search: "{{search}}"
          <a href="/p/{{selected_project_id}}/matrix?{{#if test_status_filter}}test_status_filter={{test_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
        </span>
      {{/if}}
      {{#if req_status_filter}}
        <span class="filter-pill" style="background: var(--info-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Req Status
          <a href="/p/{{selected_project_id}}/matrix?{{#if test_status_filter}}test_status_filter={{test_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
        </span>
      {{/if}}
      {{#if category_filter}}
        <span class="filter-pill" style="background: var(--warning-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Category
          <a href="/p/{{selected_project_id}}/matrix?{{#if test_status_filter}}test_status_filter={{test_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
        </span>
      {{/if}}
      {{#if applicability_filter}}
        <span class="filter-pill" style="background: var(--purple-color, #a855f7); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Applicability
          <a href="/p/{{selected_project_id}}/matrix?{{#if test_status_filter}}test_status_filter={{test_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
        </span>
      {{/if}}
      {{#if test_status_filter}}
        <span class="filter-pill" style="background: var(--success-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
          Test Status
          <a href="/p/{{selected_project_id}}/matrix?{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
        </span>
      {{/if}}
    </div>
    {{/if}}
  </div>
</div>

<section
  id="matrix-root"
  data-sort-by="{{current_sort_by}}"
  data-sort-order="{{current_sort_order}}"
  data-status-filter="{{test_status_filter}}"
  data-project-id="{{selected_project_id}}"
  class="matrix-section"
>
  <div class="card c-card matrix-card">
    <div class="card-header c-card__header matrix-card-header" style="padding: 0.5rem 1rem;">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <button id="toggleFullscreen" class="btn btn-sm btn-outline-secondary" title="Toggle fullscreen" style="padding: 0.25rem 0.5rem;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
          </svg>
        </button>
        <div class="matrix-controls d-flex gap-2 align-items-center">
          <div class="d-flex gap-1 align-items-center">
            {{#if has_prev_page}}
              <a 
                href="/p/{{selected_project_id}}/matrix?page={{prev_page}}&per_page={{per_page}}{{#if current_sort_by}}&sort_by={{current_sort_by}}{{/if}}{{#if current_sort_order}}&sort_order={{current_sort_order}}{{/if}}{{#if test_status_filter}}&test_status_filter={{test_status_filter}}{{/if}}{{#if req_status_filter}}&req_status_filter={{req_status_filter}}{{/if}}{{#if category_filter}}&category_filter={{category_filter}}{{/if}}{{#if applicability_filter}}&applicability_filter={{applicability_filter}}{{/if}}{{#if search}}&search={{search}}{{/if}}"
                class="text-secondary"
                style="text-decoration: none; font-size: 1rem; line-height: 1; opacity: 0.7; transition: opacity 0.2s;"
                onmouseover="this.style.opacity='1'"
                onmouseout="this.style.opacity='0.7'"
                aria-label="Previous page"
                title="Previous page"
              >‹</a>
            {{else}}
              <span class="text-secondary" style="font-size: 1rem; line-height: 1; opacity: 0.3;" aria-disabled="true">‹</span>
            {{/if}}
            <span class="text-secondary" style="font-size: 0.8rem; margin: 0 0.5rem;">
              <span aria-label="Showing page information">Page {{page}} of {{total_pages}}</span>
            </span>
            {{#if has_next_page}}
              <a 
                href="/p/{{selected_project_id}}/matrix?page={{next_page}}&per_page={{per_page}}{{#if current_sort_by}}&sort_by={{current_sort_by}}{{/if}}{{#if current_sort_order}}&sort_order={{current_sort_order}}{{/if}}{{#if test_status_filter}}&test_status_filter={{test_status_filter}}{{/if}}{{#if req_status_filter}}&req_status_filter={{req_status_filter}}{{/if}}{{#if category_filter}}&category_filter={{category_filter}}{{/if}}{{#if applicability_filter}}&applicability_filter={{applicability_filter}}{{/if}}{{#if search}}&search={{search}}{{/if}}"
                class="text-secondary"
                style="text-decoration: none; font-size: 1rem; line-height: 1; opacity: 0.7; transition: opacity 0.2s;"
                onmouseover="this.style.opacity='1'"
                onmouseout="this.style.opacity='0.7'"
                aria-label="Next page"
                title="Next page"
              >›</a>
            {{else}}
              <span class="text-secondary" style="font-size: 1rem; line-height: 1; opacity: 0.3;" aria-disabled="true">›</span>
            {{/if}}
          </div>
        </div>
      </div>
    </div>

    <div class="table-container c-table-container matrix-table-container" role="region" aria-label="Traceability matrix table" tabindex="0" style="padding: 0; margin: 0; border-bottom-left-radius: 0; border-bottom-right-radius: 0;">
        <table class="table c-table matrix-table" id="matrixTable" role="table" style="margin-bottom: 0; border-bottom-left-radius: 0; border-bottom-right-radius: 0;">
          <thead role="rowgroup" class="matrix-thead">
            <tr role="row" class="matrix-header-row">
              <th class="sortable c-table-sortable matrix-col-sticky matrix-col-reference" data-sort="req_reference" scope="col" role="columnheader" style="min-width: 200px; left: 0;">
                <a
                  href="/p/{{selected_project_id}}/matrix?sort_by=req_reference&sort_order={{#if (eq current_sort_by "req_reference")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}{{#if test_status_filter}}&test_status_filter={{test_status_filter}}{{/if}}{{#if search}}&search={{search}}{{/if}}&page={{page}}&per_page={{per_page}}"
                  class="text-decoration-none d-flex align-items-center justify-content-between"
                  data-matrix-sort-link
                  aria-label="Sort by requirement reference"
                >
                  <span>Requirement</span>
                  <span class="sort-indicator c-table-sort-indicator" aria-hidden="true">
                    {{#if (eq current_sort_by "req_reference")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              {{#each tests}}
                <th class="text-center sortable c-table-sortable matrix-col-test u-text-center" data-sort="test_{{test_id}}" data-column-id="test-{{test_id}}" scope="col" role="columnheader" style="min-width: 120px;">
                  <a
                    href="/p/{{@root.selected_project_id}}/matrix?sort_by=test_{{test_id}}&sort_order={{#if (eq @root.current_sort_order "asc")}}desc{{else}}asc{{/if}}{{#if @root.test_status_filter}}&test_status_filter={{@root.test_status_filter}}{{/if}}{{#if @root.search}}&search={{@root.search}}{{/if}}&page={{@root.page}}&per_page={{@root.per_page}}"
                    class="text-decoration-none d-flex align-items-center justify-content-between w-100"
                    data-matrix-sort-link
                    aria-label="Sort by test {{test_reference}} status"
                    title="{{test_name}} - {{test_status}}"
                  >
                    <span style="font-weight: 600; font-size: 0.875rem;">{{test_reference}}</span>
                    <span class="sort-indicator c-table-sort-indicator" data-test-indicator="{{test_id}}" aria-hidden="true">↕</span>
                  </a>
                </th>
              {{/each}}
            </tr>
          </thead>
          <tbody role="rowgroup" class="matrix-tbody" style="border-radius: 0;">
            {{#each requirements}}
              <tr role="row" class="matrix-body-row" data-req-id="{{req_id}}">
                <td role="cell" class="matrix-col-sticky matrix-col-reference" style="min-width: 200px; left: 0;">
                  <div class="matrix-req-cell">
                    <a href="/p/{{@root.selected_project_id}}/requirements/show/{{req_id}}" 
                       class="matrix-req-link font-medium u-font-medium" 
                       aria-label="View requirement {{req_id}}"
                       title="{{req_title}}">
                      <span class="text-secondary matrix-req-reference">{{req_reference}}</span>
                    </a>
                  </div>
                </td>
                {{#each matrix}}
                  <td class="text-center u-text-center matrix-cell" 
                      role="cell" 
                      data-column-id="test-{{@index}}"
                      data-req-id="{{../req_id}}"
                      data-test-id="{{@index}}"
                      data-linked="{{this.linked}}"
                      data-test-status="{{this.test_status}}">
                    {{#if this.linked}}
                      <div class="matrix-link-indicator" data-tooltip="Linked - Status: {{#if (eq this.test_status 7)}}Passed{{else if (eq this.test_status 6)}}Approved{{else if (eq this.test_status 1)}}Passed{{else}}In Progress{{/if}}">
                        {{#if (eq this.test_status 7)}}
                          <span class="matrix-status-dot status-passed" aria-label="Test passed" title="Test Passed">●</span>
                        {{else if (eq this.test_status 1)}}
                          <span class="matrix-status-dot status-passed" aria-label="Test passed" title="Test Passed">●</span>
                        {{else if (eq this.test_status 6)}}
                          <span class="matrix-status-dot status-approved" aria-label="Test approved" title="Test Approved">●</span>
                        {{else if (eq this.test_status 2)}}
                          <span class="matrix-status-dot status-in-progress" aria-label="Test in progress" title="In Progress">◐</span>
                        {{else if (eq this.test_status 3)}}
                          <span class="matrix-status-dot status-failed" aria-label="Test failed" title="Test Failed">✕</span>
                        {{else}}
                          <span class="matrix-status-dot status-pending" aria-label="Test pending" title="Pending">○</span>
                        {{/if}}
                      </div>
                    {{else}}
                      <span class="matrix-no-link" aria-label="Not linked" title="No link">–</span>
                    {{/if}}
                  </td>
                {{/each}}
              </tr>
            {{/each}}
            {{#unless requirements}}
              <tr role="row" class="matrix-empty-row">
                <td colspan="{{total_test_columns}}" class="text-center text-secondary p-5" role="cell">
                  <div class="matrix-empty-state">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="margin: 0 auto 1rem; opacity: 0.3;">
                      <circle cx="11" cy="11" r="8"></circle>
                      <path d="m21 21-4.35-4.35"></path>
                    </svg>
                    <h4>No requirements found</h4>
                    <p>No requirements match the current filters.</p>
                    {{#if (or test_status_filter search)}}
                      <a href="/p/{{selected_project_id}}/matrix" class="btn btn-outline-primary mt-3">Clear all filters</a>
                    {{/if}}
                  </div>
                </td>
              </tr>
            {{/unless}}
          </tbody>
        </table>
      </div>
    <div class="card-footer c-card__footer matrix-card-footer" style="padding: 0; margin: 0;">
      <nav aria-label="Matrix pagination" class="d-flex justify-content-between align-items-center flex-wrap gap-3" style="margin: 0; padding: 0;">
        <div class="matrix-legend d-flex align-items-center justify-content-center gap-3" style="font-size: 0.875rem; width: 100%; margin: 0; padding: 0.5rem 0;">
          <div class="legend-item d-flex align-items-center justify-content-center gap-1">
            <span class="matrix-status-dot status-passed">●</span>
            <span>Passed</span>
          </div>
          <div class="legend-item d-flex align-items-center justify-content-center gap-1">
            <span class="matrix-status-dot status-in-progress">◐</span>
            <span>In Progress</span>
          </div>
          <div class="legend-item d-flex align-items-center justify-content-center gap-1">
            <span class="matrix-status-dot status-pending">○</span>
            <span>Pending</span>
          </div>
          <div class="legend-item d-flex align-items-center justify-content-center gap-1">
            <span class="matrix-status-dot status-failed">✕</span>
            <span>Failed</span>
          </div>
          <div class="legend-item d-flex align-items-center justify-content-center gap-1">
            <span class="matrix-no-link">–</span>
            <span>Not Linked</span>
          </div>
        </div>
      </nav>
    </div>
  </div>
</section>

<!-- Keyboard Shortcuts Help Panel -->
<div id="keyboardShortcutsPanel" class="matrix-shortcuts-panel" style="display: none;">
  <div class="matrix-shortcuts-overlay" id="shortcutsOverlay"></div>
  <div class="matrix-shortcuts-content">
    <div class="matrix-shortcuts-header">
      <h3>Keyboard Shortcuts</h3>
      <button id="closeShortcuts" class="btn btn-sm btn-ghost" aria-label="Close shortcuts panel">✕</button>
    </div>
    <div class="matrix-shortcuts-body">
      <div class="shortcut-group">
        <h4>Navigation</h4>
        <div class="shortcut-item">
          <kbd>Ctrl</kbd> + <kbd>K</kbd>
          <span>Focus search</span>
        </div>
        <div class="shortcut-item">
          <kbd>Arrow Keys</kbd>
          <span>Navigate table cells</span>
        </div>
        <div class="shortcut-item">
          <kbd>Tab</kbd>
          <span>Navigate through controls</span>
        </div>
      </div>
      <div class="shortcut-group">
        <h4>Actions</h4>
        <div class="shortcut-item">
          <kbd>F</kbd>
          <span>Toggle fullscreen</span>
        </div>
        <div class="shortcut-item">
          <kbd>G</kbd>
          <span>Toggle grouping</span>
        </div>
        <div class="shortcut-item">
          <kbd>?</kbd>
          <span>Show this help</span>
        </div>
      </div>
    </div>
  </div>
</div>

{{/inline}}
