{{!--
  Depends on: css/50-components/tables.css, js/pages/matrix.js
  Dynamic classes: sort indicators updated by JS
--}}
{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1>Traceability Matrix</h1>
      <p class="text-secondary">Requirements to Tests mapping</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="filter-card">
        <form method="get" class="filter-form">
          <div class="filter-group">
            <label for="test_status_filter" class="filter-label">
              <svg class="filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="22,3 2,3 10,12.46 10,19 14,21 14,12.46"></polygon>
              </svg>
              Test Status
            </label>
            <select name="test_status_filter" id="test_status_filter" class="filter-select">
              <option value="">All Statuses</option>
              {{#each statuses}}
                <option value="{{test_st_id}}" {{#if (eq ../test_status_filter test_st_id)}}selected{{/if}}>{{test_st_title}}</option>
              {{/each}}
            </select>
          </div>
          <div class="filter-actions">
            <button type="submit" class="btn-filter">
              <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              Apply
            </button>
            {{#if test_status_filter}}
              <a href="/matrix" class="btn-clear">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                Clear
              </a>
            {{/if}}
          </div>
        </form>
      </div>
      <a href="/matrix.xls" class="btn btn-success">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14,2 14,8 20,8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10,9 9,9 8,9"></polyline>
        </svg>
        Export Excel
      </a>
    </div>
  </div>
</div>

<section
  id="matrix-root"
  data-sort-by="{{current_sort_by}}"
  data-sort-order="{{current_sort_order}}"
  data-status-filter="{{test_status_filter}}"
>
  <div class="card c-card">
    <div class="card-header c-card__header">
      <div class="d-flex justify-content-between align-items-center">
        <h3>Matrix Overview</h3>
        <span class="text-secondary">Total Tests: {{total_tests}}</span>
      </div>
    </div>
    <div class="card-body p-0 c-card__body">
      <!-- Top scroll indicator - positioned outside table container -->
      <div class="scroll-indicator" id="scrollIndicator">
        <div class="scroll-track">
          <div class="scroll-thumb" id="scrollThumb"></div>
        </div>
      </div>
      <div class="table-container">
        <table class="table" id="matrixTable">
          <thead>
            <tr>
              <th class="sortable" data-sort="req_id">
                <a
                  href="/matrix?sort_by=req_id&sort_order={{#if (eq current_sort_by "req_id")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}"
                  class="text-decoration-none d-flex align-items-center justify-content-between"
                  data-matrix-sort-link
                >
                  Req ID
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_id")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              <th class="sortable" data-sort="req_title">
                <a
                  href="/matrix?sort_by=req_title&sort_order={{#if (eq current_sort_by "req_title")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}"
                  class="text-decoration-none d-flex align-items-center justify-content-between"
                  data-matrix-sort-link
                >
                  Title
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_title")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              <th class="sortable" data-sort="req_reference">
                <a
                  href="/matrix?sort_by=req_reference&sort_order={{#if (eq current_sort_by "req_reference")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}"
                  class="text-decoration-none d-flex align-items-center justify-content-between"
                  data-matrix-sort-link
                >
                  Reference
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_reference")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              {{#each tests}}
                <th class="text-center sortable" data-sort="test_{{test_id}}">
                  <a
                    href="/matrix?sort_by=test_{{test_id}}&sort_order={{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}"
                    class="text-decoration-none d-flex flex-column align-items-center"
                    data-matrix-sort-link
                  >
                    <div class="d-flex align-items-center justify-content-between w-100">
                      <span>Test #{{test_id}}</span>
                      <span class="sort-indicator" data-test-indicator="{{test_id}}">↕</span>
                    </div>
                    <div class="text-xs text-secondary">{{test_status}}</div>
                  </a>
                </th>
              {{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each requirements}}
              <tr>
                <td>
                  <a href="/p/{{@root.selected_project_id}}/requirements/show/{{req_id}}" class="requirement-id c-requirement-card__id">REQ-{{req_id}}</a>
                </td>
                <td>
                  <div class="font-medium">{{req_title}}</div>
                </td>
                <td>
                  <span class="text-secondary">{{req_reference}}</span>
                </td>
                {{#each matrix}}
                  <td class="text-center">
                    {{#if this.linked}}
                      {{#if (eq this.test_status 7)}}
                        <span class="status-badge status-approved">✓</span>
                      {{else if (eq this.test_status 6)}}
                        <span class="status-badge status-approved">✓</span>
                      {{else}}
                        <span class="status-badge status-warning">?</span>
                      {{/if}}
                    {{else}}
                      <span class="text-secondary">-</span>
                    {{/if}}
                  </td>
                {{/each}}
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <div class="card c-card">
      <div class="card-header c-card__header">
        <h3>Matrix Statistics</h3>
      </div>
      <div class="card-body c-card__body">
        <div class="grid grid-3">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_requirements}}</div>
            <div class="text-secondary">Total Requirements</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_tests}}</div>
            <div class="text-secondary">Total Tests</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_links}}</div>
            <div class="text-secondary">Total Links</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{/inline}}
{{> layout page_id="matrix"}}
