{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1>Traceability Matrix</h1>
      <p class="text-secondary">Requirements to Tests mapping</p>
    </div>
    <div>
      <a href="/matrix.xls" class="btn btn-success">Export Excel</a>
    </div>
  </div>
</div>

<section id="Matrix">
  <div class="card">
    <div class="card-header">
      <div class="d-flex justify-content-between align-items-center">
        <h3>Matrix Overview</h3>
        <span class="text-secondary">Total Tests: {{total_tests}}</span>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th class="sortable" data-sort="req_id">
                <a href="/matrix?sort_by=req_id&sort_order={{#if (eq current_sort_by "req_id")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}" class="text-decoration-none d-flex align-items-center justify-content-between">
                  Req ID
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_id")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              <th class="sortable" data-sort="req_title">
                <a href="/matrix?sort_by=req_title&sort_order={{#if (eq current_sort_by "req_title")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}" class="text-decoration-none d-flex align-items-center justify-content-between">
                  Title
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_title")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              <th class="sortable" data-sort="req_reference">
                <a href="/matrix?sort_by=req_reference&sort_order={{#if (eq current_sort_by "req_reference")}}{{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}{{else}}asc{{/if}}" class="text-decoration-none d-flex align-items-center justify-content-between">
                  Reference
                  <span class="sort-indicator">
                    {{#if (eq current_sort_by "req_reference")}}
                      {{#if (eq current_sort_order "asc")}}↑{{else}}↓{{/if}}
                    {{else}}
                      ↕
                    {{/if}}
                  </span>
                </a>
              </th>
              {{#each tests}}
                <th class="text-center sortable" data-sort="test_{{test_id}}">
                  <a href="/matrix?sort_by=test_{{test_id}}&sort_order={{#if (eq current_sort_order "asc")}}desc{{else}}asc{{/if}}" class="text-decoration-none d-flex flex-column align-items-center">
                    <div class="d-flex align-items-center justify-content-between w-100">
                      <span>Test #{{test_id}}</span>
                      <span class="sort-indicator" data-test-id="{{test_id}}">↕</span>
                    </div>
                    <div class="text-xs text-secondary">{{test_status}}</div>
                  </a>
                </th>
              {{/each}}
            </tr>
          </thead>
          <tbody>
            {{#each requirements}}
              <tr>
                <td>
                  <a href="/requirements/{{req_id}}" class="requirement-id">REQ-{{req_id}}</a>
                </td>
                <td>
                  <div class="font-medium">{{req_title}}</div>
                </td>
                <td>
                  <span class="text-secondary">{{req_reference}}</span>
                </td>
                {{#each matrix}}
                  <td class="text-center">
                    {{#if this.linked}}
                      {{#if (eq this.test_status 7)}}
                        <span class="status-badge status-approved">✓</span>
                      {{else if (eq this.test_status 6)}}
                        <span class="status-badge status-approved">✓</span>
                      {{else}}
                        <span class="status-badge status-warning">?</span>
                      {{/if}}
                    {{else}}
                      <span class="text-secondary">-</span>
                    {{/if}}
                  </td>
                {{/each}}
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-4">
    <div class="card">
      <div class="card-header">
        <h3>Matrix Statistics</h3>
      </div>
      <div class="card-body">
        <div class="grid grid-3">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_requirements}}</div>
            <div class="text-secondary">Total Requirements</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_tests}}</div>
            <div class="text-secondary">Total Tests</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">{{total_links}}</div>
            <div class="text-secondary">Total Links</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Update sort indicators for test columns
  document.addEventListener('DOMContentLoaded', function() {
    const currentSortBy = '{{current_sort_by}}';
    const currentSortOrder = '{{current_sort_order}}';
    
    // Update test column sort indicators
    const testIndicators = document.querySelectorAll('.sort-indicator[data-test-id]');
    testIndicators.forEach(indicator => {
      const testId = indicator.getAttribute('data-test-id');
      const testSortKey = 'test_' + testId;
      
      if (currentSortBy === testSortKey) {
        indicator.textContent = currentSortOrder === 'asc' ? '↑' : '↓';
      } else {
        indicator.textContent = '↕';
      }
    });
  });
</script>
{{/inline}}
{{> layout}} 