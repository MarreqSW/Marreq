{{!-- Active Filter Pills --}}
{{#if (or verification_status_filter req_status_filter category_filter applicability_filter search)}}
<div class="matrix-active-filters mt-2" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; font-size: 0.875rem;">
  <span style="color: var(--text-secondary); font-weight: 500;">Active filters:</span>
  {{#if search}}
    <span class="filter-pill" style="background: var(--primary-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
      Search: "{{search}}"
      <a href="/{{selected_project_slug}}/matrix?{{#if verification_status_filter}}verification_status_filter={{verification_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
    </span>
  {{/if}}
  {{#if req_status_filter}}
    <span class="filter-pill" style="background: var(--info-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
      Req Status
      <a href="/{{selected_project_slug}}/matrix?{{#if verification_status_filter}}verification_status_filter={{verification_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
    </span>
  {{/if}}
  {{#if category_filter}}
    <span class="filter-pill" style="background: var(--warning-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
      Category
      <a href="/{{selected_project_slug}}/matrix?{{#if verification_status_filter}}verification_status_filter={{verification_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
    </span>
  {{/if}}
  {{#if applicability_filter}}
    <span class="filter-pill" style="background: var(--purple-color, #a855f7); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
      Applicability
      <a href="/{{selected_project_slug}}/matrix?{{#if verification_status_filter}}verification_status_filter={{verification_status_filter}}&{{/if}}{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
    </span>
  {{/if}}
  {{#if verification_status_filter}}
    <span class="filter-pill" style="background: var(--success-color); color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
      Test Status
      <a href="/{{selected_project_slug}}/matrix?{{#if req_status_filter}}req_status_filter={{req_status_filter}}&{{/if}}{{#if category_filter}}category_filter={{category_filter}}&{{/if}}{{#if applicability_filter}}applicability_filter={{applicability_filter}}&{{/if}}{{#if search}}search={{search}}&{{/if}}per_page={{per_page}}" style="color: white; text-decoration: none;">×</a>
    </span>
  {{/if}}
</div>
{{/if}}
