{{!-- Matrix Page Header with Title and Actions --}}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
  <div>
    <h1 class="matrix-title">Traceability Matrix</h1>
    <p class="text-secondary matrix-subtitle">Requirements to Tests mapping and verification status</p>
  </div>
  <div class="d-flex gap-2 align-items-center flex-wrap">
    <a href="/p/{{selected_project_id}}/matrix.xls" class="btn btn-success" aria-label="Export matrix to Excel">
      <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14,2 14,8 20,8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10,9 9,9 8,9"></polyline>
      </svg>
      <span class="btn-text">Excel</span>
    </a>
    <a href="/p/{{selected_project_id}}/matrix.csv{{#if verification_status_filter}}?verification_status_filter={{verification_status_filter}}{{/if}}" class="btn btn-primary" aria-label="Export matrix to CSV">
      <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14,2 14,8 20,8"></polyline>
      </svg>
      <span class="btn-text">CSV</span>
    </a>
  </div>
</div>
