{{!-- Keyboard Shortcuts Help Panel --}}
<div id="keyboardShortcutsPanel" class="matrix-shortcuts-panel" style="display: none;">
  <div class="matrix-shortcuts-overlay" id="shortcutsOverlay"></div>
  <div class="matrix-shortcuts-content">
    <div class="matrix-shortcuts-header">
      <h3>Keyboard Shortcuts</h3>
      <button id="closeShortcuts" class="btn btn-sm btn-ghost" aria-label="Close shortcuts panel">✕</button>
    </div>
    <div class="matrix-shortcuts-body">
      <div class="shortcut-group">
        <h4>Navigation</h4>
        <div class="shortcut-item">
          <kbd>Ctrl</kbd> + <kbd>K</kbd>
          <span>Focus search</span>
        </div>
        <div class="shortcut-item">
          <kbd>Arrow Keys</kbd>
          <span>Navigate table cells</span>
        </div>
        <div class="shortcut-item">
          <kbd>Tab</kbd>
          <span>Navigate through controls</span>
        </div>
      </div>
      <div class="shortcut-group">
        <h4>Actions</h4>
        <div class="shortcut-item">
          <kbd>F</kbd>
          <span>Toggle fullscreen</span>
        </div>
        <div class="shortcut-item">
          <kbd>G</kbd>
          <span>Toggle grouping</span>
        </div>
        <div class="shortcut-item">
          <kbd>?</kbd>
          <span>Show this help</span>
        </div>
      </div>
    </div>
  </div>
</div>
