{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm c-card">
                <div class="card-header d-flex justify-content-between align-items-center c-card__header">
                    <div>
                        <h1 class="h4 mb-0">Project Members</h1>
                        <p class="text-muted mb-0">{{project.name}}</p>
                    </div>
                    <span class="badge bg-primary bg-gradient">{{member_count}} Members</span>
                </div>
                <div class="card-body p-0 c-card__body">
                    {{#if members.0}}
                        <div class="table-responsive c-table-responsive">
                            <table class="table table-hover align-middle mb-0 c-table c-table--hover">
                                <thead class="table-light c-table__head">
                                    <tr>
                                        <th scope="col">Member</th>
                                        <th scope="col">Role</th>
                                        {{#if can_manage_members}}
                                            <th scope="col" class="text-end">Actions</th>
                                        {{/if}}
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#each members}}
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">{{name}}</div>
                                            <div class="text-muted small">@{{username}}</div>
                                            {{#if email}}
                                                <div class="text-muted small"><i class="fas fa-envelope me-1"></i>{{email}}</div>
                                            {{/if}}
                                        </td>
                                        <td>
                                            <span class="badge bg-info text-dark">{{role_label}}</span>
                                            {{#if is_admin}}
                                                <span class="badge bg-dark ms-1">Admin</span>
                                            {{/if}}
                                        </td>
                                        {{#if ../can_manage_members}}
                                            <td class="text-end">
                                                {{#if can_remove}}
                                                    <form method="post" action="/p/{{../project_id}}/members/{{id}}/remove" class="d-inline">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Remove this member from the project?">
                                                            <i class="fas fa-user-minus me-1"></i>Remove
                                                        </button>
                                                    </form>
                                                {{else}}
                                                    <span class="text-muted small">&nbsp;</span>
                                                {{/if}}
                                            </td>
                                        {{/if}}
                                    </tr>
                                    {{/each}}
                                </tbody>
                            </table>
                        </div>
                    {{else}}
                        <div class="p-4 text-center text-muted u-text-center">
                            <i class="fas fa-users fa-2x mb-3"></i>
                            <p class="mb-0">This project does not have any members yet.</p>
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm mb-4 c-card">
                <div class="card-header c-card__header">
                    <h2 class="h6 mb-0">Membership Rules</h2>
                </div>
                <div class="card-body c-card__body">
                    <p class="text-muted small mb-2">
                        Owners control who participates in a project. The project must always have at least one owner.
                    </p>
                    <ul class="small text-muted ps-3 mb-0">
                        <li>All members can view the roster.</li>
                        <li>Only owners may add or remove members.</li>
                        <li>User accounts are created and removed from the admin panel.</li>
                    </ul>
                </div>
            </div>

            {{#if can_manage_members}}
            <div class="card shadow-sm c-card">
                <div class="card-header c-card__header">
                    <h2 class="h6 mb-0">Add a Member</h2>
                </div>
                <div class="card-body c-card__body">
                    {{#if has_available_users}}
                        <form method="post" action="/p/{{project_id}}/members" class="vstack gap-3">
                            <div>
                                <label for="member-user" class="form-label c-form-label">User</label>
                                <select id="member-user" name="id" class="form-select c-form-select c-form-control c-form-control--select" required>
                                    <option value="" disabled selected>Select a user</option>
                                    {{#each available_users}}
                                        <option value="{{id}}">{{label}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <div>
                                <label for="member-role" class="form-label c-form-label">Role</label>
                                <select id="member-role" name="role" class="form-select c-form-select c-form-control c-form-control--select" required>
                                    {{#each role_options}}
                                        <option value="{{id}}">{{label}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-user-plus me-1"></i>Add Member
                            </button>
                        </form>
                    {{else}}
                        <p class="text-muted small mb-0">All existing users already belong to this project. Create additional users from the admin panel if you need to add more people.</p>
                    {{/if}}
                </div>
            </div>
            {{else}}
            <div class="card shadow-sm c-card">
                <div class="card-header c-card__header">
                    <h2 class="h6 mb-0">Access</h2>
                </div>
                <div class="card-body c-card__body">
                    <p class="text-muted small mb-0">Only project owners can modify the membership list. Contact an owner if changes are required.</p>
                </div>
            </div>
            {{/if}}
        </div>
    </div>
</div>
{{/inline}}

{{> layout page_id="members"}}
