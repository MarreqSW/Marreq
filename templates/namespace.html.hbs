{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="marreq-portal">
  {{> partials/sidebar user=user}}

  <main class="marreq-main" id="mainContent">
    {{> partials/header user=user}}

    <section class="marreq-section">
      <div class="marreq-section__header">
        <div>
          <h2 class="marreq-section__title">{{namespace.label}}</h2>
          <p class="text-muted mb-0">
            {{#if namespace.is_current_user}}
              Your personal project namespace.
            {{else}}
              Projects published under <code>{{namespace.slug}}</code>.
            {{/if}}
          </p>
        </div>
      </div>

      {{#if success}}
        <div class="alert alert-success c-alert" role="alert">{{success}}</div>
      {{/if}}
      {{#if error}}
        <div class="alert alert-danger c-alert" role="alert">{{error}}</div>
      {{/if}}

      {{#if namespace_projects}}
        <div class="marreq-projects-grid">
          {{#each namespace_projects}}
            {{> partials/project_card user=../user show_admin_actions=../user.is_admin}}
          {{/each}}
        </div>
      {{else}}
        <div class="marreq-empty-state">
          <i class="fas fa-folder-open" aria-hidden="true"></i>
          <h3>No Accessible Projects</h3>
          <p>No projects in this namespace are visible to you.</p>
        </div>
      {{/if}}
    </section>
  </main>
</div>
{{/inline}}
{{> layout this page_id="namespace"}}
