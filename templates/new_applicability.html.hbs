{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New Applicability</h1>
  <p class="text-secondary">Create a new applicability option for organizing requirements</p>
  
  {{#unless selected_project_id}}
  <div class="alert alert-info">
    <strong>Project Selection Required:</strong> Please select a project from the dropdown in the navigation bar above before creating an applicability.
    <br><br>
    <strong>Available Projects:</strong>
    <ul class="mb-0 mt-2">
      {{#each projects}}
        <li><strong>{{project_name}}</strong> (ID: {{project_id}})</li>
      {{/each}}
    </ul>
  </div>
  {{/unless}}
</div>

<section id="Applicability">
  <div class="card">
    <div class="card-header">
      <h3>Applicability Details</h3>
    </div>
    <div class="card-body">
      <form method="post">
        <div class="form-group">
          <label for="app_title" class="form-label">Applicability Title</label>
          <input type="text" name="app_title" id="app_title" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="app_description" class="form-label">Description</label>
          <textarea name="app_description" id="app_description" class="form-control" rows="4" required></textarea>
        </div>

        <div class="form-group">
          <label for="app_tag" class="form-label">Tag</label>
          <input type="text" name="app_tag" id="app_tag" class="form-control" placeholder="e.g., ALL, PROD_A, LEGACY" required>
          <small class="text-secondary">A short identifier for the applicability</small>
        </div>

        {{#if selected_project_id}}
        <input type="hidden" name="project_id" value="{{selected_project_id}}">
        {{else}}
        <div class="alert alert-warning">
          <strong>Warning:</strong> No project selected. Please select a project from the dropdown above before creating an applicability.
        </div>
        {{/if}}

        <div class="mt-4">
          <button type="submit" class="btn btn-primary" {{#unless selected_project_id}}disabled{{/unless}}>Create Applicability</button>
          <a href="/p/{{selected_project_id}}/applicability" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout page_id="new_applicability"}} 
