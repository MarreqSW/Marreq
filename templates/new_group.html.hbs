{{!-- Depends on: css/pages/groups.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4 marreq-group-form-page">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card c-card">
        <div class="card-header c-card__header">
          <h3 class="mb-0"><i class="fas fa-users me-2" aria-hidden="true"></i>Create Group</h3>
        </div>
        <div class="card-body c-card__body">
          {{#if error}}
            <div class="alert alert-danger c-alert" role="alert">{{error}}</div>
          {{/if}}

          <form method="POST" action="/groups" class="vstack gap-3">
            <div>
              <label for="name" class="form-label c-form-label">Group Name *</label>
              <input type="text" class="form-control c-form-control" id="name" name="name" value="{{form.name}}" required>
            </div>

            <div>
              <label for="description" class="form-label c-form-label">Description</label>
              <textarea class="form-control c-form-control c-form-control--textarea" id="description" name="description" rows="5">{{form.description}}</textarea>
              <small class="text-muted">Describe the purpose of the group and the projects it owns.</small>
            </div>

            <div class="d-flex justify-content-between">
              <a href="/groups" class="btn btn-secondary">
                <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to Groups
              </a>
              <button type="submit" class="btn btn-primary">
                <i class="fas fa-save" aria-hidden="true"></i> Create Group
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
{{/inline}}
{{> layout this page_id="new_group"}}
