{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h3 class="mb-0">
                        <i class="fas fa-plus"></i> Create New Project
                    </h3>
                </div>
                <div class="card-body c-card__body">
                    {{#if error}}
                        <div class="alert alert-danger c-alert" role="alert">
                            {{error}}
                        </div>
                    {{/if}}
                    <form method="POST" action="/new_project">
                        <div class="mb-3">
                            <label for="name" class="form-label c-form-label">Project Name *</label>
                            <input type="text" class="form-control c-form-control" id="name" name="name" value="{{form.name}}" required>
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label c-form-label">Description</label>
                            <textarea class="form-control c-form-control c-form-control--textarea" id="description" name="description" rows="3">{{form.description}}</textarea>
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label c-form-label">Status</label>
                            <select class="form-select c-form-select c-form-control c-form-control--select" id="status" name="status">
                                <option value="active" {{#if (eq form.status 'active')}}selected{{/if}}>Active</option>
                                <option value="completed" {{#if (eq form.status 'completed')}}selected{{/if}}>Completed</option>
                                <option value="on_hold" {{#if (eq form.status 'on_hold')}}selected{{/if}}>On Hold</option>
                                <option value="cancelled" {{#if (eq form.status 'cancelled')}}selected{{/if}}>Cancelled</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="owner_id" class="form-label c-form-label">Project Owner *</label>
                            <select class="form-select c-form-select c-form-control c-form-control--select" id="owner_id" name="owner_id" required>
                                {{#each users}}
                                    <option value="{{id}}" {{#if (eq id ../user.id)}}selected{{/if}}>
                                        {{name}} ({{username}})
                                    </option>
                                {{/each}}
                            </select>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/projects" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Projects
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Create Project
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}
{{> layout this page_id="new_project"}}
