{{!--
  Depends on: css/pages/requirement-create.css, js/pages/requirementForm.js
--}}
{{#*inline "page"}}
<form
  method="post"
  data-requirement-form
  data-allow-soft-mismatch="false"
  class="create-form"
  data-project-id="{{project_id}}"
  {{#if flash_success}}data-flash-success="{{flash_success}}"{{/if}}
>
  <header class="create-topbar">
    <div class="create-topbar__context">
      <nav class="create-breadcrumb" aria-label="Breadcrumb">
        <a
          href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
          class="create-breadcrumb__link"
        >
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="create-breadcrumb__sep">›</span>
        <span class="create-breadcrumb__crumb">Requirements</span>
        <span class="create-breadcrumb__sep">›</span>
        <span class="create-breadcrumb__crumb create-breadcrumb__crumb--current">Add New</span>
      </nav>
      <h1 class="create-title">New Requirement</h1>
    </div>
    <div class="create-topbar__actions">
      <div class="create-autosave" aria-live="polite">
        <span class="create-autosave__dot" data-role="autosave-indicator" hidden></span>
        <span class="create-autosave__text" data-role="autosave-text"></span>
      </div>
      <button
        type="submit"
        class="btn btn-primary create-topbar__save"
        data-role="submit-requirement"
      >Save</button>
      <a
        href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
        class="btn btn-outline-secondary create-topbar__cancel"
        data-role="cancel-create"
      >Cancel</a>
    </div>
  </header>

  <div class="create-layout">
    <section class="create-card create-card--primary">
      <header class="create-card__header">
        <div>
          <h2 class="create-card__title">Requirement Details</h2>
        </div>
      </header>

      <div class="create-card__body">
        <div class="create-field">
          <label for="req_title" class="create-field__label">
            Title <span class="create-field__required">*</span>
          </label>
          <input
            type="text"
            name="req_title"
            id="req_title"
            class="create-field__input"
            value="{{template.req_title}}"
            placeholder="Control system shall…"
            required
          >
        </div>

        <div class="create-field">
          <label for="req_reference" class="create-field__label">
            Reference <span class="create-field__optional">(optional)</span>
          </label>
          <input
            type="text"
            name="req_reference"
            id="req_reference"
            class="create-field__input"
            value="{{template.req_reference}}"
            placeholder="REQ-CAT-001 (auto-generated if left blank)"
          >
        </div>

        <div class="create-field">
          <label for="req_purpose" class="create-field__label">
            Purpose <span class="create-field__optional">(optional)</span>
          </label>
          <textarea
            name="req_purpose"
            id="req_purpose"
            class="create-field__textarea"
            rows="3"
            placeholder="Why does this requirement exist?"
          >{{template.req_purpose}}</textarea>
        </div>

        <div class="create-field">
          <label for="req_description" class="create-field__label">
            Statement <span class="create-field__required">*</span>
          </label>
          <textarea
            name="req_description"
            id="req_description"
            class="create-field__textarea create-field__textarea--statement"
            rows="6"
            required
            placeholder="The system shall…"
          >{{template.req_description}}</textarea>
        </div>

        <div class="create-field">
          <label for="req_justification" class="create-field__label">
            Rationale <span class="create-field__optional">(optional)</span>
          </label>
          <textarea
            name="req_justification"
            id="req_justification"
            class="create-field__textarea"
            rows="4"
            placeholder="What evidence or reasoning supports this?"
          >{{template.req_justification}}</textarea>
        </div>
      </div>
    </section>

    <aside class="create-card create-card--meta">
      <header class="create-card__header">
        <div>
          <h2 class="create-card__title">Ownership &amp; Traceability</h2>
        </div>
      </header>

      <div class="create-card__body">
        <div class="create-field">
          <label for="req_author_display" class="create-field__label">Author</label>
          <input
            type="text"
            id="req_author_display"
            class="create-field__input create-field__input--readonly"
            value="{{user.user_name}}"
            readonly
          >
        </div>

        <div class="create-field">
          <label for="req_reviewer" class="create-field__label">
            Reviewer <span class="create-field__required">*</span>
          </label>
          <div class="custom-dropdown" data-dropdown="reviewer">
            <button type="button" class="custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="custom-dropdown__value" data-role="dropdown-value">Select reviewer...</span>
              <span class="custom-dropdown__arrow">▼</span>
            </button>
            <div class="custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="custom-dropdown__list" data-role="dropdown-list">
                {{#each users}}
                  <button type="button" class="custom-dropdown__item" data-value="{{user_id}}">
                    {{user_name}}
                  </button>
                {{/each}}
              </div>
            </div>
            <select name="req_reviewer" id="req_reviewer" class="custom-dropdown__hidden" required hidden>
              {{#each users}}
                <option value="{{user_id}}" {{#if (eq user_id ../req_reviewer)}}selected{{/if}}>{{user_name}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="create-field">
          <label for="req_category" class="create-field__label">
            Category <span class="create-field__required">*</span>
          </label>
          <div class="custom-dropdown" data-dropdown="category">
            <button type="button" class="custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="custom-dropdown__value" data-role="dropdown-value">Select category...</span>
              <span class="custom-dropdown__arrow">▼</span>
            </button>
            <div class="custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="custom-dropdown__list" data-role="dropdown-list">
                {{#each categories}}
                  <button type="button" class="custom-dropdown__item" data-value="{{cat_id}}" data-tag="{{cat_tag}}">
                    {{cat_title}}
                  </button>
                {{/each}}
              </div>
              <div class="custom-dropdown__footer">
                <button type="button" class="custom-dropdown__action" data-action="create-category">
                  + Create category
                </button>
              </div>
            </div>
            <select name="req_category" id="req_category" class="custom-dropdown__hidden" required hidden>
              {{#each categories}}
                <option value="{{cat_id}}" data-tag="{{cat_tag}}" {{#if (eq cat_id ../req_category)}}selected{{/if}}>{{cat_title}}</option>
              {{/each}}
            </select>
          </div>
          <div id="reference-error" class="create-field__error" hidden></div>
        </div>

        <div class="create-field">
          <label for="req_applicability" class="create-field__label">
            Applicability <span class="create-field__required">*</span>
          </label>
          <div class="custom-dropdown" data-dropdown="applicability">
            <button type="button" class="custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="custom-dropdown__value" data-role="dropdown-value">Select applicability...</span>
              <span class="custom-dropdown__arrow">▼</span>
            </button>
            <div class="custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="custom-dropdown__list" data-role="dropdown-list">
                {{#each applicability}}
                  <button type="button" class="custom-dropdown__item" data-value="{{app_id}}">
                    {{app_title}}
                  </button>
                {{/each}}
              </div>
              <div class="custom-dropdown__footer">
                <button type="button" class="custom-dropdown__action" data-action="create-applicability">
                  + Create applicability
                </button>
              </div>
            </div>
            <select name="req_applicability" id="req_applicability" class="custom-dropdown__hidden" required hidden>
              {{#each applicability}}
                <option value="{{app_id}}" {{#if (eq app_id ../req_applicability)}}selected{{/if}}>{{app_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="create-field">
          <label for="req_verification" class="create-field__label">
            Verification Method <span class="create-field__required">*</span>
          </label>
          <div class="custom-dropdown" data-dropdown="verification">
            <button type="button" class="custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="custom-dropdown__value" data-role="dropdown-value">Select verification method...</span>
              <span class="custom-dropdown__arrow">▼</span>
            </button>
            <div class="custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="custom-dropdown__list" data-role="dropdown-list">
                {{#each verification}}
                  <button type="button" class="custom-dropdown__item" data-value="{{verification_id}}">
                    {{verification_name}}
                  </button>
                {{/each}}
              </div>
              <div class="custom-dropdown__footer">
                <button type="button" class="custom-dropdown__action" data-action="create-verification">
                  + Create verification method
                </button>
              </div>
            </div>
            <select name="req_verification" id="req_verification" class="custom-dropdown__hidden" required hidden>
              {{#each verification}}
                <option value="{{verification_id}}" {{#if (eq verification_id ../req_verification)}}selected{{/if}}>{{verification_name}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        {{#if is_admin_or_owner}}
        <div class="create-field">
          <label for="req_current_status" class="create-field__label">
            Status <span class="create-field__required">*</span>
          </label>
          <select
            name="req_current_status"
            id="req_current_status"
            class="create-field__select"
            required
          >
            {{#each status}}
              {{#if (or (eq req_st_title "Draft") (or (eq req_st_title "Accepted") (or (eq req_st_title "Rejected") (eq req_st_title "Deprecated"))))}}
                <option value="{{req_st_id}}" {{#if (eq req_st_id ../req_current_status)}}selected{{/if}}>
                  {{req_st_title}}
                </option>
              {{/if}}
            {{/each}}
          </select>
        </div>
        {{/if}}

        <div class="create-field">
          <label for="req_parent" class="create-field__label">
            Parent Requirement <span class="create-field__optional">(optional)</span>
          </label>
          <div class="custom-dropdown custom-dropdown--searchable" data-dropdown="parent">
            <button type="button" class="custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="custom-dropdown__value" data-role="dropdown-value">Select parent requirement...</span>
              <span class="custom-dropdown__arrow">▼</span>
            </button>
            <div class="custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="custom-dropdown__search">
                <input 
                  type="text" 
                  class="custom-dropdown__search-input" 
                  placeholder="Search requirements..." 
                  data-role="dropdown-search"
                  autocomplete="off"
                >
              </div>
              <div class="custom-dropdown__list custom-dropdown__list--scrollable" data-role="dropdown-list">
                <button type="button" class="custom-dropdown__item" data-value="0" data-search-text="none">
                  <span class="custom-dropdown__item-label">None</span>
                </button>
                {{#each parent}}
                  <button type="button" class="custom-dropdown__item" data-value="{{id}}" data-search-text="{{reference}} {{title}}">
                    <span class="custom-dropdown__item-ref">{{reference}}</span>
                    <span class="custom-dropdown__item-label">{{title}}</span>
                  </button>
                {{/each}}
              </div>
            </div>
            <select name="req_parent" id="req_parent" class="custom-dropdown__hidden" hidden>
              <option value="0" {{#if (eq ../req_parent 0)}}selected{{/if}}>None</option>
              {{#each parent}}
                <option value="{{id}}" {{#if (eq ../req_parent id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <input type="hidden" id="req_id" name="req_id" value="None">
  <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
</form>

{{> partials/modals}}

<div
  class="modal fade"
  id="categoryModal"
  tabindex="-1"
  aria-labelledby="categoryModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="categoryModalLabel">New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineCategoryForm" data-entity="category">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_cat_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_cat_title" name="cat_title" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_cat_tag" name="cat_tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_cat_description" name="cat_description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Category</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="applicabilityModal"
  tabindex="-1"
  aria-labelledby="applicabilityModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="applicabilityModalLabel">New Applicability</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineApplicabilityForm" data-entity="applicability">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_app_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_app_title" name="app_title" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_app_tag" name="app_tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_app_description" name="app_description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Applicability</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="verificationModal"
  tabindex="-1"
  aria-labelledby="verificationModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="verificationModalLabel">New Verification Method</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineVerificationForm" data-entity="verification">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_verification_name" class="form-label">Name</label>
            <input
              type="text"
              class="form-control"
              id="inline_verification_name"
              name="verification_name"
              required
            >
          </div>
          <div class="mb-3">
            <label for="inline_verification_description" class="form-label">Description</label>
            <textarea
              class="form-control"
              id="inline_verification_description"
              name="verification_description"
              rows="3"
              required
            ></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Verification</button>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="requirement-form"}}
