{{#*inline "page"}}
<div class="mb-4">
  <h1>New Requirement</h1>
  <p class="text-secondary">Create a new software requirement</p>
</div>

<section id="Requirements">
  <div class="card">
    <div class="card-header">
      <h3>Requirement Details</h3>
    </div>
    <div class="card-body">
      <form method="post">
        <div class="grid grid-2">
          <div class="form-group">
            <label for="req_title" class="form-label">Title</label>
            <input type="text" name="req_title" id="req_title" value="{{req_title}}" class="form-control" required>
          </div>
          
          <div class="form-group">
            <label for="req_reference" class="form-label">Reference (Optional)</label>
            <input type="text" name="req_reference" id="req_reference" value="{{req_reference}}" class="form-control" placeholder="Will be auto-generated if left empty">
            <small class="text-secondary">Leave empty to auto-generate reference based on category (e.g., REQ-PTP-1)</small>
            <div id="reference-error" class="text-danger" style="display: none;"></div>
          </div>
        </div>

        <div class="form-group">
          <label for="req_description" class="form-label">Description</label>
          <textarea name="req_description" id="req_description" class="form-control" rows="4" required>{{req_description}}</textarea>
        </div>

        <div class="form-group">
          <label for="req_justification" class="form-label">Justification (Optional)</label>
          <textarea name="req_justification" id="req_justification" class="form-control" rows="3">{{req_justification}}</textarea>
          <small class="text-secondary">Explain the rationale behind this requirement</small>
        </div>

        <div class="grid grid-3">
          <div class="form-group">
            <label for="req_author" class="form-label">Author</label>
            <input type="text" id="req_author_display" value="{{user.user_name}}" class="form-control" readonly>
            <input type="hidden" name="req_author" id="req_author" value="{{user.user_id}}">
            <small class="text-secondary">You are the author of this requirement</small>
          </div>

          <div class="form-group">
            <label for="req_reviewer" class="form-label">Reviewer</label>
            <select name="req_reviewer" id="req_reviewer" class="form-control" required>
              {{#each users }}
                <option value="{{user_id}}">{{user_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_category" class="form-label">Category</label>
            <select name="req_category" id="req_category" class="form-control" required>
              {{#each categories }}
                <option value="{{cat_id}}">{{cat_title}}</option>
              {{/each}}
            </select>
          </div>



          <div class="form-group">
            <label for="req_applicability" class="form-label">Applicability</label>
            <select name="req_applicability" id="req_applicability" class="form-control" required>
              {{#each applicability }}
                <option value="{{app_id}}">{{app_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="grid grid-3">
          <div class="form-group">
            <label for="req_current_status" class="form-label">Status</label>
            <select name="req_current_status" id="req_current_status" class="form-control" required>
              {{#each status }}
                <option value="{{req_st_id}}">{{req_st_title}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_verification" class="form-label">Verification Mode</label>
            <select name="req_verification" id="req_verification" class="form-control" required>
              {{#each verification}}
                <option value="{{verification_id}}">{{verification_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="req_parent" class="form-label">Parent Requirement</label>
            <select name="req_parent" id="req_parent" class="form-control">
              <option value="0">None</option>
              {{#each parent }}
                <option value="{{req_id}}">{{req_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="req_link" class="form-label">Link (Optional)</label>
          <input type="url" name="req_link" id="req_link" value="{{req_link}}" class="form-control" placeholder="https://example.com">
          <small class="text-secondary">URL to related documentation or resources</small>
        </div>

        <input type="hidden" id="req_id" name="req_id" value="None">
        <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
        <input type="hidden" id="project_id" name="project_id" value="{{#if selected_project_id}}{{selected_project_id}}{{else}}1{{/if}}">

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Create Requirement</button>
          <a href="{{#if selected_project_id}}/p/{{selected_project_id}}/requirements{{else}}/requirements{{/if}}" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
// Category data for validation
const categoryData = [
  {{#each categories}}
    { id: {{cat_id}}, tag: "{{cat_tag}}" },
  {{/each}}
];

// Reference validation function
function validateReference() {
  const referenceInput = document.getElementById('req_reference');
  const categorySelect = document.getElementById('req_category');
  const errorDiv = document.getElementById('reference-error');
  const submitButton = document.querySelector('button[type="submit"]');
  
  const reference = referenceInput.value.trim();
  const categoryId = parseInt(categorySelect.value);
  
  // Clear previous error
  errorDiv.style.display = 'none';
  errorDiv.textContent = '';
  submitButton.disabled = false;
  
  // If reference is empty, it's valid (will be auto-generated)
  if (reference === '') {
    return true;
  }
  
  // Find the selected category
  const selectedCategory = categoryData.find(cat => cat.id === categoryId);
  if (!selectedCategory) {
    return true; // Can't validate without category
  }
  
  // Check if reference starts with the correct prefix
  const expectedPrefix = `REQ-${selectedCategory.tag}-`;
  if (!reference.startsWith(expectedPrefix)) {
    errorDiv.textContent = `Reference must start with "${expectedPrefix}" for the selected category.`;
    errorDiv.style.display = 'block';
    submitButton.disabled = true;
    return false;
  }
  
  // Check if reference follows the correct format (REQ-TAG-NUMBER)
  const referencePattern = new RegExp(`^REQ-${selectedCategory.tag}-\\d+$`);
  if (!referencePattern.test(reference)) {
    errorDiv.textContent = `Reference must follow the format "REQ-${selectedCategory.tag}-NUMBER" (e.g., REQ-${selectedCategory.tag}-1).`;
    errorDiv.style.display = 'block';
    submitButton.disabled = true;
    return false;
  }
  
  return true;
}

// Add event listeners
document.addEventListener('DOMContentLoaded', function() {
  const referenceInput = document.getElementById('req_reference');
  const categorySelect = document.getElementById('req_category');
  
  referenceInput.addEventListener('input', validateReference);
  categorySelect.addEventListener('change', validateReference);
  
  // Initial validation
  validateReference();
});
</script>
{{/inline}}
{{> layout}}