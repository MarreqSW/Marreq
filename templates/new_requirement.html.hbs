{{!--
  Depends on: css/pages/requirement-create.css, js/pages/requirementForm.js
--}}
{{#*inline "page"}}
<form
  method="post"
  data-requirement-form
  data-allow-soft-mismatch="false"
  class="create-form"
  data-project-id="{{project_id}}"
  {{#if flash_success}}data-flash-success="{{flash_success}}"{{/if}}
>
  <header class="create-topbar">
    <div class="create-topbar__context">
      <nav class="create-breadcrumb" aria-label="Breadcrumb">
        <a
          href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
          class="create-breadcrumb__link"
        >
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="create-breadcrumb__sep">›</span>
        <span class="create-breadcrumb__crumb">Requirements</span>
        <span class="create-breadcrumb__sep">›</span>
        <span class="create-breadcrumb__crumb create-breadcrumb__crumb--current">Add New</span>
      </nav>
      <h1 class="create-title">New Requirement</h1>
      <p class="create-subtitle">Capture a precise, testable statement that advances the project.</p>
    </div>
    <div class="create-topbar__actions">
      <div class="create-autosave" aria-live="polite">
        <span class="create-autosave__dot" data-role="autosave-indicator" hidden></span>
        <span class="create-autosave__text" data-role="autosave-text">Draft not saved</span>
      </div>
      <button
        type="submit"
        class="btn btn-primary create-topbar__save"
        data-role="submit-requirement"
      >Save</button>
      <button
        type="submit"
        name="intent"
        value="add_another"
        class="btn btn-outline-secondary create-topbar__save-more"
        data-role="submit-requirement"
      >Save &amp; Add Another</button>
      <a
        href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
        class="btn btn-outline-secondary create-topbar__cancel"
        data-role="cancel-create"
      >Cancel</a>
    </div>
  </header>

  <div class="create-layout">
    <section class="create-card create-card--primary">
      <header class="create-card__header">
        <span class="create-card__icon" aria-hidden="true">🧾</span>
        <div>
          <h2 class="create-card__title">Requirement Details</h2>
          <p class="create-card__hint">Everything downstream depends on clarity here.</p>
        </div>
      </header>

      <div class="create-card__body">
        <div class="create-field">
          <label for="req_title" class="create-field__label">Title</label>
          <input
            type="text"
            name="req_title"
            id="req_title"
            class="create-field__input"
            value="{{req_title}}"
            placeholder="Control system shall…"
            required
          >
          <p class="create-field__help">Summarise the promise in one crisp sentence.</p>
        </div>

        <div class="create-field">
          <div class="create-field__label-row">
            <label for="req_purpose" class="create-field__label">Purpose</label>
            <span class="create-field__badge">Recommended</span>
          </div>
          <textarea
            name="req_purpose"
            id="req_purpose"
            class="create-field__textarea"
            rows="3"
            placeholder="Why does this requirement exist?"
          >{{req_purpose}}</textarea>
          <p class="create-field__help">Explain the outcome or capability this unlocks.</p>
        </div>

        <div class="create-field">
          <div class="create-field__label-row">
            <label for="req_description" class="create-field__label">Statement</label>
            <span class="create-field__badge create-field__badge--required">Required</span>
          </div>
          <textarea
            name="req_description"
            id="req_description"
            class="create-field__textarea create-field__textarea--statement"
            rows="6"
            required
            placeholder="The system shall…"
          >{{req_description}}</textarea>
          <p class="create-field__help">Be specific: prefer measurable verbs over vague terms like “user-friendly”.</p>
        </div>

        <div class="create-field">
          <div class="create-field__label-row">
            <label for="req_justification" class="create-field__label">Rationale</label>
            <span class="create-field__badge">Recommended</span>
          </div>
          <textarea
            name="req_justification"
            id="req_justification"
            class="create-field__textarea"
            rows="4"
            placeholder="What evidence or reasoning supports this?"
          >{{req_justification}}</textarea>
          <p class="create-field__help">Cite decisions, studies, or regulations that justify the requirement.</p>
        </div>

        <div class="create-field-grid">
          <div
            class="create-field create-field--combo"
            data-component="combo"
            data-combo-field="req_category"
          >
            <div class="create-field__label-row">
              <label for="req_category" class="create-field__label">Category</label>
              <button
                type="button"
                class="create-field__link"
                data-role="combo-new"
                data-entity="category"
              >+ New</button>
            </div>
            <div class="create-combo" data-role="combo-ui" hidden>
              <input
                type="text"
                class="create-combo__input"
                id="req_category_search"
                list="req_category_options"
                placeholder="Search categories"
                autocomplete="off"
              >
              <datalist id="req_category_options">
                {{#each categories}}
                  <option value="{{cat_title}}" data-id="{{cat_id}}" data-tag="{{cat_tag}}"></option>
                {{/each}}
              </datalist>
            </div>
            <select
              name="req_category"
              id="req_category"
              class="create-field__select"
              data-role="combo-source"
              required
            >
              {{#each categories}}
                <option value="{{cat_id}}" data-tag="{{cat_tag}}">{{cat_title}}</option>
              {{/each}}
            </select>
            <p class="create-field__help">Choose the taxonomy bucket this requirement contributes to.</p>
            <div id="reference-error" class="create-field__error" hidden></div>
          </div>

          <div
            class="create-field create-field--combo"
            data-component="combo"
            data-combo-field="req_applicability"
          >
            <div class="create-field__label-row">
              <label for="req_applicability" class="create-field__label">Applicability</label>
              <button
                type="button"
                class="create-field__link"
                data-role="combo-new"
                data-entity="applicability"
              >+ New</button>
            </div>
            <div class="create-combo" data-role="combo-ui" hidden>
              <input
                type="text"
                class="create-combo__input"
                id="req_applicability_search"
                list="req_applicability_options"
                placeholder="Where does this apply?"
                autocomplete="off"
              >
              <datalist id="req_applicability_options">
                {{#each applicability}}
                  <option value="{{app_title}}" data-id="{{app_id}}"></option>
                {{/each}}
              </datalist>
            </div>
            <select
              name="req_applicability"
              id="req_applicability"
              class="create-field__select"
              data-role="combo-source"
              required
            >
              {{#each applicability}}
                <option value="{{app_id}}">{{app_title}}</option>
              {{/each}}
            </select>
            <p class="create-field__help">Limit scope if the statement is not universally required.</p>
          </div>
        </div>

        <div class="create-field-grid">
          <div class="create-field create-field--combo" data-component="combo" data-combo-field="req_current_status">
            <label for="req_current_status" class="create-field__label">Status</label>
            <div class="create-combo" data-role="combo-ui" hidden>
              <input
                type="text"
                class="create-combo__input"
                id="req_status_search"
                list="req_status_options"
                placeholder="Draft, Accepted…"
                autocomplete="off"
              >
              <datalist id="req_status_options">
                {{#each status}}
                  {{#if (or (eq req_st_title "Draft") (or (eq req_st_title "Accepted") (or (eq req_st_title "Rejected") (eq req_st_title "Deprecated"))))}}
                    <option value="{{req_st_title}}" data-id="{{req_st_id}}"></option>
                  {{/if}}
                {{/each}}
              </datalist>
            </div>
            <select
              name="req_current_status"
              id="req_current_status"
              class="create-field__select"
              data-role="combo-source"
              required
            >
              {{#each status}}
                {{#if (or (eq req_st_title "Draft") (or (eq req_st_title "Accepted") (or (eq req_st_title "Rejected") (eq req_st_title "Deprecated"))))}}
                  <option value="{{req_st_id}}" {{#if (eq req_st_id ../req_current_status)}}selected{{/if}}>
                    {{req_st_title}}
                  </option>
                {{/if}}
              {{/each}}
            </select>
            <p class="create-field__help">Start in Draft, promote only when verified or reviewed.</p>
          </div>

          <div
            class="create-field create-field--combo"
            data-component="combo"
            data-combo-field="req_verification"
          >
            <div class="create-field__label-row">
              <label for="req_verification" class="create-field__label">Verification Method</label>
              <button
                type="button"
                class="create-field__link"
                data-role="combo-new"
                data-entity="verification"
              >+ New</button>
            </div>
            <div class="create-combo" data-role="combo-ui" hidden>
              <input
                type="text"
                class="create-combo__input"
                id="req_verification_search"
                list="req_verification_options"
                placeholder="Test, Analysis, Inspection…"
                autocomplete="off"
              >
              <datalist id="req_verification_options">
                {{#each verification}}
                  <option value="{{verification_name}}" data-id="{{verification_id}}"></option>
                {{/each}}
              </datalist>
            </div>
            <select
              name="req_verification"
              id="req_verification"
              class="create-field__select"
              data-role="combo-source"
              required
            >
              {{#each verification}}
                <option value="{{verification_id}}">{{verification_name}}</option>
              {{/each}}
            </select>
            <p class="create-field__help">Pick the strategy that will demonstrate compliance.</p>
          </div>
        </div>
      </div>
    </section>

    <aside class="create-card create-card--meta">
      <header class="create-card__header">
        <span class="create-card__icon" aria-hidden="true">🔗</span>
        <div>
          <h2 class="create-card__title">Ownership &amp; Traceability</h2>
          <p class="create-card__hint">Provide the hooks our audits rely on.</p>
        </div>
      </header>

      <div class="create-card__body">
        <div class="create-field">
          <label for="req_author_display" class="create-field__label">Author</label>
          <input
            type="text"
            id="req_author_display"
            class="create-field__input create-field__input--readonly"
            value="{{user.user_name}}"
            readonly
          >
          <input type="hidden" name="req_author" id="req_author" value="{{user.user_id}}">
        </div>

        <div class="create-field create-field--combo" data-component="combo" data-combo-field="req_reviewer">
          <label for="req_reviewer" class="create-field__label">Reviewer</label>
          <div class="create-combo" data-role="combo-ui" hidden>
            <input
              type="text"
              class="create-combo__input"
              id="req_reviewer_search"
              list="req_reviewer_options"
              placeholder="Who will review this?"
              autocomplete="off"
            >
            <datalist id="req_reviewer_options">
              {{#each users}}
                <option value="{{user_name}}" data-id="{{user_id}}"></option>
              {{/each}}
            </datalist>
          </div>
          <select
            name="req_reviewer"
            id="req_reviewer"
            class="create-field__select"
            data-role="combo-source"
            required
          >
            {{#each users}}
              <option value="{{user_id}}">{{user_name}}</option>
            {{/each}}
          </select>
          <p class="create-field__help">Assign a reviewer so the workflow can progress.</p>
        </div>

        <div class="create-field create-field--combo" data-component="combo" data-combo-field="req_parent">
          <label for="req_parent" class="create-field__label">Parent Requirement</label>
          <div class="create-combo" data-role="combo-ui" hidden>
            <input
              type="text"
              class="create-combo__input"
              id="req_parent_search"
              list="req_parent_options"
              placeholder="Search parent requirement"
              autocomplete="off"
            >
            <datalist id="req_parent_options">
              <option value="None" data-id="0"></option>
              {{#each parent}}
                <option value="{{req_reference}} — {{req_title}}" data-id="{{req_id}}"></option>
              {{/each}}
            </datalist>
          </div>
          <select
            name="req_parent"
            id="req_parent"
            class="create-field__select"
            data-role="combo-source"
          >
            <option value="0">None</option>
            {{#each parent}}
              <option value="{{req_id}}">{{req_title}}</option>
            {{/each}}
          </select>
          <p class="create-field__help">Optional hierarchy so traceability maps stay coherent.</p>
        </div>

        <div class="create-field">
          <label class="create-field__label">Project</label>
          <div class="create-field__meta">{{#if project}}{{project.name}}{{else}}Unknown project{{/if}}</div>
          <input
            type="hidden"
            id="project_id"
            name="project_id"
            value="{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}"
          >
        </div>

        <div class="create-field">
          <label class="create-field__label">Created Date</label>
          <div class="create-field__meta">{{created_timestamp}}</div>
        </div>

        <div class="create-field">
          <label for="req_reference" class="create-field__label">Reference</label>
          <input
            type="text"
            name="req_reference"
            id="req_reference"
            class="create-field__input"
            value="{{req_reference}}"
            placeholder="REQ-CAT-001 (auto-generated if left blank)"
          >
          <p class="create-field__help">Leave blank to auto-generate from the chosen category.</p>
        </div>

        <div class="create-field">
          <label for="req_link" class="create-field__label">Supporting Link</label>
          <input
            type="url"
            name="req_link"
            id="req_link"
            class="create-field__input"
            value="{{req_link}}"
            placeholder="https://example.com/design-decision"
          >
          <p class="create-field__help">Provide a document, ticket, or standard that backs this statement.</p>
        </div>
      </div>
    </aside>
  </div>

  <input type="hidden" id="req_id" name="req_id" value="None">
  <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
</form>

{{> partials/modals}}

<div
  class="modal fade"
  id="categoryModal"
  tabindex="-1"
  aria-labelledby="categoryModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="categoryModalLabel">New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineCategoryForm" data-entity="category">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_cat_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_cat_title" name="cat_title" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_cat_tag" name="cat_tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_cat_description" name="cat_description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Category</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="applicabilityModal"
  tabindex="-1"
  aria-labelledby="applicabilityModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="applicabilityModalLabel">New Applicability</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineApplicabilityForm" data-entity="applicability">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_app_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_app_title" name="app_title" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_app_tag" name="app_tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_app_description" name="app_description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Applicability</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="verificationModal"
  tabindex="-1"
  aria-labelledby="verificationModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="verificationModalLabel">New Verification Method</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineVerificationForm" data-entity="verification">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_verification_name" class="form-label">Name</label>
            <input
              type="text"
              class="form-control"
              id="inline_verification_name"
              name="verification_name"
              required
            >
          </div>
          <div class="mb-3">
            <label for="inline_verification_description" class="form-label">Description</label>
            <textarea
              class="form-control"
              id="inline_verification_description"
              name="verification_description"
              rows="3"
              required
            ></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Verification</button>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="requirement-form"}}
