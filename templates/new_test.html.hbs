{{#*inline "page"}}
<div class="mb-4">
  <h1>New Test</h1>
  <p class="text-secondary">Create a new test case</p>
</div>

<section id="Tests">
  <div class="card">
    <div class="card-header">
      <h3>Test Details</h3>
    </div>
    <div class="card-body">
      <form method="post">
        <div class="form-group">
          <label for="test_name" class="form-label">Test Name</label>
          <input type="text" name="test_name" id="test_name" class="form-control" required>
        </div>

        <div class="form-group">
          <label for="test_reference" class="form-label">Test Reference</label>
          <input type="text" name="test_reference" id="test_reference" class="form-control" required>
          <small class="text-secondary">Must follow format TEST-NUMBER (e.g., TEST-1, TEST-2)</small>
        </div>

        <div class="form-group">
          <label for="test_description" class="form-label">Description</label>
          <textarea name="test_description" id="test_description" class="form-control" rows="4" required></textarea>
        </div>

        <div class="grid grid-2">
          <div class="form-group">
            <label for="test_source" class="form-label">Source</label>
            <input type="text" name="test_source" id="test_source" class="form-control">
          </div>

          <div class="form-group">
            <label for="test_status" class="form-label">Status</label>
            <select name="test_status" id="test_status" class="form-control" required>
              {{#each status }}
                <option value="{{test_st_id}}">{{test_st_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="grid grid-2">
          <div class="form-group">
            <label for="test_parent" class="form-label">Parent Test</label>
            <select name="test_parent" id="test_parent" class="form-control">
              <option value="0">None</option>
              {{#each parents}}
                <option value="{{test_id}}">{{test_name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group">
            <label for="test_req" class="form-label">Related Requirements</label>
            <select name="test_req" id="test_req" class="form-control" multiple>
              {{#each requirements}}
                <option value="{{req_id}}">{{req_title}}</option>
              {{/each}}
            </select>
            <small class="text-secondary">Hold Ctrl/Cmd to select multiple requirements</small>
          </div>
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Create Test</button>
          <a href="/tests" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout}}