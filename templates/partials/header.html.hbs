{{!-- Depends on: css/50-components/dashboard.css, js/modules/sidebar.js --}}
<header class="marreq-main__header">
  <button
    type="button"
    class="marreq-mobile-toggle"
    id="mobileToggle"
    aria-label="Toggle navigation">
    <i class="fas fa-bars" aria-hidden="true"></i>
  </button>
  <div class="marreq-main__title">
    <h1>
      {{#if user.name}}
        Welcome back, {{user.name}}
      {{else}}
        Requirements Dashboard
      {{/if}}
    </h1>
    <p class="marreq-main__subtitle">
      Manage requirements, tests, and traceability across all your projects
    </p>
  </div>
</header>
