<header class="reqman-main__header">
  <button
    type="button"
    class="reqman-mobile-toggle"
    id="mobileToggle"
    aria-label="Toggle navigation">
    <i class="fas fa-bars" aria-hidden="true"></i>
  </button>
  <div class="reqman-main__title">
    <h1>
      {{#if user.user_name}}
        Welcome back, {{user.user_name}}
      {{else}}
        Requirements Dashboard
      {{/if}}
    </h1>
    <p class="reqman-main__subtitle">
      Manage requirements, tests, and traceability across all your projects
    </p>
  </div>
</header>
