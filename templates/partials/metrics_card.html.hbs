{{!-- Depends on: css/50-components/dashboard.css --}}
<div class="card dashboard-card">
  <div class="card-header">
    <h3>
      {{title}}
      {{#if badge}}
        <span class="badge {{#if badge_class}}{{badge_class}}{{else}}bg-primary{{/if}}">
          {{badge}}
        </span>
      {{/if}}
    </h3>
  </div>
  <div class="card-body">
    {{> @partial-block}}
  </div>
</div>
