{{!-- Depends on: css/50-components/dashboard.css --}}
<article class="reqman-project-card reqman-project-card--{{project_status_badge}}">
  <div class="reqman-project-card__status-bar" aria-hidden="true"></div>
  <div class="reqman-project-card__content">
    <div class="reqman-project-card__header">
      <div class="reqman-project-card__title-group">
        <span class="reqman-project-card__icon" aria-hidden="true">
          {{project_initial}}
        </span>
        <div class="reqman-project-card__titles">
          <h3>{{name}}</h3>
          {{#if project_owner_name}}
            <p class="reqman-project-card__owner">Owned by {{project_owner_name}}</p>
          {{/if}}
        </div>
      </div>
      <span class="reqman-project-card__status reqman-badge reqman-badge--{{project_status_badge}}">
        {{status_id}}
      </span>
    </div>
    {{#if description}}
      <p class="reqman-project-card__description">{{description}}</p>
    {{/if}}
    <div class="reqman-project-card__meta">
      <div class="reqman-project-card__meta-item">
        <i class="fas fa-clipboard-list" aria-hidden="true"></i>
        <span>{{#if (eq requirements_count 1)}}1 requirement{{else}}{{requirements_count}} requirements{{/if}}</span>
      </div>
      <div class="reqman-project-card__meta-item">
        <i class="fas fa-vial" aria-hidden="true"></i>
        <span>{{#if (eq tests_count 1)}}1 test{{else}}{{tests_count}} tests{{/if}}</span>
      </div>
      <div class="reqman-project-card__meta-item">
        <i class="fas fa-id-badge" aria-hidden="true"></i>
        <span>
          {{#if role_label}}
            Role: {{role_label}}
          {{else}}
            Role: Member
          {{/if}}
        </span>
      </div>
      {{#if update_date}}
        <div class="reqman-project-card__meta-item">
          <i class="fas fa-clock-rotate-left" aria-hidden="true"></i>
          <span>Updated {{update_date}}</span>
        </div>
      {{else}}
        {{#if creation_date}}
          <div class="reqman-project-card__meta-item">
            <i class="fas fa-calendar-plus" aria-hidden="true"></i>
            <span>Created {{creation_date}}</span>
          </div>
        {{/if}}
      {{/if}}
    </div>
    <div class="reqman-project-card__actions">
      <a href="/p/{{project_id}}" class="reqman-btn reqman-btn--primary">
        <i class="fas fa-eye" aria-hidden="true"></i>
        Open
      </a>
      <a href="/p/{{project_id}}/requirements" class="reqman-btn reqman-btn--outline">
        <i class="fas fa-clipboard-list" aria-hidden="true"></i>
        Requirements
      </a>
      {{#if show_admin_actions}}
      {{#if user.is_admin}}
      <a href="/p/{{project_id}}/edit" class="reqman-btn reqman-btn--outline">
        <i class="fas fa-edit" aria-hidden="true"></i>
        Edit
      </a>
      <button type="button" class="reqman-btn reqman-btn--outline" data-action="delete-project" data-project-id="{{project_id}}" data-project-name="{{name}}">
        <i class="fas fa-trash" aria-hidden="true"></i>
        Delete
      </button>
      {{/if}}
      {{/if}}
    </div>
  </div>
</article>
