{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}

<div class="text-center mb-5">
  <h2>{{selected_project_name}}</h2>
</div>

<div class="dashboard-grid">
  <div class="card dashboard-card c-card">
    <div class="card-header c-card__header">
      <h3>Requirements <span class="badge bg-primary">{{requirements_count}}</span></h3>
    </div>
    <div class="card-body c-card__body">
      <div class="card-description">
        <p>View and manage all your software requirements</p>
      </div>
      <div class="card-actions">
        {{#if selected_project_id}}
          <a href="/p/{{selected_project_id}}/requirements" class="btn btn-primary">View Requirements</a>
          <a href="/p/{{selected_project_id}}/requirements.xls" class="btn btn-success">Export Excel</a>
          {{#if user.is_admin}}
          <a href="/import_excel" class="btn btn-warning">Import Excel</a>
          {{/if}}
          <a href="/p/{{selected_project_id}}/requirements/new" class="btn btn-outline">New Requirement</a>
        {{else}}
          <span class="btn btn-primary disabled" aria-disabled="true">View Requirements</span>
          <span class="btn btn-success disabled" aria-disabled="true">Export Excel</span>
          {{#if user.is_admin}}
          <a href="/import_excel" class="btn btn-warning">Import Excel</a>
          {{/if}}
          <span class="btn btn-outline disabled" aria-disabled="true">New Requirement</span>
        {{/if}}
      </div>
    </div>
  </div>

  {{#> partials/metrics_card title="Tests" badge=tests_count badge_class="bg-primary"}}
    <div class="card-description">
      <p>Manage test cases and verification methods</p>
    </div>
    <div class="card-actions">
      {{#if selected_project_id}}
        <a href="/p/{{selected_project_id}}/tests" class="btn btn-primary">View Tests</a>
        <a href="/p/{{selected_project_id}}/tests.xls" class="btn btn-success">Export Excel</a>
        {{#if user.is_admin}}
        <a href="/import_excel" class="btn btn-warning">Import Excel</a>
        {{/if}}
        <a href="/p/{{selected_project_id}}/tests/new" class="btn btn-outline">New Test</a>
      {{else}}
        <span class="btn btn-primary disabled" aria-disabled="true">View Tests</span>
        <span class="btn btn-success disabled" aria-disabled="true">Export Excel</span>
        {{#if user.is_admin}}
        <a href="/import_excel" class="btn btn-warning">Import Excel</a>
        {{/if}}
        <span class="btn btn-outline disabled" aria-disabled="true">New Test</span>
      {{/if}}
    </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Traceability Matrix"}}
    <div class="card-description">
      <p>Link requirements to tests and generate reports</p>
    </div>
    <div class="card-actions">
      <a href="/p/{{selected_project_id}}/matrix" class="btn btn-primary">View Matrix</a>
      <a href="/p/{{selected_project_id}}/matrix.xls" class="btn btn-success">Export Excel</a>
    </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Categories"}}
    <div class="card-description">
      <p>Organize requirements with categories</p>
    </div>
    <div class="card-actions">
      {{#if selected_project_id}}
        <a href="/p/{{selected_project_id}}/categories" class="btn btn-primary">View Categories</a>
        <a href="/p/{{selected_project_id}}/categories/new" class="btn btn-outline">New Category</a>
      {{else}}
        <span class="btn btn-primary disabled" aria-disabled="true">View Categories</span>
        <span class="btn btn-outline disabled" aria-disabled="true">New Category</span>
      {{/if}}
    </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Applicability"}}
    <div class="card-description">
      <p>Define which products/systems requirements apply to</p>
    </div>
    <div class="card-actions">
      {{#if selected_project_id}}
        <a href="/p/{{selected_project_id}}/applicability" class="btn btn-primary">View Applicability</a>
        <a href="/p/{{selected_project_id}}/applicability/new" class="btn btn-outline">New Applicability</a>
      {{else}}
        <span class="btn btn-primary disabled" aria-disabled="true">View Applicability</span>
        <span class="btn btn-outline disabled" aria-disabled="true">New Applicability</span>
      {{/if}}
    </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Project Members"}}
    <div class="card-description">
      <p>See who has access to your active project and manage participation.</p>
    </div>
    <div class="card-actions d-flex flex-wrap gap-2">
      {{#if selected_project_id}}
        <a href="/p/{{selected_project_id}}/members" class="btn btn-primary">View Members</a>
      {{else}}
        <span class="btn btn-outline disabled">Select a project to view members</span>
      {{/if}}
      {{#if user.is_admin}}
        <a href="/admin/users" class="btn btn-outline">Manage Users</a>
      {{/if}}
    </div>
  {{/partials/metrics_card}}
</div>
{{/inline}}
{{> layout page_id="project"}}
