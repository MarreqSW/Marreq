{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}

<div class="text-center mb-5 u-text-center">
  <h2>{{selected_project_name}}</h2>
  {{#if group_name}}
    <p class="text-muted mb-0">
      Group:
      {{#if can_view_group}}
        <a href="/{{group_slug}}">{{group_name}}</a>
      {{else}}
        {{group_name}}
      {{/if}}
    </p>
  {{/if}}
</div>

<div class="o-dashboard-grid">
  <div class="card c-dashboard-card c-card">
    <div class="card-header c-card__header">
      <h3>Requirements <span class="badge bg-primary">{{requirements_count}}</span></h3>
    </div>
    <div class="card-body c-card__body">
      <div class="c-dashboard-card__description">
        <p>View and manage all your software requirements</p>
      </div>
      <div class="c-dashboard-card__actions">
        {{#if selected_project_id}}
        <a href="/{{selected_project_slug}}/requirements" class="btn btn-primary c-dashboard-card__action">View
          Requirements</a>
        <a href="/{{selected_project_slug}}/requirements.xls" class="btn btn-success c-dashboard-card__action">Export
          Excel</a>
        {{#if user.is_admin}}
        <a href="/{{selected_project_slug}}/import_excel" class="btn btn-warning c-dashboard-card__action">Import
          File</a>
        {{/if}}
        <a href="/{{selected_project_slug}}/requirements/new" class="btn btn-outline c-dashboard-card__action">New
          Requirement</a>
        {{else}}
        <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Requirements</span>
        <span class="btn btn-success disabled c-dashboard-card__action" aria-disabled="true">Export Excel</span>
        {{#if user.is_admin}}
        <a href="/{{selected_project_slug}}/import_excel" class="btn btn-warning c-dashboard-card__action">Import
          File</a>
        {{/if}}
        <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Requirement</span>
        {{/if}}
      </div>
    </div>
  </div>

  {{#> partials/metrics_card title="Verifications" badge=tests_count badge_class="bg-primary"}}
  <div class="c-dashboard-card__description">
    <p>Manage verifications and verification methods</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/verifications" class="btn btn-primary c-dashboard-card__action">View Verifications</a>
    <a href="/{{selected_project_slug}}/verifications.xls" class="btn btn-success c-dashboard-card__action">Export Excel</a>
    {{#if user.is_admin}}
    <a href="/{{selected_project_slug}}/import_excel" class="btn btn-warning c-dashboard-card__action">Import File</a>
    {{/if}}
    <a href="/{{selected_project_slug}}/verifications/new" class="btn btn-outline c-dashboard-card__action">New Verification</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Verifications</span>
    <span class="btn btn-success disabled c-dashboard-card__action" aria-disabled="true">Export Excel</span>
    {{#if user.is_admin}}
    <a href="/{{selected_project_slug}}/import_excel" class="btn btn-warning c-dashboard-card__action">Import File</a>
    {{/if}}
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Verification</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Traceability Matrix"}}
  <div class="c-dashboard-card__description">
    <p>Link requirements to verifications and generate reports</p>
  </div>
  <div class="c-dashboard-card__actions">
    <a href="/{{selected_project_slug}}/matrix" class="btn btn-primary c-dashboard-card__action">View Matrix</a>
    <a href="/{{selected_project_slug}}/matrix.xls" class="btn btn-success c-dashboard-card__action">Export Excel</a>
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Baselines"}}
  <div class="c-dashboard-card__description">
    <p>Immutable snapshots of requirements and traceability for export or comparison</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/baselines" class="btn btn-primary c-dashboard-card__action">View Baselines</a>
    <a href="/{{selected_project_slug}}/baselines/new" class="btn btn-outline c-dashboard-card__action">New Baseline</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Baselines</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Baseline</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Categories"}}
  <div class="c-dashboard-card__description">
    <p>Organize requirements with categories</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/categories" class="btn btn-primary c-dashboard-card__action">View Categories</a>
    <a href="/{{selected_project_slug}}/categories/new" class="btn btn-outline c-dashboard-card__action">New
      Category</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Categories</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Category</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Custom fields"}}
  <div class="c-dashboard-card__description">
    <p>Add project-specific metadata fields to requirements</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/custom_fields" class="btn btn-primary c-dashboard-card__action">View Custom fields</a>
    <a href="/{{selected_project_slug}}/custom_fields/new" class="btn btn-outline c-dashboard-card__action">New custom field</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Custom fields</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New custom field</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Requirement statuses"}}
  <div class="c-dashboard-card__description">
    <p>Manage requirement status labels (Draft, Accepted, etc.)</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/requirement_statuses" class="btn btn-primary c-dashboard-card__action">View requirement statuses</a>
    <a href="/{{selected_project_slug}}/requirement_statuses/new" class="btn btn-outline c-dashboard-card__action">New requirement status</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View requirement statuses</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New requirement status</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Verification statuses"}}
  <div class="c-dashboard-card__description">
    <p>Manage verification status labels (Passed, Failed, Pending, etc.)</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/verification_statuses" class="btn btn-primary c-dashboard-card__action">View verification statuses</a>
    <a href="/{{selected_project_slug}}/verification_statuses/new" class="btn btn-outline c-dashboard-card__action">New verification status</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View verification statuses</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New verification status</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Applicability"}}
  <div class="c-dashboard-card__description">
    <p>Define which products/systems requirements apply to</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/applicability" class="btn btn-primary c-dashboard-card__action">View
      Applicability</a>
    <a href="/{{selected_project_slug}}/applicability/new" class="btn btn-outline c-dashboard-card__action">New
      Applicability</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Applicability</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Applicability</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Verification methods"}}
  <div class="c-dashboard-card__description">
    <p>Define how requirements are verified (e.g. analysis, test, review)</p>
  </div>
  <div class="c-dashboard-card__actions">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/verification" class="btn btn-primary c-dashboard-card__action">View
      Verification</a>
    <a href="/{{selected_project_slug}}/verification/new" class="btn btn-outline c-dashboard-card__action">New
      Verification</a>
    {{else}}
    <span class="btn btn-primary disabled c-dashboard-card__action" aria-disabled="true">View Verification</span>
    <span class="btn btn-outline disabled c-dashboard-card__action" aria-disabled="true">New Verification</span>
    {{/if}}
  </div>
  {{/partials/metrics_card}}

  {{#> partials/metrics_card title="Project Members"}}
  <div class="c-dashboard-card__description">
    <p>See who has access to your active project and manage participation.</p>
  </div>
  <div class="c-dashboard-card__actions d-flex flex-wrap gap-2">
    {{#if selected_project_id}}
    <a href="/{{selected_project_slug}}/members" class="btn btn-primary c-dashboard-card__action">View Members</a>
    {{else}}
    <span class="btn btn-outline disabled c-dashboard-card__action">Select a project to view members</span>
    {{/if}}
    {{#if user.is_admin}}
    <a href="/admin/users" class="btn btn-outline c-dashboard-card__action">Manage Users</a>
    {{/if}}
  </div>
  {{/partials/metrics_card}}
</div>
{{/inline}}
{{> layout this page_id="project"}}
