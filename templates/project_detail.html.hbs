{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">{{project.project_name}}</h3>
                        <span class="badge {{#if (eq project.project_status 'active')}}bg-success{{else}}bg-secondary{{/if}} fs-6">
                            {{project.project_status}}
                        </span>
                    </div>
                </div>
                <div class="card-body c-card__body">
                    {{#if project.project_description}}
                        <p class="card-text c-card__text">{{project.project_description}}</p>
                    {{/if}}
                    
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h5>Project Information</h5>
                            <ul class="list-unstyled">
                                                <li><strong>Created:</strong> {{project.project_creation_date}}</li>
                <li><strong>Last Updated:</strong> {{project.project_update_date}}</li>
                                {{#if project.project_owner_id}}
                                    <li><strong>Owner:</strong> {{project.project_owner_id}}</li>
                                {{/if}}
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="card-footer c-card__footer">
                    <div class="btn-group" role="group">
                        <a href="/p/{{project.project_id}}/edit" class="btn btn-outline-primary">
                            <i class="fas fa-edit"></i> Edit Project
                        </a>
                        <a href="/projects" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Back to Projects
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card c-card">
                <div class="card-header c-card__header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body c-card__body">
                    <div class="d-grid gap-2">
                        <a href="/p/{{project.project_id}}/requirements" class="btn btn-outline-primary">
                            <i class="fas fa-list"></i> View Requirements
                        </a>
                        <a href="/p/{{selected_project_id}}/tests" class="btn btn-outline-primary">
                            <i class="fas fa-vial"></i> View Tests
                        </a>
                        <a href="/p/{{selected_project_id}}/matrix" class="btn btn-outline-primary">
                            <i class="fas fa-table"></i> View Matrix
                        </a>
                        <a href="/p/{{selected_project_id}}/reports" class="btn btn-outline-primary">
                            <i class="fas fa-chart-bar"></i> View Reports
                        </a>
                        <a href="/p/{{selected_project_id}}/members" class="btn btn-outline-primary">
                            <i class="fas fa-users"></i> View Members
                        </a>
                    </div>
                </div>
            </div>

            <div class="card mt-4 c-card">
                <div class="card-header c-card__header">
                    <h5 class="mb-0">Project Members</h5>
                </div>
                <div class="card-body p-0 c-card__body">
                    {{#if members.0}}
                        <ul class="list-group list-group-flush mb-0">
                            {{#each members}}
                                <li class="list-group-item member-item">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <strong>{{user_name}}</strong>
                                            <div class="text-muted small">@{{user_username}}</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="badge bg-primary member-role">{{role_label}}</span>
                                            {{#if is_admin}}
                                                <span class="badge bg-dark ms-1">Admin</span>
                                            {{/if}}
                                        </div>
                                    </div>
                                    {{#if user_email}}
                                        <div class="text-muted small mt-2">
                                            <i class="fas fa-envelope"></i> {{user_email}}
                                        </div>
                                    {{/if}}
                                </li>
                            {{/each}}
                        </ul>
                    {{else}}
                        <div class="p-3">
                            <p class="text-muted mb-0">No members have been assigned to this project yet.</p>
                        </div>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>

{{/inline}}
{{> layout page_id="project_detail"}}