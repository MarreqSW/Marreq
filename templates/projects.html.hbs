{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="marreq-portal">
  {{> partials/sidebar user=user}}

  <main class="marreq-main" id="mainContent">
    {{> partials/header user=user}}

    <section class="marreq-section">
      <div class="marreq-section__header">
        <h2 class="marreq-section__title">Projects</h2>
        {{#if user.is_admin}}
        <a href="/new_project" class="marreq-btn marreq-btn--primary">
          <i class="fas fa-plus" aria-hidden="true"></i>
          New Project
        </a>
        {{/if}}
      </div>

      {{#if projects}}
        <div class="marreq-projects-grid">
          {{#each projects}}
            {{> partials/project_card user=../user show_admin_actions=true}}
          {{/each}}
        </div>
      {{else}}
        <div class="marreq-empty-state">
          <i class="fas fa-folder-open" aria-hidden="true"></i>
          <h3>No Projects Found</h3>
          <p>Get started by creating your first project.</p>
          {{#if user.is_admin}}
          <a href="/new_project" class="marreq-btn marreq-btn--primary">
            <i class="fas fa-plus" aria-hidden="true"></i>
            Create Project
          </a>
          {{else}}
          <p>Contact an administrator to create a new project.</p>
          {{/if}}
        </div>
      {{/if}}
    </section>
  </main>
</div>
{{/inline}}
{{> layout this page_id="projects"}}
