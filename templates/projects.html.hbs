{{#*inline "page"}}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Projects</h1>
        <a href="/new_project" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Project
        </a>
    </div>

    {{#if projects}}
        <div class="row">
            {{#each projects}}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 project-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">{{project_name}}</h5>
                                <span class="badge {{#if (eq project_status 'active')}}bg-success{{else}}bg-secondary{{/if}}">
                                    {{project_status}}
                                </span>
                            </div>
                            
                            {{#if project_description}}
                                <p class="card-text text-muted">{{project_description}}</p>
                            {{/if}}
                            
                            <div class="project-meta">
                                <small class="text-muted">
                                    <i class="fas fa-calendar"></i> Created: {{project_creation_date}}
                                </small>
                                {{#if project_owner_id}}
                                    <br><small class="text-muted">
                                        <i class="fas fa-user"></i> Owner: {{project_owner_id}}
                                    </small>
                                {{/if}}
                            </div>
                        </div>
                        
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100" role="group">
                                <a href="/projects/{{project_id}}" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/edit_project/{{project_id}}" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteProject({{project_id}})">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="text-center py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <h3 class="text-muted">No Projects Found</h3>
            <p class="text-muted">Get started by creating your first project.</p>
            <a href="/new_project" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create Project
            </a>
        </div>
    {{/if}}
</div>

<script>
function deleteProject(projectId) {
    if (confirm('Are you sure you want to delete this project? This action cannot be undone.')) {
        fetch(`/delete_project/${projectId}`, {
            method: 'DELETE',
        })
        .then(response => {
            if (response.ok) {
                window.location.reload();
            } else {
                alert('Error deleting project');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error deleting project');
        });
    }
}
</script>

<style>
.project-card {
    transition: transform 0.2s, box-shadow 0.2s;
    border: 1px solid #e9ecef;
}

.project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.project-meta {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e9ecef;
}

.card-footer {
    border-top: 1px solid #e9ecef;
}

.btn-group .btn {
    flex: 1;
}
</style>
{{/inline}}
{{> layout}} 