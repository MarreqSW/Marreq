{{#*inline "page"}}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Projects</h1>
        {{#if user.is_admin}}
        <a href="/new_project" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Project
        </a>
        {{/if}}
    </div>

    {{#if projects}}
        <div class="row">
            {{#each projects}}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 project-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">{{project_name}}</h5>
                                <span class="badge {{project_status_badge}}">
                                    {{project_status}}
                                </span>
                            </div>

                            {{#if project_description}}
                                <p class="card-text text-muted">{{project_description}}</p>
                            {{/if}}

                            <div class="project-meta">
                                <small class="text-muted">
                                    <i class="fas fa-calendar"></i> Created: {{project_creation_date}}
                                </small>
                                {{#if project_owner_name}}
                                    <br><small class="text-muted">
                                        <i class="fas fa-user"></i> Owner: {{project_owner_name}}
                                    </small>
                                {{else}}
                                    {{#if project_owner_id}}
                                    <br><small class="text-muted">
                                        <i class="fas fa-user"></i> Owner: {{project_owner_id}}
                                    </small>
                                    {{/if}}
                                {{/if}}
                                {{#if role_label}}
                                    <br><small class="text-muted">
                                        <i class="fas fa-id-badge"></i> Role: {{role_label}}
                                    </small>
                                {{/if}}
                            </div>
                        </div>
                        
                        <div class="card-footer bg-transparent">
                            <div class="btn-group w-100" role="group">
                                <a href="/p/{{project_id}}" class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                {{#if ../user.is_admin}}
                                <a href="/p/{{project_id}}/edit" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm js-delete-project" type="button" data-project-id="{{project_id}}" data-project-name="{{project_name}}">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="text-center py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <h3 class="text-muted">No Projects Found</h3>
            <p class="text-muted">Get started by creating your first project.</p>
            {{#if user.is_admin}}
            <a href="/new_project" class="btn btn-primary">
                <i class="fas fa-plus"></i> Create Project
            </a>
            {{else}}
            <p class="text-muted">Contact an administrator to create a new project.</p>
            {{/if}}
        </div>
    {{/if}}
</div>


{{/inline}}
{{> layout}} 