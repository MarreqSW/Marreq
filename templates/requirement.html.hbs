{{#*inline "attachments_panel"}}
<div class="card shadow-sm">
  <div class="card-header bg-white">
    <h3 class="h6 text-uppercase text-muted mb-0">Attachments</h3>
  </div>
  <div class="card-body" data-slot="attachments">
    <p class="mb-0 text-muted">No supporting evidence has been linked yet.</p>
  </div>
</div>
{{/inline}}

{{#*inline "relationships_panel"}}
<div class="card shadow-sm">
  <div class="card-header bg-white">
    <h3 class="h6 text-uppercase text-muted mb-0">Relationships</h3>
  </div>
  <div class="card-body" data-slot="relationships">
    <p class="mb-0 text-muted">No upstream or downstream relationships recorded.</p>
  </div>
</div>
{{/inline}}

{{#*inline "requirement_sections"}}
<div class="d-flex flex-column gap-3">
  <div class="d-flex flex-column gap-3" data-slot="body-sections">
    <details class="card shadow-sm requirement-section" open>
      <summary class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="h5 mb-0">Statement</span>
        <span class="small text-muted">Tap to collapse</span>
      </summary>
      <div class="card-body">
        {{#if requirement_data.requirement.req_description}}
        <p class="mb-0">{{requirement_data.requirement.req_description}}</p>
        {{else}}
        <p class="mb-0 text-muted">No content provided yet.</p>
        {{/if}}
      </div>
    </details>

    <details class="card shadow-sm requirement-section" open>
      <summary class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="h5 mb-0">Rationale</span>
        <span class="small text-muted">Tap to collapse</span>
      </summary>
      <div class="card-body">
        {{#if requirement_data.requirement.req_justification}}
        <p class="mb-0">{{requirement_data.requirement.req_justification}}</p>
        {{else}}
        <p class="mb-0 text-muted">No rationale documented yet.</p>
        {{/if}}
      </div>
    </details>
  </div>
  {{> relationships_panel}}
  {{> attachments_panel}}
</div>
{{/inline}}

{{#*inline "verification_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h3 class="h6 text-uppercase text-muted mb-1">Verification</h3>
        <div class="fw-semibold" data-field="verification-state">No verifications linked yet</div>
      </div>
      <span class="badge" data-field="verification-badge"></span>
    </div>
    <div class="mb-3">
      <div class="progress" style="height: 8px;">
        <div
          class="progress-bar"
          role="progressbar"
          data-field="verification-progress"
          style="width: 0%;"
          aria-valuenow="0"
          aria-valuemin="0"
          aria-valuemax="100"
        ></div>
      </div>
      <div class="d-flex justify-content-between small text-muted mt-2">
        <span data-field="verification-passed">Passed 0</span>
        <span data-field="verification-failed">Failed 0</span>
        <span data-field="verification-pending">Pending 0</span>
      </div>
    </div>
    <div class="small text-muted mb-3" data-field="verification-tool">
      Tool: — · Last checked —
    </div>
    <div class="list-group list-group-flush" data-slot="linked-tests"></div>
    <p class="mb-0 text-muted" data-field="linked-tests-empty">
      No tests linked. Add a verification to start tracking compliance.
    </p>
  </div>
</div>
{{/inline}}

{{#*inline "history_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <h3 class="h6 text-uppercase text-muted mb-3">Change History</h3>
    <ul class="list-unstyled mb-0" data-slot="timeline"></ul>
  </div>
</div>
{{/inline}}

{{#*inline "comments_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <h3 class="h6 text-uppercase text-muted mb-3">Discussion</h3>
    <div class="alert alert-light border mb-3 d-none" data-field="comments-locked"></div>
    <p class="mb-3 text-muted d-none" data-field="comments-empty">
      No comments yet. Start the conversation with your team.
    </p>
    <div class="d-flex flex-column gap-3" data-slot="comments"></div>
    <button class="btn btn-outline-primary btn-sm" type="button" data-field="comments-reply-button" disabled>
      Reply (coming soon)
    </button>
  </div>
</div>
{{/inline}}

{{#*inline "page"}}
<div class="container-fluid requirement-detail-page py-4" data-requirement-root>
  <script type="application/json" id="requirement-detail-data">
    {{{requirement_data_json}}}
  </script>

  <header class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex flex-column flex-lg-row align-items-lg-start gap-3">
        <div class="flex-grow-1">
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="badge rounded-pill text-bg-dark fs-6" data-field="reference">—</span>
            <span class="badge" data-field="status-badge">—</span>
          </div>
          <h1 class="display-6 mt-3 mb-2" data-field="title">
            {{requirement_data.requirement.req_title}}
          </h1>
          <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <span class="fw-semibold text-muted" data-field="solidity-label">—</span>
            <span class="small text-muted" data-field="solidity-description"></span>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="badge" data-field="verification-badge">—</span>
            <span class="small text-muted" data-field="verification-state"></span>
          </div>
          <div class="d-flex flex-wrap gap-2" data-slot="chips"></div>
        </div>
        <div class="ms-lg-auto">
          <div class="btn-group">
            <a
              href="/p/{{selected_project_id}}/requirements/edit/{{requirement_data.requirement.req_id}}"
              class="btn btn-primary btn-sm"
            >Edit</a>
            <button class="btn btn-outline-secondary btn-sm" type="button" disabled title="Coming soon">
              Duplicate
            </button>
            <a
              href="/logs/REQUIREMENT/{{requirement_data.requirement.req_id}}"
              class="btn btn-outline-secondary btn-sm"
            >History</a>
            <div class="btn-group">
              <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                More
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <a class="dropdown-item" href="/p/{{selected_project_id}}/requirements">Back to list</a>
                </li>
                <li>
                  <a class="dropdown-item" href="/p/{{selected_project_id}}/requirements/edit/{{requirement_data.requirement.req_id}}">Edit requirement</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-3 mt-4 pt-3 border-top">
        <div class="col-sm-6 col-lg-auto d-flex align-items-center gap-3">
          <span class="badge rounded-circle text-bg-primary fs-6 px-3 py-2" data-field="author-initial">?</span>
          <div>
            <div class="text-uppercase small text-muted">Author</div>
            <div class="fw-semibold" data-field="author-name">—</div>
            <div class="small text-muted" data-field="author-timestamp"></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-auto d-flex align-items-center gap-3">
          <span class="badge rounded-circle text-bg-secondary fs-6 px-3 py-2" data-field="reviewer-initial">–</span>
          <div>
            <div class="text-uppercase small text-muted">Reviewer</div>
            <div class="fw-semibold" data-field="reviewer-name">Unassigned</div>
            <div class="small text-muted" data-field="reviewer-timestamp"></div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Last Updated</div>
          <div class="fw-semibold" data-field="metadata-updated">—</div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Deadline</div>
          <div class="fw-semibold" data-field="metadata-deadline">—</div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Version</div>
          <div class="fw-semibold" data-field="metadata-version">—</div>
        </div>
      </div>
    </div>
  </header>

  <div class="d-lg-none mb-4">
    <div class="nav nav-pills nav-fill small" role="tablist">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-details" type="button" role="tab">
        Details
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-verification" type="button" role="tab">
        Verification
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-history" type="button" role="tab">
        History
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-comments" type="button" role="tab">
        Comments
      </button>
    </div>
    <div class="tab-content mt-3">
      <div class="tab-pane fade show active" id="tab-details" role="tabpanel">
        {{> requirement_sections}}
      </div>
      <div class="tab-pane fade" id="tab-verification" role="tabpanel">
        {{> verification_panel}}
      </div>
      <div class="tab-pane fade" id="tab-history" role="tabpanel">
        {{> history_panel}}
      </div>
      <div class="tab-pane fade" id="tab-comments" role="tabpanel">
        {{> comments_panel}}
      </div>
    </div>
  </div>

  <div class="row g-4 d-none d-lg-flex">
    <div class="col-lg-8">
      {{> requirement_sections}}
    </div>
    <div class="col-lg-4">
      <div class="d-flex flex-column gap-3 position-sticky" style="top: 6rem;">
        {{> verification_panel}}
        {{> history_panel}}
        {{> comments_panel}}
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="changesModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Changes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <small class="text-muted">
            <span class="text-danger">🔴 Red</span> = Removed/Changed values ·
            <span class="text-success">🟢 Green</span> = Added/New values ·
            <span class="text-muted">⚪ Gray</span> = Unchanged values
          </small>
        </div>
        <div id="changesContent"></div>
      </div>
    </div>
  </div>
</div>
{{/inline}}

{{> layout page_id="requirement-detail"}}
