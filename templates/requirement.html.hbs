{{#*inline "attachments_panel"}}
<div class="card shadow-sm">
  <div class="card-header bg-white">
    <h3 class="h6 text-uppercase text-muted mb-0">Attachments</h3>
  </div>
  <div class="card-body">
    {{#if attachments}}
      <div class="list-group list-group-flush">
        {{#each attachments}}
        <a
          href="{{href}}"
          class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
          target="_blank"
          rel="noopener"
        >
          <span>{{label}}</span>
          <span class="small text-muted">&nearr;</span>
        </a>
        {{/each}}
      </div>
    {{else}}
      <p class="mb-0 text-muted">No supporting evidence has been linked yet.</p>
    {{/if}}
  </div>
</div>
{{/inline}}

{{#*inline "relationships_panel"}}
<div class="card shadow-sm">
  <div class="card-header bg-white">
    <h3 class="h6 text-uppercase text-muted mb-0">Relationships</h3>
  </div>
  <div class="card-body">
    {{#if relationships.has_links}}
      {{#if relationships.parent}}
      <div class="mb-3">
        <div class="small text-muted text-uppercase">Derived from</div>
        <a
          href="/p/{{@root.selected_project_id}}/requirements/show/{{relationships.parent.req_id}}"
          class="fw-semibold"
        >
          {{relationships.parent.req_reference}} · {{relationships.parent.req_title}}
        </a>
        <span class="badge bg-light text-dark border ms-2">{{relationships.parent.req_current_status}}</span>
      </div>
      {{/if}}
      {{#if relationships.children}}
      <div>
        <div class="small text-muted text-uppercase mb-2">Feeds</div>
        <ul class="list-unstyled mb-0">
          {{#each relationships.children}}
          <li class="d-flex align-items-center mb-2">
            <span class="text-muted me-2">&rarr;</span>
            <a
              href="/p/{{@root.selected_project_id}}/requirements/show/{{req_id}}"
              class="fw-semibold flex-grow-1"
            >
              {{req_reference}} · {{req_title}}
            </a>
            <span class="badge bg-light text-dark border ms-2">{{req_current_status}}</span>
          </li>
          {{/each}}
        </ul>
      </div>
      {{/if}}
    {{else}}
      <p class="mb-0 text-muted">No upstream or downstream relationships recorded.</p>
    {{/if}}
  </div>
</div>
{{/inline}}

{{#*inline "requirement_sections"}}
<div class="d-flex flex-column gap-3">
  {{#each body_sections}}
  <details class="card shadow-sm requirement-section" open>
    <summary class="card-header bg-white d-flex justify-content-between align-items-center">
      <span class="h5 mb-0">{{title}}</span>
      <span class="small text-muted">Tap to collapse</span>
    </summary>
    <div class="card-body">
      {{#if content}}
        <p class="mb-0">{{content}}</p>
      {{else}}
        <p class="mb-0 text-muted">No content provided yet.</p>
      {{/if}}
    </div>
  </details>
  {{/each}}
  {{> relationships_panel}}
  {{> attachments_panel}}
</div>
{{/inline}}

{{#*inline "verification_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h3 class="h6 text-uppercase text-muted mb-1">Verification</h3>
        <div class="fw-semibold">{{verification_badge.state}}</div>
      </div>
      <span class="badge {{verification_badge.variant}}">{{verification_badge.label}}</span>
    </div>
    <div class="mb-3">
      <div class="progress" style="height: 8px;">
        <div
          class="progress-bar"
          role="progressbar"
          style="width: {{verification_summary.percent}}%;"
          aria-valuenow="{{verification_summary.percent}}"
          aria-valuemin="0"
          aria-valuemax="100"
        ></div>
      </div>
      <div class="d-flex justify-content-between small text-muted mt-2">
        <span>Passed {{verification_summary.passed}}</span>
        <span>Failed {{verification_summary.failed}}</span>
        <span>Pending {{verification_summary.pending}}</span>
      </div>
    </div>
    <div class="small text-muted mb-3">
      Tool: {{verification_summary.tool}} · Last checked {{verification_summary.last_checked}}
    </div>
    {{#if linked_tests}}
    <div class="list-group list-group-flush">
      {{#each linked_tests}}
      <a
        href="/p/{{@root.selected_project_id}}/tests/show/{{test_id}}"
        class="list-group-item list-group-item-action d-flex justify-content-between align-items-start"
      >
        <div class="me-3">
          <div class="fw-semibold">{{test_name}}</div>
          <div class="small text-muted">{{test_description}}</div>
        </div>
        <span class="badge bg-light text-dark border">{{test_status}}</span>
      </a>
      {{/each}}
    </div>
    {{else}}
    <p class="mb-0 text-muted">No tests linked. Add a verification to start tracking compliance.</p>
    {{/if}}
  </div>
</div>
{{/inline}}

{{#*inline "history_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <h3 class="h6 text-uppercase text-muted mb-3">Change History</h3>
    <ul class="list-unstyled mb-0">
      {{#each timeline}}
      <li class="mb-3">
        <div class="d-flex justify-content-between align-items-center">
          <span class="badge bg-light text-dark border">{{version}}</span>
          <small class="text-muted">{{timestamp}}</small>
        </div>
        <div class="fw-semibold mt-2">{{summary}}</div>
        <div class="small text-muted">by {{actor}}</div>
        {{#if old_values}}
        <button
          class="btn btn-sm btn-outline-secondary mt-2"
          type="button"
          data-action="show-changes"
          data-old-values="{{old_values}}"
          data-new-values="{{new_values}}"
        >
          View diff
        </button>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </div>
</div>
{{/inline}}

{{#*inline "comments_panel"}}
<div class="card shadow-sm">
  <div class="card-body">
    <h3 class="h6 text-uppercase text-muted mb-3">Discussion</h3>
    {{#if comments.enabled}}
      {{#if comments.has_items}}
      <div class="d-flex flex-column gap-3">
        {{#each comments.items}}
        <div class="border rounded p-3 bg-light">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <span class="fw-semibold">{{author}}</span>
            <small class="text-muted">{{timestamp}}</small>
          </div>
          <p class="mb-0">{{body}}</p>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="mb-3 text-muted">No comments yet. Start the conversation with your team.</p>
      {{/if}}
      <button class="btn btn-outline-primary btn-sm" type="button" disabled>Reply (coming soon)</button>
    {{else}}
      <div class="alert alert-light border mb-0 text-muted">{{comments.locked_reason}}</div>
    {{/if}}
  </div>
</div>
{{/inline}}

{{#*inline "page"}}
<div class="container-fluid requirement-detail-page py-4">
  <header class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex flex-column flex-lg-row align-items-lg-start gap-3">
        <div class="flex-grow-1">
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="badge rounded-pill text-bg-dark fs-6">{{reference}}</span>
            <span class="badge {{status_badge.variant}}">{{status_badge.label}}</span>
          </div>
          <h1 class="display-6 mt-3 mb-2">{{requirement.req_title}}</h1>
          <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <span class="{{solidity.variant}} fw-semibold">{{solidity.label}}</span>
            <span class="small text-muted">{{solidity.description}}</span>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
            <span class="badge {{verification_badge.variant}}">{{verification_badge.label}}</span>
            <span class="small text-muted">{{verification_badge.state}}</span>
          </div>
          <div class="d-flex flex-wrap gap-2">
            {{#each chips}}
              {{#if label}}
              <span class="badge rounded-pill bg-light text-muted border">{{label}}</span>
              {{/if}}
            {{/each}}
          </div>
        </div>
        <div class="ms-lg-auto">
          <div class="btn-group">
            <a
              href="/p/{{selected_project_id}}/requirements/edit/{{requirement.req_id}}"
              class="btn btn-primary btn-sm"
            >Edit</a>
            <button class="btn btn-outline-secondary btn-sm" type="button" disabled title="Coming soon">
              Duplicate
            </button>
            <a
              href="/logs/REQUIREMENT/{{requirement.req_id}}"
              class="btn btn-outline-secondary btn-sm"
            >History</a>
            <div class="btn-group">
              <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                More
              </button>
              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <a class="dropdown-item" href="/p/{{selected_project_id}}/requirements">Back to list</a>
                </li>
                <li>
                  <a class="dropdown-item" href="/p/{{selected_project_id}}/requirements/edit/{{requirement.req_id}}">Edit requirement</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="row g-3 mt-4 pt-3 border-top">
        <div class="col-sm-6 col-lg-auto d-flex align-items-center gap-3">
          <span class="badge rounded-circle text-bg-primary fs-6 px-3 py-2">{{metadata.author.initial}}</span>
          <div>
            <div class="text-uppercase small text-muted">Author</div>
            <div class="fw-semibold">{{metadata.author.name}}</div>
            <div class="small text-muted">Created {{metadata.author.timestamp}}</div>
          </div>
        </div>
        <div class="col-sm-6 col-lg-auto d-flex align-items-center gap-3">
          <span class="badge rounded-circle text-bg-secondary fs-6 px-3 py-2">
            {{#if metadata.reviewer.assigned}}
              {{metadata.reviewer.initial}}
            {{else}}
              &ndash;
            {{/if}}
          </span>
          <div>
            <div class="text-uppercase small text-muted">Reviewer</div>
            {{#if metadata.reviewer.assigned}}
              <div class="fw-semibold">{{metadata.reviewer.name}}</div>
              <div class="small text-muted">Reviewed {{metadata.reviewer.timestamp}}</div>
            {{else}}
              <div class="fw-semibold text-muted">Unassigned</div>
            {{/if}}
          </div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Last Updated</div>
          <div class="fw-semibold">{{metadata.updated}}</div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Deadline</div>
          <div class="fw-semibold">{{metadata.deadline}}</div>
        </div>
        <div class="col-sm-6 col-lg-auto">
          <div class="text-uppercase small text-muted">Version</div>
          <div class="fw-semibold">{{metadata.version}}</div>
        </div>
      </div>
    </div>
  </header>

  <div class="d-lg-none mb-4">
    <div class="nav nav-pills nav-fill small" role="tablist">
      <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-details" type="button" role="tab">
        Details
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-verification" type="button" role="tab">
        Verification
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-history" type="button" role="tab">
        History
      </button>
      <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-comments" type="button" role="tab">
        Comments
      </button>
    </div>
    <div class="tab-content mt-3">
      <div class="tab-pane fade show active" id="tab-details" role="tabpanel">
        {{> requirement_sections}}
      </div>
      <div class="tab-pane fade" id="tab-verification" role="tabpanel">
        {{> verification_panel}}
      </div>
      <div class="tab-pane fade" id="tab-history" role="tabpanel">
        {{> history_panel}}
      </div>
      <div class="tab-pane fade" id="tab-comments" role="tabpanel">
        {{> comments_panel}}
      </div>
    </div>
  </div>

  <div class="row g-4 d-none d-lg-flex">
    <div class="col-lg-8">
      {{> requirement_sections}}
    </div>
    <div class="col-lg-4">
      <div class="d-flex flex-column gap-3 position-sticky" style="top: 6rem;">
        {{> verification_panel}}
        {{> history_panel}}
        {{> comments_panel}}
      </div>
    </div>
  </div>
</div>
{{/inline}}

{{> layout page_id="requirement-detail"}}
