
<div class="card requirement-card">
  <div class="card-body">
    <div class="requirement-header">
      <div>
        {{#if req_reference}}
          <a href="/requirements/{{req_id}}" class="requirement-reference-tag">{{req_reference}}</a>
        {{else}}
          <a href="/requirements/{{req_id}}" class="requirement-id">REQ-{{req_id}}</a>
        {{/if}}
        <h3 class="requirement-title">{{req_title}}</h3>
      </div>
      <div class="requirement-actions">
        <a href="/edit_requirement/{{req_id}}" class="btn btn-outline btn-sm">Edit</a>
      </div>
    </div>
    
    <p class="requirement-description">{{req_description}}</p>
    
    <div class="requirement-meta">
      <div class="meta-item">
        <span class="meta-label">Author</span>
        <span class="meta-value">{{req_author}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Reviewer</span>
        <span class="meta-value">{{req_reviewer}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Category</span>
        <span class="meta-value">{{req_category}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Applicability</span>
        <span class="meta-value">{{req_applicability}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Status</span>
        <span class="status-badge status-{{req_current_status}}">{{req_current_status}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Verification</span>
        <span class="meta-value">{{req_verification}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Reference</span>
        <span class="meta-value">{{req_reference}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Parent</span>
        <span class="meta-value">
          {{#if req_parent_id}}
            <a href="/requirements/{{req_parent_id}}">{{req_parent_title}}</a>
          {{else}}
            None
          {{/if}}
        </span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Created</span>
        <span class="meta-value">{{req_creation_date}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Updated</span>
        <span class="meta-value">{{req_update_date}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Deadline</span>
        <span class="meta-value">{{req_deadline_date}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Link</span>
        <span class="meta-value">
          {{#if req_link}}
            <a href="{{req_link}}" target="_blank" rel="noopener">View</a>
          {{else}}
            None
          {{/if}}
        </span>
      </div>
      {{#if req_justification}}
      <div class="meta-item">
        <span class="meta-label">Justification</span>
        <span class="meta-value">{{req_justification}}</span>
      </div>
      {{/if}}
    </div>
  </div>

  {{#if linked_tests}}
  <div class="linked-tests-section">
    <h4>Linked Tests</h4>
    <div class="linked-tests-list">
      {{#each linked_tests}}
      <div class="linked-test-item">
        <div class="test-info">
          <span class="test-id">TEST-{{test_id}}</span>
          <a href="/tests/{{test_id}}" class="test-name-link">{{test_name}}</a>
          <span class="test-status status-badge status-{{test_status}}">{{test_status}}</span>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}
</div>

