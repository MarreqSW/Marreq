{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New requirement status</h1>
  <p class="text-secondary">Add a custom requirement status for this project</p>

  {{#unless selected_project_id}}
  <div class="alert alert-info c-alert">
    <strong>Project Selection Required:</strong> Please select a project from the dropdown in the navigation bar above.
  </div>
  {{/unless}}
</div>

<section id="RequirementStatus">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Status details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post" action="/{{selected_project_slug}}/requirement_statuses/new">
        <div class="form-group c-form-group">
          <label for="title" class="form-label c-form-label">Title</label>
          <input type="text" name="title" id="title" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="4" required></textarea>
        </div>

        <div class="form-group c-form-group">
          <label for="tag" class="form-label c-form-label">Tag</label>
          <input type="text" name="tag" id="tag" class="form-control c-form-control" placeholder="e.g. Drf, Pro" required>
          <small class="text-secondary">Short identifier (e.g. Drf, Pro, Acc)</small>
        </div>

        <div class="form-group c-form-group">
          <label for="tag_color_hex" class="form-label c-form-label">Tag color</label>
          <div class="status-tag-color-group c-status-tag-color">
            <input type="color" class="status-tag-color-picker c-status-tag-color__picker" id="tag_color_picker" value="#6b7280" aria-label="Choose color">
            <input type="text" class="status-tag-color-hex form-control c-form-control c-status-tag-color__hex" name="tag_color" id="tag_color_hex" placeholder="#RRGGBB or rgb(r,g,b)" maxlength="20" autocomplete="off">
          </div>
          <small class="text-secondary">Optional: hex (#RRGGBB), rgb(r,g,b), or use the picker. Leave empty for default.</small>
        </div>

        {{#if selected_project_id}}
        <input type="hidden" name="project_id" value="{{selected_project_id}}">
        {{/if}}

        <div class="mt-4">
          <button type="submit" class="btn btn-primary" {{#unless selected_project_id}}disabled{{/unless}}>Create</button>
          <a href="/{{selected_project_slug}}/requirement_statuses" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="new_requirement_status"}}
