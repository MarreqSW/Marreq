{{!--
  List of requirement statuses; system statuses are not editable/deletable.
  Reuses list page layout; optional: css/pages/categories.css, js/pages/categories.js for search.
--}}
{{#*inline "page"}}
<section class="marreq-list-page marreq-category-page">
  <div class="marreq-list-page__header">
    <h1 class="marreq-list-page__title">Requirement statuses</h1>
    <a href="/p/{{selected_project_slug}}/requirement_statuses/new" class="btn btn-primary">New requirement status</a>
  </div>

  <div class="marreq-list-page__toolbar">
    <label for="requirement-status-search-input" class="u-sr-only">Search requirement statuses</label>
    <input
      id="requirement-status-search-input"
      type="search"
      class="form-control marreq-list-page__search c-form-control"
      placeholder="Search by title, tag, or description"
      autocomplete="off"
    >
  </div>

  <div class="marreq-list-page__list" id="requirement-status-list">
    {{#each requirement_statuses}}
      {{> requirement_statuses/requirement_status_row}}
    {{else}}
      <p class="marreq-list-page__empty" id="requirement-status-empty-state">No requirement statuses yet.</p>
    {{/each}}
  </div>
  <p class="marreq-list-page__empty" id="requirement-status-empty-filter" hidden>No statuses match your search.</p>
</section>
{{/inline}}
{{> layout this page_id="requirement_statuses"}}
