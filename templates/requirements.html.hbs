{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Requirements</h1>
    <div>
      <a href="/p/{{selected_project_id}}/requirements.xls" class="btn btn-success">Export Excel</a>
      {{#if user.is_admin}}
      <a href="/import_excel" class="btn btn-warning">Import Excel</a>
      {{/if}}
      <a href="/p/{{selected_project_id}}/requirements/new" class="btn btn-primary">New Requirement</a>
    </div>
  </div>
</div>

<!-- Filters Section -->
<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Filters</h5>
  </div>
  <div class="card-body">
    <form method="GET" action="{{#if selected_project_id}}/p/{{selected_project_id}}/requirements{{else}}/requirements{{/if}}" class="d-flex align-items-end gap-3 filters-form">
      {{> partials/filters_form
          status_field_name="status_filter"
          status_label="Status"
          status_default_label="All Statuses"
          status_options=statuses
          status_value_key="req_st_id"
          status_label_key="req_st_title"
          status_selected=current_status_filter
          verification_field_name="verification_filter"
          verification_label="Verification Mode"
          verification_default_label="All Verification Modes"
          verification_options=verifications
          verification_value_key="verification_id"
          verification_label_key="verification_name"
          verification_selected=current_verification_filter
          category_field_name="category_filter"
          category_label="Category"
          category_default_label="All Categories"
          category_options=categories
          category_value_key="cat_id"
          category_label_key="cat_title"
          category_selected=current_category_filter
      }}
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Apply Filters</button>
        <a href="{{#if selected_project_id}}/p/{{selected_project_id}}/requirements{{else}}/requirements{{/if}}" class="btn btn-secondary">Clear</a>
      </div>
    </form>
  </div>
</div>

<section id="Requirements">
  {{#each requirements }}
    {{> requirement}}
  {{/each}}
</section>
{{/inline}}
{{> layout}}
