{{!--
  PARTIAL: Card View
  Modern card-based layout for requirement browsing
--}}
<section class="marreq-requirements-cards-section" id="cardView" aria-live="polite">
  {{#if requirements}}
  <div class="marreq-requirements-cards-grid">
    {{#each requirements}}
    <article 
      class="marreq-requirement-card"
      data-requirement-id="{{id}}"
      data-status-id="{{req_current_status_id}}"
      data-status-label="{{status_id}}"
      data-verification="{{verification_method_id}}"
      data-category="{{category_id}}">
      
      {{!-- Card Header: Reference and Status --}}
      <header class="marreq-requirement-card__header">
        <div class="marreq-requirement-card__reference">
          <span class="marreq-requirement-card__reference-text">
            {{#if reference_code}}{{reference_code}}{{else}}REQ-{{id}}{{/if}}
          </span>
        </div>
        <span
          class="marreq-requirements-status-badge marreq-requirements-status-badge--{{status_id}}"
          data-status-id="{{req_current_status_id}}"
          data-status="{{status_id}}"{{#if status_tag_color}} style="background-color: {{status_tag_color}}; color: #fff; border-color: {{status_tag_color}};"{{/if}}>
          {{status_id}}
        </span>
      </header>

      {{!-- Card Body: Title and Description --}}
      <div class="marreq-requirement-card__body">
        <h3 class="marreq-requirement-card__title">
          <a 
            href="/p/{{../project.id}}/requirements/show/{{id}}"
            class="marreq-requirement-card__title-link"
            data-requirement-preview
            data-requirement-preview-project-id="{{../project.id}}"
            data-requirement-preview-id="{{id}}"
            data-requirement-preview-ref="{{reference_code}}"
            data-requirement-preview-title="{{title}}"
            data-requirement-preview-description="{{description}}"
            data-requirement-preview-status="{{status_id}}"
            data-requirement-preview-category="{{category_id}}">
            {{title}}
          </a>
        </h3>
        {{#if description}}
        <p class="marreq-requirement-card__description">
          {{description}}
        </p>
        {{/if}}
      </div>

      {{!-- Card Metadata: Tags and Badges --}}
      <div class="marreq-requirement-card__metadata" data-badge-rail>
        <div class="marreq-requirement-card__badge-rail">
          {{#if category_id}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--category" data-badge title="Category: {{category_id}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
              <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm8.5 9.5a.5.5 0 0 1-1 0V5.707L5.354 7.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 5.707V11.5z"/>
            </svg>
            {{category_id}}
          </span>
          {{/if}}
          {{#if verification_method_id}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--verification" data-badge title="Verification: {{verification_method_id}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
              <path d="M10.067.87a2.89 2.89 0 0 0-4.134 0l-.622.638-.89-.011a2.89 2.89 0 0 0-2.924 2.924l.01.89-.636.622a2.89 2.89 0 0 0 0 4.134l.637.622-.011.89a2.89 2.89 0 0 0 2.924 2.924l.89-.01.622.636a2.89 2.89 0 0 0 4.134 0l.622-.637.89.011a2.89 2.89 0 0 0 2.924-2.924l-.01-.89.636-.622a2.89 2.89 0 0 0 0-4.134l-.637-.622.011-.89a2.89 2.89 0 0 0-2.924-2.924l-.89.01-.622-.636zm.287 5.984-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708.708z"/>
            </svg>
            {{verification_method_id}}
          </span>
          {{/if}}
          {{#if applicability_id}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--applicability" data-badge title="Applicability: {{applicability_id}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
              <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
            </svg>
            {{applicability_id}}
          </span>
          {{/if}}
          {{#each req_parents}}
          <a href="/p/{{../../project.id}}/requirements/show/{{id}}" class="marreq-requirement-card__badge marreq-requirement-card__badge--parent" data-badge data-requirement-preview data-requirement-preview-project-id="{{../../project.id}}" data-requirement-preview-id="{{id}}" data-requirement-preview-ref="{{reference_code}}" data-requirement-preview-title="{{title}}" title="Parent: {{#if reference_code}}{{reference_code}} — {{/if}}{{title}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
              <path d="M1 0a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h5v-1H2v-1h4v-9H2V2h4v3h9a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1H1z"/>
            </svg>
            {{#if reference_code}}{{reference_code}} — {{/if}}{{title}}
          </a>
          {{/each}}
        </div>
        <span class="marreq-requirement-card__badge-overflow" data-overflow hidden></span>
      </div>

      {{!-- Card Footer: Author, Date, and Actions --}}
      <footer class="marreq-requirement-card__footer">
        <div class="marreq-requirement-card__info">
          {{#if author_id}}
          <span class="marreq-requirement-card__author" title="Author">
            <svg class="marreq-requirement-card__info-icon" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
              <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
              <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
            </svg>
            {{author_id}}
          </span>
          {{/if}}
          {{#if update_date}}
          <time class="marreq-requirement-card__date" title="Last modified">
            <svg class="marreq-requirement-card__info-icon" width="12" height="12" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
              <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
            </svg>
            {{update_date}}
          </time>
          {{/if}}
        </div>
        
        <div class="marreq-requirement-card__actions">
          <a 
            href="/p/{{../project.id}}/requirements/show/{{id}}" 
            class="marreq-requirement-card__action marreq-requirement-card__action--primary"
            title="View details">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
              <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
            </svg>
            <span class="u-visually-hidden">View</span>
          </a>
          {{#if ../can_edit_requirements}}
          <a 
            href="/p/{{../project.id}}/requirements/edit/{{id}}" 
            class="marreq-requirement-card__action"
            title="Edit requirement">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
            </svg>
            <span class="u-visually-hidden">Edit</span>
          </a>
          <button 
            type="button"
            class="marreq-requirement-card__action"
            data-action="duplicate-requirement"
            data-requirement-id="{{id}}"
            title="Duplicate requirement">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H6zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1H2z"/>
            </svg>
            <span class="u-visually-hidden">Duplicate</span>
          </button>
          {{/if}}
        </div>
      </footer>
    </article>
    {{/each}}
  </div>
  
  {{!-- Pagination --}}
  <nav class="marreq-requirements-pagination" aria-label="Requirements pagination">
    <button type="button" class="marreq-requirements-pagination__button is-disabled" disabled aria-disabled="true">Prev</button>
    <span class="marreq-requirements-pagination__status">All {{requirement_metrics.total}} requirements</span>
    <button type="button" class="marreq-requirements-pagination__button is-disabled" disabled aria-disabled="true">Next</button>
  </nav>
  {{else}}
  {{> requirements/_empty_state}}
  {{/if}}
</section>
