{{!--
  PARTIAL: Pagination
  Prev/Next and page numbers; preserves current filters and view
--}}
{{#if (gt pagination.total_pages 1)}}
<nav class="reqman-requirements-pagination" aria-label="Requirements pagination">
  <div class="reqman-requirements-pagination__info">
    <span class="reqman-requirements-pagination__range">
      {{pagination.start}}–{{pagination.end}} of {{pagination.total_count}}
    </span>
  </div>
  <div class="reqman-requirements-pagination__links">
    {{#if pagination.has_prev}}
    <a href="/p/{{project.id}}/requirements?{{#if pagination.query}}{{pagination.query}}&{{/if}}page={{pagination.prev_page}}"
       class="reqman-requirements-pagination__link reqman-requirements-pagination__link--prev">
      Previous
    </a>
    {{else}}
    <span class="reqman-requirements-pagination__link reqman-requirements-pagination__link--disabled" aria-disabled="true">Previous</span>
    {{/if}}

    <ol class="reqman-requirements-pagination__pages" role="list">
      {{#each pagination.page_numbers}}
      <li>
        {{#if this.is_current}}
        <span class="reqman-requirements-pagination__page reqman-requirements-pagination__page--current" aria-current="page">{{this.num}}</span>
        {{else}}
        <a href="/p/{{../project.id}}/requirements?{{#if ../pagination.query}}{{../pagination.query}}&{{/if}}page={{this.num}}" class="reqman-requirements-pagination__page">{{this.num}}</a>
        {{/if}}
      </li>
      {{/each}}
    </ol>

    {{#if pagination.has_next}}
    <a href="/p/{{project.id}}/requirements?{{#if pagination.query}}{{pagination.query}}&{{/if}}page={{pagination.next_page}}"
       class="reqman-requirements-pagination__link reqman-requirements-pagination__link--next">
      Next
    </a>
    {{else}}
    <span class="reqman-requirements-pagination__link reqman-requirements-pagination__link--disabled" aria-disabled="true">Next</span>
    {{/if}}
  </div>
</nav>
{{/if}}
