{{!--
  PARTIAL: Pagination (shared by requirements and verifications)
  Prev/Next and page numbers; preserves current filters and view.
  Expects: pagination, project. Optional: pagination_path (default "requirements") for URL segment.
--}}
{{#if (gt pagination.total_pages 1)}}
<nav class="marreq-requirements-pagination" aria-label="Pagination">
  <div class="marreq-requirements-pagination__info">
    <span class="marreq-requirements-pagination__range">
      {{pagination.start}}–{{pagination.end}} of {{pagination.total_count}}
    </span>
  </div>
  <div class="marreq-requirements-pagination__links">
    {{#if pagination.has_prev}}
    <a href="/p/{{project.id}}/{{#if pagination_path}}{{pagination_path}}{{else}}requirements{{/if}}?{{#if pagination.query}}{{pagination.query}}&{{/if}}page={{pagination.prev_page}}"
       class="marreq-requirements-pagination__link marreq-requirements-pagination__link--prev">
      Previous
    </a>
    {{else}}
    <span class="marreq-requirements-pagination__link marreq-requirements-pagination__link--disabled" aria-disabled="true">Previous</span>
    {{/if}}

    <ol class="marreq-requirements-pagination__pages" role="list">
      {{#each pagination.page_numbers}}
      <li>
        {{#if this.is_current}}
        <span class="marreq-requirements-pagination__page marreq-requirements-pagination__page--current" aria-current="page">{{this.num}}</span>
        {{else}}
        <a href="/p/{{../project.id}}/{{#if ../pagination_path}}{{../pagination_path}}{{else}}requirements{{/if}}?{{#if ../pagination.query}}{{../pagination.query}}&{{/if}}page={{this.num}}" class="marreq-requirements-pagination__page">{{this.num}}</a>
        {{/if}}
      </li>
      {{/each}}
    </ol>

    {{#if pagination.has_next}}
    <a href="/p/{{project.id}}/{{#if pagination_path}}{{pagination_path}}{{else}}requirements{{/if}}?{{#if pagination.query}}{{pagination.query}}&{{/if}}page={{pagination.next_page}}"
       class="marreq-requirements-pagination__link marreq-requirements-pagination__link--next">
      Next
    </a>
    {{else}}
    <span class="marreq-requirements-pagination__link marreq-requirements-pagination__link--disabled" aria-disabled="true">Next</span>
    {{/if}}
  </div>
</nav>
{{/if}}
