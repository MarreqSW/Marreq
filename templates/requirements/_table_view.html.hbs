{{!--
  PARTIAL: Table View (Default/Compact)
  Compact table with expandable row details
--}}
<section class="marreq-requirements-table-section" id="tableView" aria-live="polite">
  {{#if requirements}}
  <div class="marreq-requirements-table__wrapper">
    <table class="marreq-requirements-table" id="requirementsTable">
      <thead>
        <tr>
          <th scope="col" data-sort-key="key" class="is-sortable">
            Key
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="title" class="is-sortable">
            Title
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="category" class="is-sortable">
            Category
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="parent" class="is-sortable">
            Parent
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="status" class="is-sortable">
            Status
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="approval" class="is-sortable">
            Approval
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="verification" class="is-sortable">
            Verification
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="updated" class="is-sortable">
            Modified
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="author" class="is-sortable">
            Author
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" class="marreq-requirements-table__actions-head">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each requirements}}
        <tr
          class="marreq-requirements-row"
          data-requirement-id="{{id}}"
          data-status-id="{{req_current_status_id}}"
          data-status-label="{{status_id}}"
          data-category-id="{{req_category_id}}"
          data-verification-ids="{{#each req_verification_ids}} {{this}} {{/each}}"
          data-parent-id="{{#if req_parent_id}}{{req_parent_id}}{{else}}0{{/if}}">
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--key">
            <div class="marreq-requirements-key">
              <span class="marreq-requirements-key__value">
                {{#if reference_code}}{{reference_code}}{{else}}REQ-{{id}}{{/if}}
              </span>
              <button
                type="button"
                class="marreq-requirements-key__toggle"
                data-action="toggle-row-details"
                aria-expanded="false"
                aria-controls="requirement-details-{{id}}">
                <span class="u-visually-hidden">Toggle details for {{title}}</span>
              </button>
            </div>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--title">
            <a
              href="/p/{{../project.id}}/requirements/show/{{id}}"
              class="marreq-requirements-title"
              title="{{title}}"
              data-requirement-preview
              data-requirement-preview-project-id="{{../project.id}}"
              data-requirement-preview-id="{{id}}"
              data-requirement-preview-ref="{{reference_code}}"
              data-requirement-preview-title="{{title}}"
              data-requirement-preview-description="{{description}}"
              data-requirement-preview-status="{{status_id}}"
              data-requirement-preview-category="{{category_id}}">
              {{title}}
            </a>
            {{#if reference_code}}
            <span class="marreq-requirements-title__reference">({{reference_code}})</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--category marreq-requirements-cell--editable" data-inline-edit="category" title="Click to change">
            {{#if category_id}}
              <span class="marreq-requirements-cell__display">{{category_id}}</span>
            {{else}}
              <span class="marreq-requirements-cell__display marreq-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--parent">
            {{#if req_parents}}
              <span class="marreq-requirements-cell__display marreq-requirements-parents-list">
                {{#each req_parents}}
                  {{#unless @first}}<span class="marreq-requirements-parents-sep">, </span>{{/unless}}
                  <a href="/p/{{../../project.id}}/requirements/show/{{id}}" class="marreq-requirements-parent-link" title="View {{reference_code}} — {{title}}" data-requirement-preview data-requirement-preview-project-id="{{../../project.id}}" data-requirement-preview-id="{{id}}" data-requirement-preview-ref="{{reference_code}}" data-requirement-preview-title="{{title}}">{{#if reference_code}}{{reference_code}} — {{/if}}{{title}}</a>
                {{/each}}
              </span>
            {{else}}
              <span class="marreq-requirements-cell__display marreq-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--status marreq-requirements-cell--editable" data-inline-edit="status" title="Click to change">
            <span
              class="marreq-requirements-status-badge marreq-requirements-cell__display"
              data-status-id="{{req_current_status_id}}"
              data-status="{{status_id}}"{{#if status_tag_color}} style="background-color: {{status_tag_color}}; color: #fff; border-color: {{status_tag_color}};"{{/if}}>
              {{status_id}}
            </span>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--approval">
            <span class="badge marreq-approval-badge marreq-approval-badge--{{approval_state}}" aria-label="Approval: {{approval_state}}">{{approval_state}}</span>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--verification marreq-requirements-cell--editable" data-inline-edit="verification" title="Click to change">
            <span class="marreq-requirements-cell__display marreq-requirements-cell-muted">{{verification_method_id}}</span>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--updated">
            <time>{{update_date}}</time>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--author">
            {{#if author_id}}
              {{author_id}}
            {{else}}
              <span class="marreq-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--actions">
            <div class="marreq-requirements-row__actions">
              <a 
                href="/p/{{../project.id}}/requirements/show/{{id}}" 
                class="marreq-requirements-row__action marreq-requirements-row__action--icon"
                title="View requirement">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                  <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
                <span class="u-visually-hidden">View</span>
              </a>
              <a 
                href="/p/{{../project.id}}/requirements/edit/{{id}}" 
                class="marreq-requirements-row__action marreq-requirements-row__action--icon"
                title="Edit requirement">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                </svg>
                <span class="u-visually-hidden">Edit</span>
              </a>
              <button
                type="button"
                class="marreq-requirements-row__action marreq-requirements-row__action--icon"
                data-action="duplicate-requirement"
                data-requirement-id="{{id}}"
                title="Duplicate requirement">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M4 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V2zm2-1a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H6zM2 5a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1h1v1a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h1v1H2z"/>
                </svg>
                <span class="u-visually-hidden">Duplicate</span>
              </button>
            </div>
          </td>
        </tr>
        <tr
          id="requirement-details-{{id}}"
          class="marreq-requirements-row__details"
          data-details-for="{{id}}"
          hidden>
          <td colspan="10">
            <dl class="marreq-requirements-details-grid">
              <div>
                <dt>Category</dt>
                <dd>{{category_id}}</dd>
              </div>
              <div>
                <dt>Applicability</dt>
                <dd>{{applicability_id}}</dd>
              </div>
              <div>
                <dt>Reviewer</dt>
                <dd>{{#if reviewer_id}}{{reviewer_id}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Updated</dt>
                <dd>{{update_date}}</dd>
              </div>
              <div>
                <dt>Author</dt>
                <dd>{{#if author_id}}{{author_id}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Parents</dt>
                <dd>
                  {{#if req_parents}}
                    {{#each req_parents}}
                      {{#unless @first}}, {{/unless}}
                      <a href="/p/{{../../project.id}}/requirements/show/{{id}}">{{#if reference_code}}{{reference_code}} — {{/if}}{{title}}</a>
                    {{/each}}
                  {{else}}
                    —
                  {{/if}}
                </dd>
              </div>
            </dl>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  <nav class="marreq-requirements-pagination" aria-label="Requirements pagination">
    <button type="button" class="marreq-requirements-pagination__button is-disabled" disabled aria-disabled="true">Prev</button>
    <span class="marreq-requirements-pagination__status">All {{requirement_metrics.total}} requirements</span>
    <button type="button" class="marreq-requirements-pagination__button is-disabled" disabled aria-disabled="true">Next</button>
  </nav>
  {{else}}
  {{> requirements/_empty_state}}
  {{/if}}
</section>
