{{!--
PARTIAL: View Controls
View switcher buttons, export/import, and new requirement button
--}}
<div class="marreq-requirements-header__actions">
  <div class="marreq-requirements-header__secondary">
    {{!-- View Switcher Buttons --}}
    <div class="btn-group me-3" role="group" aria-label="View switcher">
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn active" data-view="table"
        id="tableViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path
            d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z" />
        </svg>
        Table
      </button>
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn" data-view="card"
        id="cardViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path
            d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z" />
        </svg>
        Card
      </button>
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn" data-view="tree"
        id="treeViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path
            d="M8.416.223a.5.5 0 0 0-.832 0l-3 4.5A.5.5 0 0 0 5 5.5h.098L3.076 8.735A.5.5 0 0 0 3.5 9.5h.191l-1.638 3.276a.5.5 0 0 0 .447.724H7V16h2v-2.5h4.5a.5.5 0 0 0 .447-.724L12.31 9.5h.191a.5.5 0 0 0 .424-.765L10.902 5.5H11a.5.5 0 0 0 .416-.777l-3-4.5zM6.437 4.758A.5.5 0 0 0 6 4.5h-.066L8 1.401 10.066 4.5H10a.5.5 0 0 0-.424.765L11.598 8.5H11.5a.5.5 0 0 0-.447.724L12.5 12.5h-9l1.447-3.276A.5.5 0 0 0 4.5 8.5h-.098l2.022-3.235a.5.5 0 0 0 .013-.507z" />
        </svg>
        Tree
      </button>
    </div>
    {{#if project.id}}
    <button type="button" class="btn btn-outline-primary btn-sm" id="semanticSearchBtn" data-bs-toggle="modal"
      data-bs-target="#semanticSearchModal" data-project-id="{{project.id}}" title="Semantic search (Ctrl+K)">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
        <path
          d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
      </svg>
      AI Search
    </button>
    <div class="btn-group btn-group-sm me-0" role="group">
      <button type="button" class="btn btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown"
        aria-expanded="false" title="Export requirements">
        Export
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><a class="dropdown-item" href="/p/{{project.id}}/requirements.xls" title="Export to Excel">Excel</a></li>
        <li><a class="dropdown-item" href="/p/{{project.id}}/export_reqif" title="Export current project as ReqIF 1.2">ReqIF (current)</a></li>
        <li><a class="dropdown-item" href="/p/{{project.id}}/baselines" title="Export a baseline as ReqIF">ReqIF (from baseline…)</a></li>
      </ul>
    </div>
    {{#if is_admin}}
    <a href="/p/{{project.id}}/import_excel" class="btn btn-outline-secondary btn-sm" title="Import from Excel/CSV">
      Import
    </a>
    <a href="/p/{{project.id}}/import_reqif" class="btn btn-outline-secondary btn-sm" title="Import from ReqIF 1.2">
      Import ReqIF
    </a>
    {{/if}}
    {{else}}
    <button type="button" class="btn btn-outline-primary btn-sm" disabled aria-disabled="true">
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
        <path
          d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
      </svg>
      AI Search
    </button>
    <div class="btn-group btn-group-sm" role="group">
      <button type="button" class="btn btn-outline-secondary dropdown-toggle" disabled aria-disabled="true"
        data-bs-toggle="dropdown" aria-expanded="false">
        Export
      </button>
      <ul class="dropdown-menu dropdown-menu-end">
        <li><span class="dropdown-item text-muted">Excel</span></li>
        <li><span class="dropdown-item text-muted">ReqIF</span></li>
      </ul>
    </div>
    {{#if is_admin}}
    <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
      Import
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
      Import ReqIF
    </button>
    {{/if}}
    {{/if}}
  </div>
  {{#if project.id}}
  {{#if can_edit_requirements}}
  <a href="/p/{{project.id}}/requirements/new" class="btn btn-primary marreq-requirements-header__primary"
    id="newRequirementButton">
    New Requirement
  </a>
  {{else}}
  <button type="button" class="btn btn-primary marreq-requirements-header__primary" id="newRequirementButton" disabled
    aria-disabled="true">
    New Requirement
  </button>
  {{/if}}
  {{else}}
  <button type="button" class="btn btn-primary marreq-requirements-header__primary" id="newRequirementButton" disabled
    aria-disabled="true">
    New Requirement
  </button>
  {{/if}}
</div>