{{!-- Depends on: css/pages/requirement-editor.css, js/pages/requirementForm.js --}}
{{#*inline "page"}}
<form method="post" data-requirement-form data-allow-soft-mismatch="true" id="requirement-edit-form"
  class="c-requirement-editor">
  <header class="c-editor-topbar sticky-top" data-editor-topbar>
    <div class="c-editor-topbar__context">
      <nav class="c-editor-breadcrumb" aria-label="Breadcrumb">
        <a href="/p/{{req.project_id}}/requirements" class="c-editor-breadcrumb__link">
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="c-editor-breadcrumb__sep">›</span>
        <a href="/p/{{req.project_id}}/requirements/show/{{req.id}}"
          class="c-editor-breadcrumb__link">{{display_reference}}</a>
      </nav>

      <h1 class="u-visually-hidden">Editing requirement {{display_reference}}</h1>
    </div>

    <div class="c-editor-topbar__actions">
      <div class="c-editor-topbar__status">
        <div class="c-editor-status" data-role="status-control">
          <button type="button" class="c-editor-status__chip" data-role="status-toggle" aria-haspopup="true"
            aria-expanded="false">
            <span class="c-editor-status__dot"></span>
            <span class="c-editor-status__label editor-status__label">{{req.status_id}}</span>
          </button>
          <div class="c-editor-status__menu" data-role="status-menu" hidden>
            {{#each statuses}}
            <button type="button" data-status-id="{{id}}">{{title}}</button>
            {{/each}}
          </div>
        </div>

        <div class="c-editor-version" data-role="version-indicator">
          Editing {{version.label}} · last updated by {{version.last_editor}} on {{version.updated_at}}
        </div>
      </div>

      <div class="c-editor-actions">
        <div class="c-editor-autosave" aria-live="polite">
          <span class="c-editor-autosave__dot" data-unsaved-indicator hidden></span>
          <span class="c-editor-autosave__text" data-role="autosave-text">All changes saved</span>
        </div>

        <button type="submit" class="btn btn-primary editor-actions__save" data-role="submit-requirement">Save</button>

        <a href="/p/{{req.project_id}}/requirements/show/{{req.id}}" class="c-editor-actions__cancel">Cancel</a>
      </div>
    </div>
  </header>

  <div class="c-editor-layout">
    <main class="c-editor-main">
      <section class="c-editor-section editor-section--title">
        <label for="title" class="c-editor-field__label">Title</label>
        <input type="text" name="title" id="title" value="{{req.title}}"
          class="c-editor-field__input editor-field__input--headline" autofocus required
          placeholder="The system shall…">
        <p class="c-editor-hint">Lead with the promise — what value does this deliver?</p>
      </section>

      <section class="c-editor-section editor-section--statement">
        <div class="c-editor-field__header">
          <label for="description" class="c-editor-field__label">
            Requirement statement
          </label>
          <div class="c-editor-inline-actions">
            <button type="button" class="c-editor-inline-actions__button" data-role="preview-toggle">
              👁 Preview
            </button>
          </div>
        </div>

        <div class="c-editor-rich-text" data-role="rich-text">
          <div class="c-editor-toolbar" role="toolbar" aria-label="Formatting options">
            <button type="button" class="c-editor-toolbar__btn" data-format="bold"><strong>B</strong></button>
            <button type="button" class="c-editor-toolbar__btn" data-format="italic"><em>I</em></button>
            <button type="button" class="c-editor-toolbar__btn" data-format="list">• List</button>
            <button type="button" class="c-editor-toolbar__btn" data-format="code">Code</button>
            <button type="button" class="c-editor-toolbar__btn" data-format="link">Link</button>
          </div>

          <textarea name="description" id="description" class="c-editor-field__textarea" rows="10"
            data-role="requirement-input" required placeholder="The system shall…">{{req.description}}</textarea>

          <div class="c-editor-preview" data-role="preview" hidden>
            <div class="c-editor-preview__content" data-role="preview-content"></div>
          </div>
        </div>

        <p class="c-editor-hint">
          Avoid ambiguous verbs like “support”; prefer “shall provide”.
        </p>
      </section>

      <section class="c-editor-section editor-section--rationale">
        <button type="button" class="c-editor-collapsible__trigger" data-role="rationale-toggle"
          aria-expanded="{{#if req.justification}}true{{else}}false{{/if}}">
          Rationale / Notes
          <span class="c-editor-collapsible__hint">Optional</span>
        </button>

        <div class="c-editor-collapsible__panel" data-role="rationale-panel" {{#unless
          req.justification}}hidden{{/unless}}>
          <textarea name="justification" id="justification" class="c-editor-field__textarea" rows="6"
            placeholder="Why is this required?">{{req.justification}}</textarea>
        </div>
      </section>

      <section class="c-editor-section editor-section--attachments">
        <h2 class="c-editor-section__title">Attachments</h2>
        <div class="c-editor-dropzone" data-role="attachments-zone">
          <input type="file" data-role="attachments-input" id="attachments-input" multiple hidden>
          <p class="c-editor-dropzone__hint">
            Drop documents or diagrams here, or
            <button type="button" class="c-editor-dropzone__action" data-role="browse-attachments">
              browse
            </button>
          </p>
          <ul class="c-editor-dropzone__list" data-role="attachment-list"></ul>
        </div>
      </section>
    </main>

    <aside class="c-editor-sidebar">
      <section class="c-editor-meta-group">
        <h2 class="c-editor-meta__title">Classification</h2>

        <div class="c-editor-field">
          <label for="reference_code" class="c-editor-field__label">Reference</label>
          <input type="text" name="reference_code" id="reference_code" value="{{req.reference_code}}"
            class="c-editor-field__input" placeholder="REQ-SYS-42" readonly disabled>
          <small class="c-editor-field__help">
            System-generated identifier.
          </small>
        </div>

        <div class="c-editor-field">
          <label for="category_id" class="c-editor-field__label">Category</label>
          <select name="category_id" id="category_id" class="c-editor-field__input" required>
            {{#each categories}}
            <option value="{{id}}" data-tag="{{tag}}" {{#if (eq id ../req.req_category_id)}}selected{{/if}}>
              {{title}}
            </option>
            {{/each}}
          </select>
        </div>

        <div class="c-editor-field">
          <label for="applicability_id" class="c-editor-field__label">Applicability</label>
          <select name="applicability_id" id="applicability_id" class="c-editor-field__input" required>
            {{#each applicability}}
            <option value="{{id}}" {{#if (eq id ../req.req_applicability_id)}}selected{{/if}}>
              {{title}}
            </option>
            {{/each}}
          </select>
        </div>

        <div class="c-editor-field">
          <label for="verification_method_ids" class="c-editor-field__label">Verification methods</label>
          <select name="verification_method_ids" id="verification_method_ids" class="c-editor-field__input" multiple
            required size="4">
            {{#each verification_with_selected}}
            <option value="{{id}}" {{#if selected}}selected{{/if}}>{{title}}</option>
            {{/each}}
          </select>
          <small class="c-editor-field__help">Hold Ctrl/Cmd to select multiple.</small>
        </div>

        {{#if custom_field_definitions_with_values}}
        <div class="c-editor-meta-group" id="custom-fields-edit-section">
          <h2 class="c-editor-meta__title">Custom fields</h2>
          {{#each custom_field_definitions_with_values}}
          <div class="c-editor-field mb-2" data-custom-field-id="{{id}}">
            <label for="custom_field_{{id}}" class="c-editor-field__label">{{label}}</label>
            {{#if (eq field_type "text")}}
            <input type="text" id="custom_field_{{id}}" class="c-editor-field__input c-create-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
            {{else if (eq field_type "number")}}
            <input type="number" id="custom_field_{{id}}" class="c-editor-field__input c-create-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
            {{else if (eq field_type "boolean")}}
            <select id="custom_field_{{id}}" class="c-editor-field__input c-create-field__custom-value" data-field-id="{{id}}">
              <option value="">—</option>
              <option value="true" {{#if (eq current_value "true")}}selected{{/if}}>Yes</option>
              <option value="false" {{#if (eq current_value "false")}}selected{{/if}}>No</option>
            </select>
            {{else if (eq field_type "enum")}}
            <select id="custom_field_{{id}}" class="c-editor-field__input c-create-field__custom-value" data-field-id="{{id}}">
              <option value="">—</option>
              {{#if enum_values}}
              {{#each enum_values}}
              <option value="{{this}}" {{#if (eq this ../current_value)}}selected{{/if}}>{{this}}</option>
              {{/each}}
              {{/if}}
            </select>
            {{else}}
            <input type="text" id="custom_field_{{id}}" class="c-editor-field__input c-create-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{/if}}
      </section>

      <section class="c-editor-meta-group">
        <h2 class="c-editor-meta__title">People</h2>

        <div class="c-editor-field">
          <label for="author_id" class="c-editor-field__label">Author</label>
          <input type="text" id="req_author_display" class="c-editor-field__input" value="{{req.author_id}}" readonly
            disabled>
          <input type="hidden" name="author_id" value="{{req.req_author_id}}">
          <small class="c-editor-field__help">
            Original author cannot be changed.
          </small>
        </div>

        <div class="c-editor-field">
          <label for="reviewer_id" class="c-editor-field__label">Reviewer</label>
          <select name="reviewer_id" id="reviewer_id" class="c-editor-field__input" required>
            {{#each users}}
            <option value="{{id}}" {{#if (eq id ../req.req_reviewer_id)}}selected{{/if}}>
              {{name}}
            </option>
            {{/each}}
          </select>
        </div>
      </section>

      <section class="c-editor-meta-group" data-role="upstream-trace">
        <h2 class="c-editor-meta__title">Upstream Trace</h2>
        <div class="c-editor-field">
          <label class="c-editor-field__label">Parent requirements</label>
          <p class="c-editor-field__help mb-2">Link this requirement to one or more parent requirements (e.g. derives from, refines).</p>
          <ul class="list-unstyled mb-3" data-role="parent-links-list" aria-label="Parent links">
            {{#each parent_links_edit}}
            <li class="d-flex align-items-center gap-2 mb-2" data-target-id="{{target_requirement_id}}" data-link-type="{{link_type}}">
              <span class="badge bg-secondary">{{link_type}}</span>
              <span class="flex-grow-1">{{#if reference}}{{reference}}{{else}}RM-{{target_requirement_id}}{{/if}} — {{title}}</span>
              <button type="button" class="btn btn-sm btn-outline-danger" data-role="remove-parent-link" aria-label="Remove parent link">Remove</button>
            </li>
            {{/each}}
          </ul>
          <div class="d-flex flex-wrap gap-2 align-items-end" data-role="add-parent-link">
            <div class="flex-grow-1 min-w-0">
              <label for="parent_link_requirement" class="form-label visually-hidden">Requirement</label>
              <select id="parent_link_requirement" class="form-select form-select-sm" data-role="parent-link-requirement" aria-label="Select parent requirement">
                <option value="">Select requirement…</option>
                {{#each linked_requirement_options}}
                <option value="{{id}}" data-reference="{{reference}}" data-title="{{title}}">{{#if reference}}{{reference}}{{else}}RM-{{id}}{{/if}} — {{title}}</option>
                {{/each}}
              </select>
            </div>
            <div>
              <label for="parent_link_type" class="form-label visually-hidden">Link type</label>
              <select id="parent_link_type" class="form-select form-select-sm" data-role="parent-link-type" aria-label="Link type">
                {{#each link_types}}
                <option value="{{this}}">{{this}}</option>
                {{/each}}
              </select>
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary" data-role="add-parent-link-btn">Add parent</button>
          </div>
        </div>
        <input type="hidden" name="parent_id" id="parent_id" value="{{#if req.req_parent_id}}{{req.req_parent_id}}{{else}}0{{/if}}">
        <input type="hidden" name="parent_links" id="parent_links" value="" data-role="parent-links-value">
      </section>
    </aside>
  </div>

  <input type="hidden" name="author_id" value="{{req.req_author_id}}">
  <input type="hidden" id="id" name="id" value="{{req.id}}">
  <input type="hidden" name="reference_code" value="{{req.reference_code}}">
  <select id="status_id" name="status_id" class="u-visually-hidden" aria-hidden="true" required>
    {{#each statuses}}
    <option value="{{id}}" {{#if (eq id ../req.req_current_status_id)}}selected{{/if}}>{{title}}</option>
    {{/each}}
  </select>
  <input type="hidden" id="project_id" name="project_id" value="{{req.project_id}}">
  <input type="hidden" id="custom_field_values" name="custom_field_values" value="[]">
  <input type="hidden" id="autosave-interval" value="{{autosave.interval_ms}}" data-role="autosave-interval">
</form>
{{/inline}}
{{> layout page_id="requirement-form"}}