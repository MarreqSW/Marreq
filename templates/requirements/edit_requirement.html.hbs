{{!--
  Depends on: css/pages/requirement-form.css, css/pages/requirement-editor.css,
              css/50-components/dropdown.css, css/50-components/pill-select.css,
              css/50-components/trace-builder.css, js/pages/requirementForm.js
--}}
{{#*inline "page"}}
<form method="post" data-requirement-form data-allow-soft-mismatch="true" id="requirement-edit-form"
  class="c-reqform c-requirement-editor">
  <header class="c-reqform-topbar c-reqform-topbar--sticky" data-editor-topbar>
    <div class="c-reqform-topbar__context">
      <nav class="c-reqform-breadcrumb" aria-label="Breadcrumb">
        <a href="/p/{{req.project_id}}/requirements" class="c-reqform-breadcrumb__link">
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="c-reqform-breadcrumb__sep">›</span>
        <a href="/p/{{req.project_id}}/requirements/show/{{req.id}}"
          class="c-reqform-breadcrumb__link">{{display_reference}}</a>
      </nav>

      <h1 class="u-visually-hidden">Editing requirement {{display_reference}}</h1>
    </div>

    <div class="c-reqform-topbar__actions">
      <div class="c-editor-topbar__status">
        <div class="c-editor-status" data-role="status-control">
          <button type="button" class="c-editor-status__chip" data-role="status-toggle" aria-haspopup="true"
            aria-expanded="false">
            <span class="c-editor-status__dot"></span>
            <span class="c-editor-status__label editor-status__label">{{req.status_id}}</span>
          </button>
          <div class="c-editor-status__menu" data-role="status-menu" hidden>
            {{#each statuses}}
            <button type="button" data-status-id="{{id}}">{{title}}</button>
            {{/each}}
          </div>
        </div>

        <div class="c-editor-version" data-role="version-indicator">
          Editing {{version.label}} · last updated by {{version.last_editor}} on {{version.updated_at}}
        </div>
      </div>

      <div class="c-editor-actions">
        <div class="c-reqform-autosave" aria-live="polite">
          <span class="c-reqform-autosave__dot" data-unsaved-indicator hidden></span>
          <span class="c-reqform-autosave__text" data-role="autosave-text">All changes saved</span>
        </div>

        <button type="submit" class="btn btn-primary c-reqform-topbar__save" data-role="submit-requirement">Save</button>

        <a href="/p/{{req.project_id}}/requirements/show/{{req.id}}" class="c-editor-actions__cancel">Cancel</a>
      </div>
    </div>
  </header>

  <div class="c-reqform-layout">
    <section class="c-reqform-card c-reqform-card--primary">
      <div class="c-reqform-card__body">
        <div class="c-editor-section">
          <label for="title" class="c-reqform-field__label">Title</label>
          <input type="text" name="title" id="title" value="{{req.title}}"
            class="c-reqform-field__input c-editor-field__input--headline" autofocus required
            placeholder="The system shall…">
          <p class="c-reqform-hint">Lead with the promise — what value does this deliver?</p>
        </div>


        <div class="c-editor-section">
          <div class="c-editor-field__header">
            <label for="description" class="c-reqform-field__label">
              Requirement statement
            </label>
            <div class="c-editor-inline-actions">
              <button type="button" class="c-editor-inline-actions__button" data-role="preview-toggle">
                👁 Preview
              </button>
            </div>
          </div>

          <div class="c-editor-rich-text" data-role="rich-text">
            <div class="c-editor-toolbar" role="toolbar" aria-label="Formatting options">
              <button type="button" class="c-editor-toolbar__btn" data-format="bold"><strong>B</strong></button>
              <button type="button" class="c-editor-toolbar__btn" data-format="italic"><em>I</em></button>
              <button type="button" class="c-editor-toolbar__btn" data-format="list">• List</button>
              <button type="button" class="c-editor-toolbar__btn" data-format="code">Code</button>
              <button type="button" class="c-editor-toolbar__btn" data-format="link">Link</button>
            </div>

            <textarea name="description" id="description" class="c-reqform-field__textarea" rows="10"
              data-role="requirement-input" required placeholder="The system shall…">{{req.description}}</textarea>

            <div class="c-editor-preview" data-role="preview" hidden>
              <div class="c-editor-preview__content" data-role="preview-content"></div>
            </div>
          </div>

          <p class="c-reqform-hint">
            Avoid ambiguous verbs like “support”; prefer “shall provide”.
          </p>
        </div>

        <div class="c-editor-section">
          <button type="button" class="c-editor-collapsible__trigger" data-role="rationale-toggle"
            aria-expanded="{{#if req.justification}}true{{else}}false{{/if}}">
            Rationale / Notes
            <span class="c-editor-collapsible__hint">Optional</span>
          </button>

          <div class="c-editor-collapsible__panel" data-role="rationale-panel" {{#unless
            req.justification}}hidden{{/unless}}>
            <textarea name="justification" id="justification" class="c-reqform-field__textarea" rows="6"
              placeholder="Why is this required?">{{req.justification}}</textarea>
          </div>
        </div>

        <div class="c-editor-section">
          <h2 class="c-editor-section__title">Attachments</h2>
          <div class="c-editor-dropzone" data-role="attachments-zone">
            <input type="file" data-role="attachments-input" id="attachments-input" multiple hidden>
            <p class="c-editor-dropzone__hint">
              Drop documents or diagrams here, or
              <button type="button" class="c-editor-dropzone__action" data-role="browse-attachments">
                browse
              </button>
            </p>
            <ul class="c-editor-dropzone__list" data-role="attachment-list"></ul>
          </div>
        </div>
      </div>
    </section>

    <aside class="c-reqform-card c-reqform-card--meta">
      <div class="c-reqform-card__body">
        <section class="c-reqform-meta-group">
          <h2 class="c-reqform-meta__title">Classification</h2>

          <div class="c-reqform-field">
            <label for="reference_code" class="c-reqform-field__label">Reference</label>
            <input type="text" name="reference_code" id="reference_code" value="{{req.reference_code}}"
              class="c-reqform-field__input c-reqform-field__input--readonly" placeholder="REQ-SYS-42" readonly disabled>
            <small class="c-reqform-field__help">
              System-generated identifier.
            </small>
          </div>

          <div class="c-reqform-field">
            <label for="category_id" class="c-reqform-field__label">Category</label>
            <div class="c-custom-dropdown" data-dropdown="category">
              <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
                <span class="c-custom-dropdown__value" data-role="dropdown-value">Select category...</span>
                <span class="c-custom-dropdown__arrow">▼</span>
              </button>
              <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
                <div class="c-custom-dropdown__list" data-role="dropdown-list">
                  {{#each categories}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}" data-tag="{{tag}}">
                    {{title}}
                  </button>
                  {{else}}
                  <div class="c-custom-dropdown__empty">
                    No categories available yet
                  </div>
                  {{/each}}
                </div>
              </div>
              <select name="category_id" id="category_id" class="c-custom-dropdown__hidden" required hidden>
                {{#each categories}}
                <option value="{{id}}" data-tag="{{tag}}" {{#if (eq id ../req.req_category_id)}}selected{{/if}}>{{title}}</option>
                {{/each}}
              </select>
            </div>
          </div>

          <div class="c-reqform-field">
            <label for="applicability_id" class="c-reqform-field__label">Applicability</label>
            <div class="c-custom-dropdown" data-dropdown="applicability">
              <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
                <span class="c-custom-dropdown__value" data-role="dropdown-value">Select applicability...</span>
                <span class="c-custom-dropdown__arrow">▼</span>
              </button>
              <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
                <div class="c-custom-dropdown__list" data-role="dropdown-list">
                  {{#each applicability}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                    {{title}}
                  </button>
                  {{else}}
                  <div class="c-custom-dropdown__empty">
                    No applicability options available yet
                  </div>
                  {{/each}}
                </div>
              </div>
              <select name="applicability_id" id="applicability_id" class="c-custom-dropdown__hidden" required hidden>
                {{#each applicability}}
                <option value="{{id}}" {{#if (eq id ../req.req_applicability_id)}}selected{{/if}}>{{title}}</option>
                {{/each}}
              </select>
            </div>
          </div>

          {{> partials/verification_pills}}

          {{#if custom_field_definitions_with_values}}
          <div class="c-reqform-meta-group" id="custom-fields-edit-section">
            <h2 class="c-reqform-meta__title">Custom fields</h2>
            {{#each custom_field_definitions_with_values}}
            <div class="c-reqform-field" data-custom-field-id="{{id}}">
              <label for="custom_field_{{id}}" class="c-reqform-field__label">{{label}}</label>
              {{#if (eq field_type "text")}}
              <input type="text" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
              {{else if (eq field_type "number")}}
              <input type="number" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
              {{else if (eq field_type "boolean")}}
              <select id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}">
                <option value="">—</option>
                <option value="true" {{#if (eq current_value "true")}}selected{{/if}}>Yes</option>
                <option value="false" {{#if (eq current_value "false")}}selected{{/if}}>No</option>
              </select>
              {{else if (eq field_type "enum")}}
              <select id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}">
                <option value="">—</option>
                {{#if enum_values}}
                {{#each enum_values}}
                <option value="{{this}}" {{#if (eq this ../current_value)}}selected{{/if}}>{{this}}</option>
                {{/each}}
                {{/if}}
              </select>
              {{else}}
              <input type="text" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" value="{{current_value}}" placeholder="">
              {{/if}}
            </div>
            {{/each}}
          </div>
          {{/if}}
        </section>

        <section class="c-reqform-meta-group">
          <h2 class="c-reqform-meta__title">People</h2>

          <div class="c-reqform-field">
            <label for="author_id" class="c-reqform-field__label">Author</label>
            <input type="text" id="req_author_display" class="c-reqform-field__input c-reqform-field__input--readonly" value="{{req.author_id}}" readonly
              disabled>
            <input type="hidden" name="author_id" value="{{req.req_author_id}}">
            <small class="c-reqform-field__help">
              Original author cannot be changed.
            </small>
          </div>

          <div class="c-reqform-field">
            <label for="reviewer_id" class="c-reqform-field__label">Reviewer</label>
            <div class="c-custom-dropdown" data-dropdown="reviewer">
              <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
                <span class="c-custom-dropdown__value" data-role="dropdown-value">Select reviewer...</span>
                <span class="c-custom-dropdown__arrow">▼</span>
              </button>
              <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
                <div class="c-custom-dropdown__list" data-role="dropdown-list">
                  {{#each users}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                    {{name}}
                  </button>
                  {{else}}
                  <div class="c-custom-dropdown__empty">
                    No reviewers available yet
                  </div>
                  {{/each}}
                </div>
              </div>
              <select name="reviewer_id" id="reviewer_id" class="c-custom-dropdown__hidden" required hidden>
                {{#each users}}
                <option value="{{id}}" {{#if (eq id ../req.req_reviewer_id)}}selected{{/if}}>
                  {{name}}
                </option>
                {{/each}}
              </select>
            </div>
          </div>
        </section>
      </div>
    </aside>
  </div>

  <div class="c-reqform-section--full">
    {{> partials/upstream_trace}}
  </div>

  <input type="hidden" name="author_id" value="{{req.req_author_id}}">
  <input type="hidden" id="id" name="id" value="{{req.id}}">
  <input type="hidden" name="reference_code" value="{{req.reference_code}}">
  <select id="status_id" name="status_id" class="u-visually-hidden" aria-hidden="true" required>
    {{#each statuses}}
    <option value="{{id}}" {{#if (eq id ../req.req_current_status_id)}}selected{{/if}}>{{title}}</option>
    {{/each}}
  </select>
  <input type="hidden" id="project_id" name="project_id" value="{{req.project_id}}">
  <input type="hidden" id="custom_field_values" name="custom_field_values" value="[]">
  <input type="hidden" id="autosave-interval" value="{{autosave.interval_ms}}" data-role="autosave-interval">
</form>
{{/inline}}
{{> layout page_id="requirement-form"}}
