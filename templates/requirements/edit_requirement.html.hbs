{{!-- Depends on: css/pages/requirement-editor.css, js/pages/requirementForm.js --}}
{{#*inline "page"}}
<form
  method="post"
  data-requirement-form
  data-allow-soft-mismatch="true"
  id="requirement-edit-form"
  class="c-requirement-editor"
>
  <header class="c-editor-topbar sticky-top" data-editor-topbar>
    <div class="c-editor-topbar__context">
      <nav class="c-editor-breadcrumb" aria-label="Breadcrumb">
        <a href="/p/{{req.project_id}}/requirements" class="c-editor-breadcrumb__link">
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="c-editor-breadcrumb__sep">›</span>
        <a
          href="/p/{{req.project_id}}/requirements/show/{{req.req_id}}"
          class="c-editor-breadcrumb__link"
        >{{display_reference}}</a>
      </nav>

      <h1 class="u-visually-hidden">Editing requirement {{display_reference}}</h1>
    </div>

    <div class="c-editor-topbar__actions">
      <div class="c-editor-topbar__status">
        <div class="c-editor-status" data-role="status-control">
          <button
            type="button"
            class="c-editor-status__chip"
            data-role="status-toggle"
            aria-haspopup="true"
            aria-expanded="false"
          >
            <span class="c-editor-status__dot"></span>
            <span class="c-editor-status__label">{{req.req_current_status}}</span>
          </button>
        </div>

        <div class="c-editor-version" data-role="version-indicator">
          Editing {{version.label}} · last updated by {{version.last_editor}} on {{version.updated_at}}
        </div>
      </div>

        <div class="c-editor-actions">
          <div class="c-editor-autosave" aria-live="polite">
            <span class="c-editor-autosave__dot" data-unsaved-indicator hidden></span>
            <span class="c-editor-autosave__text" data-role="autosave-text">All changes saved</span>
          </div>

        <button
          type="submit"
          class="btn btn-primary editor-actions__save"
          data-role="submit-requirement"
        >Save</button>

        <a
          href="/p/{{req.project_id}}/requirements/show/{{req.req_id}}"
          class="c-editor-actions__cancel"
        >Cancel</a>
      </div>
    </div>
  </header>

  <div class="c-editor-layout">
    <main class="c-editor-main">
      <section class="c-editor-section editor-section--title">
        <label for="req_title" class="c-editor-field__label">Title</label>
        <input
          type="text"
          name="req_title"
          id="req_title"
          value="{{req.req_title}}"
          class="c-editor-field__input editor-field__input--headline"
          autofocus
          required
          placeholder="The system shall…"
        >
        <p class="c-editor-hint">Lead with the promise — what value does this deliver?</p>
      </section>

      <section class="c-editor-section editor-section--statement">
        <div class="c-editor-field__header">
          <label for="req_description" class="c-editor-field__label">
            Requirement statement
          </label>
          <div class="c-editor-inline-actions">
            <button type="button" class="c-editor-inline-actions__button" data-role="preview-toggle">
              👁 Preview
            </button>
          </div>
        </div>

        <div class="c-editor-rich-text" data-role="rich-text">
          <div class="c-editor-toolbar" role="toolbar" aria-label="Formatting options">
            <button type="button" class="c-editor-toolbar__btn" data-format="bold"><strong>B</strong></button>
            <button type="button" class="c-editor-toolbar__btn" data-format="italic"><em>I</em></button>
            <button type="button" class="c-editor-toolbar__btn" data-format="list">• List</button>
            <button type="button" class="c-editor-toolbar__btn" data-format="code">Code</button>
            <button type="button" class="c-editor-toolbar__btn" data-format="link">Link</button>
          </div>

          <textarea
            name="req_description"
            id="req_description"
            class="c-editor-field__textarea"
            rows="10"
            data-role="requirement-input"
            required
            placeholder="The system shall…"
          >{{req.req_description}}</textarea>

          <div class="c-editor-preview" data-role="preview" hidden>
            <div class="c-editor-preview__content" data-role="preview-content"></div>
          </div>
        </div>

        <p class="c-editor-hint">
          Avoid ambiguous verbs like “support”; prefer “shall provide”.
        </p>
      </section>

      <section class="c-editor-section editor-section--rationale">
        <button
          type="button"
          class="c-editor-collapsible__trigger"
          data-role="rationale-toggle"
          aria-expanded="{{#if req.req_justification}}true{{else}}false{{/if}}"
        >
          Rationale / Notes
          <span class="c-editor-collapsible__hint">Optional</span>
        </button>

        <div
          class="c-editor-collapsible__panel"
          data-role="rationale-panel"
          {{#unless req.req_justification}}hidden{{/unless}}
        >
          <textarea
            name="req_justification"
            id="req_justification"
            class="c-editor-field__textarea"
            rows="6"
            placeholder="Why is this required?"
          >{{req.req_justification}}</textarea>
        </div>
      </section>

      <section class="c-editor-section editor-section--attachments">
        <h2 class="c-editor-section__title">Attachments</h2>
        <div class="c-editor-dropzone" data-role="attachments-zone">
          <input type="file" data-role="attachments-input" id="attachments-input" multiple hidden>
          <p class="c-editor-dropzone__hint">
            Drop documents or diagrams here, or
            <button type="button" class="c-editor-dropzone__action" data-role="browse-attachments">
              browse
            </button>
          </p>
          <ul class="c-editor-dropzone__list" data-role="attachment-list"></ul>
        </div>
      </section>
    </main>

    <aside class="c-editor-sidebar">
      <section class="c-editor-meta-group">
        <h2 class="c-editor-meta__title">Classification</h2>

        <div class="c-editor-field">
          <label for="req_reference" class="c-editor-field__label">Reference</label>
          <input
            type="text"
            name="req_reference"
            id="req_reference"
            value="{{req.req_reference}}"
            class="c-editor-field__input"
            placeholder="REQ-SYS-42"
            readonly
            disabled
          >
          <small class="c-editor-field__help">
            System-generated identifier.
          </small>
        </div>

        <div class="c-editor-field">
          <label for="req_category" class="c-editor-field__label">Category</label>
          <select
            name="req_category"
            id="req_category"
            class="c-editor-field__input"
            required
          >
            {{#each categories}}
              <option value="{{cat_id}}" data-tag="{{cat_tag}}" {{#if (eq cat_id ../req.req_category_id)}}selected{{/if}}>
                {{cat_title}}
              </option>
            {{/each}}
          </select>
        </div>

        <div class="c-editor-field">
          <label for="req_applicability" class="c-editor-field__label">Applicability</label>
          <select
            name="req_applicability"
            id="req_applicability"
            class="c-editor-field__input"
            required
          >
            {{#each applicability}}
              <option value="{{app_id}}" {{#if (eq app_id ../req.req_applicability_id)}}selected{{/if}}>
                {{app_title}}
              </option>
            {{/each}}
          </select>
        </div>

        <div class="c-editor-field">
          <label for="req_verification_method" class="c-editor-field__label">Verification method</label>
          <select
            name="req_verification_method"
            id="req_verification_method"
            class="c-editor-field__input"
            required
          >
            {{#each verification}}
              <option value="{{verification_id}}" {{#if (eq verification_id ../req.req_verification_id)}}selected{{/if}}>
                {{verification_name}}
              </option>
            {{/each}}
          </select>
        </div>
      </section>

      <section class="c-editor-meta-group">
        <h2 class="c-editor-meta__title">People</h2>

        <div class="c-editor-field">
          <label for="req_author" class="c-editor-field__label">Author</label>
          <input
            type="text"
            id="req_author_display"
            class="c-editor-field__input"
            value="{{req.req_author}}"
            readonly
            disabled
          >
          <input type="hidden" name="req_author" value="{{req.req_author_id}}">
          <small class="c-editor-field__help">
            Original author cannot be changed.
          </small>
        </div>

        <div class="c-editor-field">
          <label for="req_reviewer" class="c-editor-field__label">Reviewer</label>
          <select
            name="req_reviewer"
            id="req_reviewer"
            class="c-editor-field__input"
            required
          >
            {{#each users}}
              <option value="{{user_id}}" {{#if (eq user_id ../req.req_reviewer_id)}}selected{{/if}}>
                {{user_name}}
              </option>
            {{/each}}
          </select>
        </div>
      </section>

      <section class="c-editor-meta-group">
        <h2 class="c-editor-meta__title">Upstream Trace</h2>
        <div class="c-editor-field">
          <label for="req_parent" class="c-editor-field__label">Parent requirement</label>
          <select
            name="req_parent"
            id="req_parent"
            class="c-editor-field__input"
          >
            <option value="0" {{#if (eq 0 ../req.req_parent_id)}}selected{{/if}}>None</option>
            {{#each linked_requirement_options}}
              <option
                value="{{id}}"
                data-reference="{{reference}}"
                data-title="{{title}}"
                {{#if (eq id ../req.req_parent_id)}}selected{{/if}}
              >
                {{#if reference}}{{reference}}{{else}}RM-{{id}}{{/if}} — {{title}}
              </option>
            {{/each}}
          </select>
        </div>
      </section>
    </aside>
  </div>

  <input type="hidden" name="req_author" value="{{req.req_author_id}}">
  <input type="hidden" id="req_id" name="req_id" value="{{req.req_id}}">
  <input type="hidden" name="req_reference" value="{{req.req_reference}}">
  <input type="hidden" name="req_current_status" value="{{req.req_current_status_id}}">
  <input type="hidden" id="project_id" name="project_id" value="{{req.project_id}}">
  <input type="hidden" id="autosave-interval" value="{{autosave.interval_ms}}" data-role="autosave-interval">
</form>
{{/inline}}
{{> layout page_id="requirement-form"}}
