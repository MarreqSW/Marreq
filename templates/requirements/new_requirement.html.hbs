{{!--
  Depends on: css/pages/requirement-create.css, js/pages/requirementForm.js
--}}
{{#*inline "page"}}
<form
  method="post"
  data-requirement-form
  data-allow-soft-mismatch="false"
  class="c-create-form"
  data-project-id="{{project_id}}"
  {{#if flash_success}}data-flash-success="{{flash_success}}"{{/if}}
>
  <header class="c-create-topbar">
    <div class="c-create-topbar__context">
      <nav class="c-create-breadcrumb" aria-label="Breadcrumb">
        <a
          href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
          class="c-create-breadcrumb__link"
        >
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="c-create-breadcrumb__sep">›</span>
        <span class="c-create-breadcrumb__crumb">Requirements</span>
        <span class="c-create-breadcrumb__sep">›</span>
        <span class="c-create-breadcrumb__crumb c-create-breadcrumb__crumb--current">Add New</span>
      </nav>
      <h1 class="c-create-title">New Requirement</h1>
    </div>
    <div class="c-create-topbar__actions">
      <div class="c-create-autosave" aria-live="polite">
        <span class="c-create-autosave__dot" data-role="autosave-indicator" hidden></span>
        <span class="c-create-autosave__text" data-role="autosave-text"></span>
      </div>
      <button
        type="submit"
        class="btn btn-primary c-create-topbar__save"
        data-role="submit-requirement"
      >Save</button>
      <a
        href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
        class="btn btn-outline-secondary c-create-topbar__cancel"
        data-role="cancel-create"
      >Cancel</a>
    </div>
  </header>

  <div class="c-create-layout">
    <section class="c-create-card c-create-card--primary">
      <header class="c-create-card__header">
        <div>
          <h2 class="c-create-card__title">Requirement Details</h2>
        </div>
      </header>

      <div class="c-create-card__body">
        <div class="c-create-field">
          <label for="title" class="c-create-field__label">
            Title <span class="c-create-field__required">*</span>
          </label>
          <input
            type="text"
            name="title"
            id="title"
            class="c-create-field__input"
            value="{{template.title}}"
            placeholder="Control system shall…"
            required
          >
        </div>

        <div class="c-create-field">
          <label for="reference_code" class="c-create-field__label">
            Reference <span class="c-create-field__optional">(optional)</span>
          </label>
          <input
            type="text"
            name="reference_code"
            id="reference_code"
            class="c-create-field__input"
            value="{{template.reference_code}}"
            placeholder="REQ-CAT-001 (auto-generated if left blank)"
          >
          <div id="reference-error" class="c-create-field__error" hidden></div>
        </div>

        <div class="c-create-field">
          <label for="description" class="c-create-field__label">
            Statement <span class="c-create-field__required">*</span>
          </label>
          <textarea
            name="description"
            id="description"
            class="c-create-field__textarea c-create-field__textarea--statement"
            rows="6"
            required
            placeholder="The system shall…"
          >{{template.description}}</textarea>
        </div>

        <div class="c-create-field">
          <label for="justification" class="c-create-field__label">
            Rationale <span class="c-create-field__optional">(optional)</span>
          </label>
          <textarea
            name="justification"
            id="justification"
            class="c-create-field__textarea"
            rows="4"
            placeholder="What evidence or reasoning supports this?"
          >{{template.justification}}</textarea>
        </div>
      </div>
    </section>

    <aside class="c-create-card c-create-card--meta">
      <header class="c-create-card__header">
        <div>
          <h2 class="c-create-card__title">Ownership &amp; Traceability</h2>
        </div>
      </header>

      <div class="c-create-card__body">
        <div class="c-create-field">
          <label for="req_author_display" class="c-create-field__label">Author</label>
          <input
            type="text"
            id="req_author_display"
            class="c-create-field__input c-create-field__input--readonly"
            value="{{user.name}}"
            readonly
          >
        </div>

        <div class="c-create-field">
          <label for="reviewer_id" class="c-create-field__label">
            Reviewer <span class="c-create-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="reviewer">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select reviewer...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each users}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                    {{name}}
                  </button>
                {{/each}}
              </div>
            </div>
            <select name="reviewer_id" id="reviewer_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each users}}
                <option value="{{id}}" {{#if (eq id ../reviewer_id)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="c-create-field">
          <label for="category_id" class="c-create-field__label">
            Category <span class="c-create-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="category">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select category...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each categories}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}" data-tag="{{tag}}">
                    {{title}}
                  </button>
                {{/each}}
              </div>
              <div class="c-custom-dropdown__footer">
                <button type="button" class="c-custom-dropdown__action" data-action="create-category">
                  + Create category
                </button>
              </div>
            </div>
            <select name="category_id" id="category_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each categories}}
                <option value="{{id}}" data-tag="{{tag}}" {{#if (eq id ../category_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="c-create-field">
          <label for="applicability_id" class="c-create-field__label">
            Applicability <span class="c-create-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="applicability">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select applicability...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each applicability}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                    {{title}}
                  </button>
                {{/each}}
              </div>
              <div class="c-custom-dropdown__footer">
                <button type="button" class="c-custom-dropdown__action" data-action="create-applicability">
                  + Create applicability
                </button>
              </div>
            </div>
            <select name="applicability_id" id="applicability_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each applicability}}
                <option value="{{id}}" {{#if (eq id ../applicability_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="c-create-field">
          <label for="verification_method_id" class="c-create-field__label">
            Verification Method <span class="c-create-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="verification">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select verification method...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each verification}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                    {{title}}
                  </button>
                {{/each}}
              </div>
              <div class="c-custom-dropdown__footer">
                <button type="button" class="c-custom-dropdown__action" data-action="create-verification">
                  + Create verification method
                </button>
              </div>
            </div>
            <select name="verification_method_id" id="verification_method_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each verification}}
                <option value="{{id}}" {{#if (eq id ../verification_method_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        {{#if is_admin_or_owner}}
        <div class="c-create-field">
          <label for="current_status_id" class="c-create-field__label">
            Status <span class="c-create-field__required">*</span>
          </label>
          <select
            name="current_status_id"
            id="current_status_id"
            class="c-create-field__select"
            required
          >
            {{#each status}}
              {{#if (or (eq title "Draft") (or (eq title "Accepted") (or (eq title "Rejected") (eq title "Deprecated"))))}}
                <option value="{{id}}" {{#if (eq id ../current_status_id)}}selected{{/if}}>
                  {{title}}
                </option>
              {{/if}}
            {{/each}}
          </select>
        </div>
        {{/if}}

        <div class="c-create-field">
          <label for="parent_id" class="c-create-field__label">
            Parent Requirement <span class="c-create-field__optional">(optional)</span>
          </label>
          <div class="c-custom-dropdown c-custom-dropdown--searchable" data-dropdown="parent">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select parent requirement...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__search">
                <input 
                  type="text" 
                  class="c-custom-dropdown__search-input" 
                  placeholder="Search requirements..." 
                  data-role="dropdown-search"
                  autocomplete="off"
                >
              </div>
              <div class="c-custom-dropdown__list c-custom-dropdown__list--scrollable" data-role="dropdown-list">
                <button type="button" class="c-custom-dropdown__item" data-value="0" data-search-text="none">
                  <span class="c-custom-dropdown__item-label">None</span>
                </button>
                {{#each parent}}
                  <button type="button" class="c-custom-dropdown__item" data-value="{{id}}" data-search-text="{{reference}} {{title}}">
                    <span class="c-custom-dropdown__item-ref">{{reference}}</span>
                    <span class="c-custom-dropdown__item-label">{{title}}</span>
                  </button>
                {{/each}}
              </div>
            </div>
            <select name="parent_id" id="parent_id" class="c-custom-dropdown__hidden" hidden>
              <option value="0" {{#if (not template.parent_id)}}selected{{/if}}>None</option>
              {{#each parent}}
                <option value="{{id}}" {{#if (eq id ../template.parent_id)}}selected{{/if}}>{{reference}} - {{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <input type="hidden" id="id" name="id" value="None">
  <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
</form>

{{> partials/modals}}

<div
  class="modal fade"
  id="categoryModal"
  tabindex="-1"
  aria-labelledby="categoryModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="categoryModalLabel">New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineCategoryForm" data-entity="category">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_cat_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_cat_title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_cat_tag" name="tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_cat_description" name="description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Category</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="applicabilityModal"
  tabindex="-1"
  aria-labelledby="applicabilityModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="applicabilityModalLabel">New Applicability</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineApplicabilityForm" data-entity="applicability">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_app_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_app_title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_app_tag" name="tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_app_description" name="description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Applicability</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div
  class="modal fade"
  id="verificationModal"
  tabindex="-1"
  aria-labelledby="verificationModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="verificationModalLabel">New Verification Method</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineVerificationForm" data-entity="verification">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_verification_title" class="form-label">Title</label>
            <input
              type="text"
              class="form-control"
              id="inline_verification_title"
              name="title"
              required
            >
          </div>
          <div class="mb-3">
            <label for="inline_verification_tag" class="form-label">Tag</label>
            <input
              type="text"
              class="form-control"
              id="inline_verification_tag"
              name="tag"
              required
            >
          </div>
          <div class="mb-3">
            <label for="inline_verification_description" class="form-label">Description</label>
            <textarea
              class="form-control"
              id="inline_verification_description"
              name="description"
              rows="3"
              required
            ></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Verification</button>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="requirement-form"}}
