{{!--
Depends on: css/pages/requirement-form.css, css/pages/requirement-create.css,
            css/50-components/dropdown.css, css/50-components/trace-builder.css,
            js/pages/requirementForm.js
--}}
{{#*inline "page"}}
<form method="post" action="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements/new" data-requirement-form data-allow-soft-mismatch="false" class="c-reqform create-form"
  data-project-id="{{project_id}}" {{#if flash_success}}data-flash-success="{{flash_success}}" {{/if}}>
  <header class="c-reqform-topbar">
    <div class="c-reqform-topbar__context">
      <nav class="c-reqform-breadcrumb" aria-label="Breadcrumb">
        <a href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
          class="c-reqform-breadcrumb__link">
          {{#if project}}{{project.name}}{{else}}Project{{/if}}
        </a>
        <span class="c-reqform-breadcrumb__sep">›</span>
        <span class="c-reqform-breadcrumb__crumb">Requirements</span>
        <span class="c-reqform-breadcrumb__sep">›</span>
        <span class="c-reqform-breadcrumb__crumb c-reqform-breadcrumb__crumb--current">Add New</span>
      </nav>
      <h1 class="c-reqform-title">New Requirement</h1>
    </div>
    <div class="c-reqform-topbar__actions">
      <div class="c-reqform-autosave" aria-live="polite">
        <span class="c-reqform-autosave__dot" data-role="autosave-indicator" hidden></span>
        <span class="c-reqform-autosave__text" data-role="autosave-text"></span>
      </div>
      <button type="submit" class="btn btn-primary c-reqform-topbar__save" data-role="submit-requirement">Save</button>
      <a href="/p/{{#if project}}{{project.id}}{{else}}{{project_id}}{{/if}}/requirements"
        class="btn btn-outline-secondary c-reqform-topbar__cancel" data-role="cancel-create">Cancel</a>
    </div>
  </header>

  <div class="c-reqform-layout">
    <section class="c-reqform-card c-reqform-card--primary">
      <header class="c-reqform-card__header">
        <div>
          <h2 class="c-reqform-card__title">Requirement Details</h2>
        </div>
      </header>

      <div class="c-reqform-card__body">
        <div class="c-reqform-field">
          <label for="title" class="c-reqform-field__label">
            Title <span class="c-reqform-field__required">*</span>
          </label>
          <input type="text" name="title" id="title" class="c-reqform-field__input" value="{{template.title}}"
            placeholder="Control system shall…" required>
        </div>

        <div class="c-reqform-field">
          <label for="reference_code" class="c-reqform-field__label">
            Reference <span class="c-reqform-field__optional">(optional)</span>
          </label>
          <input type="text" name="reference_code" id="reference_code" class="c-reqform-field__input"
            value="{{template.reference_code}}" placeholder="REQ-CAT-001 (auto-generated if left blank)">
          <div id="reference-error" class="c-reqform-field__error" hidden></div>
        </div>

        <div class="c-reqform-field">
          <label for="description" class="c-reqform-field__label">
            Statement <span class="c-reqform-field__required">*</span>
          </label>
          <textarea name="description" id="description"
            class="c-reqform-field__textarea c-reqform-field__textarea--statement" rows="6" required
            placeholder="The system shall…">{{template.description}}</textarea>
        </div>

        <div class="c-reqform-field">
          <label for="justification" class="c-reqform-field__label">
            Rationale <span class="c-reqform-field__optional">(optional)</span>
          </label>
          <textarea name="justification" id="justification" class="c-reqform-field__textarea" rows="4"
            placeholder="What evidence or reasoning supports this?">{{template.justification}}</textarea>
        </div>

        {{#if custom_field_definitions}}
        <div class="c-reqform-field" id="custom-fields-section">
          <h3 class="c-reqform-field__label">Custom fields</h3>
          {{#each custom_field_definitions}}
          <div class="c-reqform-field" data-custom-field-id="{{id}}">
            <label for="custom_field_{{id}}" class="c-reqform-field__label">{{label}}</label>
            {{#if (eq field_type "text")}}
            <input type="text" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" placeholder="">
            {{else if (eq field_type "number")}}
            <input type="number" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" placeholder="">
            {{else if (eq field_type "boolean")}}
            <select id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}">
              <option value="">—</option>
              <option value="true">Yes</option>
              <option value="false">No</option>
            </select>
            {{else if (eq field_type "enum")}}
            <select id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}">
              <option value="">—</option>
              {{#if enum_values}}
              {{#each enum_values}}
              <option value="{{this}}">{{this}}</option>
              {{/each}}
              {{/if}}
            </select>
            {{else}}
            <input type="text" id="custom_field_{{id}}" class="c-reqform-field__input c-reqform-field__custom-value" data-field-id="{{id}}" placeholder="">
            {{/if}}
          </div>
          {{/each}}
        </div>
        {{/if}}
      </div>
    </section>

    <aside class="c-reqform-card c-reqform-card--meta">
      <header class="c-reqform-card__header">
        <div>
          <h2 class="c-reqform-card__title">Ownership &amp; Classification</h2>
        </div>
      </header>

      <div class="c-reqform-card__body">
        <div class="c-reqform-field">
          <label for="req_author_display" class="c-reqform-field__label">Author</label>
          <input type="text" id="req_author_display" class="c-reqform-field__input c-reqform-field__input--readonly"
            value="{{user.name}}" readonly>
        </div>

        <div class="c-reqform-field">
          <label for="reviewer_id" class="c-reqform-field__label">
            Reviewer <span class="c-reqform-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="reviewer">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select reviewer...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each users}}
                <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                  {{name}}
                </button>
                {{else}}
                <div class="c-custom-dropdown__empty">
                  No reviewers available yet
                </div>
                {{/each}}
              </div>
            </div>
            <select name="reviewer_id" id="reviewer_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each users}}
              <option value="{{id}}" {{#if (eq id ../reviewer_id)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="c-reqform-field">
          <label for="category_id" class="c-reqform-field__label">
            Category <span class="c-reqform-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="category">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select category...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each categories}}
                <button type="button" class="c-custom-dropdown__item" data-value="{{id}}" data-tag="{{tag}}">
                  {{title}}
                </button>
                {{else}}
                <div class="c-custom-dropdown__empty">
                  No categories available yet
                </div>
                {{/each}}
              </div>
              <div class="c-custom-dropdown__footer">
                <button type="button" class="c-custom-dropdown__action" data-action="create-category">
                  + Create category
                </button>
              </div>
            </div>
            <select name="category_id" id="category_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each categories}}
              <option value="{{id}}" data-tag="{{tag}}" {{#if (eq id ../category_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="c-reqform-field">
          <label for="applicability_id" class="c-reqform-field__label">
            Applicability <span class="c-reqform-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="applicability">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select applicability...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each applicability}}
                <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                  {{title}}
                </button>
                {{else}}
                <div class="c-custom-dropdown__empty">
                  No applicability options available yet
                </div>
                {{/each}}
              </div>
              <div class="c-custom-dropdown__footer">
                <button type="button" class="c-custom-dropdown__action" data-action="create-applicability">
                  + Create applicability
                </button>
              </div>
            </div>
            <select name="applicability_id" id="applicability_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each applicability}}
              <option value="{{id}}" {{#if (eq id ../applicability_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        {{> partials/verification_pills}}

        {{#if is_admin_or_owner}}
        <div class="c-reqform-field">
          <label for="status_id" class="c-reqform-field__label">
            Status <span class="c-reqform-field__required">*</span>
          </label>
          <div class="c-custom-dropdown" data-dropdown="status">
            <button type="button" class="c-custom-dropdown__trigger" data-role="dropdown-trigger">
              <span class="c-custom-dropdown__value" data-role="dropdown-value">Select status...</span>
              <span class="c-custom-dropdown__arrow">▼</span>
            </button>
            <div class="c-custom-dropdown__menu" data-role="dropdown-menu" hidden>
              <div class="c-custom-dropdown__list" data-role="dropdown-list">
                {{#each statuses}}
                <button type="button" class="c-custom-dropdown__item" data-value="{{id}}">
                  {{title}}
                </button>
                {{else}}
                <div class="c-custom-dropdown__empty">
                  No status options available yet
                </div>
                {{/each}}
              </div>
            </div>
            <select name="status_id" id="status_id" class="c-custom-dropdown__hidden" required hidden>
              {{#each statuses}}
              <option value="{{id}}" {{#if (eq id ../status_id)}}selected{{/if}}>
                {{title}}
              </option>
              {{/each}}
            </select>
          </div>
        </div>
        {{/if}}
      </div>
    </aside>
  </div>

  <div class="c-reqform-section--full">
    {{> partials/upstream_trace}}
  </div>

  <input type="hidden" id="id" name="id" value="None">
  <input type="hidden" id="req_author_email" name="req_author_email" value="hello@example.com">
  <input type="hidden" id="custom_field_values" name="custom_field_values" value="[]">
</form>

{{> partials/modals}}

<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="categoryModalLabel">New Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineCategoryForm" data-entity="category">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_cat_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_cat_title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_cat_tag" name="tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_cat_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_cat_description" name="description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Category</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="applicabilityModal" tabindex="-1" aria-labelledby="applicabilityModalLabel"
  aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="applicabilityModalLabel">New Applicability</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineApplicabilityForm" data-entity="applicability">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_app_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_app_title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_app_tag" name="tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_app_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_app_description" name="description" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Applicability</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="verificationModal" tabindex="-1" aria-labelledby="verificationModalLabel"
  aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="verificationModalLabel">New Verification Method</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="inlineVerificationForm" data-entity="verification">
        <div class="modal-body">
          <div class="mb-3">
            <label for="inline_verification_title" class="form-label">Title</label>
            <input type="text" class="form-control" id="inline_verification_title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="inline_verification_tag" class="form-label">Tag</label>
            <input type="text" class="form-control" id="inline_verification_tag" name="tag" required>
          </div>
          <div class="mb-3">
            <label for="inline_verification_description" class="form-label">Description</label>
            <textarea class="form-control" id="inline_verification_description" name="description" rows="3"
              required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create Verification</button>
        </div>
      </form>
    </div>
  </div>
</div>
{{/inline}}
{{> layout page_id="requirement-form"}}