{{#*inline "relationships_panel"}}
<section class="card shadow-sm border-0 requirement-side-card" aria-labelledby="relationships-heading">
  <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
    <div>
      <div class="text-uppercase small text-muted mb-0">Traceability</div>
    </div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementRelationshipsContent" aria-expanded="true"
      aria-controls="requirementRelationshipsContent" aria-label="Toggle relationships section">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementRelationshipsContent">
    <div class="card-body">
      <div data-slot="relationships">
        <p class="mb-0 text-muted">No upstream or downstream relationships recorded.</p>
      </div>
    </div>
  </div>
</section>
{{/inline}}

{{#*inline "verification_panel"}}
<section class="card shadow-sm border-0 requirement-main-card" aria-labelledby="verification-heading">
  <div
    class="card-header requirement-card-header border-0 d-flex flex-wrap gap-3 justify-content-between align-items-center">
    <div>
      <div class="text-uppercase small text-muted" id="verification-heading">Verification</div>
    </div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementVerificationContent" aria-expanded="true"
      aria-controls="requirementVerificationContent" aria-label="Toggle verification section">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementVerificationContent">
    <div class="card-body">
      <div class="mb-3">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
          <span class="badge" data-field="verification-badge" role="status">—</span>
          <span class="small text-muted" data-field="verification-state">No verifications linked yet</span>
        </div>
        <div class="d-flex flex-column gap-2">
          <div class="progress progress-thin flex-grow-1" role="progressbar" aria-label="Verification progress">
            <div class="progress-bar" data-field="verification-progress" style="width: 0%;" aria-valuenow="0"
              aria-valuemin="0" aria-valuemax="100"></div>
          </div>
          <div class="d-flex justify-content-between align-items-baseline">
            <div class="d-flex flex-wrap gap-3 small text-muted">
              <span data-field="verification-passed" aria-label="Passed tests">Passed 0</span>
              <span data-field="verification-failed" aria-label="Failed tests">Failed 0</span>
              <span data-field="verification-pending" aria-label="Pending tests">Pending 0</span>
            </div>
            <div class="text-end">
              <div class="fs-3 fw-semibold lh-1" data-field="verification-percent" aria-label="Pass rate">0%</div>
              <div class="small text-muted">Overall pass rate</div>
            </div>
          </div>
        </div>
      </div>
      <div class="list-group list-group-flush requirement-linked-tests" data-slot="linked-tests"></div>
      <p class="mb-0 text-muted" data-field="linked-tests-empty">
        No tests linked. Add a verification to start tracking compliance.
      </p>
    </div>
  </div>
</section>
{{/inline}}

{{#*inline "custom_fields_panel"}}
{{#if requirement_data.has_custom_fields}}
<section class="card shadow-sm border-0 requirement-side-card" aria-labelledby="custom-fields-heading">
  <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
    <div class="text-uppercase small text-muted mb-0" id="custom-fields-heading">Custom metadata</div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementCustomFieldsContent" aria-expanded="true" aria-controls="requirementCustomFieldsContent"
      aria-label="Toggle custom metadata">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementCustomFieldsContent">
    <div class="card-body">
      <dl class="row requirement-meta-list mb-0">
        {{#each requirement_data.requirement.custom_fields}}
        <dt class="col-6 text-uppercase small text-muted">{{this.label}}</dt>
        <dd class="col-6 fw-semibold text-end text-lg-start">{{this.value}}</dd>
        {{/each}}
      </dl>
    </div>
  </div>
</section>
{{/if}}
{{/inline}}

{{#*inline "metadata_panel"}}
<section class="card shadow-sm border-0 requirement-side-card" aria-labelledby="metadata-heading">
  <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
    <div class="text-uppercase small text-muted mb-0" id="metadata-heading">Key People & Dates</div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementMetadataContent" aria-expanded="true" aria-controls="requirementMetadataContent"
      aria-label="Toggle metadata section">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementMetadataContent">
    <div class="card-body">
      <div class="d-flex flex-column gap-3 mb-3">
        <div class="d-flex align-items-center gap-3">
          <span class="reqman-requirement-avatar bg-primary text-white" data-field="author-initial">?</span>
          <div>
            <div class="text-uppercase small text-muted">Author</div>
            <div class="fw-semibold" data-field="author-name">—</div>
            <div class="small text-muted" data-field="author-timestamp"></div>
          </div>
        </div>
        <div class="d-flex align-items-center gap-3">
          <span class="reqman-requirement-avatar bg-secondary-subtle text-muted border"
            data-field="reviewer-initial">–</span>
          <div>
            <div class="text-uppercase small text-muted">Reviewer</div>
            <div class="fw-semibold" data-field="reviewer-name">Unassigned</div>
            <div class="small text-muted" data-field="reviewer-timestamp"></div>
          </div>
        </div>
      </div>
      <dl class="row requirement-meta-list mb-0">
        <dt class="col-6 text-uppercase small text-muted">Last Updated</dt>
        <dd class="col-6 fw-semibold text-end text-lg-start" data-field="metadata-updated">—</dd>
        <dt class="col-6 text-uppercase small text-muted">Deadline</dt>
        <dd class="col-6 fw-semibold text-end text-lg-start" data-field="metadata-deadline">—</dd>
        <dt class="col-6 text-uppercase small text-muted">Version</dt>
        <dd class="col-6 fw-semibold text-end text-lg-start" data-field="metadata-version">—</dd>
      </dl>
    </div>
  </div>
</section>
{{/inline}}

{{#*inline "requirement_sections"}}
<div class="d-flex flex-column gap-3" data-slot="body-sections">
  <details class="card shadow-sm requirement-section" open>
    <summary class="card-header requirement-card-header d-flex justify-content-between align-items-center">
      <span class="h5 mb-0">Rationale</span>
    </summary>
    <div class="card-body">
      {{#if requirement_data.requirement.justification}}
      <p class="mb-0">{{requirement_data.requirement.justification}}</p>
      {{else}}
      <p class="mb-0 text-muted">No rationale documented yet.</p>
      {{/if}}
    </div>
  </details>

  <details class="card shadow-sm requirement-section" open>
    <summary class="card-header requirement-card-header d-flex justify-content-between align-items-center">
      <span class="h5 mb-0">Notes</span>
    </summary>
    <div class="card-body">
      <p class="mb-0 text-muted">No implementation notes recorded.</p>
    </div>
  </details>
</div>
{{/inline}}

{{#*inline "versions_panel"}}
<section class="card shadow-sm border-0 requirement-side-card" aria-labelledby="versions-heading">
  <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
    <div class="text-uppercase small text-muted mb-0" id="versions-heading">Version history</div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementVersionsContent" aria-expanded="true" aria-controls="requirementVersionsContent"
      aria-label="Toggle version history">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementVersionsContent">
    <div class="card-body">
      <ul class="list-unstyled mb-0" data-slot="version-history">
        {{#if requirement_data.versions}}
        {{#each requirement_data.versions}}
        <li class="d-flex align-items-center justify-content-between gap-2 py-2 border-bottom border-light border-opacity-50">
          <div class="d-flex align-items-center gap-2 flex-grow-1 min-w-0">
            {{#if this.is_current}}
            <a href="/p/{{../project_id}}/requirements/show/{{../requirement_data.requirement.id}}"
              class="text-decoration-none fw-semibold text-truncate">{{this.title}}</a>
            {{else}}
            <a href="/p/{{../project_id}}/requirements/show/{{../requirement_data.requirement.id}}/version/{{this.id}}"
              class="text-decoration-none text-truncate">{{this.title}}</a>
            {{/if}}
            <span class="badge reqman-approval-badge reqman-approval-badge--{{this.approval_state}} flex-shrink-0" aria-label="Approval: {{this.approval_state}}">{{this.approval_state}}</span>
          </div>
          {{#if this.is_current}}
          <span class="badge bg-primary flex-shrink-0">Current</span>
          {{else}}
          <div class="d-flex align-items-center gap-2 flex-shrink-0">
            <a href="/p/{{../project_id}}/requirements/show/{{../requirement_data.requirement.id}}/version/{{this.id}}"
              class="small text-muted">View</a>
            <button type="button" class="btn btn-link btn-sm p-0 small text-muted text-decoration-none"
              data-action="show-version-diff"
              data-req-id="{{../requirement_data.requirement.id}}"
              data-v1="{{this.id}}"
              data-v2="{{../requirement_data.current_version_id}}"
              aria-label="Compare this version with current">Compare with current</button>
          </div>
          {{/if}}
        </li>
        {{/each}}
        {{else}}
        <li class="text-muted small">No version history.</li>
        {{/if}}
      </ul>
    </div>
  </div>
</section>
{{/inline}}

{{#*inline "history_panel"}}
<section class="card shadow-sm border-0 requirement-main-card" aria-labelledby="history-heading">
  <div
    class="card-header requirement-card-header border-0 d-flex flex-wrap gap-3 justify-content-between align-items-center">
    <div>
      <div class="text-uppercase small text-muted mb-1">Change Log</div>
    </div>
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse"
      data-bs-target="#requirementHistoryContent" aria-expanded="true" aria-controls="requirementHistoryContent"
      aria-label="Toggle history section">
      <span aria-hidden="true">▼</span>
      <span class="visually-hidden">Collapse</span>
    </button>
  </div>
  <div class="collapse show" id="requirementHistoryContent">
    <div class="card-body">
      <ul class="list-unstyled requirement-timeline mb-0" data-slot="timeline">
        {{#if requirement_data.history.entries}}
        {{#each requirement_data.history.entries}}
        <li
          class="d-flex flex-column gap-2 py-2 border-bottom border-light border-opacity-50 requirement-timeline-item">
          <span class="small fw-medium text-body">{{#if this.summary}}{{this.summary}}{{else}}{{#if
            this.description}}{{this.description}}{{else}}{{this.action_type}}{{/if}}{{/if}}</span>
          <span class="small text-muted">{{this.created_at}} · {{this.username}}</span>
          {{#if this.changes}}
          <ul class="list-unstyled small mb-0 ms-2 ps-2 border-start border-2 border-light">
            {{#each this.changes}}
            <li class="py-1 text-muted">
              <span class="fw-medium text-body">{{this.field}}:</span>
              <span class="text-decoration-line-through">{{this.old_value}}</span>
              <span class="text-muted" aria-hidden="true"> → </span>
              <span class="text-success">{{this.new_value}}</span>
            </li>
            {{/each}}
          </ul>
          {{/if}}
        </li>
        {{/each}}
        {{else}}
        <li class="text-muted">No change history recorded yet.</li>
        {{/if}}
      </ul>
    </div>
  </div>
</section>
{{/inline}}

{{#*inline "page"}}
<div class="reqman-requirement-detail-page" data-requirement-root>
  <script type="application/json" id="requirement-detail-data">
    {{{requirement_data_json}}}
  </script>

  {{#if viewing_past_version}}
  <div class="alert alert-info d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3" role="status">
    <span>You are viewing a past version of this requirement.</span>
    <a href="/p/{{project_id}}/requirements/show/{{requirement_data.requirement.id}}"
      class="btn btn-sm btn-outline-primary">View current version</a>
  </div>
  {{/if}}

  <header class="reqman-requirement-header card shadow-sm border-0">
    <div class="reqman-requirement-header__body">
      <div class="d-flex flex-column gap-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div class="d-flex flex-wrap align-items-center gap-3">
            <span class="badge rounded-pill text-bg-dark fs-5" data-field="reference"
              aria-label="Requirement reference">—</span>
            <h1 class="h4 mb-0 text-break" data-field="title">
              {{requirement_data.requirement.title}}
            </h1>
          </div>
          <div class="d-flex flex-wrap align-items-center gap-2">
            <span class="badge" data-field="status-badge" role="status" aria-label="Requirement status">—</span>
            <span class="badge reqman-approval-badge reqman-approval-badge--{{requirement_data.requirement.approval_state}}" data-field="approval-badge" role="status" aria-label="Approval state">{{requirement_data.requirement.approval_state}}</span>
          </div>
          <nav class="ms-lg-auto" aria-label="Requirement actions">
            <div class="btn-toolbar gap-2 justify-content-lg-end flex-wrap">
              <a href="/p/{{project_id}}/requirements/edit/{{requirement_data.requirement.id}}"
                class="btn btn-primary btn-sm {{#if requirement_data.approval_is_approved}}reqman-edit-approved-link{{/if}}"
                aria-label="Edit requirement"
                {{#if requirement_data.approval_is_approved}}data-action="edit-approved-requirement" data-edit-href="/p/{{project_id}}/requirements/edit/{{requirement_data.requirement.id}}"{{/if}}>
                <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                  <use href="#icon-pencil" />
                </svg>
                <span class="ms-1">Edit</span>
              </a>
              <a href="/logs/REQUIREMENT/{{requirement_data.requirement.id}}" class="btn btn-outline-secondary btn-sm"
                aria-label="View requirement history">
                <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                  <use href="#icon-clock-history" />
                </svg>
                <span class="ms-1">History</span>
              </a>
              <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                  aria-expanded="false" aria-label="More actions">
                  More
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <a class="dropdown-item"
                      href="/p/{{project_id}}/requirements/new?parent={{requirement_data.requirement.id}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-plus-circle" />
                      </svg>
                      <span class="ms-2">New child requirement</span>
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item"
                      href="/p/{{project_id}}/requirements/new?template={{requirement_data.requirement.id}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-clipboard" />
                      </svg>
                      <span class="ms-2">New from template</span>
                    </a>
                  </li>
                  <li>
                    <button class="dropdown-item" type="button" data-action="copy-requirement-link"
                      data-requirement-url="/p/{{project_id}}/requirements/show/{{requirement_data.requirement.id}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-link" />
                      </svg>
                      <span class="ms-2">Copy link</span>
                    </button>
                  </li>
                  <li>
                    <hr class="dropdown-divider">
                  </li>
                  <li>
                    <button class="dropdown-item text-danger" type="button" data-action="delete-requirement"
                      data-project-id="{{project_id}}" data-requirement-id="{{requirement_data.requirement.id}}"
                      data-requirement-title="{{requirement_data.requirement.title}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-trash" />
                      </svg>
                      <span class="ms-2">Delete</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>
          </nav>
        </div>

        {{!-- Approval section: badge, metadata, action buttons --}}
        <section class="reqman-approval-section mb-4" data-approval-section aria-labelledby="approval-heading">
          <h2 id="approval-heading" class="visually-hidden">Approval</h2>
          <div class="d-flex flex-wrap align-items-center gap-3">
            <span class="badge reqman-approval-badge reqman-approval-badge--{{requirement_data.requirement.approval_state}}" aria-label="Approval state">{{requirement_data.requirement.approval_state}}</span>
            {{#if requirement_data.approval_is_approved}}
              {{#if requirement_data.approved_by_name}}
                <span class="text-muted small">Approved by {{requirement_data.approved_by_name}}{{#if requirement_data.approved_at_formatted}} on {{requirement_data.approved_at_formatted}}{{/if}}</span>
              {{else}}
                <span class="text-muted small">Approved</span>
              {{/if}}
            {{else}}
              {{#if requirement_data.can_approve}}
                {{#if requirement_data.approval_is_draft}}
                  <button type="button" class="btn btn-outline-warning btn-sm" data-action="approval-transition" data-state="reviewed" aria-label="Mark as Reviewed">Mark as Reviewed</button>
                {{/if}}
                {{#if requirement_data.approval_is_reviewed}}
                  <button type="button" class="btn btn-outline-success btn-sm" data-action="approval-transition" data-state="approved" aria-label="Approve Requirement">Approve Requirement</button>
                {{/if}}
              {{/if}}
            {{/if}}
          </div>
        </section>

        <section class="reqman-requirement-statement-card p-4 p-lg-5 rounded-4">
          <div class="text-uppercase small text-muted mb-2">Requirement Statement</div>
          <div class="reqman-requirement-header__statement fs-2 lh-base text-break fw-semibold mb-4">
            {{#if requirement_data.requirement.description}}
            <p class="mb-0">{{requirement_data.requirement.description}}</p>
            {{else}}
            <p class="mb-0 text-muted"><em>No requirement statement provided yet.</em></p>
            {{/if}}
          </div>

          <hr class="my-4 opacity-25">

          <div class="row g-4">
            <div class="col-lg-6">
              <div class="h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <svg class="text-primary" width="20" height="20" fill="currentColor" aria-hidden="true">
                    <use href="#icon-lightbulb" />
                  </svg>
                  <h2 class="h5 mb-0 fw-semibold">Rationale</h2>
                </div>
                <div class="text-muted lh-lg">
                  {{#if requirement_data.requirement.justification}}
                  <p class="mb-0">{{requirement_data.requirement.justification}}</p>
                  {{else}}
                  <p class="mb-0 fst-italic">No rationale documented yet.</p>
                  {{/if}}
                </div>
              </div>
            </div>

            <div class="col-lg-6">
              <div class="h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <svg class="text-secondary" width="20" height="20" fill="currentColor" aria-hidden="true">
                    <use href="#icon-file-text" />
                  </svg>
                  <h2 class="h5 mb-0 fw-semibold">Notes</h2>
                </div>
                <div class="text-muted lh-lg" data-slot="body-sections">
                  <p class="mb-0 fst-italic">No implementation notes recorded.</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </header>

  <div class="reqman-requirement-detail-grid">
    <div class="reqman-requirement-detail-main">
      {{> verification_panel}}
      {{> history_panel}}
    </div>
    <aside class="reqman-requirement-detail-sidebar" aria-label="Requirement metadata and relationships">
      {{> metadata_panel}}
      {{> custom_fields_panel}}
      {{> versions_panel}}
      {{> relationships_panel}}
    </aside>
  </div>
</div>

<!-- SVG Icon Sprite -->
