<div class="modal fade" id="changesModal" tabindex="-1" aria-labelledby="changesModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="changesModalLabel">Changes</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <small class="text-muted">
            <span class="text-danger" aria-label="Removed">🔴 Red</span> = Removed/Changed values ·
            <span class="text-success" aria-label="Added">🟢 Green</span> = Added/New values ·
            <span class="text-muted" aria-label="Unchanged">⚪ Gray</span> = Unchanged values
          </small>
        </div>
        <div id="changesContent"></div>
      </div>
    </div>
  </div>
</div>

{{!-- Approval: Mark as Reviewed confirmation --}}
<div class="modal fade" id="approvalReviewedModal" tabindex="-1" aria-labelledby="approvalReviewedModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="approvalReviewedModalLabel">Mark as Reviewed?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">This version will be marked as <strong>Reviewed</strong>. An approver can then promote it to Approved.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-warning" id="approvalReviewedConfirm">Confirm</button>
      </div>
    </div>
  </div>
</div>

{{!-- Approval: Approve Requirement confirmation --}}
<div class="modal fade" id="approvalApproveModal" tabindex="-1" aria-labelledby="approvalApproveModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="approvalApproveModalLabel">Approve Requirement Version?</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">This version becomes <strong>stable</strong>. Any future change will create a new Draft version requiring re-approval.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-success" id="approvalApproveConfirm">Confirm</button>
      </div>
    </div>
  </div>
</div>

{{!-- Edit approved requirement: warning --}}
<div class="modal fade" id="editApprovedWarningModal" tabindex="-1" aria-labelledby="editApprovedWarningModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="editApprovedWarningModalLabel">This requirement is approved</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="mb-0">Editing will create a new <strong>Draft</strong> version requiring re-approval.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <a href="#" class="btn btn-primary" id="editApprovedConfirm">Create New Version</a>
      </div>
    </div>
  </div>
</div>
{{/inline}}

{{> layout page_id="requirement-detail"}}