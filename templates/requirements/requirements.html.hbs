{{!--
  Depends on: css/pages/requirements.css, js/pages/requirements.js
  Dynamic classes: reqman-requirements-status-badge--{variant}
--}}

{{!-- ============================================================
     MAIN PAGE COMPOSITION
     Assembles all partials into the complete page structure
     ============================================================ --}}
{{#*inline "page"}}
<div class="reqman-requirements-page">
  {{> requirements/_page_header}}
  <div class="reqman-requirements-main">
    {{> requirements/_metrics_section}}
    {{> requirements/_filter_controls}}
    {{> requirements/_card_view}}
    {{> requirements/_table_view}}
    {{> requirements/_tree_view}}
  </div>
</div>

<script type="module">
import { initTreeControls } from '/static/js/modules/tree.js';

// View switcher functionality
(function() {
  const VIEW_KEY = 'requirements_view_preference';
  
  // Get all view buttons and sections
  const cardBtn = document.getElementById('cardViewBtn');
  const tableBtn = document.getElementById('tableViewBtn');
  const treeBtn = document.getElementById('treeViewBtn');
  
  const cardView = document.getElementById('cardView');
  const tableView = document.getElementById('tableView');
  const treeView = document.getElementById('treeView');
  
  // Function to switch views
  function switchView(viewName) {
    // Hide all views
    cardView.style.display = 'none';
    tableView.style.display = 'none';
    treeView.style.display = 'none';
    
    // Remove active class from all buttons
    cardBtn.classList.remove('active');
    tableBtn.classList.remove('active');
    treeBtn.classList.remove('active');
    
    // Show selected view and activate button
    switch(viewName) {
      case 'card':
        cardView.style.display = 'block';
        cardBtn.classList.add('active');
        break;
      case 'tree':
        treeView.style.display = 'block';
        treeBtn.classList.add('active');
        // Redraw connectors when tree view becomes visible
        if (window.__treeAPI) {
          setTimeout(() => window.__treeAPI.redrawConnectors(), 50);
        }
        break;
      case 'table':
      default:
        tableView.style.display = 'block';
        tableBtn.classList.add('active');
        break;
    }
    
    // Save preference to localStorage
    try {
      localStorage.setItem(VIEW_KEY, viewName);
    } catch (e) {
      console.warn('Could not save view preference:', e);
    }
  }
  
  // Add click listeners
  cardBtn.addEventListener('click', () => switchView('card'));
  tableBtn.addEventListener('click', () => switchView('table'));
  treeBtn.addEventListener('click', () => switchView('tree'));
  
  // Initialize tree controls
  const treeContainer = document.querySelector('.c-tree');
  if (treeContainer) {
    console.log('[TreeInit] Found tree container:', treeContainer);
    console.log('[TreeInit] Tree has', treeContainer.querySelectorAll('[role="treeitem"]').length, 'tree items');
    console.log('[TreeInit] Tree has', treeContainer.querySelectorAll('.c-tree__node').length, 'nodes');
    console.log('[TreeInit] Tree has', treeContainer.querySelectorAll('.c-tree__children').length, 'children containers');
    
    const treeAPI = initTreeControls({
      rootSelector: '.c-tree',
      toggleSelector: '[data-tree-toggle]',
      branchSelector: '[data-tree-branch]',
      expandAllSelector: '[data-tree-expand-all]',
      collapseAllSelector: '[data-tree-collapse-all]',
    });
    
    console.log('[TreeInit] Tree API initialized:', treeAPI);
    
    // Store tree API globally for connector redrawing
    window.__treeAPI = treeAPI;
  } else {
    console.warn('[TreeInit] Tree container (.c-tree) not found!');
  }
  
  // Load saved preference or use default
  try {
    const savedView = localStorage.getItem(VIEW_KEY) || 'table';
    switchView(savedView);
  } catch (e) {
    switchView('table');
  }
})();
</script>
{{/inline}}

{{> layout page_id="requirements"}}
