{{!--
  Depends on: css/pages/requirements.css, js/pages/requirements.js
  Dynamic classes: reqman-requirements-status-badge--{variant}
--}}

{{!-- ============================================================
     PARTIAL: Page Header
     Breadcrumb navigation, title, view switcher, and action buttons
     ============================================================ --}}
{{#*inline "page_header"}}
<header class="reqman-requirements-header">
  <div class="reqman-requirements-header__meta">
    <nav class="reqman-requirements-breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/projects" class="reqman-requirements-breadcrumb__link">Projects</a></li>
        {{#if project.id}}
        <li>
          <a href="/p/{{project.id}}" class="reqman-requirements-breadcrumb__link">{{project.name}}</a>
        </li>
        {{/if}}
        <li aria-current="page" class="reqman-requirements-breadcrumb__current">Requirements</li>
      </ol>
    </nav>
    <div>
      <h1 class="reqman-requirements-header__title">
        {{#if project.name}}
          {{project.name}}
          <span class="reqman-requirements-header__title-accent">requirements</span>
        {{else}}
          Requirements
        {{/if}}
      </h1>
      <p class="reqman-requirements-header__subtitle">
        Instant insight into scope, status, and verification progress.
      </p>
    </div>
  </div>
  {{> view_controls}}
</header>
{{/inline}}

{{!-- ============================================================
     PARTIAL: View Controls
     View switcher buttons, export/import, and new requirement button
     ============================================================ --}}
{{#*inline "view_controls"}}
<div class="reqman-requirements-header__actions">
  <div class="reqman-requirements-header__secondary">
    {{!-- View Switcher Buttons --}}
    <div class="btn-group me-3" role="group" aria-label="View switcher">
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn active" data-view="card" id="cardViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm15 2h-4v3h4V4zm0 4h-4v3h4V8zm0 4h-4v3h3a1 1 0 0 0 1-1v-2zm-5 3v-3H6v3h4zm-5 0v-3H1v2a1 1 0 0 0 1 1h3zm-4-4h4V8H1v3zm0-4h4V4H1v3zm5-3v3h4V4H6zm4 4H6v3h4V8z"/>
        </svg>
        Table
      </button>
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn" data-view="table" id="tableViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z"/>
        </svg>
        Card
      </button>
      <button type="button" class="btn btn-outline-secondary btn-sm view-switcher-btn" data-view="tree" id="treeViewBtn">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="M1 0a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h5v-1H2v-1h4v-9H2V2h4v3h9a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1H1z"/>
          <path d="M15 6v3h-4V6h4zm-1 1h-2v1h2V7z"/>
        </svg>
        Tree
      </button>
    </div>
    {{#if project.id}}
    <a href="/p/{{project.id}}/requirements.xls" class="btn btn-outline-secondary btn-sm">
      Export
    </a>
    {{#if is_admin}}
    <a href="/import_excel" class="btn btn-outline-secondary btn-sm">
      Import
    </a>
    {{/if}}
    {{else}}
    <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
      Export
    </button>
    {{#if is_admin}}
    <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
      Import
    </button>
    {{/if}}
    {{/if}}
  </div>
  {{#if project.id}}
    <a href="/p/{{project.id}}/requirements/new" class="btn btn-primary reqman-requirements-header__primary" id="newRequirementButton">
      New Requirement
    </a>
  {{else}}
    <button type="button" class="btn btn-primary reqman-requirements-header__primary" id="newRequirementButton" disabled aria-disabled="true">
      New Requirement
    </button>
  {{/if}}
</div>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Metrics Section
     Dashboard cards showing requirement health statistics
     ============================================================ --}}
{{#*inline "metrics_section"}}
<section class="reqman-requirements-metrics" aria-label="Requirement health">
  <article class="reqman-requirements-metric-card reqman-requirements-metric-card--total">
    <span class="reqman-requirements-metric-card__label">Total</span>
    <span class="reqman-requirements-metric-card__value">{{requirement_metrics.total}}</span>
    <span class="reqman-requirements-metric-card__hint">Tracked items</span>
  </article>
  <article class="reqman-requirements-metric-card reqman-requirements-metric-card--draft">
    <span class="reqman-requirements-metric-card__label">Draft</span>
    <span class="reqman-requirements-metric-card__value">{{requirement_metrics.draft}}</span>
    <span class="reqman-requirements-metric-card__badge">Needs polish</span>
  </article>
  <article class="reqman-requirements-metric-card reqman-requirements-metric-card--accepted">
    <span class="reqman-requirements-metric-card__label">Accepted</span>
    <span class="reqman-requirements-metric-card__value">{{requirement_metrics.accepted}}</span>
    <span class="reqman-requirements-metric-card__badge">Ready to build</span>
  </article>
  <article class="reqman-requirements-metric-card reqman-requirements-metric-card--rejected">
    <span class="reqman-requirements-metric-card__label">Rejected</span>
    <span class="reqman-requirements-metric-card__value">{{requirement_metrics.rejected}}</span>
    <span class="reqman-requirements-metric-card__badge">Out of scope</span>
  </article>
  <article class="reqman-requirements-metric-card reqman-requirements-metric-card--coverage">
    <div class="reqman-requirements-metric-card__header">
      <span class="reqman-requirements-metric-card__label">Coverage</span>
      <span class="reqman-requirements-metric-card__value">{{requirement_metrics.coverage.percent}}%</span>
    </div>
    <div class="reqman-requirements-metric-card__progress">
      <div
        class="reqman-requirements-metric-card__progress-bar"
        style="width: {{requirement_metrics.coverage.percent}}%;"
        aria-valuenow="{{requirement_metrics.coverage.percent}}"
        aria-valuemin="0"
        aria-valuemax="100"
        role="progressbar">
      </div>
    </div>
    <span class="reqman-requirements-metric-card__hint">
      {{requirement_metrics.coverage.verified}} verified of {{requirement_metrics.total}}
    </span>
  </article>
</section>

{{!-- Expose metrics for tests and client-side initialization --}}
<script id="requirement_metrics" type="application/json">
  {"total": {{requirement_metrics.total}}, "draft": {{requirement_metrics.draft}}, "accepted": {{requirement_metrics.accepted}}, "rejected": {{requirement_metrics.rejected}}, "coverage_percent": {{requirement_metrics.coverage.percent}}, "coverage_verified": {{requirement_metrics.coverage.verified}}}
</script>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Filter Controls
     Search bar and filter dropdowns for requirements
     ============================================================ --}}
{{#*inline "filter_controls"}}
<section class="reqman-requirements-controls c-card" aria-label="Filters">
  <div class="reqman-requirements-controls__inner">
    <form
      method="GET"
      action="{{#if project.id}}/p/{{project.id}}/requirements{{else}}/requirements{{/if}}"
      class="reqman-requirements-filter-bar"
      id="requirementsFilterForm">
      <div class="reqman-requirements-filter-bar__search">
        <label for="requirementsSearch" class="u-visually-hidden">Search requirements</label>
        <input type="search"
          id="requirementsSearch"
          class="reqman-requirements-filter-bar__search-input"
          name="search"
          placeholder="Filter by title, key, or text…"
          autocomplete="off" />
        <span class="reqman-requirements-filter-bar__shortcut" aria-hidden="true">/</span>
      </div>
      <div class="reqman-requirements-filter-bar__selects">
        <label for="statusFilter" class="u-visually-hidden">Filter by status</label>
        <select
          id="statusFilter"
          name="status_filter"
          class="reqman-requirements-filter-bar__select"
          data-filter-control="status"
          data-filter-label="Status">
          <option value="">Status · All</option>
          {{#each statuses}}
            <option value="{{st_id}}" {{#if (eq st_id ../current_status_filter)}}selected{{/if}}>
              {{st_title}}
            </option>
          {{/each}}
        </select>

        <label for="verificationFilter" class="u-visually-hidden">Filter by verification mode</label>
        <select
          id="verificationFilter"
          name="verification_filter"
          class="reqman-requirements-filter-bar__select"
          data-filter-control="verification"
          data-filter-label="Verification">
          <option value="">Verification · All</option>
          {{#each verifications}}
            <option value="{{verification_id}}" {{#if (eq verification_id ../current_verification_filter)}}selected{{/if}}>
              {{verification_name}}
            </option>
          {{/each}}
        </select>

        <label for="categoryFilter" class="u-visually-hidden">Filter by category</label>
        <select
          id="categoryFilter"
          name="category_filter"
          class="reqman-requirements-filter-bar__select"
          data-filter-control="category"
          data-filter-label="Category">
          <option value="">Category · All</option>
          {{#each categories}}
            <option value="{{cat_id}}" {{#if (eq cat_id ../current_category_filter)}}selected{{/if}}>
              {{cat_title}}
            </option>
          {{/each}}
        </select>
      </div>

      <div class="reqman-requirements-filter-bar__actions">
        <button type="button" class="reqman-requirements-filter-bar__clear" data-action="clear-filters">
          Clear filters
        </button>
        <button type="submit" class="reqman-requirements-filter-bar__submit">
          Apply
        </button>
      </div>
    </form>

    <div
      class="reqman-requirements-filter-chips"
      aria-live="polite"
      id="requirementsFilterChips"
      hidden>
    </div>
  </div>
</section>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Empty State
     Shown when no requirements exist
     ============================================================ --}}
{{#*inline "empty_state"}}
<div class="reqman-requirements-empty-state">
  <div class="reqman-requirements-empty-state__illustration" aria-hidden="true">📄</div>
  <h2>No requirements yet</h2>
  <p>Let's add your first one and start shaping this project.</p>
  <a href="/p/{{project.id}}/requirements/new" class="btn btn-primary">New Requirement</a>
</div>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Card View (Default Table View)
     Compact table with expandable row details
     ============================================================ --}}
{{#*inline "card_view"}}
<section class="reqman-requirements-table-section" id="cardView" aria-live="polite">
  {{#if requirements}}
  <div class="reqman-requirements-table__wrapper">
    <table class="reqman-requirements-table" id="requirementsTable">
      <thead>
        <tr>
          <th scope="col" data-sort-key="key" class="is-sortable">
            Key
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="title" class="is-sortable">
            Title
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="status" class="is-sortable">
            Status
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="verification" class="is-sortable">
            Verification
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="updated" class="is-sortable">
            Modified
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="author" class="is-sortable">
            Author
            <span class="reqman-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" class="reqman-requirements-table__actions-head">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each requirements}}
        <tr
          class="reqman-requirements-row"
          data-requirement-id="{{req_id}}"
          data-status-id="{{req_current_status_id}}"
          data-status-label="{{req_current_status}}">
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--key">
            <div class="reqman-requirements-key">
              <span class="reqman-requirements-key__value">
                {{#if req_reference}}{{req_reference}}{{else}}REQ-{{req_id}}{{/if}}
              </span>
              <button
                type="button"
                class="reqman-requirements-key__toggle"
                data-action="toggle-row-details"
                aria-expanded="false"
                aria-controls="requirement-details-{{req_id}}">
                <span class="u-visually-hidden">Toggle details for {{req_title}}</span>
              </button>
            </div>
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--title">
            <a
              href="/p/{{../project.id}}/requirements/show/{{req_id}}"
              class="reqman-requirements-title"
              title="{{req_title}}">
              {{req_title}}
            </a>
            {{#if req_reference}}
            <span class="reqman-requirements-title__reference">({{req_reference}})</span>
            {{/if}}
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--status">
            <span
              class="reqman-requirements-status-badge"
              data-status-id="{{req_current_status_id}}"
              data-status="{{req_current_status}}">
              {{req_current_status}}
            </span>
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--verification">
            <span class="reqman-requirements-cell-muted">{{req_verification}}</span>
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--updated">
            <time>{{req_update_date}}</time>
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--author">
            {{#if req_author}}
              {{req_author}}
            {{else}}
              <span class="reqman-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="reqman-requirements-row__cell reqman-requirements-row__cell--actions">
            <div class="reqman-requirements-row__actions">
              <a href="/p/{{../project.id}}/requirements/edit/{{req_id}}" class="reqman-requirements-row__action reqman-requirements-row__action--link">Edit</a>
              <button
                type="button"
                class="reqman-requirements-row__action"
                data-action="duplicate-requirement"
                data-requirement-id="{{req_id}}">
                Duplicate
              </button>
              <button
                type="button"
                class="reqman-requirements-row__action reqman-requirements-row__action--menu"
                data-action="open-row-menu"
                aria-haspopup="true"
                aria-expanded="false">
                ⋯
                <span class="u-visually-hidden">More for {{req_title}}</span>
              </button>
            </div>
          </td>
        </tr>
        <tr
          id="requirement-details-{{req_id}}"
          class="reqman-requirements-row__details"
          data-details-for="{{req_id}}"
          hidden>
          <td colspan="7">
            <dl class="reqman-requirements-details-grid">
              <div>
                <dt>Category</dt>
                <dd>{{req_category}}</dd>
              </div>
              <div>
                <dt>Applicability</dt>
                <dd>{{req_applicability}}</dd>
              </div>
              <div>
                <dt>Reviewer</dt>
                <dd>{{#if req_reviewer}}{{req_reviewer}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Updated</dt>
                <dd>{{req_update_date}}</dd>
              </div>
              <div>
                <dt>Author</dt>
                <dd>{{#if req_author}}{{req_author}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Parent</dt>
                <dd>
                  {{#if req_parent_id}}
                    <a href="/p/{{project.id}}/requirements/show/{{req_parent_id}}">{{req_parent_title}}</a>
                  {{else}}
                    —
                  {{/if}}
                </dd>
              </div>
            </dl>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  <nav class="reqman-requirements-pagination" aria-label="Requirements pagination">
    <button type="button" class="reqman-requirements-pagination__button is-disabled" disabled aria-disabled="true">Prev</button>
    <span class="reqman-requirements-pagination__status">All {{requirement_metrics.total}} requirements</span>
    <button type="button" class="reqman-requirements-pagination__button is-disabled" disabled aria-disabled="true">Next</button>
  </nav>
  {{else}}
  {{> empty_state}}
  {{/if}}
</section>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Table View (Detailed)
     Bootstrap-styled table with all columns visible
     ============================================================ --}}
{{#*inline "table_view"}}
<section class="reqman-requirements-table-view" id="tableView" style="display: none;" aria-live="polite">
  {{#if requirements}}
  <div class="card c-card">
    <div class="card-body p-0 c-card__body">
      <div class="table-responsive c-table-responsive">
        <table class="table table-hover mb-0 c-table c-table--hover" id="requirementsTableDetailed">
          <thead class="table-light c-table__head">
            <tr>
              <th class="sortable c-table-sortable" style="width: 10%;">ID</th>
              <th class="sortable c-table-sortable" style="width: 25%;">Title</th>
              <th class="sortable c-table-sortable" style="width: 12%;">Reference</th>
              <th class="sortable c-table-sortable" style="width: 12%;">Category</th>
              <th class="sortable c-table-sortable" style="width: 10%;">Status</th>
              <th class="sortable c-table-sortable" style="width: 12%;">Verification</th>
              <th class="sortable c-table-sortable" style="width: 10%;">Author</th>
              <th style="width: 9%;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each requirements}}
            <tr data-requirement-id="{{req_id}}">
              <td>
                <a href="/p/{{../project.id}}/requirements/show/{{req_id}}" class="text-decoration-none fw-bold">
                  {{#if req_reference}}{{req_reference}}{{else}}REQ-{{req_id}}{{/if}}
                </a>
              </td>
              <td>{{req_title}}</td>
              <td><span class="text-muted">{{req_reference}}</span></td>
              <td>{{req_category}}</td>
              <td>{{req_current_status}}</td>
              <td>{{req_verification}}</td>
              <td>{{req_author}}</td>
              <td>
                <div class="btn-group btn-group-sm">
                  <a class="btn btn-outline-primary btn-sm" href="/p/{{../project.id}}/requirements/edit/{{req_id}}" title="Edit">Edit</a>
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  {{else}}
  {{> empty_state}}
  {{/if}}
</section>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Tree View
     Hierarchical tree structure showing parent-child relationships
     ============================================================ --}}
{{#*inline "tree_view"}}
<section class="reqman-requirements-tree-view" id="treeView" style="display: none;" aria-live="polite">
  {{#if tree_data}}
  <div class="card c-card">
    <div class="card-header c-card__header">
      <div class="d-flex justify-content-between align-items-center">
        <h3>Requirements Hierarchy</h3>
        <div class="c-tree__controls">
          <button class="btn btn-outline-primary btn-sm c-tree__control-button" type="button" data-tree-expand-all>Expand All</button>
          <button class="btn btn-outline-primary btn-sm c-tree__control-button" type="button" data-tree-collapse-all>Collapse All</button>
        </div>
      </div>
    </div>
    <div class="card-body c-card__body">
      <div class="c-tree">
        <div class="c-tree__root">
          {{#each tree_data}}
          {{> tree_node}}
          {{/each}}
        </div>
      </div>
    </div>
  </div>
  {{else}}
  {{> empty_state}}
  {{/if}}
</section>
{{/inline}}

{{!-- ============================================================
     PARTIAL: Tree Node (Recursive)
     Individual node in the tree hierarchy
     ============================================================ --}}
{{#*inline "tree_node"}}
<div class="c-tree__node" data-node-id="{{requirement.req_id}}">
  <div class="c-tree__node-content">
    <button class="c-tree__toggle" type="button" data-tree-toggle="{{requirement.req_id}}">
      {{#if children}}
      <svg class="c-tree__toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9,18 15,12 9,6"></polyline>
      </svg>
      {{else}}
      <span class="c-tree__toggle-placeholder"></span>
      {{/if}}
    </button>
    <div class="c-tree__requirement-card c-requirement-card">
      <div class="c-tree__requirement-header">
        <div class="requirement-id c-requirement-card__id">
          <a href="/p/{{requirement.project_id}}/requirements/show/{{requirement.req_id}}"
            class="c-tree__requirement-link c-linked-requirements__link">
            {{requirement.req_reference}}
          </a>
        </div>
        <div class="requirement-status">
          <span class="status-badge status-{{requirement.req_current_status}}"
            data-status="{{requirement.req_current_status}}">
            {{requirement.req_current_status}}
          </span>
        </div>
      </div>
      <div class="c-tree__requirement-title c-linked-requirements__title">{{requirement.req_title}}</div>
      <div class="c-tree__requirement-description">{{requirement.req_description}}</div>
      <div class="c-tree__requirement-meta">
        <div class="c-tree__meta-item">
          <span class="c-tree__meta-label">Category:</span>
          <span class="meta-value c-requirement-card__meta-value">{{requirement.req_category}}</span>
        </div>
        <div class="c-tree__meta-item">
          <span class="c-tree__meta-label">Reference:</span>
