{{!--
  Requirements Table View - Modern card-based layout for reading requirements
  Depends on: css/pages/requirements-cards.css, js/pages/requirements-cards.js
--}}
{{#*inline "page"}}
<div class="reqman-requirements-cards-page">
  <header class="reqman-requirements-header">
    <div class="reqman-requirements-header__meta">
      <nav class="reqman-requirements-breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/projects" class="reqman-requirements-breadcrumb__link">Projects</a></li>
          {{#if project.id}}
          <li>
            <a href="/p/{{project.id}}" class="reqman-requirements-breadcrumb__link">{{project.name}}</a>
          </li>
          {{/if}}
          <li aria-current="page" class="reqman-requirements-breadcrumb__current">Requirements - Table View</li>
        </ol>
      </nav>
      <div>
        <h1 class="reqman-requirements-header__title">
          {{#if project.name}}
            {{project.name}}
            <span class="reqman-requirements-header__title-accent">requirements</span>
          {{else}}
            Requirements
          {{/if}}
        </h1>
        <p class="reqman-requirements-header__subtitle">
          Browse and read requirement statements in a clear, card-based layout.
        </p>
      </div>
    </div>
    <div class="reqman-requirements-header__actions">
      <div class="reqman-requirements-header__secondary">
        {{#if project.id}}
        <a href="/p/{{project.id}}/requirements_table" class="btn btn-outline-secondary btn-sm">
          Card View
        </a>
        <a href="/p/{{project.id}}/requirements/tree" class="btn btn-outline-secondary btn-sm">
          Tree View
        </a>
        <a href="/p/{{project.id}}/requirements.xls" class="btn btn-outline-secondary btn-sm">
          Export
        </a>
        {{#if is_admin}}
        <a href="/import_excel" class="btn btn-outline-secondary btn-sm">
          Import
        </a>
        {{/if}}
        {{else}}
        <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
          Card View
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
          Tree View
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
          Export
        </button>
        {{#if is_admin}}
        <button type="button" class="btn btn-outline-secondary btn-sm" disabled aria-disabled="true">
          Import
        </button>
        {{/if}}
        {{/if}}
      </div>
      {{#if project.id}}
        <a href="/p/{{project.id}}/requirements/new" class="btn btn-primary reqman-requirements-header__primary" id="newRequirementButton">
          New Requirement
        </a>
      {{else}}
        <button type="button" class="btn btn-primary reqman-requirements-header__primary" id="newRequirementButton" disabled aria-disabled="true">
          New Requirement
        </button>
      {{/if}}
    </div>
  </header>

  <div class="reqman-requirements-main">
    <section class="reqman-requirements-metrics" aria-label="Requirement health">
      <article class="reqman-requirements-metric-card reqman-requirements-metric-card--total">
        <span class="reqman-requirements-metric-card__label">Total</span>
        <span class="reqman-requirements-metric-card__value">{{requirement_metrics.total}}</span>
        <span class="reqman-requirements-metric-card__hint">Tracked items</span>
      </article>
      <article class="reqman-requirements-metric-card reqman-requirements-metric-card--draft">
        <span class="reqman-requirements-metric-card__label">Draft</span>
        <span class="reqman-requirements-metric-card__value">{{requirement_metrics.draft}}</span>
        <span class="reqman-requirements-metric-card__badge">Needs polish</span>
      </article>
      <article class="reqman-requirements-metric-card reqman-requirements-metric-card--accepted">
        <span class="reqman-requirements-metric-card__label">Accepted</span>
        <span class="reqman-requirements-metric-card__value">{{requirement_metrics.accepted}}</span>
        <span class="reqman-requirements-metric-card__badge">Ready to build</span>
      </article>
      <article class="reqman-requirements-metric-card reqman-requirements-metric-card--rejected">
        <span class="reqman-requirements-metric-card__label">Rejected</span>
        <span class="reqman-requirements-metric-card__value">{{requirement_metrics.rejected}}</span>
        <span class="reqman-requirements-metric-card__badge">Out of scope</span>
      </article>
      <article class="reqman-requirements-metric-card reqman-requirements-metric-card--coverage">
        <div class="reqman-requirements-metric-card__header">
          <span class="reqman-requirements-metric-card__label">Coverage</span>
          <span class="reqman-requirements-metric-card__value">{{requirement_metrics.coverage.percent}}%</span>
        </div>
        <div class="reqman-requirements-metric-card__progress">
          <div
            class="reqman-requirements-metric-card__progress-bar"
            style="width: {{requirement_metrics.coverage.percent}}%;"
            aria-valuenow="{{requirement_metrics.coverage.percent}}"
            aria-valuemin="0"
            aria-valuemax="100"
            role="progressbar">
          </div>
        </div>
        <span class="reqman-requirements-metric-card__hint">
          {{requirement_metrics.coverage.verified}} verified of {{requirement_metrics.total}}
        </span>
      </article>
    </section>

    <section class="reqman-requirements-controls c-card" aria-label="Filters">
      <div class="reqman-requirements-controls__inner">
        <form
          method="GET"
          action="{{#if project.id}}/p/{{project.id}}/requirements{{else}}/requirements{{/if}}"
          class="reqman-requirements-filter-bar"
          id="requirementsFilterForm">
          <div class="reqman-requirements-filter-bar__search">
            <label for="requirementsSearch" class="u-visually-hidden">Search requirements</label>
            <input type="search"
              id="requirementsSearch"
              class="reqman-requirements-filter-bar__search-input"
              name="search"
              placeholder="Filter by title, key, or text…"
              autocomplete="off" />
            <span class="reqman-requirements-filter-bar__shortcut" aria-hidden="true">/</span>
          </div>
          <div class="reqman-requirements-filter-bar__selects">
            <label for="statusFilter" class="u-visually-hidden">Filter by status</label>
            <select
              id="statusFilter"
              name="status_filter"
              class="reqman-requirements-filter-bar__select"
              data-filter-control="status"
              data-filter-label="Status">
              <option value="">Status · All</option>
              {{#each statuses}}
                <option value="{{st_id}}" {{#if (eq st_id ../current_status_filter)}}selected{{/if}}>
                  {{st_title}}
                </option>
              {{/each}}
            </select>

            <label for="verificationFilter" class="u-visually-hidden">Filter by verification mode</label>
            <select
              id="verificationFilter"
              name="verification_filter"
              class="reqman-requirements-filter-bar__select"
              data-filter-control="verification"
              data-filter-label="Verification">
              <option value="">Verification · All</option>
              {{#each verifications}}
                <option value="{{verification_id}}" {{#if (eq verification_id ../current_verification_filter)}}selected{{/if}}>
                  {{verification_name}}
                </option>
              {{/each}}
            </select>

            <label for="categoryFilter" class="u-visually-hidden">Filter by category</label>
            <select
              id="categoryFilter"
              name="category_filter"
              class="reqman-requirements-filter-bar__select"
              data-filter-control="category"
              data-filter-label="Category">
              <option value="">Category · All</option>
              {{#each categories}}
                <option value="{{cat_id}}" {{#if (eq cat_id ../current_category_filter)}}selected{{/if}}>
                  {{cat_title}}
                </option>
              {{/each}}
            </select>
          </div>

          <div class="reqman-requirements-filter-bar__actions">
            <button type="button" class="reqman-requirements-filter-bar__clear" data-action="clear-filters">
              Clear filters
            </button>
            <button type="submit" class="reqman-requirements-filter-bar__submit">
              Apply
            </button>
          </div>
        </form>

        <div
          class="reqman-requirements-filter-chips"
          aria-live="polite"
          id="requirementsFilterChips"
          hidden>
        </div>
      </div>
    </section>

    <section class="reqman-requirements-cards-section" aria-live="polite">
      {{#if requirements}}
      <div class="reqman-requirements-cards-grid">
        {{#each requirements}}
        <article class="reqman-requirement-card" data-requirement-id="{{req_id}}" data-status-id="{{req_current_status_id}}">
          <div class="reqman-requirement-card__header">
            <div class="reqman-requirement-card__header-left">
              <span class="reqman-requirement-card__key">
                {{#if req_reference}}{{req_reference}}{{else}}REQ-{{req_id}}{{/if}}
              </span>
              <span
                class="reqman-requirement-card__status-badge"
                data-status-id="{{req_current_status_id}}"
                data-status="{{req_current_status}}">
                {{req_current_status}}
              </span>
            </div>
            <div class="reqman-requirement-card__header-actions">
              <a href="/p/{{../project.id}}/requirements/edit/{{req_id}}" 
                 class="reqman-requirement-card__action-btn" 
                 title="Edit requirement"
                 aria-label="Edit {{req_title}}">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5L13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5z"/>
                </svg>
              </a>
              <a href="/p/{{../project.id}}/requirements/show/{{req_id}}" 
                 class="reqman-requirement-card__action-btn" 
                 title="View details"
                 aria-label="View details of {{req_title}}">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                  <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
              </a>
            </div>
          </div>

          <h2 class="reqman-requirement-card__title">
            <a href="/p/{{../project.id}}/requirements/show/{{req_id}}" class="reqman-requirement-card__title-link">
              {{req_title}}
            </a>
          </h2>

          <div class="reqman-requirement-card__statement">
            <p class="reqman-requirement-card__description">
              {{req_description}}
            </p>
          </div>

          <div class="reqman-requirement-card__metadata">
            <div class="reqman-requirement-card__meta-row">
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Category</span>
                <span class="reqman-requirement-card__meta-value">{{req_category}}</span>
              </div>
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Verification</span>
                <span class="reqman-requirement-card__meta-value">{{req_verification}}</span>
              </div>
            </div>
            <div class="reqman-requirement-card__meta-row">
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Applicability</span>
                <span class="reqman-requirement-card__meta-value">{{req_applicability}}</span>
              </div>
              {{#if req_parent_id}}
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Parent</span>
                <span class="reqman-requirement-card__meta-value">
                  <a href="/p/{{../project.id}}/requirements/show/{{req_parent_id}}" class="reqman-requirement-card__meta-link">
                    {{req_parent_title}}
                  </a>
                </span>
              </div>
              {{/if}}
            </div>
            <div class="reqman-requirement-card__meta-row">
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Author</span>
                <span class="reqman-requirement-card__meta-value">{{#if req_author}}{{req_author}}{{else}}—{{/if}}</span>
              </div>
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Reviewer</span>
                <span class="reqman-requirement-card__meta-value">{{#if req_reviewer}}{{req_reviewer}}{{else}}—{{/if}}</span>
              </div>
              <div class="reqman-requirement-card__meta-item">
                <span class="reqman-requirement-card__meta-label">Updated</span>
                <span class="reqman-requirement-card__meta-value">
                  <time datetime="{{req_update_date}}">{{req_update_date}}</time>
                </span>
              </div>
            </div>
            {{#if req_justification}}
            <div class="reqman-requirement-card__justification">
              <span class="reqman-requirement-card__meta-label">Justification</span>
              <p class="reqman-requirement-card__justification-text">{{req_justification}}</p>
            </div>
            {{/if}}
          </div>

          <div class="reqman-requirement-card__footer">
            <a href="/p/{{../project.id}}/requirements/show/{{req_id}}" class="reqman-requirement-card__view-link">
              View full details →
            </a>
          </div>
        </article>
        {{/each}}
      </div>

      <nav class="reqman-requirements-pagination" aria-label="Requirements pagination">
        <button type="button" class="reqman-requirements-pagination__button is-disabled" disabled aria-disabled="true">Prev</button>
        <span class="reqman-requirements-pagination__status">Showing {{requirement_metrics.total}} requirements</span>
        <button type="button" class="reqman-requirements-pagination__button is-disabled" disabled aria-disabled="true">Next</button>
      </nav>
      {{else}}
      <div class="reqman-requirements-empty-state">
        <div class="reqman-requirements-empty-state__illustration" aria-hidden="true">📄</div>
        <h2>No requirements yet</h2>
        <p>Let's add your first one and start shaping this project.</p>
        {{#if project.id}}
        <a href="/p/{{project.id}}/requirements/new" class="btn btn-primary">New Requirement</a>
        {{/if}}
      </div>
      {{/if}}
    </section>
  </div>
</div>

{{/inline}}
{{> layout page_id="requirements-cards"}}
