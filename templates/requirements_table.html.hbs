{{!--
  Depends on: css/50-components/tables.css, js/pages/requirements.js
  Dynamic classes: sort-indicator, editable-field/select toggled by JS
--}}
{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Requirements Table</h1>
    <div>
      <a href="{{#if selected_project_id}}/p/{{selected_project_id}}/requirements{{else}}/requirements{{/if}}" class="btn btn-outline-secondary me-2">Card View</a>
      <a href="/p/{{selected_project_id}}/requirements.xls" class="btn btn-success me-2">Export Excel</a>
      {{#if user.is_admin}}
      <a href="/import_excel" class="btn btn-warning me-2">Import Excel</a>
      {{/if}}
      <button id="addNewRequirement" class="btn btn-primary">Add New Requirement</button>
    </div>
  </div>
</div>

<!-- Filters Section -->
<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Filters</h5>
  </div>
  <div class="card-body">
    <form method="GET" action="/p/{{selected_project_id}}/requirements_table" class="d-flex align-items-end gap-3 filters-form">
      {{> partials/filters_form
          status_field_name="status_filter"
          status_label="Status"
          status_default_label="All Statuses"
          status_options=statuses
          status_value_key="req_st_id"
          status_label_key="req_st_title"
          status_selected=current_status_filter
          verification_field_name="verification_filter"
          verification_label="Verification Mode"
          verification_default_label="All Verification Modes"
          verification_options=verifications
          verification_value_key="verification_id"
          verification_label_key="verification_name"
          verification_selected=current_verification_filter
          category_field_name="category_filter"
          category_label="Category"
          category_default_label="All Categories"
          category_options=categories
          category_value_key="cat_id"
          category_label_key="cat_title"
          category_selected=current_category_filter
      }}
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Apply Filters</button>
        <a href="/requirements_table" class="btn btn-secondary">Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Requirements Table -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0" id="requirementsTable">
        <thead class="table-light">
          <tr>
            <th class="sortable" data-sort="req_id" style="width: 8%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_id">
                ID
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_title" style="width: 20%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_title">
                Title
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_reference" style="width: 12%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_reference">
                Reference
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_category" style="width: 10%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_category">
                Category
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_current_status" style="width: 10%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_current_status">
                Status
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_verification" style="width: 10%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_verification">
                Verification
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_author" style="width: 8%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_author">
                Author
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_reviewer" style="width: 8%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_reviewer">
                Reviewer
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_creation_date" style="width: 10%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_creation_date">
                Creation Date
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th class="sortable" data-sort="req_deadline_date" style="width: 10%;">
              <a href="#" class="text-decoration-none d-flex align-items-center justify-content-between sort-trigger" data-sort-key="req_deadline_date">
                Deadline
                <span class="sort-indicator">↕</span>
              </a>
            </th>
            <th style="width: 8%;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each requirements}}
          <tr data-requirement-id="{{req_id}}">
            <td>
              <a href="/p/{{project_id}}/requirements/show/{{req_id}}" class="text-decoration-none fw-bold">REQ-{{req_id}}</a>
            </td>
            <td>
              <span class="editable-field" data-field="req_title" data-id="{{req_id}}">{{req_title}}</span>
            </td>
            <td>
              <span class="text-muted">{{req_reference}}</span>
            </td>
            <td>
              <select class="form-select form-select-sm editable-select" data-field="req_category" data-id="{{req_id}}">
                {{#each ../categories}}
                  <option value="{{cat_id}}" {{#if (eq cat_id ../req_category_id)}}selected{{/if}}>{{cat_title}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <select class="form-select form-select-sm editable-select" data-field="req_current_status" data-id="{{req_id}}">
                {{#each ../statuses}}
                  <option value="{{req_st_id}}" {{#if (eq req_st_id ../req_current_status_id)}}selected{{/if}}>{{req_st_title}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <select class="form-select form-select-sm editable-select" data-field="req_verification" data-id="{{req_id}}">
                {{#each ../verifications}}
                  <option value="{{verification_id}}" {{#if (eq verification_id ../req_verification_id)}}selected{{/if}}>{{verification_name}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <select class="form-select form-select-sm editable-select" data-field="req_author" data-id="{{req_id}}">
                {{#each ../users}}
                  <option value="{{user_id}}" {{#if (eq user_id ../req_author_id)}}selected{{/if}}>{{user_name}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <select class="form-select form-select-sm editable-select" data-field="req_reviewer" data-id="{{req_id}}">
                {{#each ../users}}
                  <option value="{{user_id}}" {{#if (eq user_id ../req_reviewer_id)}}selected{{/if}}>{{user_name}}</option>
                {{/each}}
              </select>
            </td>
            <td>
              <span class="text-muted small">{{req_creation_date}}</span>
            </td>
            <td>
              <input type="date" class="form-control form-control-sm editable-date" data-field="req_deadline_date" data-id="{{req_id}}" value="{{req_deadline_date}}">
            </td>
            <td>
              <div class="btn-group btn-group-sm">
                <a
                  class="btn btn-outline-primary btn-sm"
                  href="/p/{{project_id}}/requirements/edit/{{req_id}}"
                  title="Edit">
                  <i class="bi bi-pencil"></i>
                </a>
                <button
                  class="btn btn-outline-danger btn-sm js-delete-requirement"
                  type="button"
                  data-project-id="{{project_id}}"
                  data-requirement-id="{{req_id}}"
                  data-requirement-title="{{req_title}}"
                  title="Delete">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>

{{> partials/modals render_requirement_modal=true}}
          <div class="mb-3">
            <label for="new_req_description" class="form-label">Description *</label>
            <textarea class="form-control" id="new_req_description" name="req_description" rows="3" required></textarea>
          </div>
          <div class="row">
            <div class="col-md-4">
              <div class="mb-3">
                <label for="new_req_category" class="form-label">Category</label>
                <select class="form-select" id="new_req_category" name="req_category">
                  {{#each categories}}
                    <option value="{{cat_id}}">{{cat_title}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="col-md-4">
              <div class="mb-3">
                <label for="new_req_status" class="form-label">Status</label>
                <select class="form-select" id="new_req_status" name="req_current_status">
                  {{#each statuses}}
                    <option value="{{req_st_id}}">{{req_st_title}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="col-md-4">
              <div class="mb-3">
                <label for="new_req_verification" class="form-label">Verification</label>
                <select class="form-select" id="new_req_verification" name="req_verification">
                  {{#each verifications}}
                    <option value="{{verification_id}}">{{verification_name}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label for="new_req_author" class="form-label">Author</label>
                <select class="form-select" id="new_req_author" name="req_author">
                  {{#each users}}
                    <option value="{{user_id}}">{{user_name}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label for="new_req_reviewer" class="form-label">Reviewer</label>
                <select class="form-select" id="new_req_reviewer" name="req_reviewer">
                  {{#each users}}
                    <option value="{{user_id}}">{{user_name}}</option>
                  {{/each}}
                </select>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Requirement</button>
        </div>
      </form>
    </div>
  </div>
</div>

{{/inline}}
{{> layout page_id="requirements"}}
