{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1>Requirements Tree View</h1>
      <p class="text-secondary">Hierarchical view of all requirements</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="tree-controls">
        <button class="btn btn-outline-primary btn-sm" onclick="expandAll()">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9,18 15,12 9,6"></polyline>
          </svg>
          Expand All
        </button>
        <button class="btn btn-outline-primary btn-sm" onclick="collapseAll()">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15,18 9,12 15,6"></polyline>
          </svg>
          Collapse All
        </button>
      </div>
      <a href="/requirements" class="btn btn-secondary">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11H1l8-8 8 8h-8v8z"></path>
        </svg>
        List View
      </a>
    </div>
  </div>
</div>

<section id="RequirementsTree">
  <div class="card">
    <div class="card-header">
      <div class="d-flex justify-content-between align-items-center">
        <h3>Requirements Hierarchy</h3>
        <span class="text-secondary">Total Requirements: {{total_requirements}}</span>
      </div>
    </div>
    <div class="card-body">
      <div class="tree-container">
        {{#if tree_data}}
          <div class="tree-root">
            {{#each tree_data}}
              <div class="tree-node" data-node-id="{{requirement.req_id}}">
                <div class="node-content">
                  <div class="node-toggle" onclick="toggleNode({{requirement.req_id}})">
                    {{#if children}}
                      <svg class="toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9,18 15,12 9,6"></polyline>
                      </svg>
                    {{else}}
                      <div class="toggle-placeholder"></div>
                    {{/if}}
                  </div>
                  <div class="requirement-card">
                    <div class="requirement-header">
                      <div class="requirement-id">
                        <a href="/requirements/{{requirement.req_id}}" class="requirement-link">
                          REQ-{{requirement.req_id}}
                        </a>
                      </div>
                      <div class="requirement-status">
                        <span class="status-badge status-{{requirement.req_current_status}}">
                          {{requirement.req_current_status}}
                        </span>
                      </div>
                    </div>
                    <div class="requirement-title">{{requirement.req_title}}</div>
                    <div class="requirement-description">{{requirement.req_description}}</div>
                    <div class="requirement-meta">
                      <div class="meta-item">
                        <span class="meta-label">Category:</span>
                        <span class="meta-value">{{requirement.req_category}}</span>
                      </div>
                      <div class="meta-item">
                        <span class="meta-label">Reference:</span>
                        <span class="meta-value">{{requirement.req_reference}}</span>
                      </div>
                    </div>
                  </div>
                </div>
                {{#if children}}
                  <div class="node-children" id="children-{{requirement.req_id}}">
                    {{#each children}}
                      <div class="tree-node child-node" data-node-id="{{requirement.req_id}}">
                        <div class="node-content">
                          <div class="node-toggle">
                            <div class="toggle-placeholder"></div>
                          </div>
                          <div class="requirement-card child-card">
                            <div class="requirement-header">
                              <div class="requirement-id">
                                <a href="/requirements/{{requirement.req_id}}" class="requirement-link">
                                  REQ-{{requirement.req_id}}
                                </a>
                              </div>
                              <div class="requirement-status">
                                <span class="status-badge status-{{requirement.req_current_status}}">
                                  {{requirement.req_current_status}}
                                </span>
                              </div>
                            </div>
                            <div class="requirement-title">{{requirement.req_title}}</div>
                            <div class="requirement-description">{{requirement.req_description}}</div>
                            <div class="requirement-meta">
                              <div class="meta-item">
                                <span class="meta-label">Category:</span>
                                <span class="meta-value">{{requirement.req_category}}</span>
                              </div>
                              <div class="meta-item">
                                <span class="meta-label">Reference:</span>
                                <span class="meta-value">{{requirement.req_reference}}</span>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="empty-state">
            <div class="empty-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11H1l8-8 8 8h-8v8z"></path>
              </svg>
            </div>
            <h3>No Requirements Found</h3>
            <p>There are no requirements to display in the tree view.</p>
            <a href="/p/{{selected_project_id}}/requirements/new" class="btn btn-primary">Create First Requirement</a>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</section>

<script>
  // Tree view functionality
  function toggleNode(nodeId) {
    const childrenContainer = document.getElementById(`children-${nodeId}`);
    const toggleIcon = event.currentTarget.querySelector('.toggle-icon');
    
    if (childrenContainer) {
      const isExpanded = childrenContainer.style.display !== 'none';
      
      if (isExpanded) {
        childrenContainer.style.display = 'none';
        toggleIcon.style.transform = 'rotate(0deg)';
      } else {
        childrenContainer.style.display = 'block';
        toggleIcon.style.transform = 'rotate(90deg)';
      }
    }
  }
  
  function expandAll() {
    const childrenContainers = document.querySelectorAll('.node-children');
    const toggleIcons = document.querySelectorAll('.toggle-icon');
    
    childrenContainers.forEach(container => {
      container.style.display = 'block';
    });
    
    toggleIcons.forEach(icon => {
      icon.style.transform = 'rotate(90deg)';
    });
  }
  
  function collapseAll() {
    const childrenContainers = document.querySelectorAll('.node-children');
    const toggleIcons = document.querySelectorAll('.toggle-icon');
    
    childrenContainers.forEach(container => {
      container.style.display = 'none';
    });
    
    toggleIcons.forEach(icon => {
      icon.style.transform = 'rotate(0deg)';
    });
  }
  
  // Initialize tree state
  document.addEventListener('DOMContentLoaded', function() {
    // Start with all nodes collapsed
    collapseAll();
  });
</script>
{{/inline}}
{{> layout}} 