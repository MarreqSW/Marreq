{{!--
  Depends on: css/50-components/tree.css, js/pages/requirementsTree.js
  Dynamic classes: status-{{requirement.req_current_status}}
--}}
{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <div>
      <h1>Requirements Tree View</h1>
      <p class="text-secondary">Hierarchical view of all requirements</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="c-tree__controls">
        <button class="btn btn-outline-primary btn-sm" type="button" data-tree-expand-all>
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9,18 15,12 9,6"></polyline>
          </svg>
          Expand All
        </button>
        <button class="btn btn-outline-primary btn-sm" type="button" data-tree-collapse-all>
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15,18 9,12 15,6"></polyline>
          </svg>
          Collapse All
        </button>
      </div>
      <a href="/p/{{selected_project_id}}/requirements" class="btn btn-secondary">
        <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 11H1l8-8 8 8h-8v8z"></path>
        </svg>
        List View
      </a>
    </div>
  </div>
</div>

<section id="RequirementsTree">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <div class="d-flex justify-content-between align-items-center">
        <h3>Requirements Hierarchy</h3>
        <span class="text-secondary">Total Requirements: {{total_requirements}}</span>
      </div>
    </div>
    <div class="card-body c-card__body">
      <div class="c-tree">
        {{#if tree_data}}
          <div class="c-tree__root">
            {{#each tree_data}}
              <div class="c-tree__node" data-node-id="{{requirement.req_id}}">
                <div class="c-tree__node-content">
                  <button class="c-tree__toggle" type="button" data-tree-toggle="{{requirement.req_id}}">
                    {{#if children}}
                      <svg class="c-tree__toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="9,18 15,12 9,6"></polyline>
                      </svg>
                    {{else}}
                      <span class="c-tree__toggle-placeholder"></span>
                    {{/if}}
                  </button>
                  <div class="c-tree__requirement-card c-requirement-card">
                    <div class="c-tree__requirement-header">
                      <div class="requirement-id c-requirement-card__id">
                        <a href="/p/{{requirement.project_id}}/requirements/show/{{requirement.req_id}}" class="c-tree__requirement-link c-linked-requirements__link">
                          REQ-{{requirement.req_id}}
                        </a>
                      </div>
                      <div class="requirement-status">
                        <span class="status-badge status-{{requirement.req_current_status}}" data-status="{{requirement.req_current_status}}">
                          {{requirement.req_current_status}}
                        </span>
                      </div>
                    </div>
                    <div class="c-tree__requirement-title c-linked-requirements__title">{{requirement.req_title}}</div>
                    <div class="c-tree__requirement-description">{{requirement.req_description}}</div>
                    <div class="c-tree__requirement-meta">
                      <div class="c-tree__meta-item">
                        <span class="c-tree__meta-label">Category:</span>
                        <span class="meta-value c-requirement-card__meta-value">{{requirement.req_category}}</span>
                      </div>
                      <div class="c-tree__meta-item">
                        <span class="c-tree__meta-label">Reference:</span>
                        <span class="meta-value c-requirement-card__meta-value">{{requirement.req_reference}}</span>
                      </div>
                    </div>
                  </div>
                </div>
                {{#if children}}
                  <div class="c-tree__children" id="children-{{requirement.req_id}}" data-tree-branch="{{requirement.req_id}}" hidden>
                    {{#each children}}
                      <div class="c-tree__node c-tree__child-node" data-node-id="{{requirement.req_id}}">
                        <div class="c-tree__node-content">
                          <div class="c-tree__toggle">
                            <div class="c-tree__toggle-placeholder"></div>
                          </div>
                          <div class="c-tree__requirement-card c-tree__child-card c-requirement-card">
                            <div class="c-tree__requirement-header">
                              <div class="requirement-id c-requirement-card__id">
                                <a href="/p/{{requirement.project_id}}/requirements/show/{{requirement.req_id}}" class="c-tree__requirement-link c-linked-requirements__link">
                                  REQ-{{requirement.req_id}}
                                </a>
                              </div>
                              <div class="requirement-status">
                                <span class="status-badge status-{{requirement.req_current_status}}" data-status="{{requirement.req_current_status}}">
                                  {{requirement.req_current_status}}
                                </span>
                              </div>
                            </div>
                            <div class="c-tree__requirement-title c-linked-requirements__title">{{requirement.req_title}}</div>
                            <div class="c-tree__requirement-description">{{requirement.req_description}}</div>
                            <div class="c-tree__requirement-meta">
                              <div class="c-tree__meta-item">
                                <span class="c-tree__meta-label">Category:</span>
                                <span class="meta-value c-requirement-card__meta-value">{{requirement.req_category}}</span>
                              </div>
                              <div class="c-tree__meta-item">
                                <span class="c-tree__meta-label">Reference:</span>
                                <span class="meta-value c-requirement-card__meta-value">{{requirement.req_reference}}</span>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="c-tree__empty-state">
            <div class="c-tree__empty-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11H1l8-8 8 8h-8v8z"></path>
              </svg>
            </div>
            <h3>No Requirements Found</h3>
            <p>There are no requirements to display in the tree view.</p>
            <a href="/p/{{selected_project_id}}/requirements/new" class="btn btn-primary">Create First Requirement</a>
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</section>

{{/inline}}
{{> layout page_id="requirements-tree"}}
