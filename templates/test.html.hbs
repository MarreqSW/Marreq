
<div class="card requirement-card">
  <div class="card-body">
    <div class="requirement-header">
      <div>
        <a href="/tests/{{test_id}}" class="requirement-id">TEST-{{test_id}}</a>
        <h3 class="requirement-title">{{test_name}}</h3>
      </div>
      <div class="requirement-actions">
        <a href="/edit_test/{{test_id}}" class="btn btn-outline btn-sm">Edit</a>
      </div>
    </div>
    
    <p class="requirement-description">{{test_description}}</p>
    
    <div class="requirement-meta">
      <div class="meta-item">
        <span class="meta-label">Source</span>
        <span class="meta-value">{{test_source}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Status</span>
        <span class="status-badge status-{{test_status}}">{{test_status}}</span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Parent</span>
        <span class="meta-value">
          {{#if test_parent_id}}
            <a href="/tests/{{test_parent_id}}">{{test_parent_title}}</a>
          {{else}}
            None
          {{/if}}
        </span>
      </div>
    </div>
  </div>
</div>