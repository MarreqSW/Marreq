{{#*inline "page"}}
<div class="mb-4">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Tests</h1>
    <div>
      <a href="/tests.xls" class="btn btn-success me-2">Export Excel</a>
      {{#if user.is_admin}}
      <a href="/import_excel" class="btn btn-warning me-2">Import Excel</a>
      {{/if}}
      <a href="/p/{{selected_project_id}}/tests/new" class="btn btn-primary">New Test</a>
    </div>
  </div>
</div>

<!-- Filters Section -->
<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Filters</h5>
  </div>
  <div class="card-body">
    <form method="GET" action="/p/{{selected_project_id}}/tests" class="d-flex align-items-end gap-3">
      <div class="flex-grow-1">
        <label for="status_filter" class="form-label">Status</label>
        <select class="form-select" id="status_filter" name="status_filter">
          <option value="">All Statuses</option>
          {{#if statuses}}
            {{#each statuses}}
              <option value="{{test_st_id}}" {{#if (eq test_st_id ../current_status_filter)}}selected{{/if}}>
                {{test_st_title}}
              </option>
            {{/each}}
          {{/if}}
        </select>
      </div>
      <div class="flex-grow-1">
        <label for="verification_filter" class="form-label">Verification Mode</label>
        <select class="form-select" id="verification_filter" name="verification_filter">
          <option value="">All Verification Modes</option>
          {{#if verifications}}
            {{#each verifications}}
              <option value="{{verification_id}}" {{#if (eq verification_id ../current_verification_filter)}}selected{{/if}}>
                {{verification_name}}
              </option>
            {{/each}}
          {{/if}}
        </select>
      </div>
      <div class="flex-grow-1">
        <label for="category_filter" class="form-label">Category</label>
        <select class="form-select" id="category_filter" name="category_filter">
          <option value="">All Categories</option>
          {{#if categories}}
            {{#each categories}}
              <option value="{{cat_id}}" {{#if (eq cat_id ../current_category_filter)}}selected{{/if}}>
                {{cat_title}}
              </option>
            {{/each}}
          {{/if}}
        </select>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Apply Filters</button>
        <a href="/p/{{selected_project_id}}/tests" class="btn btn-secondary">Clear</a>
      </div>
    </form>
  </div>
</div>

<section id="Tests">
  {{#each tests }}
    {{> test}}
  {{/each}}
</section>
{{/inline}}
{{> layout}}


