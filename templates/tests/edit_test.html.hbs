{{!--
  Depends on: css/50-components/forms.css
--}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Test</h1>
  <p class="text-secondary">Update test case details</p>
</div>

<section id="Tests">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Test Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="test_name" class="form-label c-form-label">Test Name</label>
          <input type="text" name="test_name" id="test_name" value="{{tests.test_name}}" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="test_reference" class="form-label c-form-label">Test Reference</label>
          <input type="text" name="test_reference" id="test_reference" value="{{tests.test_reference}}" class="form-control c-form-control" required>
          <small class="text-secondary">Must follow format TEST-NUMBER (e.g., TEST-1, TEST-2)</small>
        </div>

        <div class="form-group c-form-group">
          <label for="test_description" class="form-label c-form-label">Description</label>
          <textarea name="test_description" id="test_description" class="form-control c-form-control c-form-control--textarea" rows="4" required>{{tests.test_description}}</textarea>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="test_source" class="form-label c-form-label">Source</label>
            <input type="text" id="test_source" name="test_source" value="{{tests.test_source}}" class="form-control c-form-control">
          </div>

          <div class="form-group c-form-group">
            <label for="test_status" class="form-label c-form-label">Status</label>
            <select name="test_status" id="test_status" class="form-control c-form-control c-form-control--select" required>
              {{#each status }}
                <option value="{{test_st_id}}" {{#if (eq test_st_id ../tests.test_status_id)}}selected{{/if}}>{{test_st_title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="test_parent" class="form-label c-form-label">Parent Test</label>
            <select name="test_parent" id="test_parent" class="form-control c-form-control c-form-control--select">
              <option value="0" {{#if (eq ../tests.test_parent_id 0)}}selected{{/if}}>None</option>
              {{#each parent }}
                <option value="{{test_id}}" {{#if (eq test_id ../tests.test_parent_id)}}selected{{/if}}>{{test_name}}</option>
              {{/each}}
            </select>
          </div>

        </div>

        <input type="hidden" id="test_id" name="test_id" value="{{tests.test_id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{tests.project_id}}">

        <div class="form-group mt-4 c-form-group">
          <label for="linked_requirements" class="form-label c-form-label">Linked Requirements</label>
          <select name="linked_requirements" id="linked_requirements" class="form-control c-form-control c-form-control--select c-form-control--multiple" multiple size="8">
            {{#each requirements}}
              <option value="{{id}}" {{#each ../linked_req_ids}}{{#if (eq this ../id)}}selected{{/if}}{{/each}}>REQ-{{id}}: {{title}}</option>
            {{/each}}
          </select>
          <small class="form-text c-form-text">Hold Ctrl (or Cmd on Mac) to select multiple requirements</small>
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update Test</button>
          <a href="/p/{{tests.project_id}}/tests/show/{{tests.test_id}}" class="btn btn-outline">Cancel</a>
          <a href="/p/{{tests.project_id}}/tests" class="btn btn-outline">Back to Tests</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout page_id="test-form"}}
