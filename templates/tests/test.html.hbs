{{!-- Test detail page - styled to match requirement detail layout --}}
{{#*inline "page"}}
<div class="reqman-requirement-detail-page" aria-live="polite">
  <header class="reqman-requirement-header card shadow-sm border-0">
    <div class="reqman-requirement-header__body">
      <div class="d-flex flex-column gap-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
          <div class="d-flex flex-wrap align-items-center gap-3">
            <span class="badge rounded-pill text-bg-dark fs-5" aria-label="Test reference">{{test_reference}}</span>
            <h1 class="h4 mb-0 text-break">{{test_name}}</h1>
          </div>
          <nav class="ms-lg-auto" aria-label="Test actions">
            <div class="btn-toolbar gap-2 justify-content-lg-end flex-wrap">
              <a href="/p/{{selected_project_id}}/tests/edit/{{test_id}}"
                class="btn btn-primary btn-sm" aria-label="Edit test">
                <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                  <use href="#icon-pencil" />
                </svg>
                <span class="ms-1">Edit</span>
              </a>
              <a href="/logs/TEST/{{test_id}}"
                class="btn btn-outline-secondary btn-sm" aria-label="View test history">
                <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                  <use href="#icon-clock-history" />
                </svg>
                <span class="ms-1">History</span>
              </a>
              <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                  aria-expanded="false" aria-label="More actions">
                  More
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <button class="dropdown-item" type="button" data-action="copy-requirement-link" data-requirement-url="/p/{{selected_project_id}}/tests/show/{{test_id}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-link" />
                      </svg>
                      <span class="ms-2">Copy link</span>
                    </button>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <button class="dropdown-item text-danger" type="button" data-action="delete-test" data-project-id="{{selected_project_id}}" data-test-id="{{test_id}}" data-test-name="{{test_name}}">
                      <svg width="16" height="16" fill="currentColor" aria-hidden="true">
                        <use href="#icon-trash" />
                      </svg>
                      <span class="ms-2">Delete</span>
                    </button>
                  </li>
                </ul>
              </div>
            </div>
          </nav>
        </div>

        <section class="reqman-requirement-statement-card p-4 p-lg-5 rounded-4 bg-white">
          <div class="text-uppercase small text-muted mb-2">Test Description</div>
          <div class="reqman-requirement-header__statement fs-5 lh-base text-break fw-semibold mb-3">
            {{#if test_description}}
              <p class="mb-0">{{test_description}}</p>
            {{else}}
              <p class="mb-0 text-muted"><em>No test description provided yet.</em></p>
            {{/if}}
          </div>

          <hr class="my-3 opacity-25">

          <div class="row g-4">
            <div class="col-lg-6">
              <div class="h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <svg class="text-primary" width="20" height="20" fill="currentColor" aria-hidden="true"><use href="#icon-lightbulb"/></svg>
                  <h2 class="h5 mb-0 fw-semibold">Source</h2>
                </div>
                <div class="text-muted lh-lg">{{test_source}}</div>
              </div>
            </div>

            <div class="col-lg-6">
              <div class="h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <svg class="text-secondary" width="20" height="20" fill="currentColor" aria-hidden="true"><use href="#icon-file-text"/></svg>
                  <h2 class="h5 mb-0 fw-semibold">Notes</h2>
                </div>
                <div class="text-muted lh-lg">{{#if test_notes}}<p class="mb-0">{{test_notes}}</p>{{else}}<p class="mb-0 fst-italic">No notes recorded.</p>{{/if}}</div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </header>

  <div class="reqman-requirement-detail-grid">
    <div class="reqman-requirement-detail-main">
      <section class="card shadow-sm border-0 requirement-main-card mb-3">
        <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
          <div class="text-uppercase small text-muted">Verification</div>
          {{#if test_status}}
            {{#if (eq test_status "passed")}}
              <span class="badge" style="background-color: #d4edda; color: #155724;">Passed</span>
            {{else if (eq test_status "failed")}}
              <span class="badge bg-danger">Failed</span>
            {{else}}
              <span class="badge bg-secondary">{{test_status}}</span>
            {{/if}}
          {{/if}}
        </div>
        <div class="card-body">
          <div class="d-flex flex-column gap-2">
            <div class="mt-2 text-muted">TODO: Add verification steps.</div>
          </div>
        </div>
      </section>

      <section class="card shadow-sm requirement-section">
        <div class="card-body">
          {{#if linked_requirements}}
          <h5 class="mb-3">Linked Requirements</h5>
          <div class="list-group list-group-flush">
            {{#each linked_requirements}}
            <a href="/p/{{project_id}}/requirements/show/{{id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
              <div class="me-3">
                <span class="fw-semibold">REQ-{{id}}</span>
                <span class="small text-muted ms-2">{{title}}</span>
              </div>
              {{#if category_id}}
                <span class="badge bg-secondary">{{category_id}}</span>
              {{else if applicability_id}}
                <span class="badge bg-info">{{applicability_id}}</span>
              {{else}}
                <span class="badge bg-light text-dark border">—</span>
              {{/if}}
            </a>
            {{/each}}
          </div>
          {{else}}
          <p class="text-muted mb-0">No linked requirements.</p>
          {{/if}}
        </div>
      </section>
    </div>

    <aside class="reqman-requirement-detail-sidebar" aria-label="Test metadata and relationships">
      <section class="card shadow-sm border-0 requirement-side-card mb-3">
        <div class="card-header requirement-card-header border-0 d-flex justify-content-between align-items-center">
          <div class="text-uppercase small text-muted mb-0">Key Info</div>
          <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#testMetadataContent" aria-expanded="true" aria-controls="testMetadataContent">▼</button>
        </div>
        <div class="collapse show" id="testMetadataContent">
          <div class="card-body">
            <dl class="row mb-0">
              <dt class="col-6 text-uppercase small text-muted">Status</dt>
              <dd class="col-6 fw-semibold text-end text-lg-start">{{test_status}}</dd>
              <dt class="col-6 text-uppercase small text-muted">Parent</dt>
              <dd class="col-6 fw-semibold text-end text-lg-start">{{#if test_parent_id}}<a href="/p/{{selected_project_id}}/tests/show/{{test_parent_id}}">{{test_parent_title}}</a>{{else}}—{{/if}}</dd>
              <dt class="col-6 text-uppercase small text-muted">TODO: Add verification type</dt>
              <dd class="col-6 fw-semibold text-end text-lg-start">—</dd>
              <dt class="col-6 text-uppercase small text-muted">TODO: Add date/Changelog</dt>
              <dd class="col-6 fw-semibold text-end text-lg-start">—</dd>
            </dl>
          </div>
        </div>
      </section>
    </aside>
  </div>
</div>

