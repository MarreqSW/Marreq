{{!-- Depends on: css/index.css, js/app.js --}}
{{#*inline "page"}}
<section id="profile" class="user-details-section">
  <div class="card user-details-card">
    <div class="user-details-header">
      <div class="user-details-title">
        <span class="user-details-label">My Profile</span>
        <div class="user-name-row">
          <h1 class="user-details-name">{{user.user_name}}</h1>
          {{#if user.is_admin}}
            <span class="user-level-badge">Administrator</span>
          {{else}}
            <span class="user-level-badge">Standard User</span>
          {{/if}}
        </div>
        <p class="user-details-username">@{{user.user_username}}</p>
      </div>
      <div class="user-details-actions">
        <a href="/user/profile/edit" class="btn btn-primary btn-sm">Edit Profile</a>
      </div>
    </div>
    {{#if profile_updated}}
      <div class="alert alert-success mt-3" role="status">
        Your profile was updated successfully.
      </div>
    {{/if}}
    <div class="user-details-body">
      <div class="user-info-grid">
        <div class="user-info-item">
          <span class="user-info-label">Full Name</span>
          <span class="user-info-value">{{user.user_name}}</span>
        </div>
        <div class="user-info-item">
          <span class="user-info-label">Username</span>
          <span class="user-info-value">@{{user.user_username}}</span>
        </div>
        <div class="user-info-item">
          <span class="user-info-label">Email</span>
          <span class="user-info-value">{{user.user_email}}</span>
        </div>
        <div class="user-info-item">
          <span class="user-info-label">Member Since</span>
          <span class="user-info-value">{{user.user_creation_date}}</span>
        </div>
        <div class="user-info-item">
          <span class="user-info-label">Last Login</span>
          <span class="user-info-value">{{user.user_last_login}}</span>
        </div>
      </div>
      <p class="user-details-help-text">
        Keep your contact information up to date so teammates can reach you.
      </p>
    </div>
  </div>
</section>
{{/inline}}
{{> layout page_id="user_profile"}}
