{{!--
Depends on: css/pages/verification.css, js/pages/verification.js
Dynamic classes: marreq-list-page__row[hidden]
--}}
{{#*inline "page"}}
<section class="marreq-list-page marreq-verification-page">
  <div class="marreq-list-page__header">
    <h1 class="marreq-list-page__title">Verification methods</h1>
    <a href="/{{selected_project_slug}}/verification/new" class="btn btn-primary">New Verification Method</a>
  </div>

  <div class="marreq-list-page__toolbar">
    <label for="verification-search-input" class="u-sr-only">Search verification methods</label>
    <input id="verification-search-input" type="search" class="form-control marreq-list-page__search c-form-control"
      placeholder="Search by title, tag, or description" autocomplete="off">
  </div>

  <div class="marreq-list-page__list" id="verification-list">
    {{#each verifications}}
    {{> verification/verification_item}}
    {{else}}
    <p class="marreq-list-page__empty" id="verification-empty-state">No verification methods yet.</p>
    {{/each}}
  </div>
  <p class="marreq-list-page__empty" id="verification-empty-filter" hidden>No verification methods match your search.
  </p>
</section>
{{/inline}}
{{> layout this page_id="verification"}}