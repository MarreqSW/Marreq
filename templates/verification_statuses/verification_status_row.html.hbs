<article class="marreq-list-page__row" data-test-status-row data-search-text="{{title}} {{tag}} {{description}} {{id}}">
  <div class="marreq-list-page__row-main">
    <div class="marreq-list-page__row-headline">
      <span class="marreq-list-page__tag" aria-label="Status tag {{tag}}"{{#if tag_color}} style="background-color: {{tag_color}}; color: #fff; border-color: {{tag_color}};"{{/if}}>{{tag}}</span>
      <h3 class="marreq-list-page__row-title">{{title}}</h3>
      {{#if is_system}}
        <span class="badge bg-secondary ms-2" title="Default status (cannot be edited or deleted)">System</span>
      {{/if}}
    </div>
    {{#if description}}
      <p class="marreq-list-page__row-description">{{description}}</p>
    {{/if}}
  </div>
  <div class="marreq-list-page__row-meta">
    <span class="marreq-list-page__row-id" title="Status ID">#{{id}}</span>
    <div class="marreq-list-page__row-actions">
      {{#unless is_system}}
        <a href="/p/{{@root.selected_project_id}}/verification_statuses/edit/{{id}}" class="btn btn-outline btn-sm marreq-list-page__action-btn">Edit</a>
        <button
          class="btn btn-danger btn-sm marreq-list-page__action-btn"
          type="button"
          data-action="delete-test-status"
          data-status-id="{{id}}"
          data-status-title="verification status {{tag}}"
          data-project-id="{{@root.selected_project_id}}"
        >Delete</button>
      {{/unless}}
    </div>
  </div>
</article>
