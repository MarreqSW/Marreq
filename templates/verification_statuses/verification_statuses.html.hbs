{{!--
  List of verification statuses; system statuses are not editable/deletable.
--}}
{{#*inline "page"}}
<section class="marreq-list-page marreq-category-page">
  <div class="marreq-list-page__header">
    <h1 class="marreq-list-page__title">Verification statuses</h1>
    <a href="/p/{{selected_project_slug}}/verification_statuses/new" class="btn btn-primary">New verification status</a>
  </div>

  <div class="marreq-list-page__toolbar">
    <label for="verification-status-search-input" class="u-sr-only">Search verification statuses</label>
    <input
      id="verification-status-search-input"
      type="search"
      class="form-control marreq-list-page__search c-form-control"
      placeholder="Search by title, tag, or description"
      autocomplete="off"
    >
  </div>

  <div class="marreq-list-page__list" id="verification-status-list">
    {{#each verification_statuses}}
      {{> verification_statuses/verification_status_row}}
    {{else}}
      <p class="marreq-list-page__empty" id="verification-status-empty-state">No verification statuses yet.</p>
    {{/each}}
  </div>
  <p class="marreq-list-page__empty" id="verification-status-empty-filter" hidden>No statuses match your search.</p>
</section>
{{/inline}}
{{> layout this page_id="verification_statuses"}}
