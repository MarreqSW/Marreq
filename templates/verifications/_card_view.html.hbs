{{!--
PARTIAL: Card View
Modern card-based layout for test browsing
--}}
<section class="marreq-requirements-cards-section" id="cardView" aria-live="polite">
  {{#if tests}}
  <div class="marreq-requirements-cards-grid">
    {{#each tests}}
    <article class="marreq-requirement-card" data-test-id="{{id}}" data-status-id="{{test_status_id}}"
      data-status-label="{{status_id}}" data-source="{{source}}">

      {{!-- Card Header: Reference and Status --}}
      <header class="marreq-requirement-card__header">
        <div class="marreq-requirement-card__reference">
          <span class="marreq-requirement-card__reference-text">
            {{#if reference_code}}{{reference_code}}{{else}}TEST-{{id}}{{/if}}
          </span>
        </div>
        <span class="marreq-requirements-status-badge marreq-requirements-status-badge--{{status_variant}}"
          data-status-id="{{test_status_id}}" data-status="{{status_id}}" data-status-variant="{{status_variant}}"{{#if status_tag_color}} style="background-color: {{status_tag_color}}; color: #fff; border-color: {{status_tag_color}};"{{/if}}>
          {{status_id}}
        </span>
      </header>

      {{!-- Card Body: Title and Description --}}
      <div class="marreq-requirement-card__body">
        <h3 class="marreq-requirement-card__title">
          <a
            href="/p/{{../project.id}}/verifications/show/{{id}}"
            class="marreq-requirement-card__title-link"
            data-test-preview
            data-test-preview-project-id="{{../project.id}}"
            data-test-preview-id="{{id}}"
            data-test-preview-ref="{{reference_code}}"
            data-test-preview-title="{{name}}"
            data-test-preview-description="{{description}}"
            data-test-preview-status="{{status_id}}"
            data-test-preview-category="{{test_category}}"
            data-test-preview-source="{{source}}">
            {{name}}
          </a>
        </h3>
        {{#if description}}
        <p class="marreq-requirement-card__description">
          {{description}}
        </p>
        {{/if}}
      </div>

      {{!-- Card Metadata: Tags and Badges (verification type, status, source, parent) --}}
      <div class="marreq-requirement-card__metadata" data-badge-rail>
        <div class="marreq-requirement-card__badge-rail">
          {{#if verification_method_title}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--verification" data-badge
            title="Verification type: {{verification_method_title}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor"
              viewBox="0 0 16 16">
              <path
                d="M10.067.87a2.89 2.89 0 0 0-4.134 0l-.622.638-.89-.011a2.89 2.89 0 0 0-2.924 2.924l.01.89-.636.622a2.89 2.89 0 0 0 0 4.134l.637.622-.011.89a2.89 2.89 0 0 0 2.924 2.924l.89-.01.622.636a2.89 2.89 0 0 0 4.134 0l.622-.637.89.011a2.89 2.89 0 0 0 2.924-2.924l-.01-.89.636-.622a2.89 2.89 0 0 0 0-4.134l-.637-.622.011-.89a2.89 2.89 0 0 0-2.924-2.924l-.89.01-.622-.636zm.287 5.984-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708.708z" />
            </svg>
            {{verification_method_title}}
          </span>
          {{/if}}
          {{#if status_id}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--status" data-badge
            title="Status: {{status_id}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor"
              viewBox="0 0 16 16">
              <path
                d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
              <path
                d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
            </svg>
            {{status_id}}
          </span>
          {{/if}}
          {{#if test_category}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--category" data-badge
            title="Category: {{test_category}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor"
              viewBox="0 0 16 16">
              <path
                d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2zm8.5 9.5a.5.5 0 0 1-1 0V5.707L5.354 7.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 5.707V11.5z" />
            </svg>
            {{test_category}}
          </span>
          {{/if}}
          {{#if source}}
          <span class="marreq-requirement-card__badge marreq-requirement-card__badge--source" data-badge
            title="Source: {{source}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor"
              viewBox="0 0 16 16">
              <path
                d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zM2.5 2a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zM1 10.5A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3zm6.5.5A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3zm1.5-.5a.5.5 0 0 0-.5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 0-.5-.5h-3z" />
            </svg>
            {{source}}
          </span>
          {{/if}}
          {{#if verification_parent_title}}
          <a href="/p/{{../project.id}}/verifications/show/{{verification_parent_id}}"
            class="marreq-requirement-card__badge marreq-requirement-card__badge--parent" data-badge
            title="Parent: {{verification_parent_title}}">
            <svg class="marreq-requirement-card__badge-icon" width="10" height="10" fill="currentColor"
              viewBox="0 0 16 16">
              <path d="M1 0a1 1 0 0 0-1 1v14a1 1 0 0 0 1 1h5v-1H2v-1h4v-9H2V2h4v3h9a1 1 0 0 0 1-1V1a1 1 0 0 0-1-1H1z" />
            </svg>
            {{verification_parent_title}}
          </a>
          {{/if}}
        </div>
        <span class="marreq-requirement-card__badge-overflow" data-overflow hidden></span>
      </div>

      {{!-- Card Footer: Source, Status and Actions (like requirements card author/date) --}}
      <footer class="marreq-requirement-card__footer">
        <div class="marreq-requirement-card__info">
          {{#if source}}
          <span class="marreq-requirement-card__source" title="Source">
            <svg class="marreq-requirement-card__info-icon" width="12" height="12" fill="currentColor"
              viewBox="0 0 16 16">
              <path
                d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3z" />
            </svg>
            {{source}}
          </span>
          {{/if}}
          {{#if status_id}}
          <span class="marreq-requirement-card__status" title="Status">
            <svg class="marreq-requirement-card__info-icon" width="12" height="12" fill="currentColor"
              viewBox="0 0 16 16">
              <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z" />
              <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z" />
            </svg>
            {{status_id}}
          </span>
          {{/if}}
        </div>

        <div class="marreq-requirement-card__actions">
          <a href="/p/{{../project.id}}/verifications/show/{{id}}"
            class="marreq-requirement-card__action marreq-requirement-card__action--primary" title="View details">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path
                d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
              <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
            </svg>
            <span class="u-visually-hidden">View</span>
          </a>
          {{#if ../can_edit_requirements}}
          <a href="/p/{{../project.id}}/verifications/edit/{{id}}" class="marreq-requirement-card__action"
            data-action="open-edit-panel"
            data-test-id="{{id}}"
            data-project-id="{{../project.id}}"
            title="Edit test">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path
                d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z" />
            </svg>
            <span class="u-visually-hidden">Edit</span>
          </a>
          {{#if (or (eq status_id "Passed") (eq status_id "Failed") ../user.is_admin)}}
          <button type="button" class="marreq-requirement-card__action marreq-requirement-card__action--danger"
            data-action="delete-test" data-project-id="{{../project.id}}" data-test-id="{{id}}"
            data-test-name="{{name}}" title="Delete test">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path
                d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z" />
              <path fill-rule="evenodd"
                d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z" />
            </svg>
            <span class="u-visually-hidden">Delete</span>
          </button>
          {{/if}}
          {{/if}}
        </div>
      </footer>
    </article>
    {{/each}}
  </div>
  {{else}}
  {{> verifications/_empty_state}}
  {{/if}}
</section>