{{!--
  PARTIAL: Table View (Default/Compact)
  Compact table with expandable row details
--}}
<section class="marreq-requirements-table-section" id="tableView" aria-live="polite">
  {{#if tests}}
  <div class="marreq-requirements-table__wrapper">
    <table class="marreq-requirements-table" id="testsTable">
      <thead>
        <tr>
          <th scope="col" data-sort-key="reference" class="is-sortable">
            Reference
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="name" class="is-sortable">
            Name
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="status" class="is-sortable">
            Status
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="verification_type">
            Verification type
          </th>
          <th scope="col" data-sort-key="source" class="is-sortable">
            Source
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" data-sort-key="parent" class="is-sortable">
            Parent
            <span class="marreq-requirements-table__sort-indicator" aria-hidden="true">↕</span>
          </th>
          <th scope="col" class="marreq-requirements-table__actions-head">Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each tests}}
        <tr
          class="marreq-requirements-row"
          data-test-id="{{id}}"
          data-status-id="{{test_status_id}}"
          data-status-label="{{status_id}}">
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--key">
            <div class="marreq-requirements-key">
              <span class="marreq-requirements-key__value">
                {{#if reference_code}}{{reference_code}}{{else}}TEST-{{id}}{{/if}}
              </span>
              <button
                type="button"
                class="marreq-requirements-key__toggle"
                data-action="toggle-row-details"
                aria-expanded="false"
                aria-controls="test-details-{{id}}">
                <span class="u-visually-hidden">Toggle details for {{name}}</span>
              </button>
            </div>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--title">
            <a
              href="/p/{{../project.id}}/verifications/show/{{id}}"
              class="marreq-requirements-title"
              title="{{name}}"
              data-test-preview
              data-test-preview-project-id="{{../project.id}}"
              data-test-preview-id="{{id}}"
              data-test-preview-ref="{{reference_code}}"
              data-test-preview-title="{{name}}"
              data-test-preview-description="{{description}}"
              data-test-preview-status="{{status_id}}"
              data-test-preview-category="{{test_category}}"
              data-test-preview-source="{{source}}">
              {{name}}
            </a>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--status marreq-requirements-cell--editable" data-inline-edit="status" title="Click to change">
            <span
              class="marreq-requirements-status-badge marreq-requirements-status-badge--{{status_variant}} marreq-requirements-cell__display"
              data-status-id="{{test_status_id}}"
              data-status="{{status_id}}"
              data-status-variant="{{status_variant}}"{{#if status_tag_color}} style="background-color: {{status_tag_color}}; color: #fff; border-color: {{status_tag_color}};"{{/if}}>
              {{status_id}}
            </span>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--verification-type">
            {{#if verification_method_title}}
              <span>{{verification_method_title}}</span>
            {{else}}
              <span class="marreq-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--verification">
            <span class="marreq-requirements-cell-muted">{{source}}</span>
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--parent">
            {{#if verification_parent_title}}
              <a
                href="/p/{{../project.id}}/verifications/show/{{verification_parent_id}}"
                title="{{verification_parent_title}}"
                data-test-preview
                data-test-preview-project-id="{{../project.id}}"
                data-test-preview-id="{{verification_parent_id}}"
                data-test-preview-ref="{{verification_parent_reference_code}}"
                data-test-preview-title="{{verification_parent_title}}"
                data-test-preview-description="{{verification_parent_description}}"
                data-test-preview-status="{{verification_parent_status_id}}"
                data-test-preview-source="{{verification_parent_source}}">
                {{verification_parent_title}}
              </a>
            {{else}}
              <span class="marreq-requirements-cell-muted">—</span>
            {{/if}}
          </td>
          <td class="marreq-requirements-row__cell marreq-requirements-row__cell--actions">
            <div class="marreq-requirements-row__actions">
              <a 
                href="/p/{{../project.id}}/verifications/show/{{id}}" 
                class="marreq-requirements-row__action marreq-requirements-row__action--icon"
                title="View test">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                  <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                </svg>
                <span class="u-visually-hidden">View</span>
              </a>
              {{#if ../can_edit_requirements}}
              <a 
                href="/p/{{../project.id}}/verifications/edit/{{id}}" 
                class="marreq-requirements-row__action marreq-requirements-row__action--icon"
                data-action="open-edit-panel"
                data-test-id="{{id}}"
                data-project-id="{{../project.id}}"
                title="Edit test">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                </svg>
                <span class="u-visually-hidden">Edit</span>
              </a>
              {{#if (or (eq status_id "Passed") (eq status_id "Failed") ../user.is_admin)}}
              <button
                type="button"
                class="marreq-requirements-row__action marreq-requirements-row__action--icon marreq-requirements-row__action--danger"
                data-action="delete-test"
                data-project-id="{{../project.id}}"
                data-test-id="{{id}}"
                data-test-name="{{name}}"
                title="Delete test">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                  <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                </svg>
                <span class="u-visually-hidden">Delete</span>
              </button>
              {{/if}}
              {{/if}}
            </div>
          </td>
        </tr>
        <tr
          id="test-details-{{id}}"
          class="marreq-requirements-row__details"
          data-details-for="{{id}}"
          hidden>
          <td colspan="7">
            <dl class="marreq-requirements-details-grid">
              <div>
                <dt>Description</dt>
                <dd>{{description}}</dd>
              </div>
              <div>
                <dt>Verification type</dt>
                <dd>{{#if verification_method_title}}{{verification_method_title}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Category</dt>
                <dd>{{#if test_category}}{{test_category}}{{else}}—{{/if}}</dd>
              </div>
              <div>
                <dt>Parent</dt>
                <dd>
                  {{#if verification_parent_id}}
                    <a href="/p/{{../project.id}}/verifications/show/{{verification_parent_id}}">{{verification_parent_title}}</a>
                  {{else}}
                    —
                  {{/if}}
                </dd>
              </div>
            </dl>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{> verifications/_empty_state}}
  {{/if}}
</section>
