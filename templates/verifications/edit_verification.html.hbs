{{!--
  Depends on: css/50-components/forms.css
--}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>Edit Verification</h1>
  <p class="text-secondary">Update verification details</p>
</div>

<section id="Verifications">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Verification Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="name" class="form-label c-form-label">Verification Name</label>
          <input type="text" name="name" id="name" value="{{tests.name}}" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="reference_code" class="form-label c-form-label">Reference</label>
          <input type="text" name="reference_code" id="reference_code" value="{{tests.reference_code}}" class="form-control c-form-control" required>
          <small class="text-secondary">e.g. VER-1, VER-2</small>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="4" required>{{tests.description}}</textarea>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="source" class="form-label c-form-label">Source</label>
            <input type="text" id="source" name="source" value="{{tests.source}}" class="form-control c-form-control">
          </div>

          <div class="form-group c-form-group">
            <label for="status_id" class="form-label c-form-label">Status</label>
            <select name="status_id" id="status_id" class="form-control c-form-control c-form-control--select" required>
              {{#each status }}
                <option value="{{id}}" {{#if (eq id ../tests.test_status_id)}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="verification_method_id" class="form-label c-form-label">Verification Method</label>
          <select name="verification_method_id" id="verification_method_id" class="form-control c-form-control c-form-control--select">
            <option value="0" {{#unless tests.verification_method_id}}selected{{/unless}}>None</option>
            {{#each verification}}
              <option value="{{id}}" {{#if (eq id ../tests.verification_method_id)}}selected{{/if}}>{{title}}</option>
            {{/each}}
          </select>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="parent_id" class="form-label c-form-label">Parent Verification</label>
            <select name="parent_id" id="parent_id" class="form-control c-form-control c-form-control--select">
              <option value="0" {{#unless ../tests.verification_parent_id}}selected{{/unless}}>None</option>
              {{#each parent }}
                <option value="{{id}}" {{#if (eq id ../tests.verification_parent_id)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </div>

        </div>

        <input type="hidden" id="id" name="id" value="{{tests.id}}">
        <input type="hidden" id="project_id" name="project_id" value="{{tests.project_id}}">

        <div class="form-group mt-4 c-form-group">
          <label for="linked_requirements" class="form-label c-form-label">Linked Requirements</label>
          <select name="linked_requirements" id="linked_requirements" class="form-control c-form-control c-form-control--select c-form-control--multiple" multiple size="8">
            {{#each requirements}}
              <option value="{{id}}" {{#each ../linked_req_ids}}{{#if (eq this ../id)}}selected{{/if}}{{/each}}>REQ-{{id}}: {{title}}</option>
            {{/each}}
          </select>
          <small class="form-text c-form-text">Hold Ctrl (or Cmd on Mac) to select multiple requirements</small>
        </div>

        <div class="mt-4">
          <button type="submit" class="btn btn-primary">Update Verification</button>
          <a href="/{{project_slug}}/verifications/show/{{tests.id}}" class="btn btn-outline">Cancel</a>
          <a href="/{{project_slug}}/verifications" class="btn btn-outline">Back to Verifications</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="verification-form"}}
