{{!--
  Depends on: css/50-components/forms.css
--}}
{{#*inline "page"}}
<div class="mb-4">
  <h1>New Verification</h1>
  <p class="text-secondary">Create a new verification</p>
</div>

<section id="Verifications">
  <div class="card c-card">
    <div class="card-header c-card__header">
      <h3>Verification Details</h3>
    </div>
    <div class="card-body c-card__body">
      <form method="post">
        <div class="form-group c-form-group">
          <label for="name" class="form-label c-form-label">Verification Name</label>
          <input type="text" name="name" id="name" class="form-control c-form-control" required>
        </div>

        <div class="form-group c-form-group">
          <label for="reference_code" class="form-label c-form-label">Reference</label>
          <input type="text" name="reference_code" id="reference_code" class="form-control c-form-control" required>
          <small class="text-secondary">e.g. VER-1, VER-2</small>
        </div>

        <div class="form-group c-form-group">
          <label for="description" class="form-label c-form-label">Description</label>
          <textarea name="description" id="description" class="form-control c-form-control c-form-control--textarea" rows="4" required></textarea>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="source" class="form-label c-form-label">Source</label>
            <input type="text" name="source" id="source" class="form-control c-form-control">
          </div>

          <div class="form-group c-form-group">
            <label for="status_id" class="form-label c-form-label">Status</label>
            <select name="status_id" id="status_id" class="form-control c-form-control c-form-control--select" required>
              {{#each status }}
                <option value="{{id}}" {{#if selected}}selected{{/if}}>{{title}}</option>
              {{/each}}
            </select>
          </div>
        </div>

        <div class="form-group c-form-group">
          <label for="verification_method_id" class="form-label c-form-label">Verification Method</label>
          <select name="verification_method_id" id="verification_method_id" class="form-control c-form-control c-form-control--select">
            <option value="0">None</option>
            {{#each verification}}
              <option value="{{id}}">{{title}}</option>
            {{/each}}
          </select>
          <small class="text-secondary">Type of verification (e.g. Test, Analysis, Review)</small>
        </div>

        <div class="o-grid o-grid--two">
          <div class="form-group c-form-group">
            <label for="parent_id" class="form-label c-form-label">Parent Verification</label>
            <select name="parent_id" id="parent_id" class="form-control c-form-control c-form-control--select">
              <option value="0">None</option>
              {{#each parents}}
                <option value="{{id}}">{{name}}</option>
              {{/each}}
            </select>
          </div>

          <div class="form-group c-form-group">
            <label for="verification_req" class="form-label c-form-label">Related Requirements</label>
            <select name="verification_req" id="verification_req" class="form-control c-form-control c-form-control--select c-form-control--multiple" multiple>
              {{#each requirements}}
                <option value="{{id}}">{{title}}</option>
              {{/each}}
            </select>
            <small class="text-secondary">Hold Ctrl/Cmd to select multiple requirements</small>
          </div>
        </div>

        <div class="mt-4">
          <input type="hidden" name="project_id" value="{{#if selected_project_id}}{{selected_project_id}}{{else}}{{project_id}}{{/if}}">
          <button type="submit" class="btn btn-primary">Create Verification</button>
          <a href="/p/{{selected_project_slug}}/verifications" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</section>
{{/inline}}
{{> layout this page_id="verification-form"}}
